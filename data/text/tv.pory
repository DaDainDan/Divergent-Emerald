text gTVNameRaterText01 {
	"A nickname that hints at talent in many
	different ways.

	I urge this TRAINER to take courage
	and take on many challenges."
}

text gTVNameRaterText02 {
	"A nickname that perfectly complements
	{STR_VAR_1}, the TRAINER's name.

	It suggests that you will forge a fine
