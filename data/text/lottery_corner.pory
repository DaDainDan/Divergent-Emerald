text(local) LilycoveCity_DepartmentStore_1F_Text_LotteryCornerDrawTicket {
	"This is the POKéMON LOTTERY CORNER.

	All shoppers at our DEPARTMENT STORE
	get to draw a POKéMON LOTO TICKET.

	If the LOTO TICKET's number matches
	the ID number of any of your POKéMON,
	you will receive a fabulous gift.

	Would you like to draw a POKéMON
	LOTO TICKET?"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_ComeBackTomorrow {
	"Please come back tomorrow."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_PleaseVisitAgain {
	"Please do visit again."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_PleasePickTicket {
	"Please pick a LOTO TICKET.
	…{PAUSE 15}{PAUSE 15}{PAUSE 15}{PAUSE 15}…{PAUSE 15}{PAUSE 15}{PAUSE 15}{PAUSE 15}…{PAUSE 15}{PAUSE 15}{PAUSE 15}{PAUSE 15}"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_TicketNumberIsXPleaseWait {
	"The LOTO TICKET number is {STR_VAR_1}.

	I need to run a check on this number
	to see if it matches any of your
	POKéMON's ID numbers. Please wait."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_TicketMatchesPartyMon {
	"Congratulations!

	The ID number of your team's
	{STR_VAR_1} matches your
	LOTO TICKET's number!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_TicketMatchesPCMon {
	"Congratulations!

	The ID number of your PC-boxed
	{STR_VAR_1} matches your
	LOTO TICKET's number!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_NoNumbersMatched {
	"I'm sorry.
	None of the numbers matched."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_TwoDigitsMatched {
	"Two digits matched, so you win the
	third prize!
	You've won the {STR_VAR_1}!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_ThreeDigitsMatched {
	"Three digits matched, so you win the
	second prize!
	You've won the {STR_VAR_1}!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_FourDigitsMatched {
	"Four digits matched, so you win the
	first prize!
	You've won the {STR_VAR_1}!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_AllFiveDigitsMatched {
	"Oh, my goodness, all five digits
	matched!

	You've won the jackpot prize!
	You've won the {STR_VAR_1}!"
}

text(local) LilycoveCity_DepartmentStore_1F_Text_NoRoomForThis {
	"Oh?
	You seem to have no room for this.

	Please make room in your BAG and
	let me know."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_PrizeWeveBeenHolding {
	"{PLAYER}?
	Yes, I've been expecting you.

	This is the prize we've been holding
	for you."
}

text(local) LilycoveCity_DepartmentStore_1F_Text_PleaseVisitAgain2 {
	"Please do visit again."
}
