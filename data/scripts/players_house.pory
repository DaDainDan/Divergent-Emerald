script PlayersHouse_1F_EventScript_GetSSTicketAndSeeLatiTV {
    lockall
    checkplayergender
    switch (var(VAR_RESULT)) {
        case MALE: setvar(VAR_0x8008, MALE)
        case FEMALE: setvar(VAR_0x8008, FEMALE)
    }
    setvar(VAR_0x8009, LOCALID_PLAYERS_HOUSE_1F_DAD)
    setvar(VAR_0x800A, LOCALID_PLAYERS_HOUSE_1F_MOM)
    switch (var(VAR_0x8008)) {
        case MALE: applymovement(LOCALID_PLAYER, moves(delay_16,  walk_down * 3,  step_faster_left))
        case FEMALE: applymovement(LOCALID_PLAYER, moves(delay_16,  walk_down * 3,  step_faster_right))
    }
    waitmovement(0)
    applymovement(VAR_0x8009, Common_Movement_FacePlayer)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(VAR_0x8009, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(VAR_0x8009, Common_Movement_Delay48)
    waitmovement(0)
    delay(20)
    switch (var(VAR_0x8008)) {
        case MALE: applymovement(VAR_0x8009, moves(walk_right * 2))
        case FEMALE: applymovement(VAR_0x8009, moves(walk_left * 2))
    }
    waitmovement(0)
    msgbox(PlayersHouse_1F_Text_TicketFromBrineyCameForYou, MSGBOX_DEFAULT)
    giveitem(ITEM_SS_TICKET)
    msgbox(PlayersHouse_1F_Text_PortsInSlateportLilycove, MSGBOX_DEFAULT)
    closemessage
    delay(20)
    switch (var(VAR_0x8008)) {
        case MALE:
            applymovement(VAR_0x800A, moves(walk_up,  walk_right * 4,  walk_down,  step_faster_right))
            waitmovement(0)
            applymovement(VAR_0x8009, Common_Movement_FaceLeft)
        case FEMALE:
            applymovement(VAR_0x800A, moves(walk_up,  walk_left * 4,  walk_down,  step_faster_left))
            waitmovement(0)
            applymovement(VAR_0x8009, Common_Movement_FaceRight)
    }
    waitmovement(0)
    msgbox(PlayersHouse_1F_Text_BetterGetBackToGym, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PLAYER, moves(delay_8,  delay_16 * 2,  step_faster_down))
    applymovement(VAR_0x800A, moves(delay_8,  delay_16 * 2,  step_faster_down))
    switch (var(VAR_0x8008)) {
        case MALE: applymovement(VAR_0x8009, moves(walk_down,  walk_right,  walk_down,  delay_8))
        case FEMALE: applymovement(VAR_0x8009, moves(walk_down,  walk_left,  walk_down,  delay_8))
    }
    waitmovement(0)
    playse(SE_DOOR)
    removeobject(VAR_0x8009)
    setflag(FLAG_RECEIVED_SS_TICKET)
    delay(30)
    switch (var(VAR_0x8008)) {
        case MALE:
            applymovement(VAR_0x800A, Common_Movement_WalkRight)
            waitmovement(0)
            applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
        case FEMALE:
            applymovement(VAR_0x800A, Common_Movement_WalkLeft)
            waitmovement(0)
            applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    }
    waitmovement(0)
    delay(20)
    msgbox(PlayersHouse_1F_Text_DadShouldStayLonger, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_SYS_TV_LATIAS_LATIOS)
    special(TurnOnTVScreen)
    delay(60)
    switch (var(VAR_0x8008)) {
        case MALE: applymovement(VAR_0x800A, moves(step_faster_left,  delay_16 * 4,  step_faster_right,  delay_16 * 2))
        case FEMALE: applymovement(VAR_0x800A, moves(step_faster_right,  delay_16 * 4,  step_faster_left,  delay_16 * 2))
    }
    waitmovement(0)
    msgbox(PlayersHouse_1F_Text_IsThatABreakingStory, MSGBOX_DEFAULT)
    closemessage
    switch (var(VAR_0x8008)) {
        case MALE:
            applymovement(LOCALID_PLAYER, moves(walk_up,  walk_left * 4,  step_faster_up))
            waitmovement(0)
            applymovement(VAR_0x800A, Common_Movement_StepFasterLeft)
        case FEMALE:
            applymovement(LOCALID_PLAYER, moves(walk_up,  walk_right * 4,  step_faster_up))
            waitmovement(0)
            applymovement(VAR_0x800A, Common_Movement_StepFasterRight)
    }
    waitmovement(0)
    msgbox(PlayersHouse_1F_Text_LatiEmergencyNewsFlash, MSGBOX_DEFAULT)
    closemessage
    clearflag(FLAG_SYS_TV_LATIAS_LATIOS)
    setflag(FLAG_LATIOS_OR_LATIAS_ROAMING)
    special(TurnOffTVScreen)
    switch (var(VAR_0x8008)) {
        case MALE:
            applymovement(VAR_0x800A, moves(walk_up,  walk_left * 2))
            waitmovement(0)
            applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
        case FEMALE:
            applymovement(VAR_0x800A, moves(walk_up,  walk_right * 2))
            waitmovement(0)
            applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    }
    waitmovement(0)
    msgbox(PlayersHouse_1F_Text_WhatColorDidTheySay, MSGBOX_DEFAULT)
    multichoice(22, 8, MULTI_TV_LATI, TRUE)
    copyvar(VAR_0x8004, VAR_RESULT)
    special(InitRoamer)
    copyvar(VAR_ROAMER_POKEMON, VAR_RESULT)
    msgbox(PlayersHouse_1F_Text_StillUnknownPokemon, MSGBOX_DEFAULT)
    closemessage
    setvar(VAR_LITTLEROOT_HOUSES_STATE_MAY, 4)
    setvar(VAR_LITTLEROOT_HOUSES_STATE_BRENDAN, 4)
    releaseall
    end
}

