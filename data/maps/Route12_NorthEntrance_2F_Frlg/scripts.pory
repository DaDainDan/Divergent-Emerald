mapscripts Route12_NorthEntrance_2F_Frlg_MapScripts {}

script Route12_NorthEntrance_2F_EventScript_LeftBinoculars {
    msgbox(Route12_NorthEntrance_2F_Text_TheresManFishing, MSGBOX_SIGN)
    end
}

script Route12_NorthEntrance_2F_EventScript_RightBinoculars {
    msgbox(Route12_NorthEntrance_2F_Text_ItsPokemonTower, MSGBOX_SIGN)
    end
}

script Route12_NorthEntrance_2F_EventScript_Lass {
    lock_faceplayer
    if (flag(FLAG_GOT_TM27)) {
        msgbox(Route12_NorthEntrance_2F_Text_ExplainTM27)
    	release_end
    }
    if (checkplayergender == MALE) {
		msgbox(Route12_NorthEntrance_2F_Text_TakeTMDontNeedAnymoreMale)
	} else {
		msgbox(Route12_NorthEntrance_2F_Text_TakeTMDontNeedAnymoreFemale)
	}
    if (checkitemspace(ITEM_TM27) == FALSE) {
        msgbox(Route12_NorthEntrance_2F_Text_DontHaveRoomForThis)
    } else {
		giveitem_msg(Route12_NorthEntrance_2F_Text_ReceivedTM27FromLittleGirl, ITEM_TM27)
		msgbox(Route12_NorthEntrance_2F_Text_ExplainTM27)
		setflag(FLAG_GOT_TM27)
	}
    release_end
}

// Male and female text identical, differ (presumably) in JP
text Route12_NorthEntrance_2F_Text_TakeTMDontNeedAnymoreMale {
	"My POKéMON's ashes are stored in
	POKéMON TOWER.

	You can have this TM.
	I don't need it anymore…"
}

text Route12_NorthEntrance_2F_Text_TakeTMDontNeedAnymoreFemale {
	"My POKéMON's ashes are stored in
	POKéMON TOWER.

	You can have this TM.
	I don't need it anymore…"
}

text Route12_NorthEntrance_2F_Text_ReceivedTM27FromLittleGirl {
	"{PLAYER} received TM27
	from the little girl."
}

text Route12_NorthEntrance_2F_Text_ExplainTM27 {
	"TM27 is a move called RETURN…

	If you treat your POKéMON good,
	it will return your love by working
	its hardest in battle."
}

text Route12_NorthEntrance_2F_Text_DontHaveRoomForThis {
	"You don't have room for this."
}

text Route12_NorthEntrance_2F_Text_TheresManFishing {
	"Let's see what the binoculars have
	to show…

	There's a man fishing!"
}

text Route12_NorthEntrance_2F_Text_ItsPokemonTower {
	"Let's see what the binoculars have
	to show…

	It's POKéMON TOWER!"
}
