mapscripts SSAnne_2F_Room3_Frlg_MapScripts {}

script SSAnne_2F_Room3_EventScript_Gentleman {
    msgbox(SSAnne_2F_Room3_Text_SeenMonsFerryPeople, MSGBOX_NPC)
    end
}

script SSAnne_2F_Room3_EventScript_OldMan {
    msgbox(SSAnne_2F_Room3_Text_SomeTreesCanBeCutDown, MSGBOX_NPC)
    end
}

text SSAnne_2F_Room3_Text_SeenMonsFerryPeople {
	"Ah, yes, I have seen some POKéMON
	ferry people across the water!"
}

text SSAnne_2F_Room3_Text_SomeTreesCanBeCutDown {
	"Small trees can be chopped down
	using the move CUT.

	But remember this!
	CUT is an HM technique.

	Once learned, it is not so easily
	discarded."
}
