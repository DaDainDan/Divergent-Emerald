script SlateportCity_EventScript_CaptStern {
    lockall
    msgbox(SlateportCity_Text_SternMoveAheadWithExploration, MSGBOX_DEFAULT)
    msgbox(SlateportCity_Text_GabbyWonderfulThanksForInterview, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SLATEPORT_GABBY, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(10)
    applymovement(LOCALID_SLATEPORT_TY, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(25)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, moves(delay_16 * 5,  walk_down,  walk_left))
    applymovement(LOCALID_PLAYER, moves(delay_16 * 7,  step_faster_down))
    applymovement(LOCALID_SLATEPORT_GABBY, moves(delay_16,  walk_left * 2,  walk_down,  walk_left * 8))
    applymovement(LOCALID_SLATEPORT_TY, moves(walk_down,  walk_left * 3,  walk_down,  walk_left * 8))
    waitmovement(0)
    removeobject(LOCALID_SLATEPORT_GABBY)
    removeobject(LOCALID_SLATEPORT_TY)
    msgbox(SlateportCity_Text_SternWhewFirstInterview, MSGBOX_DEFAULT)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(SlateportCity_Text_OhPlayerWeMadeDiscovery, MSGBOX_DEFAULT)
    playbgm(MUS_ENCOUNTER_AQUA, FALSE)
    msgbox(SlateportCity_Text_AquaWillAssumeControlOfSubmarine, MSGBOX_DEFAULT)
    applymovement(LOCALID_SLATEPORT_COOK, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_SLATEPORT_FAT_MAN, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_SLATEPORT_OLD_WOMAN, SlateportCity_Movement_OldWomanConcern)
    applymovement(LOCALID_SLATEPORT_RICH_BOY, Common_Movement_QuestionMark)
    applymovement(LOCALID_SLATEPORT_MAN_1, SlateportCity_Movement_ManConcern)
    waitmovement(0)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(SlateportCity_Text_SternWhatWasAllThat, MSGBOX_DEFAULT)
    playse(SE_PIN)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, Common_Movement_Delay48)
    waitmovement(0)
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(SlateportCity_Text_FromHarborTryingToTakeSub, MSGBOX_DEFAULT)
    msgbox(SlateportCity_Text_PleaseComeWithMe, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SLATEPORT_CAPT_STERN, moves(walk_right,  walk_up * 2,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(step_faster_right,  delay_16 * 2,  walk_right,  walk_up))
    waitmovement(0)
    removeobject(LOCALID_SLATEPORT_CAPT_STERN)
    clearflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_CAPTAIN_STERN)
    clearflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_SUBMARINE_SHADOW)
    clearflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_AQUA_GRUNT)
    clearflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_ARCHIE)
    setvar(VAR_SLATEPORT_CITY_STATE, 2)
    warp(MAP_SLATEPORT_CITY_HARBOR, 11, 14)
    waitstate
    releaseall
    end
}

movement SlateportCity_Movement_OldWomanConcern {
    // moves(delay_16 * 2,  emote_question_mark,  step_faster_right,  delay_16 * 2,  step_faster_left)
    delay_16 * 2
    emote_question_mark
    step_faster_right
    delay_16 * 2
    step_faster_left
}

movement SlateportCity_Movement_ManConcern {
    // moves(emote_question_mark,  step_faster_up,  delay_16,  step_faster_down,  delay_16 * 2,  step_faster_left)
    emote_question_mark
    step_faster_up
    delay_16
    step_faster_down
    delay_16 * 2
    step_faster_left
}

movement SlateportCity_Movement_Unused {
    // moves(walk_down,  step_faster_up)
    walk_down
    step_faster_up
}

