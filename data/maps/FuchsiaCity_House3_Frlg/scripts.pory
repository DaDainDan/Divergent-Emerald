mapscripts FuchsiaCity_House3_Frlg_MapScripts {}

script FuchsiaCity_House3_EventScript_MoveDeleter {
    lock_faceplayer
    msgbox(FuchsiaCity_House3_Text_WouldYouLikeToForgetMove, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(FuchsiaCity_House3_EventScript_ChooseMonForMoveDeleter)
    }
    goto(FuchsiaCity_House3_EventScript_CancelForgetMove)
    end
}

script FuchsiaCity_House3_EventScript_ChooseMonForMoveDeleter {
    msgbox(FuchsiaCity_House3_Text_WhichMonShouldForgetMove)
    special(ChoosePartyMon)
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(FuchsiaCity_House3_EventScript_CancelForgetMove)
    }
    special(IsSelectedMonEgg)
    if (var(VAR_RESULT) == TRUE) {
        msgbox(FuchsiaCity_House3_Text_NoEggShouldKnowMoves)
    	release_end
    }
    special(GetNumMovesSelectedMonHas)
    if (var(VAR_RESULT) == 1) {
        special(BufferMoveDeleterNicknameAndMove)
		msgbox(FuchsiaCity_House3_Text_MonOnlyKnowsOneMove)
		release_end
    }
    msgbox(FuchsiaCity_House3_Text_WhichMoveShouldBeForgotten)
    fadescreen(FADE_TO_BLACK)
    special(MoveDeleterChooseMoveToForget)
    fadescreen(FADE_FROM_BLACK)
    if (var(VAR_0x8005) == MAX_MON_MOVES) {
        goto(FuchsiaCity_House3_EventScript_ChooseMonForMoveDeleter)
    }
    special(BufferMoveDeleterNicknameAndMove)
    msgbox(FuchsiaCity_House3_Text_MonsMoveShouldBeForgotten, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        special(MoveDeleterForgetMove)
		playfanfare(MUS_MOVE_DELETED)
		waitfanfare
		msgbox(FuchsiaCity_House3_Text_MonHasForgottenMoveCompletely)
		release_end
    }
    goto(FuchsiaCity_House3_EventScript_CancelForgetMove)
    end
}

script FuchsiaCity_House3_EventScript_CancelForgetMove {
    msgbox(FuchsiaCity_House3_Text_ComeAgainToForgetOtherMoves)
    release_end
}

text FuchsiaCity_House3_Text_WouldYouLikeToForgetMove {
	"Uh…
	Oh, yes, I'm the MOVE DELETER.

	I can make POKéMON forget their
	moves.

	Would you like me to do that?"
}

text FuchsiaCity_House3_Text_WhichMonShouldForgetMove {
	"Which POKéMON should forget a
	move?"
}

text FuchsiaCity_House3_Text_WhichMoveShouldBeForgotten {
	"Which move should be forgotten?"
}

text FuchsiaCity_House3_Text_MonOnlyKnowsOneMove {
	"{STR_VAR_1} seems to know only one
	move…"
}

text FuchsiaCity_House3_Text_MonsMoveShouldBeForgotten {
	"Hm! {STR_VAR_1}'s {STR_VAR_2}?
	That move should be forgotten?"
}

text FuchsiaCity_House3_Text_MonHasForgottenMoveCompletely {
	"It worked to perfection!

	{STR_VAR_1} has forgotten
	{STR_VAR_2} completely."
}

text FuchsiaCity_House3_Text_ComeAgainToForgetOtherMoves {
	"Come again if there are other
	moves to be forgotten."
}

text FuchsiaCity_House3_Text_NoEggShouldKnowMoves {
	"What?
	No EGG should know any moves."
}
