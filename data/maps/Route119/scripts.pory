mapscripts Route119_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        if (flag(FLAG_SYS_CTRL_OBJ_DELETE) && specialvar(VAR_RESULT, GetBattleOutcome) == B_OUTCOME_CAUGHT) {
			removeobject(VAR_LAST_TALKED)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        call(Common_EventScript_SetupRivalGfxId)
		call(Common_EventScript_SetupRivalOnBikeGfxId)
		if (var(VAR_WEATHER_INSTITUTE_STATE) == 1) {
			setflag(FLAG_HIDE_WEATHER_INSTITUTE_2F_WORKERS)
			clearflag(FLAG_HIDE_WEATHER_INSTITUTE_1F_WORKERS)
			setvar(VAR_WEATHER_INSTITUTE_STATE, 2)
		}
		special(SetRoute119Weather)
		end
    }
}

script Route119_EventScript_RivalTrigger1 {
    setvar(VAR_TEMP_1, 1)
    goto(Route119_EventScript_RivalEncounter)
    end
}

script Route119_EventScript_RivalTrigger2 {
    setvar(VAR_TEMP_1, 2)
    goto(Route119_EventScript_RivalEncounter)
    end
}

script Route119_EventScript_RivalEncounter {
    lockall
    addobject(LOCALID_ROUTE119_RIVAL_ON_BIKE)
    if (checkplayergender == MALE) {
        playbgm(MUS_ENCOUNTER_MAY, TRUE)
    } else {
        playbgm(MUS_ENCOUNTER_BRENDAN, TRUE)
    }
    delay(65)
	switch (var(VAR_TEMP_1)) {
		case 1: applymovement(LOCALID_ROUTE119_RIVAL_ON_BIKE, moves(run_right * 8,  run_up))
		case 2: applymovement(LOCALID_ROUTE119_RIVAL_ON_BIKE, moves(run_right * 9,  run_up))
	}
	waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(30)
	switch (var(VAR_TEMP_1)) {
		case 1: call(Route119_EventScript_SetRivalPos1)
		case 2: call(Route119_EventScript_SetRivalPos2)
	}
    removeobject(LOCALID_ROUTE119_RIVAL_ON_BIKE)
    addobject(LOCALID_ROUTE119_RIVAL)
    delay(30)
    if (checkplayergender == MALE) {
        goto(Route119_EventScript_BattleMay)
    } else{
        goto(Route119_EventScript_BattleBrendan)
    }
    end
}

script Route119_EventScript_BattleMay {
    msgbox(Route119_Text_MayIntro, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case CHOSE_TREECKO: trainerbattle_no_intro(TRAINER_MAY_ROUTE_119_TREECKO, Route119_Text_MayDefeat)
        case CHOSE_TORCHIC: trainerbattle_no_intro(TRAINER_MAY_ROUTE_119_TORCHIC, Route119_Text_MayDefeat)
        case CHOSE_MUDKIP: trainerbattle_no_intro(TRAINER_MAY_ROUTE_119_MUDKIP, Route119_Text_MayDefeat)
    }
	msgbox(Route119_Text_MayPresentForYou, MSGBOX_DEFAULT)
    giveitem(ITEM_HM_FLY)
    setflag(FLAG_RECEIVED_HM_FLY)
    msgbox(Route119_Text_MayExplainFly, MSGBOX_DEFAULT)
    goto(Route119_EventScript_RivalExitScottArrive)
    end
}

script Route119_EventScript_BattleBrendan {
    msgbox(Route119_Text_BrendanIntro, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case 0: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_119_TREECKO, Route119_Text_BrendanDefeat)
        case 1: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_119_TORCHIC, Route119_Text_BrendanDefeat)
        case 2: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_119_MUDKIP, Route119_Text_BrendanDefeat)
    }
	msgbox(Route119_Text_BrendanIllGiveYouThis, MSGBOX_DEFAULT)
    giveitem(ITEM_HM_FLY)
    setflag(FLAG_RECEIVED_HM_FLY)
    msgbox(Route119_Text_BrendanExplainFly, MSGBOX_DEFAULT)
    goto(Route119_EventScript_RivalExitScottArrive)
    end
}

script Route119_EventScript_RivalExitScottArrive {
    closemessage
	switch (var(VAR_TEMP_1)) {
		case 1: call(Route119_EventScript_SetRivalPos1)
		case 2: call(Route119_EventScript_SetRivalPos2)
	}
    removeobject(LOCALID_ROUTE119_RIVAL)
    addobject(LOCALID_ROUTE119_RIVAL_ON_BIKE)
    delay(30)
	switch (var(VAR_TEMP_1)) {
		case 1:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_right,  delay_8,  step_faster_up))
    		applymovement(LOCALID_ROUTE119_RIVAL_ON_BIKE, moves(run_right,  run_up * 3,  run_right,  run_up * 4))
		case 2:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_left,  delay_8,  step_faster_up))
    		applymovement(LOCALID_ROUTE119_RIVAL_ON_BIKE, moves(run_left,  run_up * 3,  run_right * 2,  run_up * 4))
	}
	waitmovement(0)
    removeobject(LOCALID_ROUTE119_RIVAL_ON_BIKE)
    setvar(VAR_ROUTE119_STATE, 1)
    savebgm(MUS_DUMMY)
    fadedefaultbgm
    delay(60)
	switch (var(VAR_TEMP_1)) {
		case 1: setobjectxyperm(LOCALID_ROUTE119_SCOTT, 27, 25)
		case 2: setobjectxyperm(LOCALID_ROUTE119_SCOTT, 28, 25)
	}
    addobject(LOCALID_ROUTE119_SCOTT)
    applymovement(LOCALID_ROUTE119_SCOTT, moves(walk_down * 4,  walk_left * 2,  walk_down))
    waitmovement(0)
    addvar(VAR_SCOTT_STATE, 1)
    msgbox(Route119_Text_ScottWayToGoBeSeeingYou, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_TEMP_1)) {
		case 1: applymovement(LOCALID_ROUTE119_SCOTT, moves(walk_up,  walk_right * 2,  walk_up * 5))
		case 2: applymovement(LOCALID_ROUTE119_SCOTT, moves(walk_up,  walk_right,  walk_up * 5))
	}
	waitmovement(0)
    removeobject(LOCALID_ROUTE119_SCOTT)
    releaseall
    end
}

script Route119_EventScript_SetRivalPos1 {
    setobjectxyperm(LOCALID_ROUTE119_RIVAL, 25, 32)
    setobjectxyperm(LOCALID_ROUTE119_RIVAL_ON_BIKE, 25, 32)
    return
}

script Route119_EventScript_SetRivalPos2 {
    setobjectxyperm(LOCALID_ROUTE119_RIVAL, 26, 32)
    setobjectxyperm(LOCALID_ROUTE119_RIVAL_ON_BIKE, 26, 32)
    return
}

