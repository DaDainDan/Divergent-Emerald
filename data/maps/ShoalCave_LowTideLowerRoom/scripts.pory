mapscripts ShoalCave_LowTideLowerRoom_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_RECEIVED_SHOAL_SALT_4)) {
			setmetatile(18, 2, METATILE_Cave_ShoalCave_DirtPile_Large, TRUE)
		}
		end
    }
}

script ShoalCave_LowTideLowerRoom_EventScript_ShoalSalt4 {
    lockall
    if (flag(FLAG_RECEIVED_SHOAL_SALT_4)) {
        msgbox(ShoalCave_Text_WasShoalSaltNowNothing, MSGBOX_DEFAULT)
    } else {
		if (giveitem(ITEM_SHOAL_SALT) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		setmetatile(18, 2, METATILE_Cave_ShoalCave_DirtPile_Small, FALSE)
		special(DrawWholeMapView)
		setflag(FLAG_RECEIVED_SHOAL_SALT_4)
	}
    releaseall
    end
}

script ShoalCave_LowTideLowerRoom_EventScript_BlackBelt {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_FOCUS_BAND)) {
        msgbox(ShoalCave_LowTideLowerRoom_Text_EverythingStartsWithFocus, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(ShoalCave_LowTideLowerRoom_Text_CanOvercomeColdWithFocus, MSGBOX_DEFAULT)
    if (giveitem(ITEM_FOCUS_BAND) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_FOCUS_BAND)
    release_end
}

text ShoalCave_LowTideLowerRoom_Text_CanOvercomeColdWithFocus {
	"The penetrating cold around these
	parts is an impediment to training.

	But with focus, one can overcome!

	With this FOCUS BAND, buckle down and
	withstand the cold!"
}

text ShoalCave_LowTideLowerRoom_Text_EverythingStartsWithFocus {
	"Everything starts with focus!"
}
