mapscripts SootopolisCity_MysteryEventsHouse_1F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        frontier_checkvisittrainer
		if (var(VAR_RESULT) == 0) {
			setvar(VAR_TEMP_1, 1)
			setobjectxyperm(LOCALID_MYSTERY_EVENTS_OLD_MAN, 3, 2)
			setobjectmovementtype(LOCALID_MYSTERY_EVENTS_OLD_MAN, MOVEMENT_TYPE_FACE_DOWN)
			setmaplayoutindex(LAYOUT_SOOTOPOLIS_CITY_MYSTERY_EVENTS_HOUSE_1F_STAIRS_UNBLOCKED)
		}
		if (var(VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE) != 0) {
			setobjectxyperm(LOCALID_MYSTERY_EVENTS_OLD_MAN, 2, 2)
			setobjectmovementtype(LOCALID_MYSTERY_EVENTS_OLD_MAN, MOVEMENT_TYPE_FACE_RIGHT)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE, 1: SootopolisCity_MysteryEventsHouse_1F_EventScript_OldManCommentOnBattle
    	VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE, 2: SootopolisCity_MysteryEventsHouse_1F_EventScript_OldManCommentOnBattle
    	VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE, 3: SootopolisCity_MysteryEventsHouse_1F_EventScript_OldManCommentOnBattle
    ]
}

script SootopolisCity_MysteryEventsHouse_1F_EventScript_OldManCommentOnBattle {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    applymovement(LOCALID_MYSTERY_EVENTS_OLD_MAN, moves(walk_right,  step_faster_down))
    waitmovement(0)
    copyobjectxytoperm(LOCALID_MYSTERY_EVENTS_OLD_MAN)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
	switch (var(VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE)) {
		case 1: msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_ThatWasSuperlative, MSGBOX_DEFAULT)
		case 2: msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_TooBadForYou, MSGBOX_DEFAULT)
		case 3: msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_BrilliantStandoff, MSGBOX_DEFAULT)
	}
    special(LoadPlayerParty)
    setvar(VAR_SOOTOPOLIS_MYSTERY_EVENTS_STATE, 0)
    releaseall
    end
}

script SootopolisCity_MysteryEventsHouse_1F_EventScript_OldMan {
    lock_faceplayer
    frontier_checkvisittrainer
    if (var(VAR_RESULT) == 1) {
        msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_OnlyAmusementWatchingBattles, MSGBOX_DEFAULT)
    	release_end
    }
    if (var(VAR_TEMP_1) == 1) {
        goto(SootopolisCity_MysteryEventsHouse_1F_EventScript_TrainerVisiting)
    }
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_OnlyAmusementWatchingBattles, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_MysteryEventsHouse_1F_EventScript_TrainerVisiting {
    special(SavePlayerParty)
    special(BufferEReaderTrainerName)
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_ChallengeVisitingTrainer, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SootopolisCity_MysteryEventsHouse_1F_EventScript_DeclineBattle)
    }
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_KeepItTo3On3, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    special(ChooseHalfPartyForBattle)
    if (var(VAR_RESULT) == 0) {
        goto(SootopolisCity_MysteryEventsHouse_1F_EventScript_DeclineBattle)
    }
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_SaveProgressBeforeBattle, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SootopolisCity_MysteryEventsHouse_1F_EventScript_DeclineBattle)
    }
    special(LoadPlayerParty)
    call(Common_EventScript_SaveGame)
    if (var(VAR_RESULT) == FALSE) {
        goto(SootopolisCity_MysteryEventsHouse_1F_EventScript_DeclineBattle)
    }
    special(SavePlayerParty)
    special(ReducePlayerPartyToSelectedMons)
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_HopeToSeeGoodMatch, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement(VAR_LAST_TALKED, moves(walk_left,  step_faster_right))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_up * 2))
		case DIR_EAST:
			applymovement(VAR_LAST_TALKED, moves(walk_right,  step_faster_left))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_right,  walk_up))
		case DIR_WEST:
			applymovement(VAR_LAST_TALKED, moves(walk_left,  step_faster_right))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_left,  walk_up))
	}
	waitmovement(0)
    warp(MAP_SOOTOPOLIS_CITY_MYSTERY_EVENTS_HOUSE_B1F, 3, 1)
    waitstate
    release_end
}

script SootopolisCity_MysteryEventsHouse_1F_EventScript_DeclineBattle {
    special(LoadPlayerParty)
    msgbox(SootopolisCity_MysteryEventsHouse_1F_Text_YouWontBattle, MSGBOX_DEFAULT)
    release_end
}

text SootopolisCity_MysteryEventsHouse_1F_Text_OnlyAmusementWatchingBattles {
	"When I was young, I traveled the world
	as a POKéMON TRAINER.

	Now that I've become an old buzzard,
	my only amusement is watching young
	TRAINERS battle."
}

text SootopolisCity_MysteryEventsHouse_1F_Text_DoorAppearsToBeLocked {
	"The door appears to be locked."
}

text SootopolisCity_MysteryEventsHouse_1F_Text_ChallengeVisitingTrainer {
	"A TRAINER named {STR_VAR_1}
	is visiting my home.

	Would you like to challenge
	{STR_VAR_1}?"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_YouWontBattle {
	"You won't battle? I'm disappointed
	that I can't see you battle…"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_KeepItTo3On3 {
	"Oh, good, good!

	But my house isn't all that sturdy.

	Could I ask you to keep it down to
	a 3-on-3 match?"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_SaveProgressBeforeBattle {
	"Before you two battle, you should
	save your progress."
}

text SootopolisCity_MysteryEventsHouse_1F_Text_HopeToSeeGoodMatch {
	"I hope to see a good match!"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_StrVar1Tie {
	"{STR_VAR_1}"
}

text SootopolisCity_MysteryEventsHouse_B1F_Text_MatchEndedUpDraw {
	"The match ended up a draw."
}

text SootopolisCity_MysteryEventsHouse_1F_Text_BrilliantStandoff {
	"So, it became a standoff.

	It was a brilliant match in which
	neither side conceded a step!"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_StrVar1Won {
	"{STR_VAR_1}"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_ThatWasSuperlative {
	"That was superlative!

	Why, it was like seeing myself in
	my youth again!"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_StrVar1Lost {
	"{STR_VAR_1}"
}

text SootopolisCity_MysteryEventsHouse_1F_Text_TooBadForYou {
	"Ah, too bad for you!

	But it was a good match.
	I hope you can win next time."
}
