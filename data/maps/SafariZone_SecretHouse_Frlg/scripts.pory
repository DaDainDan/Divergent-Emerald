mapscripts SafariZone_SecretHouse_Frlg_MapScripts {}

script SafariZone_SecretHouse_EventScript_Attendant {
    lock_faceplayer
    if (flag(FLAG_GOT_HM03)) {
        msgbox(SafariZone_SecretHouse_Text_ExplainSurf)
    	release_end
    }
    msgbox(SafariZone_SecretHouse_Text_CongratsYouveWon)
    if (checkitemspace(ITEM_HM03) == FALSE) {
        msgbox(SafariZone_SecretHouse_Text_DontHaveRoomForPrize)
    	release_end
    }
    giveitem_msg(SafariZone_SecretHouse_Text_ReceivedHM03FromAttendant, ITEM_HM03)
    msgbox(SafariZone_SecretHouse_Text_ExplainSurf)
    setflag(FLAG_GOT_HM03)
    release_end
}

text SafariZone_SecretHouse_Text_CongratsYouveWon {
	"Ah! Finally!

	You're the first person to reach
	the SECRET HOUSE!

	Although I made a campaign
	for our grand opening,

	I was getting worried that no one
	would win our campaign prize.

	Congratulations!
	You have won!"
}

text SafariZone_SecretHouse_Text_ReceivedHM03FromAttendant {
	"{PLAYER} received HM03
	from the attendant!"
}

text SafariZone_SecretHouse_Text_ExplainSurf {
	"HM03 is SURF.

	POKéMON will be able to ferry you
	across water using it.

	And, this HM isn't disposable, so
	you can use it over and over.

	You're super lucky for winning this
	fabulous prize!"
}

text SafariZone_SecretHouse_Text_DontHaveRoomForPrize {
	"You don't have room for this
	fabulous prize!"
}
