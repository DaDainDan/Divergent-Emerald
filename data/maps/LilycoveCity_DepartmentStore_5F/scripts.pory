mapscripts LilycoveCity_DepartmentStore_5F_MapScripts {
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_SOOTOPOLIS_CITY_STATE, 1: LilycoveCity_DepartmentStore_5F_EventScript_BlockRoofStairs
    	VAR_SOOTOPOLIS_CITY_STATE, 2: LilycoveCity_DepartmentStore_5F_EventScript_BlockRoofStairs
    	VAR_SOOTOPOLIS_CITY_STATE, 3: LilycoveCity_DepartmentStore_5F_EventScript_BlockRoofStairs
    ]
}

// During the abnormal weather from Kyogre/Groudon awakening the dept store rooftop is inaccessible
// Likely done to avoid dealing with showing the weather. Technically the rooftop is indoors
script LilycoveCity_DepartmentStore_5F_EventScript_BlockRoofStairs {
    setobjectxy(LOCALID_DEPARTMENT_STORE_STAIRS_WOMAN, 16, 2)
    turnobject(LOCALID_DEPARTMENT_STORE_STAIRS_WOMAN, DIR_NORTH)
    end
}

script LilycoveCity_DepartmentStore_5F_EventScript_ClerkFarLeft {
    lock_faceplayer
	setvar(VAR_0x8007, 0)
    goto(LilycoveCity_DepartmentStore_5F_EventScript_ClerkMain)
	end
}

script LilycoveCity_DepartmentStore_5F_EventScript_ClerkMain {
	message(gText_HowMayIServeYou)
    waitmessage
	switch (var(VAR_0x8007)) {
		case 0: pokemartdecoration2(LilycoveCity_DepartmentStore_5F_Pokemart_Dolls)
		case 1: pokemartdecoration2(LilycoveCity_DepartmentStore_5F_Pokemart_Cushions)
		case 2: pokemartdecoration2(LilycoveCity_DepartmentStore_5F_Pokemart_Posters)
		case 3: pokemartdecoration2(LilycoveCity_DepartmentStore_5F_Pokemart_Mats)
	}
    pokemartdecoration2(LilycoveCity_DepartmentStore_5F_Pokemart_Dolls)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

