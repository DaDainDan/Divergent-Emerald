script LilycoveCity_DepartmentStore_5F_EventScript_PokefanF {
    msgbox(LilycoveCity_DepartmentStore_5F_Text_PlaceFullOfCuteDolls, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_5F_EventScript_Woman {
    lockall
    applymovement(LOCALID_DEPARTMENT_STORE_STAIRS_WOMAN, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 0 || var(VAR_SOOTOPOLIS_CITY_STATE) >= 4) {
        msgbox(LilycoveCity_DepartmentStore_5F_Text_SellManyCuteMatsHere, MSGBOX_DEFAULT)
		closemessage
    } else {
		msgbox(LilycoveCity_DepartmentStore_5F_Text_ClosedRooftopForWeather, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_DEPARTMENT_STORE_STAIRS_WOMAN, Common_Movement_StepFasterUp)
		waitmovement(0)
	}
    releaseall
    end
}

script LilycoveCity_DepartmentStore_5F_EventScript_LittleGirl {
    msgbox(LilycoveCity_DepartmentStore_5F_Text_GettingDollInsteadOfPokemon, MSGBOX_NPC)
    end
}

text LilycoveCity_DepartmentStore_5F_Text_PlaceFullOfCuteDolls {
	"This place is full of cute DOLLS.

	I should buy some for me, instead of
	just for my children."
}

text LilycoveCity_DepartmentStore_5F_Text_GettingDollInsteadOfPokemon {
	"I'm not big enough to raise POKéMON,
	so I'm getting a cute DOLL instead."
}

text LilycoveCity_DepartmentStore_5F_Text_SellManyCuteMatsHere {
	"They sell many cute MATS here.

	I wonder which one I should get?
	Maybe I'll buy them all…"
}

text LilycoveCity_DepartmentStore_5F_Text_ClosedRooftopForWeather {
	"I think they closed the rooftop
	because the weather is wild today."
}
