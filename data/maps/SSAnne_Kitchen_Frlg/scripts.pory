mapscripts SSAnne_Kitchen_Frlg_MapScripts {}

script SSAnne_Kitchen_EventScript_Chef1 {
    msgbox(SSAnne_Kitchen_Text_BusyOutOfTheWay, MSGBOX_NPC)
    end
}

script SSAnne_Kitchen_EventScript_Chef2 {
    msgbox(SSAnne_Kitchen_Text_SawOddBerryInTrash, MSGBOX_NPC)
    end
}

script SSAnne_Kitchen_EventScript_Chef3 {
    msgbox(SSAnne_Kitchen_Text_SoBusyImDizzy, MSGBOX_NPC)
    end
}

script SSAnne_Kitchen_EventScript_Chef4 {
    lock_faceplayer
    msgbox(SSAnne_Kitchen_Text_IAmLeChefMainCourseIs)
    random(3)
    copyvar(VAR_0x8008, VAR_RESULT)
	switch (var(VAR_0x8008)) {
		case 0: msgbox(SSAnne_Kitchen_Text_SalmonDuSalad)
		case 1: msgbox(SSAnne_Kitchen_Text_EelsAuBarbecue)
		case 2: msgbox(SSAnne_Kitchen_Text_PrimeBeefsteak)
	}
    release_end
}

script SSAnne_Kitchen_EventScript_Chef5 {
    msgbox(SSAnne_Kitchen_Text_PeelSpudsEveryDay, MSGBOX_NPC)
    end
}

script SSAnne_Kitchen_EventScript_Chef6 {
    msgbox(SSAnne_Kitchen_Text_HearAboutSnorlaxItsAGlutton, MSGBOX_NPC)
    end
}

script SSAnne_Kitchen_EventScript_Chef7 {
    msgbox(SSAnne_Kitchen_Text_OnlyGetToPeelOnions, MSGBOX_NPC)
    end
}

text SSAnne_Kitchen_Text_BusyOutOfTheWay {
	"You, mon petit!
	We're busy here!
	Out of the way!"
}

text SSAnne_Kitchen_Text_SawOddBerryInTrash {
	"I saw an odd BERRY in the trash.
	I wonder what that was?"
}

text SSAnne_Kitchen_Text_SoBusyImDizzy {
	"I'm so busy I'm getting dizzy!
	You have to give me room here!"
}

text SSAnne_Kitchen_Text_PeelSpudsEveryDay {
	"Hum-de-hum-de-ho…

	I peel spuds every day!
	Hum-hum…"
}

text SSAnne_Kitchen_Text_HearAboutSnorlaxItsAGlutton {
	"Did you hear about SNORLAX?
	It's a glutton.

	No other POKéMON eats and sleeps
	the way SNORLAX can and does!"
}

text SSAnne_Kitchen_Text_OnlyGetToPeelOnions {
	"Snivel… Sniff…

	I only get to peel onions…
	Snivel…"
}

text SSAnne_Kitchen_Text_IAmLeChefMainCourseIs {
	"Er-hem!
	Indeed I am le CHEF!

	Le main course is"
}

text SSAnne_Kitchen_Text_SalmonDuSalad {
	"Salmon du Salad!

	Les guests may gripe it's fish
	again, however!"
}

text SSAnne_Kitchen_Text_EelsAuBarbecue {
	"Eels au Barbecue!

	Les guests will mutiny, I fear."
}

text SSAnne_Kitchen_Text_PrimeBeefsteak {
	"Prime Beefsteak!

	But, have I enough fillets du
	beef?"
}
