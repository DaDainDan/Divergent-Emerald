mapscripts CinnabarIsland_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_CINNABAR_ISLAND)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script CinnabarIsland_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script CinnabarIsland_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(CinnabarIsland_PokemonCenter_1F_Text_VisitUnionRoom, MSGBOX_NPC)
    end
}

script CinnabarIsland_PokemonCenter_1F_EventScript_CooltrainerF {
    msgbox(CinnabarIsland_PokemonCenter_1F_Text_CinnabarGymLocked, MSGBOX_NPC)
    end
}

script CinnabarIsland_PokemonCenter_1F_EventScript_Youngster {
    msgbox(CinnabarIsland_PokemonCenter_1F_Text_EvolutionCanWaitForNewMoves, MSGBOX_NPC)
    end
}

script CinnabarIsland_PokemonCenter_1F_EventScript_Bill {
    lock_faceplayer
    msgbox(CinnabarIsland_PokemonCenter_1F_Text_ReadyToSailToOneIsland, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(CinnabarIsland_PokemonCenter_1F_Text_OhNotDoneYet)
    	release_end
    }
    msgbox(CinnabarIsland_PokemonCenter_1F_Text_LetsGo)
    closemessage
    playbgm(MUS_FOLLOW_ME, 1)
    savebgm(MUS_FOLLOW_ME)
    setflag(FLAG_DONT_TRANSITION_MUSIC)
    setflag(FLAG_HIDE_CINNABAR_POKECENTER_BILL)
    delay(20)
	switch (var(VAR_FACING)) {
		case DIR_SOUTH:
			applymovement(LOCALID_CINNABAR_POKEMON_CENTER_BILL, moves(walk_left * 4,  walk_down * 3,  delay_8,  set_invisible))
    		applymovement(LOCALID_PLAYER, moves(walk_down,  walk_left * 4,  walk_down * 2,  delay_16,  walk_down))
		case DIR_EAST:
			applymovement(LOCALID_CINNABAR_POKEMON_CENTER_BILL, CinnabarIsland_PokemonCenter_1F_Movement_BillExitEast)
    		applymovement(LOCALID_PLAYER, CinnabarIsland_PokemonCenter_1F_Movement_PlayerExitEast)
		case DIR_WEST:
			applymovement(LOCALID_CINNABAR_POKEMON_CENTER_BILL, moves(walk_left * 4,  walk_down * 3,  delay_8,  set_invisible))
    		applymovement(LOCALID_PLAYER, moves(walk_left * 5,  walk_down * 2,  delay_16,  walk_down))
	}
	waitmovement(0)
    removeobject(LOCALID_CINNABAR_POKEMON_CENTER_BILL)
    setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_2, 1)
    clearflag(FLAG_HIDE_CINNABAR_BILL)
    warp(MAP_CINNABAR_ISLAND, 14, 11)
    waitstate
    release_end
}

movement CinnabarIsland_PokemonCenter_1F_Movement_BillExitEast {
    // moves(walk_up,  walk_left * 2,  walk_down,  walk_left * 2,  walk_down * 3,  delay_8,  set_invisible)
    walk_up
    walk_left * 2
    walk_down
    walk_left * 2
    walk_down * 3
    delay_8
    set_invisible
}

movement CinnabarIsland_PokemonCenter_1F_Movement_PlayerExitEast {
    // moves(delay_16 * 3,  face_left,  delay_16,  walk_left * 3,  walk_down * 2,  delay_8,  walk_down,  delay_8,  set_invisible)
    delay_16 * 3
    face_left
    delay_16
    walk_left * 3
    walk_down * 2
    delay_8
    walk_down
    delay_8
    set_invisible
}

text CinnabarIsland_PokemonCenter_1F_Text_CinnabarGymLocked {
	"I came to visit the CINNABAR GYM,
	but the door is locked tight.

	There should be a key for it
	somewhere.

	Could it be in that burned-out
	mansion?

	The GYM LEADER's friend used to
	live there, they say."
}

text CinnabarIsland_PokemonCenter_1F_Text_VisitUnionRoom {
	"Do you have lots of friends?

	Linking up with the usual friends
	is fun, of course.

	But how about visiting the
	UNION ROOM every so often?

	Who knows, you may end up making
	new friends.

	I think it would be worth your time
	to check the UNION ROOM."
}

text CinnabarIsland_PokemonCenter_1F_Text_EvolutionCanWaitForNewMoves {
	"POKéMON can still learn techniques
	after canceling evolution.

	Evolution can wait until new moves
	have been learned."
}

text CinnabarIsland_PokemonCenter_1F_Text_ReadyToSailToOneIsland {
	"BILL: Hey, you kept me waiting!
	Ready to set sail to ONE ISLAND?"
}

text CinnabarIsland_PokemonCenter_1F_Text_OhNotDoneYet {
	"Oh, you're still not done yet?"
}

text CinnabarIsland_PokemonCenter_1F_Text_LetsGo {
	"Well, that's it.
	Let's go!"
}
