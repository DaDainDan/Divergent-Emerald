mapscripts PokemonTower_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_POKEMON_TOWER_1F)
    	end
    }
}

script PokemonTower_1F_EventScript_Channeler {
    msgbox(PokemonTower_1F_Text_SenseSpiritsUpToMischief, MSGBOX_NPC)
    end
}

script PokemonTower_1F_EventScript_Woman1 {
    msgbox(PokemonTower_1F_Text_GrowlitheWhyDidYouDie, MSGBOX_NPC)
    end
}

script PokemonTower_1F_EventScript_BaldingMan {
    msgbox(PokemonTower_1F_Text_CameToPrayForDepartedClefairy, MSGBOX_NPC)
    end
}

script PokemonTower_1F_EventScript_Woman2 {
    lock_faceplayer
    if (checkplayergender == MALE) {
        msgbox(PokemonTower_1F_Text_ComeToPayRespectsSon)
    	release_end
    }
    msgbox(PokemonTower_1F_Text_ComeToPayRespectsGirl)
    release_end
}

script PokemonTower_1F_EventScript_WorkerF {
    msgbox(PokemonTower_1F_Text_ErectedInMemoryOfDeadMons, MSGBOX_NPC)
    end
}

text PokemonTower_1F_Text_ErectedInMemoryOfDeadMons {
	"POKéMON TOWER was erected in the
	memory of POKéMON that died."
}

text PokemonTower_1F_Text_ComeToPayRespectsSon {
	"Did you come to pay respects?

	Bless your POKéMON-loving heart,
	son."
}

text PokemonTower_1F_Text_ComeToPayRespectsGirl {
	"Did you come to pay respects?

	Bless your POKéMON-loving heart,
	girl."
}

text PokemonTower_1F_Text_CameToPrayForDepartedClefairy {
	"I came to pray for my dearly
	departed CLEFAIRY.

	Sniff!
	I'm awash in tears…"
}

text PokemonTower_1F_Text_GrowlitheWhyDidYouDie {
	"My GROWLITHE…
	Why did you die?"
}

text PokemonTower_1F_Text_SenseSpiritsUpToMischief {
	"I am a CHANNELER.

	There are spirits up to mischief.
	I sense them high in the TOWER."
}
