mapscripts MossdeepCity_PokemonCenter_1F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_MOSSDEEP_CITY)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script MossdeepCity_PokemonCenter_1F_EventScript_Nurse {
    setvar(VAR_0x800B, LOCALID_MOSSDEEP_NURSE)
    call(Common_EventScript_PkmnCenterNurse)
    waitmessage
    waitbuttonpress
    release_end
}

script MossdeepCity_PokemonCenter_1F_EventScript_Woman {
    msgbox(MossdeepCity_PokemonCenter_1F_Text_GymLeaderDuoFormidable, MSGBOX_NPC)
    end
}

script MossdeepCity_PokemonCenter_1F_EventScript_Girl {
    msgbox(MossdeepCity_PokemonCenter_1F_Text_AbilitiesMightChangeMoves, MSGBOX_NPC)
    end
}

text MossdeepCity_PokemonCenter_1F_Text_GymLeaderDuoFormidable {
	"The GYM LEADERS in this town are
	a formidable duo.

	Their combination attacks are, like,
	excellent and wow!"
}

text MossdeepCity_PokemonCenter_1F_Text_AbilitiesMightChangeMoves {
	"Depending on the special abilities of
	POKéMON, some moves might change
	or not work at all."
}
