const RECEIVED_TOWN_MAP = VAR_TEMP_1

mapscripts PalletTown_RivalsHouse_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE) < 2) {
			setobjectmovementtype(LOCALID_DAISY, MOVEMENT_TYPE_FACE_RIGHT)
			setobjectxyperm(LOCALID_DAISY, 5, 4)
		} else {
			setvar(RECEIVED_TOWN_MAP, TRUE)
		}
		end
    }
}

script PalletTown_RivalsHouse_EventScript_Daisy {
    lock_faceplayer
    famechecker(FAMECHECKER_DAISY, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        goto(PalletTown_RivalsHouse_EventScript_GroomMon)
    }
    elif (var(RECEIVED_TOWN_MAP) == TRUE) {
        msgbox(PalletTown_RivalsHouse_Text_PleaseGiveMonsRest)
    }
    elif (var(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE) == 2) {
        msgbox(PalletTown_RivalsHouse_Text_ExplainTownMap)
    }
    elif (var(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE) == 1) {
        msgbox(PalletTown_RivalsHouse_Text_ErrandForGrandpaThisWillHelp)
		closemessage
		if (checkitemspace(ITEM_TOWN_MAP) == FALSE) {
			msgbox(PalletTown_RivalsHouse_Text_DontHaveSpaceForThis)
			release_end
		}
		applymovement(LOCALID_DAISY, Common_Movement_StepFasterRight)
		waitmovement(0)
		removeobject(LOCALID_TOWN_MAP)
		setvar(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE, 2)
		delay(15)
		applymovement(LOCALID_DAISY, Common_Movement_FacePlayer)
		waitmovement(0)
		delay(12)
		giveitem_msg(PalletTown_RivalsHouse_Text_ReceivedTownMapFromDaisy, ITEM_TOWN_MAP, 1, MUS_RG_OBTAIN_KEY_ITEM)
    }
    elif (var(VAR_MAP_SCENE_PALLET_TOWN_PROFESSOR_OAKS_LAB) >= 1) {
        msgbox(PalletTown_RivalsHouse_Text_HeardYouBattledRival)
    }
	else {
		msgbox(PalletTown_RivalsHouse_Text_HiBrothersAtLab)
		closemessage
		applymovement(LOCALID_DAISY, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    release_end
}

script PalletTown_RivalsHouse_EventScript_GroomMon {
    if (var(VAR_MASSAGE_COOLDOWN_STEP_COUNTER) < 500) {
        msgbox(PalletTown_RivalsHouse_Text_MayISeeFirstMon)
		specialvar(VAR_RESULT, GetLeadMonFriendship)
		switch (var(VAR_RESULT)) {
			case 0: msgbox(PalletTown_RivalsHouse_Text_WhyWouldMonHateYouSoMuch)
			case 1: msgbox(PalletTown_RivalsHouse_Text_DontLikeWayItGlaresAtYou)
			case 2: msgbox(PalletTown_RivalsHouse_Text_NotFamiliarWithYouYet)
			case 3: msgbox(PalletTown_RivalsHouse_Text_ItsWarmingUpToYou)
			case 4: msgbox(PalletTown_RivalsHouse_Text_ItsQuiteFriendly)
			case 5: msgbox(PalletTown_RivalsHouse_Text_ItLooksVeryHappy)
			case 6: msgbox(PalletTown_RivalsHouse_Text_CouldntLoveYouMore)
		}
		release_end
    }
    msgbox(PalletTown_RivalsHouse_Text_LikeMeToGroomMon, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(PalletTown_RivalsHouse_EventScript_DeclineGrooming)
    }
    msgbox(PalletTown_RivalsHouse_Text_GroomWhichOne)
    special(ChoosePartyMon)
    lock_faceplayer
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(PalletTown_RivalsHouse_EventScript_DeclineGrooming)
    }
    if (specialvar(VAR_RESULT, ScriptGetPartyMonSpecies) == SPECIES_EGG) {
        msgbox(PalletTown_RivalsHouse_Text_CantGroomAnEgg)
    	release_end
    }
    msgbox(PalletTown_RivalsHouse_Text_LookingNiceInNoTime)
    closemessage
    fadescreen(FADE_TO_BLACK)
    playfanfare(MUS_HEAL)
    waitfanfare
    special(DaisyMassageServices)
    fadescreen(FADE_FROM_BLACK)
    special(BufferMonNickname)
    msgbox(PalletTown_RivalsHouse_Text_ThereYouGoAllDone)
    release_end
}

script PalletTown_RivalsHouse_EventScript_DeclineGrooming {
    msgbox(PalletTown_RivalsHouse_Text_DontNeedAnyGrooming)
    release_end
}

script PalletTown_RivalsHouse_EventScript_TownMap {
    msgbox(PalletTown_RivalsHouse_Text_ItsBigMapOfKanto, MSGBOX_NPC)
    end
}

script PalletTown_RivalsHouse_EventScript_Bookshelf {
    msgbox(PalletTown_RivalsHouse_Text_ShelvesCrammedFullOfBooks, MSGBOX_SIGN)
    end
}

script PalletTown_RivalsHouse_EventScript_Picture {
    msgbox(PalletTown_RivalsHouse_Text_LovelyAndSweetClefairy, MSGBOX_SIGN)
    end
}

text PalletTown_RivalsHouse_Text_HiBrothersAtLab {
	"DAISY: Hi, {PLAYER}!

	My brother, {RIVAL}, is out at
	Grandpa's LAB."
}

text PalletTown_RivalsHouse_Text_HeardYouBattledRival {
	"DAISY: {PLAYER}, I heard you had
	a battle against {RIVAL}.

	I wish I'd seen that!"
}

text PalletTown_RivalsHouse_Text_ErrandForGrandpaThisWillHelp {
	"Grandpa asked you to run an
	errand?

	Gee, that's lazy of him.
	Here, this will help you."
}

text PalletTown_RivalsHouse_Text_ReceivedTownMapFromDaisy {
	"{PLAYER} received a TOWN MAP
	from DAISY."
}

text PalletTown_RivalsHouse_Text_DontHaveSpaceForThis {
	"You don't have space for this in
	your BAG."
}

text PalletTown_RivalsHouse_Text_ExplainTownMap {
	"You can use the TOWN MAP to find
	out where you are, or check the
	names of places."
}

text PalletTown_RivalsHouse_Text_PleaseGiveMonsRest {
	"DAISY: Just like people, POKéMON
	are living things.

	When they get tired, please give
	them a rest."
}

text PalletTown_RivalsHouse_Text_ItsBigMapOfKanto {
	"It's a big map of the KANTO region.
	Now this would be useful!"
}

text PalletTown_RivalsHouse_Text_ShelvesCrammedFullOfBooks {
	"The shelves are crammed full of
	books on POKéMON."
}

text PalletTown_RivalsHouse_Text_LikeMeToGroomMon {
	"DAISY: Hi, {PLAYER}!
	Good timing.

	I'm about to have some tea.
	Would you like to join me?

	Oh, but look.
	Your POKéMON are a little dirty.

	Would you like me to groom one?"
}

text PalletTown_RivalsHouse_Text_DontNeedAnyGrooming {
	"You don't need any grooming done?
	Okay, we'll just have tea."
}

text PalletTown_RivalsHouse_Text_GroomWhichOne {
	"Which one should I groom?"
}

text PalletTown_RivalsHouse_Text_LookingNiceInNoTime {
	"DAISY: Okay, I'll get it looking
	nice in no time."
}

raw `
PalletTown_RivalsHouse_Text_ThereYouGoAllDone::
#ifdef BUGFIX @ The localizers missed what should be a textcolor change in the localizations.
	.string "{COLOR DARK_GRAY}{STR_VAR_1} looks dreamily content…\p"
	.string "{COLOR RED}DAISY: There you go! All done.\n"
#else @ In the JP games, gender-based text used a different font instead of different colors.
	.string "{FONT_NORMAL}{STR_VAR_1} looks dreamily content…\p"
	.string "{FONT_FEMALE}DAISY: There you go! All done.\n"
#endif
	.string "See? Doesn't it look nice?\p"
	.string "Giggle…\n"
	.string "It's such a cute POKéMON.$"
`

text PalletTown_RivalsHouse_Text_CantGroomAnEgg {
	"Oh, sorry. I honestly can't
	groom an EGG."
}

text PalletTown_RivalsHouse_Text_MayISeeFirstMon {
	"DAISY: Your POKéMON grow to love
	you if you raise them with love.

	For example, {PLAYER}, may I see
	your first POKéMON?"
}

text PalletTown_RivalsHouse_Text_CouldntLoveYouMore {
	"It couldn't possibly love you
	any more than it does now.

	Your POKéMON is happy beyond
	words."
}

text PalletTown_RivalsHouse_Text_ItLooksVeryHappy {
	"It looks very happy.

	I wish {RIVAL} could see this and
	learn something from it."
}

text PalletTown_RivalsHouse_Text_ItsQuiteFriendly {
	"It's quite friendly with you.
	Keep being good to it!"
}

text PalletTown_RivalsHouse_Text_ItsWarmingUpToYou {
	"It's warming up to you.
	Trust must be growing between you."
}

text PalletTown_RivalsHouse_Text_NotFamiliarWithYouYet {
	"It's not quite familiar with you
	yet.

	POKéMON are all quite wary when
	you first get them."
}

text PalletTown_RivalsHouse_Text_DontLikeWayItGlaresAtYou {
	"{PLAYER}, I don't like the way it
	glares at you.

	Could you try being a little nicer
	to it?"
}

text PalletTown_RivalsHouse_Text_WhyWouldMonHateYouSoMuch {
	"…Um, it's not easy for me to say
	this, but…

	Is there some reason why your
	POKéMON would hate you so much?"
}

text PalletTown_RivalsHouse_Text_LovelyAndSweetClefairy {
	"“The lovely and sweet
	CLEFAIRY”"
}
