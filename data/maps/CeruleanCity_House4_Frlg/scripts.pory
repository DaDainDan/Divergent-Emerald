const REWARD_TYPE = VAR_0x8004
const REWARD_ITEM = VAR_0x8008

mapscripts CeruleanCity_House4_Frlg_MapScripts {}

script CeruleanCity_House4_EventScript_WonderNewsBerryMan {
    lock
    specialvar(REWARD_TYPE, WonderNews_GetRewardInfo)
    copyvar(REWARD_ITEM, VAR_RESULT)
	switch (var(REWARD_TYPE)) {
		case NEWS_REWARD_NONE: goto(CeruleanCity_House4_EventScript_NoNews)
		case NEWS_REWARD_RECV_SMALL: goto(CeruleanCity_House4_EventScript_Reward_RecvSmall)
		case NEWS_REWARD_RECV_BIG: goto(CeruleanCity_House4_EventScript_Reward_RecvBig)
		case NEWS_REWARD_WAITING: goto(CeruleanCity_House4_EventScript_Waiting)
		case NEWS_REWARD_SENT_SMALL: goto(CeruleanCity_House4_EventScript_Reward_SentSmall)
		case NEWS_REWARD_SENT_BIG: goto(CeruleanCity_House4_EventScript_Reward_SentBig)
		case NEWS_REWARD_AT_MAX: goto(CeruleanCity_House4_EventScript_AtMax)
	}
    end
}

// Mystery Gift is not enabled, or the player has no saved Wonder News
script CeruleanCity_House4_EventScript_NoNews {
    msgbox(CeruleanCity_House4_Text_NothingEntertaining)
    release_end
}

// Small reward for receiving Wonder News from friend
script CeruleanCity_House4_EventScript_Reward_RecvSmall {
    call(CeruleanCity_House4_EventScript_MovementReactionToNews)
    msgbox(CeruleanCity_House4_Text_NewNewsInformativeHaveThis)
    giveitem(REWARD_ITEM)
    if (var(VAR_RESULT) == FALSE) {
        goto(CeruleanCity_House4_EventScript_NoRoomForBerries)
    }
    release_end
}

// Big reward for receiving Wonder News from non-friend source
script CeruleanCity_House4_EventScript_Reward_RecvBig {
    call(CeruleanCity_House4_EventScript_MovementReactionToNews)
    msgbox(CeruleanCity_House4_Text_IncredibleNewsHaveBerries)
    if (giveitem(REWARD_ITEM, 4) == FALSE) {
        goto(CeruleanCity_House4_EventScript_NoRoomForBerries)
    }
    release_end
}

// Player has not recently sent Wonder News
script CeruleanCity_House4_EventScript_Waiting {
    applymovement(LOCALID_WONDER_NEWS_BERRY_MAN, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(CeruleanCity_House4_Text_WishCouldShareNewsWithOthers)
    release_end
}

// Small reward for sending Wonder News every 1-3 times
script CeruleanCity_House4_EventScript_Reward_SentSmall {
    call(CeruleanCity_House4_EventScript_MovementReactionToNews)
    msgbox(CeruleanCity_House4_Text_ThanksForSpreadingNewsTakeThis)
    if (giveitem(REWARD_ITEM) == FALSE) {
        goto(CeruleanCity_House4_EventScript_NoRoomForBerries)
    }
    release_end
}

// Big reward for sending Wonder News every 4th time
script CeruleanCity_House4_EventScript_Reward_SentBig {
    call(CeruleanCity_House4_EventScript_MovementReactionToNews)
    msgbox(CeruleanCity_House4_Text_MagnificentNewsSpreadHaveBerries)
    if (giveitem(REWARD_ITEM, 4) == FALSE) {
        goto(CeruleanCity_House4_EventScript_NoRoomForBerries)
    }
    release_end
}

// Player has hit reward limit and must wait to receive new rewards
script CeruleanCity_House4_EventScript_AtMax {
    applymovement(LOCALID_WONDER_NEWS_BERRY_MAN, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(CeruleanCity_House4_Text_EnjoyingMyselfWithAllSortsOfNews)
    release_end
}

script CeruleanCity_House4_EventScript_MovementReactionToNews {
    playse(SE_PIN)
    applymovement(LOCALID_WONDER_NEWS_BERRY_MAN, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_WONDER_NEWS_BERRY_MAN, Common_Movement_FacePlayer)
    waitmovement(0)
    applymovement(LOCALID_WONDER_NEWS_BERRY_MAN, Common_Movement_Delay48)
    waitmovement(0)
    return
}

script CeruleanCity_House4_EventScript_NoRoomForBerries {
    msgbox(CeruleanCity_House4_Text_YourBerryPouchIsFull)
    release_end
}

text CeruleanCity_House4_Text_NothingEntertaining {
	"Sigh…
	Too much time, too little to do…

	Is nothing entertaining happening
	anywhere?"
}

text CeruleanCity_House4_Text_NewNewsInformativeHaveThis {
	"Ah!
	A new news report!

	Hmm…

	I see!
	That was quite informative!

	I applaud you for taking interest
	in the news at your young age.

	As my thanks for sharing the news
	with me, I want you to have this."
}

text CeruleanCity_House4_Text_IncredibleNewsHaveBerries {
	"Oh, oh!
	Th-this news report!

	Hmm…

	Amazing!
	What an incredible piece of news!

	I haven't seen a news story this
	incredible in too long a time!

	Thanks for sharing this fantastic
	news. Have a bunch of BERRIES!"
}

text CeruleanCity_House4_Text_WishCouldShareNewsWithOthers {
	"It seems such a shame to not share
	this news with other folks…

	I wish I could tell someone…
	Let others know the news…"
}

text CeruleanCity_House4_Text_ThanksForSpreadingNewsTakeThis {
	"Ah, you've spread the news for me?

	Good news becomes worthwhile when
	all sorts of people share it.

	As my thanks for your spreading
	the news, take this!"
}

text CeruleanCity_House4_Text_MagnificentNewsSpreadHaveBerries {
	"You've spread the news some more?
	Magnificent!

	That piece of news must be
	delighted to be passed around so.

	Yes, indeed!

	Consider this a show of
	appreciation from me and the news.

	I'll give you more BERRIES than
	I usually do."
}

text CeruleanCity_House4_Text_EnjoyingMyselfWithAllSortsOfNews {
	"I'm quite enjoying myself with all
	sorts of news.

	Yes, I am satisfied!
	I won't be bored for a while."
}

text CeruleanCity_House4_Text_YourBerryPouchIsFull {
	"Hm? Your BERRY POUCH is full.
	My gift remains ungiven, then."
}
