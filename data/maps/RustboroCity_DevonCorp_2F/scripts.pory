mapscripts RustboroCity_DevonCorp_2F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
			call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
		}
		end
    }
}

script RustboroCity_DevonCorp_2F_EventScript_SetFossilReady {
    setvar(VAR_FOSSIL_RESURRECTION_STATE, 2)
    return
}

script RustboroCity_DevonCorp_2F_EventScript_TalkToPokemonScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_DeviceForTalkingToPokemon, MSGBOX_DEFAULT)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_BallScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
    }
    if (flag(FLAG_MET_DEVON_EMPLOYEE)) {
        msgbox(RustboroCity_DevonCorp_2F_Text_WeFinallyMadeNewBalls, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_DevelopingNewBalls, MSGBOX_DEFAULT)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_PokenavScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
    }
    if (flag(FLAG_RECEIVED_POKENAV)) {
        msgbox(RustboroCity_DevonCorp_2F_Text_WowThatsAPokenav, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_IMadePokenav, MSGBOX_DEFAULT)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_PokemonDreamsScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_DeviceToVisualizePokemonDreams, MSGBOX_DEFAULT)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_FossilScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 2) {
		switch(var(VAR_WHICH_FOSSIL_REVIVED)) {
            case 1: setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_LILEEP)
            case 2: setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ANORITH)
        }
        bufferspeciesname(STR_VAR_2, VAR_TEMP_TRANSFERRED_SPECIES)
        msgbox(RustboroCity_DevonCorp_2F_Text_FossilizedMonBroughtBackToLife, MSGBOX_DEFAULT)
        goto(RustboroCity_DevonCorp_2F_EventScript_ReceiveFossil)
        end
    }
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        msgbox(RustboroCity_DevonCorp_2F_Text_FossilRegeneratorTakesTime, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_DevelopDeviceToResurrectFossils, MSGBOX_DEFAULT)
    if (checkitem(ITEM_ROOT_FOSSIL) == TRUE || checkitem(ITEM_CLAW_FOSSIL) == TRUE) {
        goto(RustboroCity_DevonCorp_2F_EventScript_NoticeFossil)
    }
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_NoticeFossil {
	closemessage
    playse(SE_PIN)
    applymovement(LOCALID_FOSSIL_SCIENTIST, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_FOSSIL_SCIENTIST, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(RustboroCity_DevonCorp_2F_Text_WantToBringFossilBackToLife, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(RustboroCity_DevonCorp_2F_Text_OhIsThatSo, MSGBOX_DEFAULT)
    	release_end
    }
	if (checkitem(ITEM_CLAW_FOSSIL) == TRUE && checkitem(ITEM_ROOT_FOSSIL) == TRUE) {
        goto(RustboroCity_DevonCorp_2F_EventScript_ChooseFossil)
    }
	elif (checkitem(ITEM_CLAW_FOSSIL) == TRUE) {
		setvar(VAR_EXCHANGE_ITEM, ITEM_CLAW_FOSSIL)
		setvar(VAR_WHICH_FOSSIL_REVIVED, 2)
	}
	else {
		setvar(VAR_EXCHANGE_ITEM, ITEM_ROOT_FOSSIL)
		setvar(VAR_WHICH_FOSSIL_REVIVED, 1)
	}
    goto(RustboroCity_DevonCorp_2F_EventScript_GiveFossil)
    end
}

script RustboroCity_DevonCorp_2F_EventScript_ChooseFossil {
    message(RustboroCity_DevonCorp_2F_Text_TwoFossilsPickOne)
    waitmessage
    multichoice(17, 6, MULTI_FOSSIL, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: 
			setvar(VAR_EXCHANGE_ITEM, ITEM_CLAW_FOSSIL)
			setvar(VAR_WHICH_FOSSIL_REVIVED, 2)
        case 1: 
			setvar(VAR_EXCHANGE_ITEM, ITEM_ROOT_FOSSIL)
			setvar(VAR_WHICH_FOSSIL_REVIVED, 1)
		case 2:
		case MULTI_B_PRESSED: 
			release_end
    }
    goto(RustboroCity_DevonCorp_2F_EventScript_GiveFossil)
    end
}

script RustboroCity_DevonCorp_2F_EventScript_GiveFossil {
    bufferitemname(STR_VAR_1, VAR_EXCHANGE_ITEM)
    msgbox(RustboroCity_DevonCorp_2F_Text_HandedFossilToResearcher, MSGBOX_DEFAULT)
    removeitem(VAR_EXCHANGE_ITEM)
    setvar(VAR_FOSSIL_RESURRECTION_STATE, 1)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_ReceiveFossil {
    givemon(VAR_TEMP_TRANSFERRED_SPECIES, 20)
    switch(var(VAR_RESULT)) {
        case MON_GIVEN_TO_PARTY:
            call(RustboroCity_DevonCorp_2F_EventScript_ReceivedFossilFanfare)
            msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
            if (var(VAR_RESULT) == YES) {
                call(Common_EventScript_GetGiftMonPartySlot)
                call(Common_EventScript_NameReceivedPartyMon)
            }
        case MON_GIVEN_TO_PC:
            call(RustboroCity_DevonCorp_2F_EventScript_ReceivedFossilFanfare)
            msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
            if (var(VAR_RESULT) == YES) {
                call(Common_EventScript_NameReceivedBoxMon)
            }
            call(Common_EventScript_TransferredToPC)
        case MON_CANT_GIVE:
            goto(Common_EventScript_NoMoreRoomForPokemon)
            end
    }
    setvar(VAR_FOSSIL_RESURRECTION_STATE, 0)
    setflag(FLAG_RECEIVED_REVIVED_FOSSIL_MON)
    release_end
}

script RustboroCity_DevonCorp_2F_EventScript_ReceivedFossilFanfare {
    bufferspeciesname(STR_VAR_2, VAR_TEMP_TRANSFERRED_SPECIES)
    playfanfare(MUS_OBTAIN_ITEM)
    message(RustboroCity_DevonCorp_2F_Text_ReceivedMonFromResearcher)
    waitmessage
    waitfanfare
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    return
}

script RustboroCity_DevonCorp_2F_EventScript_MatchCallScientist {
    lock_faceplayer
    if (var(VAR_FOSSIL_RESURRECTION_STATE) == 1) {
        call(RustboroCity_DevonCorp_2F_EventScript_SetFossilReady)
    }
    if (var(VAR_RUSTBORO_CITY_STATE) >= 6) {
        msgbox(RustboroCity_DevonCorp_2F_Text_WhatToWorkOnNext, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_DevonCorp_2F_Text_DevelopNewPokenavFeature, MSGBOX_DEFAULT)
    release_end
}

text RustboroCity_DevonCorp_2F_Text_DeviceForTalkingToPokemon {
	"We're developing a device for talking
	with POKéMON.

	But we haven't had much success…"
}

text RustboroCity_DevonCorp_2F_Text_DevelopingNewBalls {
	"I'm developing new kinds of
	POKé BALLS…

	But I haven't made much headway…"
}

text RustboroCity_DevonCorp_2F_Text_WeFinallyMadeNewBalls {
	"We finally made new kinds of
	POKé BALLS!

	The REPEAT BALL makes it easier to
	catch POKéMON you've caught before.

	The TIMER BALL gets better at catching
	POKéMON the longer a battle runs.

	Both are proudly developed by
	the DEVON CORPORATION.

	Please give them a try!"
}

text RustboroCity_DevonCorp_2F_Text_IMadePokenav {
	"I made the POKéNAV!

	As an engineer, I feel blessed to have
	made something so great!"
}

text RustboroCity_DevonCorp_2F_Text_WowThatsAPokenav {
	"Oh, wow!
	That's a POKéNAV!

	It came about as a result of our
	PRESIDENT's desire to learn about
	the feelings of POKéMON.

	Would you like me to describe its
	features in detail?

	No, no. I think you'll find out just by
	trying the POKéNAV out."
}

text RustboroCity_DevonCorp_2F_Text_DeviceToVisualizePokemonDreams {
	"I'm trying to develop a device that
	visually reproduces the dreams of
	POKéMON…

	But it's not going well."
}

text RustboroCity_DevonCorp_2F_Text_DevelopDeviceToResurrectFossils {
	"I've been trying to develop a device
	that resurrects POKéMON from fossils…

	And, it's working!"
}

text RustboroCity_DevonCorp_2F_Text_WantToBringFossilBackToLife {
	"Wait! That thing you have there…
	Is that a POKéMON fossil?

	Would you like to bring that POKéMON
	back to life?

	I can with my newly developed
	FOSSIL REGENERATOR."
}

text RustboroCity_DevonCorp_2F_Text_OhIsThatSo {
	"Oh, is that so?

	DEVON's technological expertise
	is outstanding, I tell you."
}

text RustboroCity_DevonCorp_2F_Text_TwoFossilsPickOne {
	"Oh, now that's a surprise!
	You have not one, but two, fossils?

	Unfortunately, my machine can only
	regenerate one POKéMON at a time.

	Would you like to pick one of your
	fossils for regeneration?"
}

text RustboroCity_DevonCorp_2F_Text_HandedFossilToResearcher {
	"Excellent!
	Let's do this right away.

	{PLAYER} handed the {STR_VAR_1} to
	the DEVON RESEARCHER."
}

text RustboroCity_DevonCorp_2F_Text_FossilRegeneratorTakesTime {
	"The FOSSIL REGENERATOR, which I made,
	is incredible.

	But it has one drawback--it takes
	a long time to work.

	So, uh… How about you go for a stroll
	and look around for a while?"
}

text RustboroCity_DevonCorp_2F_Text_FossilizedMonBroughtBackToLife {
	"Thanks for waiting!

	Your fossilized POKéMON has been
	brought back to life!

	The fossil was an ancient POKéMON.
	{STR_VAR_2}, it was!"
}

text RustboroCity_DevonCorp_2F_Text_ReceivedMonFromResearcher {
	"{PLAYER} received {STR_VAR_2} from
	the DEVON RESEARCHER."
}

text RustboroCity_DevonCorp_2F_Text_TooManyPokemon {
	"Uh-oh, you've got too many POKéMON.
	You have no room for this one."
}

text RustboroCity_DevonCorp_2F_Text_DevelopNewPokenavFeature {
	"I'm trying to develop a new feature
	for the POKéNAV…

	But it's not going well."
}

text RustboroCity_DevonCorp_2F_Text_WhatToWorkOnNext {
	"Well, now what shall I work on
	developing next?

	Our company allows us to make our
	inspirations into reality.

	One couldn't ask for a better
	environment as an engineer."
}
