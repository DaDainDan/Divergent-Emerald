mapscripts CeladonCity_DepartmentStore_4F_Frlg_MapScripts {}

script CeladonCity_DepartmentStore_4F_EventScript_Man {
    msgbox(CeladonCity_DepartmentStore_4F_Text_GettingPokeDollAsPresent, MSGBOX_NPC)
    end
}

script CeladonCity_DepartmentStore_4F_EventScript_Youngster {
    msgbox(CeladonCity_DepartmentStore_4F_Text_CanRunAwayWithPokeDoll, MSGBOX_NPC)
    end
}

script CeladonCity_DepartmentStore_4F_EventScript_FloorSign {
    msgbox(CeladonCity_DepartmentStore_4F_Text_FloorSign, MSGBOX_SIGN)
    end
}

script CeladonCity_DepartmentStore_4F_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(CeladonCity_DepartmentStore_4F_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart CeladonCity_DepartmentStore_4F_Items {
    ITEM_POKE_DOLL
    ITEM_RETRO_MAIL
    ITEM_FIRE_STONE
    ITEM_THUNDER_STONE
    ITEM_WATER_STONE
    ITEM_LEAF_STONE
}

text CeladonCity_DepartmentStore_4F_Text_GettingPokeDollAsPresent {
	"I'm getting a present for my
	girlfriend.

	I guess a POKé DOLL will be it.
	It's the popular thing."
}

text CeladonCity_DepartmentStore_4F_Text_CanRunAwayWithPokeDoll {
	"I heard something useful.

	If a wild POKéMON appears, you can
	distract it with a POKé DOLL.

	You can run away while the wild
	POKéMON is distracted."
}

text CeladonCity_DepartmentStore_4F_Text_FloorSign {
	"Express yourself with gifts!
	4F: WISE MAN GIFTS

	Evolution Special!
	Element STONES on sale now!"
}
