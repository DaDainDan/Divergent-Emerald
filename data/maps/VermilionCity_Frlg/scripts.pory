text VermilionCity_Text_GrimerMultipliesInSludge {
	"We're careful about pollution here.

	We've heard GRIMER multiplies in
	toxic sludge."
}

text VermilionCity_Text_DidYouSeeSSAnneInHarbor {
	"Did you see the S.S. ANNE moored
	in the harbor?"
}

text VermilionCity_Text_SSAnneHasDepartedForYear {
	"So, the S.S. ANNE has departed?

	She'll be back in VERMILION about
	this time next year."
}

text VermilionCity_Text_BuildingOnThisLand {
	"I'm putting up a building on this
	plot of land. I own it all.

	My POKéMON is tamping the land
	to lay the foundation."
}

text VermilionCity_Text_Machop {
	"MACHOP: Guoh! Gogogoh!"
}

text VermilionCity_Text_MachopStompingLandFlat {
	"A MACHOP is stomping the land flat."
}

text VermilionCity_Text_SSAnneVisitsOnceAYear {
	"The S.S. ANNE is a famous luxury
	cruise ship.

	It visits VERMILION once a year."
}

text VermilionCity_Text_CitySign {
	"VERMILION CITY
	The Port of Exquisite Sunsets"
}

text VermilionCity_Text_SnorlaxBlockingRoute12 {
	"NOTICE!

	ROUTE 12 may be blocked off by a
	sleeping POKéMON.

	Detour through ROCK TUNNEL to
	LAVENDER TOWN.

	VERMILION POLICE"
}

text VermilionCity_Text_PokemonFanClubSign {
	"POKéMON FAN CLUB
	All POKéMON fans welcome!"
}

text VermilionCity_Text_GymSign {
	"VERMILION CITY POKéMON GYM
	LEADER: LT. SURGE
	The Lightning American!"
}

text VermilionCity_Text_VermilionHarbor {
	"VERMILION HARBOR"
}

text VermilionCity_Text_WelcomeToTheSSAnne {
	"Welcome to the S.S. ANNE!"
}

text VermilionCity_Text_DoYouHaveATicket {
	"Welcome to the S.S. ANNE!

	Excuse me, do you have a ticket?"
}

text VermilionCity_Text_FlashedSSTicket {
	"{FONT_NORMAL}{PLAYER} flashed the S.S. TICKET!

	{FONT_MALE}Great!
	Welcome to the S.S. ANNE!"
}

text VermilionCity_Text_DontHaveNeededSSTicket {
	"{FONT_NORMAL}{PLAYER} doesn't have the needed
	S.S. TICKET.

	{FONT_MALE}Sorry!

	You need a ticket to get aboard."
}

text VermilionCity_Text_TheShipSetSail {
	"The ship set sail."
}

text VermilionCity_Text_BoardSeagallopTriPass {
	"Ah, you have a TRI-PASS.

	Would you like to board
	a SEAGALLOP ferry?"
}

text VermilionCity_Text_Seagallop7Departing {
	"Okay, everything's in order.

	SEAGALLOP HI-SPEED 7 will be
	departing immediately."
}

text VermilionCity_Text_BoardSeagallopRainbowPass {
	"Ah, you have a RAINBOW PASS.

	Would you like to board
	a SEAGALLOP ferry?"
