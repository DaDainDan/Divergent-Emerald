mapscripts VermilionCity_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_VERMILION_CITY)
		if (flag(FLAG_TALKED_TO_OAKS_AIDE_IN_VERMILION)) {
			setflag(FLAG_HIDE_VERMILION_CITY_OAKS_AIDE)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_VERMILION_CITY, 2 {
			lockall
			applymovement(LOCALID_PLAYER, moves(walk_up * 2))
			waitmovement(0)
			setvar(VAR_MAP_SCENE_VERMILION_CITY, 3)
			releaseall
			end
		}
    ]
}

script VermilionCity_EventScript_Woman {
    msgbox(VermilionCity_Text_GrimerMultipliesInSludge, MSGBOX_NPC)
    end
}

script VermilionCity_EventScript_OldMan1 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_VERMILION_CITY) == 3) {
        msgbox(VermilionCity_Text_SSAnneHasDepartedForYear)
    	release_end
    }
    msgbox(VermilionCity_Text_DidYouSeeSSAnneInHarbor)
    release_end
}

script VermilionCity_EventScript_FerrySailor {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_VERMILION_CITY) == 3) {
        call(VermilionCity_EventScript_Seagallop)
		release_end
    }
    msgbox(VermilionCity_Text_WelcomeToTheSSAnne)
    release_end
}

script VermilionCity_EventScript_Seagallop {
	setvar(VAR_0x8004, SEAGALLOP_VERMILION_CITY)
	if (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) >= 5) {
		call(VermilionCity_EventScript_CheckHasMysticTicket)
		if (var(VAR_RESULT) == TRUE) {
			goto(VermilionCity_EventScript_HasMysticTicket)
		}
		call(VermilionCity_EventScript_CheckHasAuroraTicket)
		if (var(VAR_RESULT) == TRUE) {
			goto(VermilionCity_EventScript_HasAuroraTicket)
		}
		setvar(VAR_0x8004, SEAGALLOP_VERMILION_CITY)
		message(VermilionCity_Text_BoardSeagallopRainbowPass)
		waitmessage
		goto(EventScript_SeviiDestinationsPage1)
	}
	elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) >= 1) {
		message(VermilionCity_Text_BoardSeagallopTriPass)
		waitmessage
		setvar(VAR_0x8004, SEAGALLOP_VERMILION_CITY)
		multichoice(19, 5, MULTI_SEAGALLOP_123, FALSE)
		switch (var(VAR_RESULT)) {
			case 0: goto(EventScript_SailToOneIsland2)
			case 1: goto(EventScript_SailToTwoIsland2)
			case 2: goto(EventScript_SailToThreeIsland2)
			case 3:
			case MULTI_B_PRESSED: 
                goto(EventScript_CancelSail)
		}
	}
	msgbox(VermilionCity_Text_TheShipSetSail)
	return
}

script VermilionCity_EventScript_CheckHasMysticTicket {
    if (!flag(FLAG_ENABLE_SHIP_NAVEL_ROCK) || checkitem(ITEM_MYSTIC_TICKET) == FALSE) {
        goto(EventScript_SetResultFalse)
    }
    goto(EventScript_SetResultTrue)
    end
}

script VermilionCity_EventScript_CheckHasAuroraTicket {
    if (!flag(FLAG_ENABLE_SHIP_BIRTH_ISLAND) || checkitem(ITEM_AURORA_TICKET) == FALSE) {
        goto(EventScript_SetResultFalse)
    }
    goto(EventScript_SetResultTrue)
    end
}

script VermilionCity_EventScript_HasMysticTicket {
    call(VermilionCity_EventScript_CheckHasAuroraTicket)
    if (var(VAR_RESULT) == TRUE) {
        goto(VermilionCity_EventScript_HasMysticAndAuroraTickets)
    }
    if (!flag(FLAG_SHOWN_MYSTIC_TICKET)) {
        call(VermilionCity_EventScript_ShowMysticTicket)
    }
    message(VermilionCity_Text_BoardSeagallopFerry)
    waitmessage
    multichoice(17, 6, MULTI_SEVII_NAVEL, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(EventScript_SeviiDestinationsPage1)
        case 1: goto(EventScript_SailToNavelRock)
        case 2:
        case MULTI_B_PRESSED: 
            goto(EventScript_CancelSail)
    }
    end
}

script VermilionCity_EventScript_ShowMysticTicket {
    setflag(FLAG_SHOWN_MYSTIC_TICKET)
    msgbox(VermilionCity_Text_OhMysticTicketTakeYouToNavelRock)
    return
}

script VermilionCity_EventScript_HasAuroraTicket {
    if (!flag(FLAG_SHOWN_AURORA_TICKET)) {
        call(VermilionCity_EventScript_ShowAuroraTicket)
    }
    message(VermilionCity_Text_BoardSeagallopFerry)
    waitmessage
    multichoice(13, 6, MULTI_SEVII_BIRTH, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(EventScript_SeviiDestinationsPage1)
        case 1: goto(EventScript_SailToBirthIsland)
        case 2:
        case MULTI_B_PRESSED: 
            goto(EventScript_CancelSail)
    }
    end
}

script VermilionCity_EventScript_ShowAuroraTicket {
    setflag(FLAG_SHOWN_AURORA_TICKET)
    msgbox(VermilionCity_Text_OhAuroraTicketTakeYouToBirthIsland)
    return
}

script VermilionCity_EventScript_HasMysticAndAuroraTickets {
    if (!flag(FLAG_SHOWN_MYSTIC_TICKET)) {
        call(VermilionCity_EventScript_ShowMysticTicket)
    }
    if (!flag(FLAG_SHOWN_AURORA_TICKET)) {
        call(VermilionCity_EventScript_ShowAuroraTicket)
    }
    message(VermilionCity_Text_BoardSeagallopFerry)
    waitmessage
    multichoice(13, 5, MULTI_SEVII_NAVEL_BIRTH, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(EventScript_SeviiDestinationsPage1)
        case 1: goto(EventScript_SailToNavelRock)
        case 2: goto(EventScript_SailToBirthIsland)
        case 3:
        case MULTI_B_PRESSED: 
            goto(EventScript_CancelSail)
    }
    end
}

script EventScript_SailToNavelRock {
    msgbox(VermilionCity_Text_Seagallop10Departing)
    setvar(VAR_0x8004, SEAGALLOP_VERMILION_CITY)
    setvar(VAR_0x8006, SEAGALLOP_NAVEL_ROCK)
    goto(EventScript_SetSail)
    end
}

script EventScript_SailToBirthIsland {
    msgbox(VermilionCity_Text_Seagallop12Departing)
    setvar(VAR_0x8004, SEAGALLOP_VERMILION_CITY)
    setvar(VAR_0x8006, SEAGALLOP_BIRTH_ISLAND)
    goto(EventScript_SetSail)
    end
}

// Unreachable
script Vermilion_EventScript_Unused {
    release_end
}

script VermilionCity_EventScript_CheckTicketLeft {
    lockall
    goto(VermilionCity_EventScript_CheckTicket)
    end
}

script VermilionCity_EventScript_CheckTicketRight {
    lockall
    goto(VermilionCity_EventScript_CheckTicket)
    end
}

script VermilionCity_EventScript_ExitedTicketCheck {
    lockall
    setvar(VAR_VERMILION_CITY_TICKET_CHECK_TRIGGER, 0)
    releaseall
    end
}

script VermilionCity_EventScript_CheckTicket {
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_VERMILION_FERRY_SAILOR, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    if (var(VAR_MAP_SCENE_VERMILION_CITY) == 3) {
        call(VermilionCity_EventScript_Seagallop)
		closemessage
		goto(VermilionCity_EventScript_WalkUpPier)
    }
    msgbox(VermilionCity_Text_DoYouHaveATicket)
    if (!flag(FLAG_GOT_SS_TICKET)) {
        msgbox(VermilionCity_Text_DontHaveNeededSSTicket)
		closemessage
		goto(VermilionCity_EventScript_WalkUpPier)
    }
    msgbox(VermilionCity_Text_FlashedSSTicket)
    setvar(VAR_VERMILION_CITY_TICKET_CHECK_TRIGGER, 1)
    releaseall
    end
}

