mapscripts PokemonMansion_2F_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (flag(FLAG_POKEMON_MANSION_SWITCH_STATE)) {
			call(PokemonMansion_EventScript_PressSwitch_2F)
		}
		end
    }
}

script PokemonMansion_2F_EventScript_Statue {
    lockall
    setvar(VAR_0x8004, 1)
    call(PokemonMansion_EventScript_SecretSwitch)
    playse(SE_UNLOCK)
    special(DrawWholeMapView)
    waitse
    releaseall
    end
}

script PokemonMansion_2F_EventScript_DiaryJuly5th {
    msgbox(PokemonMansion_1F_Text_NewMonDiscoveredInGuyanaJungle, MSGBOX_SIGN)
    end
}

script PokemonMansion_2F_EventScript_DiaryJuly10th {
    msgbox(PokemonMansion_1F_Text_ChristenedDiscoveredMonMew, MSGBOX_SIGN)
    end
}

script PokemonMansion_2F_EventScript_Arnie {
    trainerbattle_single(TRAINER_BURGLAR_ARNIE, PokemonMansion_1F_Text_ArnieIntro, PokemonMansion_1F_Text_ArnieDefeat)
    msgbox(PokemonMansion_1F_Text_ArniePostBattle, MSGBOX_AUTOCLOSE)
    end
}

text PokemonMansion_Text_PressSecretSwitch {
	"A secret switch!

	Press it?"
}

text PokemonMansion_Text_WhoWouldnt {
	"Who wouldn't?"
}

text PokemonMansion_Text_NotQuiteYet {
	"Not quite yet!"
}

text PokemonMansion_1F_Text_ArnieIntro {
	"I can't get out!
	This old place is one big puzzle."
}

text PokemonMansion_1F_Text_ArnieDefeat {
	"Oh, no!
	My bag of loot!"
}

text PokemonMansion_1F_Text_ArniePostBattle {
	"The switches here open and close
	alternating sets of doors."
}

text PokemonMansion_1F_Text_NewMonDiscoveredInGuyanaJungle {
	"Diary: July 5
	Guyana, South America

	A new POKéMON was discovered deep
	in the jungle."
}

text PokemonMansion_1F_Text_ChristenedDiscoveredMonMew {
	"Diary: July 10
	We christened the newly discovered
	POKéMON, MEW."
}
