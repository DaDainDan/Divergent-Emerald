mapscripts SixIsland_WaterPath_House1_Frlg_MapScripts {}

script SixIsland_WaterPath_House1_EventScript_Beauty {
    lock_faceplayer
    setvar(VAR_0x8004, SPECIES_HERACROSS)
    if (specialvar(VAR_RESULT, DoesPlayerPartyContainSpecies) == FALSE) {
        msgbox(SixIsland_WaterPath_House1_Text_LoveItNeedItHeracross)
    	release_end
    }
    special(GetHeracrossSizeRecordInfo)
    msgbox(SixIsland_WaterPath_House1_Text_MayIMeasureHeracross)
    special(ChoosePartyMon)
    copyvar(VAR_RESULT, VAR_0x8004)
    if (var(VAR_RESULT) < PARTY_SIZE) {
        special(CompareHeracrossSize)
		switch (var(VAR_RESULT)) {
			case 1:
				msgbox(SixIsland_WaterPath_House1_Text_ThisWontDo)
				release_end
			case 2:
				if (flag(FLAG_GOT_NEST_BALL_FROM_WATER_PATH_HOUSE_1)) {
					msgbox(SixIsland_WaterPath_House1_Text_ItsXInchesYInchesWasBiggest)
					release_end
				}
			case 4:
				if (flag(FLAG_GOT_NEST_BALL_FROM_WATER_PATH_HOUSE_1)) {
					msgbox(SixIsland_WaterPath_House1_Text_ItsXInchesSameAsBefore)
					release_end
				}
		}
    }
    setflag(FLAG_GOT_NEST_BALL_FROM_WATER_PATH_HOUSE_1)
    msgbox(SixIsland_WaterPath_House1_Text_ItsXInchesDeserveReward)
    if (giveitem(ITEM_NEST_BALL) == FALSE) {
        msgbox(SixIsland_WaterPath_House1_Text_YourBagIsFull)
    	release_end
    }
    msgbox(SixIsland_WaterPath_House1_Text_WantToSeeBiggerOne)
    release_end
}

script SixIsland_WaterPath_House1_EventScript_SizeRecord {
    lockall
    if (flag(FLAG_GOT_NEST_BALL_FROM_WATER_PATH_HOUSE_1)) {
        special(GetHeracrossSizeRecordInfo)
		msgbox(SixIsland_WaterPath_House1_Text_BiggestHeracrossIsXInches)
    } else {
		msgbox(SixIsland_WaterPath_House1_Text_BlankChartOfSomeSort)
	}
    releaseall
    end
}

text SixIsland_WaterPath_House1_Text_LoveItNeedItHeracross {
	"Hera, hera, HERACROSS!
	Big and shiny, it's the bug boss!
	Love it, need it, HERACROSS!"
}

text SixIsland_WaterPath_House1_Text_MayIMeasureHeracross {
	"Eeeeek!
	That's a HERACROSS!

	Please, please, may I measure how
	big it is?"
}

text SixIsland_WaterPath_House1_Text_ItsXInchesDeserveReward {
	"Eeeek, it's {STR_VAR_2} inches!
	I've never seen anything like this!
	You deserve a reward!"
}

text SixIsland_WaterPath_House1_Text_WantToSeeBiggerOne {
	"I want to see a much, much bigger
	HERACROSS than that one.

	Oh, how I adore them, big
	HERACROSS!"
}

text SixIsland_WaterPath_House1_Text_ItsXInchesSameAsBefore {
	"Huh? This {STR_VAR_2}-inch measurement…
	Oh, boo! It's the same as before."
}

text SixIsland_WaterPath_House1_Text_ItsXInchesYInchesWasBiggest {
	"Oh, it's just {STR_VAR_2} inches.
	The HERACROSS before was bigger.

	It was {STR_VAR_3} inches, the biggest
	HERACROSS you've brought me."
}

text SixIsland_WaterPath_House1_Text_ThisWontDo {
	"Oh, no! This won't do!

	HERACROSS looks much more macho
	and cool, and has a lovely horn!"
}

text SixIsland_WaterPath_House1_Text_YourBagIsFull {
	"Your BAG is full.
	My reward won't fit."
}

text SixIsland_WaterPath_House1_Text_BiggestHeracrossIsXInches {
	"The biggest HERACROSS that I have
	ever seen measured so far is:

	{STR_VAR_3} inches!"
}

text SixIsland_WaterPath_House1_Text_BlankChartOfSomeSort {
	"It's a blank chart of some sort.

	It has spaces for writing in
	records of some kind."
}
