mapscripts BattleFrontier_BattleFactoryPreBattleRoom_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterRoom
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			if (var(VAR_0x8006) == 1) {
				setobjectxy(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, 8, 7)
				turnobject(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, DIR_SOUTH)
			}
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterRoom {
    if (var(VAR_0x8006) == 1) {
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_ReturnToRoomFromBattle)
    }
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, moves(walk_up * 5,  face_down))
    applymovement(LOCALID_PLAYER, moves(walk_up * 5))
    waitmovement(0)
    if (var(VAR_0x8006) == 2) {
        special(SavePlayerParty)
		factory_setparties(0)
		frontier_set(FRONTIER_DATA_RECORD_DISABLED, TRUE)
		special(CalculatePlayerPartyCount)
		goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    }
    factory_generaterentalmons
    factory_generateopponentmons
    factory_getopponentmontype
    setorcopyvar(VAR_0x8005, VAR_RESULT)
    factory_getopponentstyle
    setorcopyvar(VAR_0x8006, VAR_RESULT)
    call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentType)
    call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentStyle)
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_HoldMonsChooseFromSelection, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    factory_setswapped
    factory_rentmons
    waitstate
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom)
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_ReturnToRoomFromBattle {
    factory_setopponentmons
    factory_resethelditems
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_LetUsRestoreMons, MSGBOX_DEFAULT)
    playfanfare(MUS_HEAL)
    waitfanfare
    special(HealPlayerParty)
    frontier_getbrainstatus
    if (var(VAR_RESULT) == FRONTIER_BRAIN_NOT_READY) {
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForRegularOpponent)
    }
    playse(SE_POKENAV_CALL)
    waitse
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_WaitFewMoments, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, moves(walk_left * 3))
    waitmovement(0)
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_UnderstoodSirWillDo, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, moves(walk_right * 3,  face_down))
    waitmovement(0)
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_MessageFromHeadComeRightNow, MSGBOX_DEFAULT)
    closemessage
    delay(16)
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHead)
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_RightThisWay, MSGBOX_DEFAULT)
    closemessage
    frontier_get(FRONTIER_DATA_LVL_MODE)
	switch (var(VAR_RESULT)) {
		case FRONTIER_LVL_50:
			applymovement(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, moves(walk_left * 2,  walk_up * 2,  set_invisible))
    		applymovement(LOCALID_PLAYER, moves(walk_up,  walk_left * 2,  walk_up * 2))
		case FRONTIER_LVL_OPEN:
			applymovement(LOCALID_FACTORY_PRE_BATTLE_ATTENDANT, moves(walk_right * 2,  walk_up * 2,  set_invisible))
    		applymovement(LOCALID_PLAYER, moves(walk_up,  walk_right * 2,  walk_up * 2))
	}
    waitmovement(0)
    warp(MAP_BATTLE_FRONTIER_BATTLE_FACTORY_BATTLE_ROOM, 6, 11)
    waitstate
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent {
    frontier_getbrainstatus
    if (var(VAR_RESULT) != FRONTIER_BRAIN_NOT_READY) {
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHead)
    }
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForRegularOpponent)
	end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForRegularOpponent {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
	switch (var(VAR_RESULT)) {
		case 1: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor2ndOpponent)
		case 2: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor3rdOpponent)
		case 3: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor4thOpponent)
		case 4: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor5thOpponent)
		case 5: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor6thOpponent)
		case 6: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor7thOpponent)
	}
	waitmessage
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponentNoRecord)
    }
    multichoice(19, 4, MULTI_GO_ON_RECORD_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapMon)
        case 1: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRecordBattle)
        case 2: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskPauseChallenge)
        case 3: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    }
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponentNoRecord {
    multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapMon)
        case 1: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskPauseChallenge)
        case 2: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    }
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRecordBattle {
    message(BattleFrontier_BattleFactoryPreBattleRoom_Text_RecordLatestBattle)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		call(BattleFrontier_EventScript_SaveBattle)
	}
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		message(BattleFrontier_BattleFactoryPreBattleRoom_Text_SavingDataPleaseWait)
		waitmessage
		factory_save(CHALLENGE_STATUS_PAUSED)
		playse(SE_SAVE)
		waitse
		fadescreen(FADE_TO_BLACK)
		frontier_reset
		end
	}
	goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattleFactoryPreBattleRoom_Text_RetireFromChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		goto(BattleFrontier_BattleFactoryBattleRoom_EventScript_WarpToLobbyLost)
	}
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapMon {
    factory_generateopponentmons
    factory_getopponentmontype
    setorcopyvar(VAR_0x8005, VAR_RESULT)
    factory_getopponentstyle
    setorcopyvar(VAR_0x8006, VAR_RESULT)
    call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentType)
    call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentStyle)
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_LikeToSwapMon, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_SwapMons)
	}
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom)
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_SwapMons {
    fadescreen(FADE_TO_BLACK)
    factory_swapmons
    waitstate
    if (var(VAR_RESULT) == TRUE) { // Did player keep current pokemon
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom)
    }
    factory_setswapped
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_YourSwapIsComplete, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom)
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentType {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_InvestigatedUpcomingOpponent, MSGBOX_DEFAULT)
	switch (var(VAR_0x8005)) {
		case TYPE_NORMAL: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInNormalType, MSGBOX_DEFAULT)
		case TYPE_FIGHTING: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInFightingType, MSGBOX_DEFAULT)
		case TYPE_FLYING: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInFlyingType, MSGBOX_DEFAULT)
		case TYPE_POISON: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInPoisonType, MSGBOX_DEFAULT)
		case TYPE_GROUND: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInGroundType, MSGBOX_DEFAULT)
		case TYPE_ROCK: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInRockType, MSGBOX_DEFAULT)
		case TYPE_BUG: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInBugType, MSGBOX_DEFAULT)
		case TYPE_GHOST: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInGhostType, MSGBOX_DEFAULT)
		case TYPE_STEEL: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInSteelType, MSGBOX_DEFAULT)
		case TYPE_FIRE: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInFireType, MSGBOX_DEFAULT)
		case TYPE_WATER: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInWaterType, MSGBOX_DEFAULT)
		case TYPE_GRASS: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInGrassType, MSGBOX_DEFAULT)
		case TYPE_ELECTRIC: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInElectricType, MSGBOX_DEFAULT)
		case TYPE_PSYCHIC: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInPsychicType, MSGBOX_DEFAULT)
		case TYPE_ICE: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInIceType, MSGBOX_DEFAULT)
		case TYPE_DRAGON: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInDragonType, MSGBOX_DEFAULT)
		case TYPE_DARK: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInDarkType, MSGBOX_DEFAULT)
		case TYPE_FAIRY: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerSkilledInFairyType, MSGBOX_DEFAULT)
		case NUMBER_OF_MON_TYPES: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_TrainerHasNoClearFavorite, MSGBOX_DEFAULT)
	}
    return
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentStyle {
	switch (var(VAR_0x8006)) {
		case FACTORY_STYLE_NONE: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleUnrestrained, MSGBOX_DEFAULT)
		case FACTORY_STYLE_PREPARATION: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleTotalPreparation, MSGBOX_DEFAULT)
		case FACTORY_STYLE_SLOW_STEADY: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleSlowAndSteady, MSGBOX_DEFAULT)
		case FACTORY_STYLE_ENDURANCE: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleEndurance, MSGBOX_DEFAULT)
		case FACTORY_STYLE_HIGH_RISK: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleHighRisk, MSGBOX_DEFAULT)
		case FACTORY_STYLE_WEAKENING: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleWeakenFoe, MSGBOX_DEFAULT)
		case FACTORY_STYLE_UNPREDICTABLE: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleImpossibleToPredict, MSGBOX_DEFAULT)
		case FACTORY_STYLE_WEATHER: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleDependsOnFlow, MSGBOX_DEFAULT)
		case FACTORY_NUM_STYLES: msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_StyleFlexible, MSGBOX_DEFAULT)
	}
    return
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHead {
    message(BattleFrontier_BattleFactoryPreBattleRoom_Text_PreparedToFaceHead)
    waitmessage
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHeadNoRecord)
    }
    multichoice(19, 4, MULTI_GO_ON_RECORD_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapBeforeHead)
        case 1: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRecordBattle)
        case 2: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskPauseChallenge)
        case 3: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHead)
    }
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHeadNoRecord {
    multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapBeforeHead)
        case 1: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskPauseChallenge)
        case 2: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskReadyForHead)
    }
    end
}

script BattleFrontier_BattleFactoryPreBattleRoom_EventScript_AskSwapBeforeHead {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_CantTellAnythingAboutHead, MSGBOX_DEFAULT)
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_LikeToSwapMon, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_SwapMons)
	}
    goto(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_EnterBattleRoom)
    end
}

