text MtMoon_1F_Text_MarcosIntro {
	"WHOA!
	You shocked me!
	…Oh, you're just a kid!"
}

text MtMoon_1F_Text_MarcosDefeat {
	"Wow!
	Shocked again!"
}

text MtMoon_1F_Text_MarcosPostBattle {
	"Kids like you shouldn't be
	wandering around here in the dark."
}

text MtMoon_1F_Text_JoshIntro {
	"Did you come to explore the cave,
	too?"
}

text MtMoon_1F_Text_JoshDefeat {
	"Losing stinks!
	It's so uncool."
}

text MtMoon_1F_Text_JoshPostBattle {
	"I came all the way down here to
	show off to girls."
}

text MtMoon_1F_Text_MiriamIntro {
	"Wow! It's way bigger in here than
	I thought!"
}

text MtMoon_1F_Text_MiriamDefeat {
	"Oh!
	I lost it!"
}

text MtMoon_1F_Text_MiriamPostBattle {
	"How do you get out of here?
	It's so big, I may get lost."
}

text MtMoon_1F_Text_JovanIntro {
	"What!
	Don't sneak up on me!"
}

text MtMoon_1F_Text_JovanDefeat {
	"My POKéMON won't do!"
}

text MtMoon_1F_Text_JovanPostBattle {
	"I have to find stronger POKéMON.
	Where might they be?"
}

text MtMoon_1F_Text_IrisIntro {
	"What?
	I'm waiting for my friends to find
	me here."
}

text MtMoon_1F_Text_IrisDefeat {
	"I lost?"
}

text MtMoon_1F_Text_IrisPostBattle {
	"I came because I heard there are
	some very rare fossils here."
}

text MtMoon_1F_Text_KentIntro {
	"Suspicious men are in the cave.
	What about you?"
}

text MtMoon_1F_Text_KentDefeat {
	"You got me!"
}

text MtMoon_1F_Text_KentPostBattle {
	"I saw them!
	I'm sure they're from TEAM ROCKET!"
}

text MtMoon_1F_Text_RobbyIntro {
	"You need to go through this cave
	to get to CERULEAN CITY."
}

text MtMoon_1F_Text_RobbyDefeat {
	"I lost."
}

text MtMoon_1F_Text_RobbyPostBattle {
	"ZUBAT is tough!
	But if you can catch one, you'll
	be able to count on it."
}

text MtMoon_1F_Text_ZubatIsABloodsucker {
	"Beware!
	ZUBAT is a bloodsucker!"
}

text MtMoon_1F_Text_BrockHelpsExcavateFossils {
	"Hi, I'm excavating for fossils here
	under MT. MOON.

	Sometimes, BROCK of PEWTER GYM
	lends me a hand."
}
