mapscripts BattleFrontier_Lounge5_MapScripts {}

script BattleFrontier_Lounge5_EventScript_NatureGirl {
    lock_faceplayer
    msgbox(BattleFrontier_Lounge5_Text_NatureGirlGreeting, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(BattleFrontier_Lounge5_EventScript_NatureGirlNoneShown)
    }
    chooseboxmon
    waitstate
    lock_faceplayer
    if (var(VAR_0x8004) == PARTY_NOTHING_CHOSEN) {
        goto(BattleFrontier_Lounge5_EventScript_NatureGirlNoneShown)
    }
    if (specialvar(VAR_RESULT, ScriptGetPartyMonSpecies) == SPECIES_EGG) {
		msgbox(BattleFrontier_Lounge5_Text_NatureGirlEgg, MSGBOX_DEFAULT)
    	release_end
	}
    special(ShowNatureGirlMessage)
    waitmessage
    waitbuttonpress
    release_end
}

script BattleFrontier_Lounge5_EventScript_NatureGirlNoneShown {
    msgbox(BattleFrontier_Lounge5_Text_NatureGirlNoneShown, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge5_EventScript_Gentleman {
    msgbox(BattleFrontier_Lounge5_Text_LadyClaimsSheUnderstandsPokemon, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge5_EventScript_BlackBelt {
    msgbox(BattleFrontier_Lounge5_Text_GirlSayingSomethingProfound, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge5_EventScript_LittleBoy {
    msgbox(BattleFrontier_Lounge5_Text_GirlPlaysAtRedHouseALot, MSGBOX_NPC)
    end
}

text BattleFrontier_Lounge5_Text_NatureGirlGreeting {
	"Ehehe!
	I can tell what POKéMON are thinking!

	Please!
	Can I see your POKéMON?"
}

text BattleFrontier_Lounge5_Text_NatureGirlNoneShown {
	"Boo!
	Cheapie!"
}

text BattleFrontier_Lounge5_Text_NatureGirlAttackHighAttackLow {
	"Hmhm…

	This one says it likes to battle!
	It will battle even if it has a lot
	of ouchies!"
}

text BattleFrontier_Lounge5_Text_NatureGirlAttackHighDefenseLow {
	"Hmhm…

	This one says it likes to battle!
	But if it gets enough ouchies,
	it will worry about itself!"
}

text BattleFrontier_Lounge5_Text_NatureGirlAttackHighSupportLow {
	"Hmhm…

	This one says it likes to battle!
	But if it gets enough ouchies,
	it will turn sneaky!"
}

text BattleFrontier_Lounge5_Text_NatureGirlDefenseHighAttackLow {
	"Hmhm…

	This one says it looks after itself!
	But if it gets enough ouchies,
	it will hit back!"
}

text BattleFrontier_Lounge5_Text_NatureGirlDefenseHighDefenseLow {
	"Hmhm…

	This one says it looks after itself!
	It says it worries about itself whether
	or not it has a lot of ouchies!"
}

text BattleFrontier_Lounge5_Text_NatureGirlDefenseHighSupportLow {
	"Hmhm…

	This one says it looks after itself!
	But if it gets enough ouchies,
	it will turn sneaky!"
}

text BattleFrontier_Lounge5_Text_NatureGirlSupportHighAttackLow {
	"Hmhm…

	This one says it likes to be sneaky!
	But if it gets enough ouchies,
	it will hit back!"
}

text BattleFrontier_Lounge5_Text_NatureGirlSupportHighDefenseLow {
	"Hmhm…

	This one says it likes to be sneaky!
	But if it gets enough ouchies,
	it will worry about itself!"
}

text BattleFrontier_Lounge5_Text_NatureGirlSupportHighSupportLow {
	"Hmhm…

	This one says it likes to be sneaky!
	It says it likes to be sneaky even
	if it has a lot of ouchies!"
}

text BattleFrontier_Lounge5_Text_NatureGirlEgg {
	"That's silly! An EGG is asleep!
	I can't talk to it!"
}

text BattleFrontier_Lounge5_Text_LadyClaimsSheUnderstandsPokemon {
	"How charming!
	That little lady claims she can
	understand POKéMON!"
}

text BattleFrontier_Lounge5_Text_GirlSayingSomethingProfound {
	"I have this feeling that the little girl
	is saying something profound."
}

text BattleFrontier_Lounge5_Text_GirlPlaysAtRedHouseALot {
	"I know something!

	That little girl plays at the red house
	a lot!"
}
