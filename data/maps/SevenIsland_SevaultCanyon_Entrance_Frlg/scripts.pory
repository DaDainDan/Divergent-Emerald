mapscripts SevenIsland_SevaultCanyon_Entrance_Frlg_MapScripts {}

script SevenIsland_SevaultCanyon_Entrance_EventScript_RouteSign {
    msgbox(SevenIsland_SevaultCanyon_Entrance_Text_RouteSign, MSGBOX_SIGN)
    end
}

text SevenIsland_SevaultCanyon_Entrance_Text_MiahIntro {
	"Kyahaha!
	I'll flick you away effortlessly!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MiahDefeat {
	"Tch!
	Too strong for me!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MiahPostBattle {
	"What's that?
	I don't act the way I look?

	Heh, that's a part of my strategy!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MasonIntro {
	"Howdy!
	Are you a member of my fan club?"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MasonDefeat {
	"Oh, so you're not a fan…

	Well, I can change that.
	Let me sing for you!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MasonPostBattle {
	"Lalalah…
	My POKéMON, I send them out,
	all the girls scream and shout!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_NicolasIntro {
	"This island is too spread out…
	It's not easy patrolling the place."
}

text SevenIsland_SevaultCanyon_Entrance_Text_NicolasDefeat {
	"Uh-huh…"
}

text SevenIsland_SevaultCanyon_Entrance_Text_NicolasPostBattle {
	"TRAINERS like you from cities,
	they sure are tough.

	You'll be headed for the TOWER,
	won't you?"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MadelineIntro {
	"I punish people who abuse
	POKéMON!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_MadelineDefeat {
	"You don't seem to be a problem
	TRAINER."
}

text SevenIsland_SevaultCanyon_Entrance_Text_MadelinePostBattle {
	"If you treat your POKéMON with
	kindness, they'll understand."
}

text SevenIsland_SevaultCanyon_Entrance_Text_EveIntro {
	"EVE: I'll team up with JON and
	battle together."
}

text SevenIsland_SevaultCanyon_Entrance_Text_EveDefeat {
	"EVE: Me and JON, we lost.
	Ehehe."
}

text SevenIsland_SevaultCanyon_Entrance_Text_EvePostBattle {
	"EVE: I'm going to work harder with
	JON."
}

text SevenIsland_SevaultCanyon_Entrance_Text_EveNotEnoughMons {
	"EVE: I want to team up with JON
	when I battle you.

	Come back with two POKéMON, okay?"
}

text SevenIsland_SevaultCanyon_Entrance_Text_JonIntro {
	"JON: When I'm with EVE, it feels
	like we could never lose."
}

text SevenIsland_SevaultCanyon_Entrance_Text_JonDefeat {
	"JON: When I'm with EVE,
	it doesn't feel like I've lost!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_JonPostBattle {
	"JON: When I'm with EVE, I feel
	giddy whether I win or lose.

	It's magical!"
}

text SevenIsland_SevaultCanyon_Entrance_Text_JonNotEnoughMons {
	"JON: If it's with EVE, I'll be
	happy to battle with you.

	So, I'd like to make it a
	two-on-two battle, if I may."
}

text SevenIsland_SevaultCanyon_Entrance_Text_RouteSign {
	"SEVAULT CANYON ENTRANCE

	TRAINERS are asked to refrain from
	damaging plants in the CANYON."
}
