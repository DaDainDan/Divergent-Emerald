mapscripts CeruleanCity_House2_Frlg_MapScripts {}

script CeruleanCity_House2_EventScript_Hiker {
    lock_faceplayer
    if (flag(FLAG_GOT_TM28_FROM_ROCKET)) {
        msgbox(CeruleanCity_House2_Text_TeachDiglettDigWithoutTM)
    	release_end
    }
    msgbox(CeruleanCity_House2_Text_RocketsStoleTMForDig)
    release_end
}

script CeruleanCity_House2_EventScript_Lass {
    msgbox(CeruleanCity_House2_Text_TeamRocketTryingToDigIntoNoGood, MSGBOX_NPC)
    end
}

script CeruleanCity_House2_EventScript_WallHole {
    msgbox(CeruleanCity_House2_Text_TeamRocketLeftWayOut, MSGBOX_SIGN)
    end
}

text CeruleanCity_House2_Text_RocketsStoleTMForDig {
	"Those miserable ROCKETS!

	Look what they've done to my
	house!

	They stole a TM for teaching
	POKéMON how to DIG holes!

	I was going to use it on a
	MANKEY or a SANDSHREW…

	That cost me a bundle, it did!"
}

text CeruleanCity_House2_Text_TeachDiglettDigWithoutTM {
	"I figure what's lost is lost.

	I decided to teach DIGLETT how to
	DIG without a TM."
}

text CeruleanCity_House2_Text_TeamRocketTryingToDigIntoNoGood {
	"TEAM ROCKET must be trying to DIG
	their way into no good!"
}

text CeruleanCity_House2_Text_TeamRocketLeftWayOut {
	"TEAM ROCKET left a way out!"
}
