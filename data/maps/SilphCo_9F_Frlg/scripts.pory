mapscripts SilphCo_9F_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_SILPH_9F_DOOR_1)) {
			call(EventScript_Close9FDoor1)
		}
		if (!flag(FLAG_SILPH_9F_DOOR_2)) {
			call(EventScript_Close9FDoor2)
		}
		if (!flag(FLAG_SILPH_9F_DOOR_3)) {
			call(EventScript_Close9FDoor3)
		}
		if (!flag(FLAG_SILPH_9F_DOOR_4)) {
			call(EventScript_Close9FDoor4)
		}
		end
    }
}

script SilphCo_9F_EventScript_HealWoman {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_9F_Text_ThankYouSoMuch)
    	release_end
    }
    msgbox(SilphCo_9F_Text_YouShouldTakeQuickNap)
    closemessage
    call(Common_EventScript_OutOfCenterPartyHeal)
    msgbox(SilphCo_9F_Text_DontGiveUp)
    release_end
}

script SilphCo_9F_EventScript_FloorSign {
    msgbox(SilphCo_9F_Text_FloorSign, MSGBOX_SIGN)
    end
}

script SilphCo_9F_EventScript_Ed {
    trainerbattle_single(TRAINER_SCIENTIST_ED, SilphCo_9F_Text_EdIntro, SilphCo_9F_Text_EdDefeat)
    msgbox(SilphCo_9F_Text_EdPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SilphCo_9F_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_37, SilphCo_9F_Text_Grunt1Intro, SilphCo_9F_Text_Grunt1Defeat)
    msgbox(SilphCo_9F_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SilphCo_9F_EventScript_Grunt2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_38, SilphCo_9F_Text_Grunt2Intro, SilphCo_9F_Text_Grunt2Defeat)
    msgbox(SilphCo_9F_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SilphCo_9F_Text_YouShouldTakeQuickNap {
	"You look tired.
	You should take a quick nap."
}

text SilphCo_9F_Text_DontGiveUp {
	"Don't give up!"
}

text SilphCo_9F_Text_ThankYouSoMuch {
	"Thank you so much."
}

text SilphCo_9F_Text_Grunt1Intro {
	"Your POKéMON seem to adore you,
	kid!"
}

text SilphCo_9F_Text_Grunt1Defeat {
	"Ghaaah!"
}

text SilphCo_9F_Text_Grunt1PostBattle {
	"If I had started as a TRAINER at
	your age…"
}

text SilphCo_9F_Text_EdIntro {
	"Your POKéMON have weak points!
	I can nail them!"
}

text SilphCo_9F_Text_EdDefeat {
	"You hammered me!"
}

text SilphCo_9F_Text_EdPostBattle {
	"Exploiting weak spots does work.
	Think about type advantages."
}

text SilphCo_9F_Text_Grunt2Intro {
	"I am one of the four ROCKET
	BROTHERS!"
}

text SilphCo_9F_Text_Grunt2Defeat {
	"Warg!
	Brothers, I lost!"
}

text SilphCo_9F_Text_Grunt2PostBattle {
	"My brothers will avenge me!"
}

text SilphCo_9F_Text_FloorSign {
	"SILPH CO. HEAD OFFICE
	9F"
}
