mapscripts SootopolisCity_Gym_1F_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_ICE_STEP_COUNT, 8: SootopolisCity_Gym_1F_EventScript_UnlockStairs
		VAR_ICE_STEP_COUNT, 28: SootopolisCity_Gym_1F_EventScript_UnlockStairs
		VAR_ICE_STEP_COUNT, 67: SootopolisCity_Gym_1F_EventScript_UnlockStairs
		VAR_ICE_STEP_COUNT, 0 {
			lockall
			delay(20)
			applymovement(LOCALID_PLAYER, Common_Movement_SetInvisible)
			waitmovement(0)
			playse(SE_FALL)
			delay(60)
			warphole(MAP_SOOTOPOLIS_CITY_GYM_B1F)
			waitstate
			end
		}
    ]
    MAP_SCRIPT_ON_RESUME {
        setstepcallback(STEP_CB_SOOTOPOLIS_ICE)
    	end
    }
    MAP_SCRIPT_ON_LOAD {
        call(SootopolisCity_Gym_1F_EventScript_CheckSetStairMetatiles)
		special(SetSootopolisGymCrackedIceMetatiles)
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        setvar(VAR_ICE_STEP_COUNT, 1)
    	end
    }
}

script SootopolisCity_Gym_1F_EventScript_UnlockStairs {
    addvar(VAR_ICE_STEP_COUNT, 1)
    delay(40)
    playse(SE_ICE_STAIRS)
    call(SootopolisCity_Gym_1F_EventScript_CheckSetStairMetatiles)
    special(DrawWholeMapView)
    end
}

script SootopolisCity_Gym_1F_EventScript_CheckSetStairMetatiles {
    if (var(VAR_ICE_STEP_COUNT) >= 8) {
        setmetatile(8, 15, METATILE_SootopolisGym_Stairs, FALSE)
    	setmetatile(8, 16, METATILE_SootopolisGym_Stairs, FALSE)
    }
    if (var(VAR_ICE_STEP_COUNT) >= 28) {
        setmetatile(8, 10, METATILE_SootopolisGym_Stairs, FALSE)
    	setmetatile(8, 11, METATILE_SootopolisGym_Stairs, FALSE)
    }
    if (var(VAR_ICE_STEP_COUNT) >= 67) {
		setmetatile(8, 4, METATILE_SootopolisGym_Stairs, FALSE)
		setmetatile(8, 5, METATILE_SootopolisGym_Stairs, FALSE)  
    }
	return
}

script SootopolisCity_Gym_1F_EventScript_Juan {
    trainerbattle_single(TRAINER_JUAN_1, SootopolisCity_Gym_1F_Text_JuanIntro, SootopolisCity_Gym_1F_Text_JuanDefeat, SootopolisCity_Gym_1F_EventScript_JuanDefeated, NO_MUSIC)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
        trainerbattle_rematch_double(TRAINER_JUAN_1, SootopolisCity_Gym_1F_Text_JuanPreRematch, SootopolisCity_Gym_1F_Text_JuanRematchDefeat, SootopolisCity_Gym_1F_Text_JuanRematchNeedTwoMons)
		msgbox(SootopolisCity_Gym_1F_Text_JuanPostRematch, MSGBOX_AUTOCLOSE)
		end
    }
    if (!flag(FLAG_RECEIVED_TM_WATER_PULSE)) {
        if (giveitem(ITEM_TM_WATER_PULSE) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		msgbox(SootopolisCity_Gym_1F_Text_ExplainWaterPulse, MSGBOX_DEFAULT)
		setflag(FLAG_RECEIVED_TM_WATER_PULSE)
		release_end
    }
    if (!flag(FLAG_BADGE06_GET)) {
        msgbox(SootopolisCity_Gym_1F_Text_GoGetFortreeBadge, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Gym_1F_Text_JuanPostBattle, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_Gym_1F_EventScript_JuanDefeated {
    message(SootopolisCity_Gym_1F_Text_ReceivedRainBadge)
    waitmessage
    call(Common_EventScript_PlayGymBadgeFanfare)
    msgbox(SootopolisCity_Gym_1F_Text_ExplainRainBadgeTakeThis, MSGBOX_DEFAULT)
    setflag(FLAG_DEFEATED_SOOTOPOLIS_GYM)
    setflag(FLAG_BADGE08_GET)
    setflag(FLAG_HIDE_SOOTOPOLIS_CITY_RESIDENTS)
    setflag(FLAG_HIDE_SOOTOPOLIS_CITY_STEVEN)
    setflag(FLAG_HIDE_SOOTOPOLIS_CITY_WALLACE)
    setvar(VAR_SOOTOPOLIS_CITY_STATE, 6)
    clearflag(FLAG_HIDE_SOOTOPOLIS_CITY_MAN_1)
    setvar(VAR_0x8008, 8)
    call(Common_EventScript_SetGymTrainers)
    if (giveitem(ITEM_TM_WATER_PULSE) == FALSE) {
        goto(Common_EventScript_BagIsFull)
    }
    msgbox(SootopolisCity_Gym_1F_Text_ExplainWaterPulse, MSGBOX_DEFAULT)
    setflag(FLAG_RECEIVED_TM_WATER_PULSE)
    closemessage
    delay(30)
    playfanfare(MUS_REGISTER_MATCH_CALL)
    msgbox(SootopolisCity_Gym_1F_Text_RegisteredJuan, MSGBOX_DEFAULT)
    waitfanfare
    closemessage
    delay(30)
    setflag(FLAG_ENABLE_JUAN_MATCH_CALL)
    release_end
}

script SootopolisCity_Gym_1F_EventScript_GymGuide {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_SOOTOPOLIS_GYM)) {
        msgbox(SootopolisCity_Gym_1F_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Gym_1F_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_Gym_1F_EventScript_LeftGymStatue {
    lockall
    goto(SootopolisCity_Gym_1F_EventScript_GymStatue)
	end
}

script SootopolisCity_Gym_1F_EventScript_RightGymStatue {
    lockall
	goto(SootopolisCity_Gym_1F_EventScript_GymStatue)
	end
}

script SootopolisCity_Gym_1F_EventScript_GymStatue {
    if (flag(FLAG_BADGE08_GET)) {
        msgbox(SootopolisCity_Gym_1F_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(SootopolisCity_Gym_1F_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

text SootopolisCity_Gym_1F_Text_GymGuideAdvice {
	"Yo! How's it going, CHAMPION-
	bound {PLAYER}?

	SOOTOPOLIS's GYM LEADER JUAN is
	a master of WATER-type POKéMON.

	And, to get to JUAN, an icy floor
	will hamper your progress…

	Listen, I'm sorry, but that's all the
	advice that I have for you.

	The rest of the way, you have to
	go for it yourself!"
}

text SootopolisCity_Gym_1F_Text_GymGuidePostVictory {
	"Yow! You've beaten even JUAN, who
	was supposedly the best in all HOENN!

	Okay! Check out your TRAINER CARD.

	If you've gotten all the BADGES, you're
	set for the POKéMON LEAGUE challenge!"
}

text SootopolisCity_Gym_1F_Text_JuanIntro {
	"Let me ask you.
	Did you know?
	Ah, I should not be so coy.

	It was I who taught WALLACE everything
	there is to know about POKéMON.

	Once, I had given up my position as
	the GYM LEADER.

	In my place, I had entrusted WALLACE
	with the GYM.

	However, a compelling reason arose for
	me to make a comeback.

	Ah, but enough chatter.
	Let us begin our match, shall we?

	Please, you shall bear witness to
	our artistry.

	A grand illusion of water sculpted
	by POKéMON and myself!"
}

text SootopolisCity_Gym_1F_Text_JuanDefeat {
	"Ahahaha, excellent!
	Very well, you are the winner.

	From you, I sense the brilliant shine
	of skill that will overcome all.

	However, compared with me or even
	WALLACE, you are lacking in elegance.

	Perhaps I should make you a loan
	of my outfit?

	… … … … … …
	… … … … … …

	Hahaha, I merely jest!

	Rather than my clothes, I shall reward
	you with this, the RAIN BADGE!"
}

text SootopolisCity_Gym_1F_Text_ReceivedRainBadge {
	"{PLAYER} received the RAIN BADGE
	from JUAN."
}

text SootopolisCity_Gym_1F_Text_ExplainRainBadgeTakeThis {
	"Having the RAIN BADGE shall assure you
	the full obedience of all your POKéMON
	to your every command.

	The RAIN BADGE also allows the use
	of the HM move WATERFALL to scale
	walls of cascading water.

	And, so that you never forget the
	battle we shared, take this…"
}

text SootopolisCity_Gym_1F_Text_ExplainWaterPulse {
	"The TECHNICAL MACHINE I handed you
	contains WATER PULSE.

	In use, it will occasionally confuse
	the target with ultrasonic waves.

	… … … … … …"
}

text SootopolisCity_Gym_1F_Text_RegisteredJuan {
	"Registered GYM LEADER JUAN
	in the POKéNAV."
}

text SootopolisCity_Gym_1F_Text_JuanPostBattle {
	"The TRAINERS who have gathered all
	the GYM BADGES of HOENN should make
	way to the ultimate destination.

	The POKéMON LEAGUE.

	Travel to the easternmost reaches
	of HOENN, to the island EVER GRANDE.

	There, you shall find the POKéMON
	LEAGUE."
}

text SootopolisCity_Gym_1F_Text_GoGetFortreeBadge {
	"There remains but one BADGE to
	obtain in HOENN.

	If you wish to challenge the POKéMON
	LEAGUE, you must obtain the last
	BADGE from the GYM in FORTREE."
}

text SootopolisCity_Gym_1F_Text_GymStatue {
	"SOOTOPOLIS CITY POKéMON GYM"
}

text SootopolisCity_Gym_1F_Text_GymStatueCertified {
	"SOOTOPOLIS CITY POKéMON GYM

	JUAN'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text SootopolisCity_Gym_1F_Text_JuanPreRematch {
	"JUAN: Ah, this GYM had returned to its
	usual state of serenity…

	But our young typhoon has returned
	to put us to the test again!

	Well, my friend, most certainly!

	I shall be delighted to dance with you
	as often as you wish!"
}

text SootopolisCity_Gym_1F_Text_JuanRematchDefeat {
	"Ahahaha, you are the winner!
	You have defeated me again!"
}

text SootopolisCity_Gym_1F_Text_JuanPostRematch {
	"JUAN: If I told you to become my
	apprentice, you will refuse, I am sure.

	I would like to make a gift of my coat
	to you.

	But again, you will refuse.
	I imagine that to be so.

	And that, my friend, is a certain sign
	of nobility!"
}

text SootopolisCity_Gym_1F_Text_JuanRematchNeedTwoMons {
	"JUAN: Ah, this GYM had returned to its
	usual state of serenity…

	But our young typhoon has returned
	to put us to the test again!

	Well, my friend, most certainly!
	I shall be delighted to dance with you…

	Ah, no, no, no.
	You have with you but one POKéMON.

	I wish that you would return with
	two, perhaps more, POKéMON, please."
}
