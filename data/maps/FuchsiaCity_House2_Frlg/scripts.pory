mapscripts FuchsiaCity_House2_Frlg_MapScripts {}

script FuchsiaCity_House2_EventScript_FishingGurusBrother {
    lock_faceplayer
    if (flag(FLAG_GOT_GOOD_ROD)) {
        msgbox(FuchsiaCity_House2_Text_HowAreTheFishBiting)
    	release_end
    }
    msgbox(FuchsiaCity_House2_Text_DoYouLikeToFish, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(FuchsiaCity_House2_Text_LikeYourStyleTakeThis)
		if (checkitemspace(ITEM_GOOD_ROD) == FALSE) {
			msgbox(FuchsiaCity_House2_Text_YouHaveNoRoomForGift)
			release_end
		}
		giveitem_msg(FuchsiaCity_House2_Text_ReceivedGoodRod, ITEM_GOOD_ROD)
		msgbox(FuchsiaCity_House2_Text_GoodRodCanCatchBetterMons)
		setflag(FLAG_GOT_GOOD_ROD)
		release_end
    }
    msgbox(FuchsiaCity_House2_Text_OhThatsDisappointing)
    release_end
}

text FuchsiaCity_House2_Text_DoYouLikeToFish {
	"I'm the FISHING GURU's older
	brother.

	I simply looove fishing!
	I can't bear to go without.

	Tell me, do you like to fish?"
}

text FuchsiaCity_House2_Text_LikeYourStyleTakeThis {
	"Grand! I like your style.
	I think we can be friends.

	Take this and fish, young friend!"
}

text FuchsiaCity_House2_Text_ReceivedGoodRod {
	"{PLAYER} received a GOOD ROD from
	the FISHING GURU's brother."
}

text FuchsiaCity_House2_Text_GoodRodCanCatchBetterMons {
	"Fishing is a way of life!
	It is like the finest poetry.

	A crummy OLD ROD could only catch
	MAGIKARP, yes?

	But with a GOOD ROD, you can
	catch much better POKéMON."
}

text FuchsiaCity_House2_Text_OhThatsDisappointing {
	"Oh…
	That's so disappointing…"
}

text FuchsiaCity_House2_Text_HowAreTheFishBiting {
	"Hello there, {PLAYER}!

	How are the fish biting?"
}

text FuchsiaCity_House2_Text_YouHaveNoRoomForGift {
	"Oh, no!

	I had a gift for you, but you have
	no room for it!"
}
