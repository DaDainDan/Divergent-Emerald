    msgbox(SlateportCity_OceanicMuseum_2F_Text_WantToRideSubmarine, MSGBOX_DEFAULT)
    closemessage
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release_end
}

text SlateportCity_OceanicMuseum_2F_Text_ThankYouForTheParts {
	"Yes? If you're looking for STERN,
	that would be me.

	Ah! Those must be the parts I ordered
	from MR. STONE of DEVON.

	Thank you! That's great!
	We can prepare for our expedition now."
}

text SlateportCity_OceanicMuseum_2F_Text_WellTakeThoseParts {
	"Hehehe, hold it!
	We'll take those parts!"
}

text SlateportCity_OceanicMuseum_2F_Text_SternWhoAreYou {
	"{SPEAKER NAME_STERN}Wh-what?
	Who are you people?"
}

text SlateportCity_OceanicMuseum_2F_Text_WereTeamAqua {
	"We're TEAM AQUA!

	Our BOSS wants those parts!
	Shut your yap and fork them over!"
}

text SlateportCity_OceanicMuseum_2F_Text_Grunt1Defeat {
	"Awaaaah!
	A kid beat me!"
}

text SlateportCity_OceanicMuseum_2F_Text_BossGoingToBeFurious {
	"Oh, man, what a disaster…
	The BOSS is going to be furious…"
}

text SlateportCity_OceanicMuseum_2F_Text_LetMeTakeCareOfThis {
	"Humph, sniveling wimp!
	Let me take care of this!"
}

text SlateportCity_OceanicMuseum_2F_Text_Grunt2Defeat {
	"What?!
	I lost, too!"
}

text SlateportCity_OceanicMuseum_2F_Text_MeddlingKid {
	"Now what? If we don't get the parts,
	we're in for it!

	Arrgh, I didn't count on being meddled
	with by some meddling kid!"
}

text SlateportCity_OceanicMuseum_2F_Text_CameToSeeWhatsTakingSoLong {
	"I came to see what was taking so
	long to snatch some parts, and you
	simps are held up by a mere child?"
}

text SlateportCity_OceanicMuseum_2F_Text_ArchieWarning {
	"We are TEAM AQUA,
	and we love the sea!

	And I am TEAM AQUA's leader,
	ARCHIE!

	What makes you interfere with us?

	…No! You can't be!
	You're not one of TEAM MAGMA?

	Wait, that can't be right.
	You're not dressed for the part.

	… … … … … …
	… … … … … …

	POKéMON, people… All life depends on
	the sea.

	So, TEAM AQUA is dedicated to
	the expansion of the sea.

	Don't you agree? What we are doing
	is a magnificent undertaking.

	Ah, fine…
	You're still too young to understand
	our noble objective.

	But, I warn you, don't even consider
	interfering with our plans again.

	The consequences will cost you
	dearly!

	And don't you forget it!"
}

text SlateportCity_OceanicMuseum_2F_Text_SternThankYouForSavingUs {
	"{SPEAKER NAME_STERN}You're…
	Ah, okay, you're {PLAYER}{KUN}…

	Anyway, that was a tense situation!
	Thank you for saving us!

	Oh, yes, I almost forgot that you
	even brought the parts from DEVON!"
}

text SlateportCity_OceanicMuseum_2F_Text_SternIveGotToGo {
	"{SPEAKER NAME_STERN}Whoops!
	There's no time to lose!

	We have to set out on our ocean-floor
	expedition really soon.

	Thanks again, but now I've got
	to go!

	Feel free to wander around and check
	out our facilities, though."
}

text SlateportCity_OceanicMuseum_2F_Text_RemindsMeOfAbandonedShip {
	"I saw a model of a ship here.

	It reminded me of the ABANDONED SHIP
	near DEWFORD TOWN…"
}

text SlateportCity_OceanicMuseum_2F_Text_DontRunInMuseum {
	"Don't you dare run around inside
	the MUSEUM!"
}

text SlateportCity_OceanicMuseum_2F_Text_WantToRideSubmarine {
	"Wow, the submarine's awesome!
	I want to go for a ride!"
}

text SlateportCity_OceanicMuseum_2F_Text_WaterQualitySample1 {
	"“WATER QUALITY SAMPLE 1,” the
	label says.

	The sea is all connected, but the
	water seems to differ by region."
}

text SlateportCity_OceanicMuseum_2F_Text_WaterQualitySample2 {
	"“WATER QUALITY SAMPLE 2,” the
	label says.

	Does the saltiness of seawater differ
	by region, too?"
}

text SlateportCity_OceanicMuseum_2F_Text_PressureExperiment {
	"A rubber ball is expanding and
	shrinking.

	“In the sea, the weight of water itself
	exerts pressure.

	“In shallow water, the pressure is not
	very heavy.

	“However, in extremely deep water,
	the pressure can reach even tens of
	thousands of tons on a small area.”"
}

text SlateportCity_OceanicMuseum_2F_Text_HoennModel {
	"“MODEL OF HOENN REGION”

	It's a miniature diorama of the
	HOENN region.

	Where is LITTLEROOT TOWN on this?"
}

text SlateportCity_OceanicMuseum_2F_Text_DeepSeawaterDisplay {
	"It's a display on the flow of seawater.

	“Near the bottom of the sea, water
	flows due to differences in such
	factors as temperature and salinity.”"
}

text SlateportCity_OceanicMuseum_2F_Text_SurfaceSeawaterDisplay {
	"It's a display on the flow of seawater.

	“Toward the surface, seawater flows
	as currents driven by the winds.”"
}

text SlateportCity_OceanicMuseum_2F_Text_SSTidalReplica {
	"“THE FERRY S.S. TIDAL

	“A scale replica of the ship under
	construction at STERN'S SHIPYARD.”"
}

text SlateportCity_OceanicMuseum_2F_Text_SubmarineReplica {
	"“SUBMARINE EXPLORER 1

	“A replica of the high-performance
	ocean floor exploration submarine.”"
}

text SlateportCity_OceanicMuseum_2F_Text_SumbersibleReplica {
	"“SUBMERSIBLE POD

	“A replica of a compact, unmanned
	pod for seafloor exploration.”"
}

text SlateportCity_OceanicMuseum_2F_Text_SSAnneReplica {
	"“S.S. ANNE

	“A replica of the luxury liner that
	circles the globe.”"
}
