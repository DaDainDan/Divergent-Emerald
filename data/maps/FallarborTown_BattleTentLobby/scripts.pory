mapscripts FallarborTown_BattleTentLobby_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_CHALLENGE_STATUS, 0 {
			frontier_getstatus
    		end
		}
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING: FallarborTown_BattleTentLobby_EventScript_QuitWithoutSaving
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_PAUSED: FallarborTown_BattleTentLobby_EventScript_ResumeChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_WON: FallarborTown_BattleTentLobby_EventScript_WonChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST: FallarborTown_BattleTentLobby_EventScript_LostChallenge
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script FallarborTown_BattleTentLobby_EventScript_QuitWithoutSaving {
    lockall
    msgbox(FallarborTown_BattleTentLobby_Text_DidntSaveBeforeQuitting, MSGBOX_DEFAULT)
    closemessage
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    releaseall
    end
}

script FallarborTown_BattleTentLobby_EventScript_WonChallenge {
    lockall
    msgbox(FallarborTown_BattleTentLobby_Text_BeatThreeTrainers, MSGBOX_DEFAULT)
    message(FallarborTown_BattleTentLobby_Text_WaitWhileSaveGame)
    waitmessage
    fallarbortent_setrandomprize
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    fallarbortent_save(0)
    playse(SE_SAVE)
    waitse
    end
}

script FallarborTown_BattleTentLobby_EventScript_LostChallenge {
    lockall
    message(FallarborTown_BattleTentLobby_Text_ThankYouWaitWhileSaving)
    waitmessage
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    fallarbortent_save(0)
    playse(SE_SAVE)
    waitse
    msgbox(FallarborTown_BattleTentLobby_Text_AwaitAnotherChallenge2, MSGBOX_DEFAULT)
    closemessage
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    releaseall
    end
}

script FallarborTown_BattleTentLobby_EventScript_ResumeChallenge {
    lockall
    message(FallarborTown_BattleTentLobby_Text_LookingForwardToArrival)
    waitmessage
    fallarbortent_save(CHALLENGE_STATUS_SAVING)
    playse(SE_SAVE)
    waitse
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    goto(FallarborTown_BattleTentLobby_EventScript_EnterChallenge)
}

script FallarborTown_BattleTentLobby_EventScript_Attendant {
    lock_faceplayer
    fallarbortent_getprize
    if (var(VAR_RESULT) != ITEM_NONE) {
        lockall
		msgbox(FallarborTown_BattleTentLobby_Text_BeatThreeTrainers, MSGBOX_DEFAULT)
		msgbox(FallarborTown_BattleTentLobby_Text_PresentYouWithPrize, MSGBOX_DEFAULT)
		fallarbortent_giveprize
		if (var(VAR_RESULT) == FALSE) {
			msgbox(FallarborTown_BattleTentLobby_Text_BagFullReturnForPrize, MSGBOX_DEFAULT)
			waitmessage
			closemessage
			setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
		} else {
			frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
			message(FallarborTown_BattleTentLobby_Text_ReceivedPrize)
			waitmessage
			playfanfare(MUS_OBTAIN_ITEM)
			waitfanfare
			msgbox(FallarborTown_BattleTentLobby_Text_AwaitAnotherChallenge2, MSGBOX_DEFAULT)
			closemessage
			setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
		}
		releaseall
		end
    }
    special(SavePlayerParty)
    msgbox(FallarborTown_BattleTentLobby_Text_WelcomeToBattleTent, MSGBOX_DEFAULT)
    goto(FallarborTown_BattleTentLobby_EventScript_AskEnterChallenge)
    end
}

script FallarborTown_BattleTentLobby_EventScript_AskEnterChallenge {
    message(FallarborTown_BattleTentLobby_Text_TakeChallenge)
    waitmessage
    multichoice(17, 6, MULTI_CHALLENGEINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(FallarborTown_BattleTentLobby_EventScript_TryEnterChallenge)
        case 1:
			msgbox(FallarborTown_BattleTentLobby_Text_ExplainFallarborTent, MSGBOX_DEFAULT)
    		goto(FallarborTown_BattleTentLobby_EventScript_AskEnterChallenge)
        case 2:
        case MULTI_B_PRESSED: goto(FallarborTown_BattleTentLobby_EventScript_CancelChallenge)
    }
    end
}

script FallarborTown_BattleTentLobby_EventScript_TryEnterChallenge {
    setvar(VAR_FRONTIER_FACILITY, FRONTIER_FACILITY_ARENA)
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_SINGLES)
    setvar(VAR_RESULT, 2)
    frontier_checkineligible
    if (var(VAR_0x8004) == TRUE) {
        switch (var(VAR_RESULT)) {
			case FRONTIER_LVL_50: msgbox(FallarborTown_BattleTentLobby_Text_NotEnoughValidMonsLv50, MSGBOX_DEFAULT)
			case FRONTIER_LVL_OPEN: msgbox(FallarborTown_BattleTentLobby_Text_NotEnoughValidMonsLvOpen, MSGBOX_DEFAULT)
		}
		release_end
    }
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_TENT)
    msgbox(FallarborTown_BattleTentLobby_Text_SelectThreeMons, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    setvar(VAR_0x8004, 2)
    setvar(VAR_0x8005, FRONTIER_PARTY_SIZE)
    special(ChoosePartyForBattleFrontier)
    if (var(VAR_RESULT) == 0) {
        goto(FallarborTown_BattleTentLobby_EventScript_LoadPartyCancelChallenge)
    }
    msgbox(FallarborTown_BattleTentLobby_Text_SaveBeforeChallenge, MSGBOX_YESNO)
    switch (var(VAR_RESULT)) {
        case YES: goto(FallarborTown_BattleTentLobby_EventScript_SaveBeforeChallenge)
		case NO:
        case MULTI_B_PRESSED: goto(FallarborTown_BattleTentLobby_EventScript_LoadPartyCancelChallenge)
    }
    end
}

script FallarborTown_BattleTentLobby_EventScript_SaveBeforeChallenge {
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    frontier_set(FRONTIER_DATA_SELECTED_MON_ORDER)
    fallarbortent_init
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING)
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    special(LoadPlayerParty)
    closemessage
    delay(2)
    call(Common_EventScript_SaveGame)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    if (var(VAR_RESULT) == 0) {
        frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
    	goto(FallarborTown_BattleTentLobby_EventScript_CancelChallenge)
    }
    goto(FallarborTown_BattleTentLobby_EventScript_EnterChallenge)
    end
}

script FallarborTown_BattleTentLobby_EventScript_EnterChallenge {
    special(SavePlayerParty)
    frontier_setpartyorder(FRONTIER_PARTY_SIZE)
    msgbox(FallarborTown_BattleTentLobby_Text_GuideYouToBattleTent, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FALLARBOR_TENT_ATTENDANT, moves(walk_up * 3))
    applymovement(LOCALID_PLAYER, moves(walk_up * 3))
    waitmovement(0)
    opendoor(6, 1)
    waitdooranim
    applymovement(LOCALID_FALLARBOR_TENT_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    closedoor(6, 1)
    waitdooranim
    warp(MAP_FALLARBOR_TOWN_BATTLE_TENT_CORRIDOR, 2, 7)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    waitstate
    end
}

script FallarborTown_BattleTentLobby_EventScript_LoadPartyCancelChallenge {
    special(LoadPlayerParty)
    goto(FallarborTown_BattleTentLobby_EventScript_CancelChallenge)
    end
}

script FallarborTown_BattleTentLobby_EventScript_CancelChallenge {
    msgbox(FallarborTown_BattleTentLobby_Text_AwaitAnotherChallenge, MSGBOX_DEFAULT)
    release_end
}

script FallarborTown_BattleTentLobby_EventScript_Hiker {
    msgbox(FallarborTown_BattleTentLobby_Text_CameToCampOut, MSGBOX_NPC)
    end
}

script FallarborTown_BattleTentLobby_EventScript_LittleBoy {
    msgbox(FallarborTown_BattleTentLobby_Text_MakeThinkImJustKid, MSGBOX_NPC)
    end
}

script FallarborTown_BattleTentLobby_EventScript_Lass {
    msgbox(FallarborTown_BattleTentLobby_Text_FallarborTentMyFavorite, MSGBOX_NPC)
    end
}

script FallarborTown_BattleTentLobby_EventScript_Scott {
    lock_faceplayer
    if (flag(FLAG_MET_SCOTT_IN_FALLARBOR)) {
        msgbox(FallarborTown_BattleTentLobby_Text_ScottMakeChallenge, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(FallarborTown_BattleTentLobby_Text_ScottLookingForSomeone, MSGBOX_DEFAULT)
    addvar(VAR_SCOTT_STATE, 1)
    setflag(FLAG_MET_SCOTT_IN_FALLARBOR)
    release_end
}

script FallarborTown_BattleTentLobby_EventScript_RulesBoard {
    lockall
    msgbox(BattleFrontier_BattleArenaLobby_Text_RulesAreListed, MSGBOX_DEFAULT)
    goto(FallarborTown_BattleTentLobby_EventScript_ReadRulesBoard)
    end
}

script FallarborTown_BattleTentLobby_EventScript_ReadRulesBoard {
    message(BattleFrontier_BattleArenaLobby_Text_ReadWhichHeading)
    waitmessage
    multichoice(17, 0, MULTI_FALLARBOR_TENT_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleTentLobby_Text_ExplainLevelRules, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_BattleArenaLobby_Text_ExplainBattleRules, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_BattleArenaLobby_Text_ExplainMindRules, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_BattleArenaLobby_Text_ExplainSkillRules, MSGBOX_DEFAULT)
        case 4: msgbox(BattleFrontier_BattleArenaLobby_Text_ExplainBodyRules, MSGBOX_DEFAULT)
        case 5:
        case MULTI_B_PRESSED:
			releaseall
    		end
    }
	goto(FallarborTown_BattleTentLobby_EventScript_ReadRulesBoard)
    end
}

text FallarborTown_BattleTentLobby_Text_MakeThinkImJustKid {
	"Fufufufufu.

	I'm going to make everyone think
	I'm just a kid and let them play down.

	Then, I'll shock them and grab
	the title!"
}

text FallarborTown_BattleTentLobby_Text_FallarborTentMyFavorite {
	"You know how BATTLE TENTS offer
	different events in different towns?

	My favorite is definitely the BATTLE
	TENT in FALLARBOR TOWN.

	I think it's fantastic how TRAINERS
	try to win with all their faith in
	their POKéMON."
}

text FallarborTown_BattleTentLobby_Text_CameToCampOut {
	"I heard something about some tent,
	so I came to camp out.

	I didn't know that tents these days
	are so luxurious!

	Since I'm here, I may as well try
	my hand at battling!"
}

text FallarborTown_BattleTentLobby_Text_ScottLookingForSomeone {
	"SCOTT: Hi, {PLAYER}{KUN}!
	So you came out to this BATTLE TENT!

	The people in these parts tend to be
	easygoing and laid-back.

	But, you see, what I'm looking for are
	people with…

	How should I say this?

	Someone bursting with the desire
	and the drive to win.

	If there were a TRAINER like that,
	I'd immediately…

	Whoops! Never mind!
	Keep working at it!"
}

text FallarborTown_BattleTentLobby_Text_ScottMakeChallenge {
	"SCOTT: Instead of wasting your
	time with the likes of me, why not
	make a challenge?"
}
