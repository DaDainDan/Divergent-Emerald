script BattleFrontier_OutsideWest_EventScript_Maniac1 {
    lock
    goto(BattleFrontier_OutsideWest_EventScript_FactoryChallengersTalk)
    end
}

script BattleFrontier_OutsideWest_EventScript_Maniac2 {
    lock
    goto(BattleFrontier_OutsideWest_EventScript_FactoryChallengersTalk)
    end
}

script BattleFrontier_OutsideWest_EventScript_FactoryChallengersTalk {
    applymovement(LOCALID_FRONTIER_MANIAC_1, Common_Movement_StepFasterRight)
    waitmovement(0)
    msgbox(BattleFrontier_OutsideWest_Text_SureWeCanChallengeWithNoMons, MSGBOX_DEFAULT)
    applymovement(LOCALID_FRONTIER_MANIAC_2, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(BattleFrontier_OutsideWest_Text_BigGuySaidIllLendYouMons, MSGBOX_DEFAULT)
    closemessage
    delay(25)
    applymovement(LOCALID_FRONTIER_MANIAC_1, Common_Movement_StepFasterUp)
    applymovement(LOCALID_FRONTIER_MANIAC_2, Common_Movement_StepFasterUp)
    waitmovement(0)
    release_end
}

script BattleFrontier_OutsideWest_EventScript_Camper {
    lock_faceplayer
    delay(20)
	if (var(VAR_FACING) != DIR_SOUTH) {
		applymovement(LOCALID_FRONTIER_CAMPER, Common_Movement_StepFasterUp)
    	waitmovement(0)
	}
    msgbox(BattleFrontier_OutsideWest_Text_WhosRaisingThoseRentalMons, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_OutsideWest_EventScript_Girl {
    lock_faceplayer
    message(BattleFrontier_OutsideWest_Text_ScaredOfPikeBecauseSeviper)
    waitmessage
	switch (var(VAR_FACING)) {
		case DIR_NORTH: applymovement(LOCALID_FRONTIER_GIRL, moves(step_faster_down * 2))
		case DIR_SOUTH: applymovement(LOCALID_FRONTIER_GIRL, moves(step_faster_up * 2))
		case DIR_WEST: applymovement(LOCALID_FRONTIER_GIRL, moves(step_faster_right * 2))
		case DIR_EAST: applymovement(LOCALID_FRONTIER_GIRL, moves(step_faster_left * 2))
	}
    waitmovement(0)
    waitbuttonpress
    release_end
}

script BattleFrontier_OutsideWest_EventScript_Woman2 {
    lock_faceplayer
    msgbox(BattleFrontier_OutsideWest_Text_LetsPlayRockPaperScissors, MSGBOX_DEFAULT)
    random(2)
    if (var(VAR_RESULT) == 1) {
        msgbox(BattleFrontier_OutsideWest_Text_WonIllTakePikeChallenge, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(BattleFrontier_OutsideWest_Text_LostIllPutOffPikeChallenge, MSGBOX_DEFAULT)
    release_end
}

