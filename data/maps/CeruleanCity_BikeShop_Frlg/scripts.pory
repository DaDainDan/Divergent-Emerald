mapscripts CeruleanCity_BikeShop_Frlg_MapScripts {}

script CeruleanCity_BikeShop_EventScript_Clerk {
    lock_faceplayer
    if (flag(FLAG_GOT_BICYCLE)) {
        msgbox(CeruleanCity_BikeShop_Text_HowDoYouLikeNewBicycle)
    }
    elif (flag(FLAG_GOT_BIKE_VOUCHER)) {
        msgbox(CeruleanCity_BikeShop_Text_OhBikeVoucherHereYouGo)
		msgreceiveditem(CeruleanCity_BikeShop_Text_ExchangedVoucherForBicycle, ITEM_BICYCLE, 1, MUS_RG_OBTAIN_KEY_ITEM)
		setflag(FLAG_GOT_BICYCLE)
		additem(ITEM_BICYCLE)
		removeitem(ITEM_BIKE_VOUCHER)
		msgbox(CeruleanCity_BikeShop_Text_ThankYouComeAgain)
    }
	else {
		showmoneybox(0, 0)
		message(CeruleanCity_BikeShop_Text_WelcomeToBikeShop)
		waitmessage
		multichoice(11, 0, MULTI_BIKE_SHOP, FALSE)
		hidemoneybox
		showmoneybox(0, 0)
		if (var(VAR_RESULT) == 0) {
			msgbox(CeruleanCity_BikeShop_Text_SorryYouCantAffordIt)
		}
		msgbox(CeruleanCity_BikeShop_Text_ThankYouComeAgain)
		hidemoneybox
	}
    release_end
}

// Unused
script CeruleanCity_BikeShop_EventScript_NoRoomForBicycle {
    msgbox(CeruleanCity_BikeShop_Text_MakeRoomForBicycle)
    release_end
}

script CeruleanCity_BikeShop_EventScript_Woman {
    msgbox(CeruleanCity_BikeShop_Text_CityBikeGoodEnoughForMe, MSGBOX_NPC)
    end
}

script CeruleanCity_BikeShop_EventScript_Youngster {
    lock_faceplayer
    if (flag(FLAG_GOT_BICYCLE)) {
        msgbox(CeruleanCity_BikeShop_Text_WowYourBikeIsCool)
    	release_end
    }
    msgbox(CeruleanCity_BikeShop_Text_BikesCoolButExpensive)
    release_end
}

script CeruleanCity_BikeShop_EventScript_Bicycle {
    msgbox(CeruleanCity_BikeShop_Text_ShinyNewBicycle, MSGBOX_SIGN)
    end
}

text CeruleanCity_BikeShop_Text_WelcomeToBikeShop {
	"Hi!
	Welcome to our BIKE SHOP.

	Have we got just the BIKE for
	you!"
}

text CeruleanCity_BikeShop_Text_SorryYouCantAffordIt {
	"Sorry!
	You can't afford it!"
}

text CeruleanCity_BikeShop_Text_OhBikeVoucherHereYouGo {
	"Oh, that's…

	A BIKE VOUCHER!

	Okay!
	Here you go!"
}

text CeruleanCity_BikeShop_Text_ExchangedVoucherForBicycle {
	"{PLAYER} exchanged the
	BIKE VOUCHER for a BICYCLE."
}

text CeruleanCity_BikeShop_Text_ThankYouComeAgain {
	"Thank you!
	Come back again sometime!"
}

text CeruleanCity_BikeShop_Text_HowDoYouLikeNewBicycle {
	"How do you like your new BICYCLE?
	Do you like how it rides?

	You can take it out on CYCLING
	ROAD and even into caves!"
}

text CeruleanCity_BikeShop_Text_MakeRoomForBicycle {
	"You better make room for your
	BICYCLE!"
}

text CeruleanCity_BikeShop_Text_CityBikeGoodEnoughForMe {
	"A plain city bike is good enough
	for me.

	After all, you can't put a shopping
	basket on a mountain bike."
}

text CeruleanCity_BikeShop_Text_BikesCoolButExpensive {
	"These bikes are cool, but they're
	way expensive!"
}

text CeruleanCity_BikeShop_Text_WowYourBikeIsCool {
	"Wow.
	Your BIKE is really cool!"
}

// Unused
text CeruleanCity_BikeShop_Text_GermanFoldableBicyleFinallyOnMarket {
	"ついに　はつばい！

	ドイツ　せい　さいこうきゅう
	おりたたみ　じてんしゃ！"
}

text CeruleanCity_BikeShop_Text_ShinyNewBicycle {
	"A shiny new BICYCLE!"
}
