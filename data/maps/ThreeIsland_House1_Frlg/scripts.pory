mapscripts ThreeIsland_House1_Frlg_MapScripts {}

script ThreeIsland_House1_EventScript_Lostelle {
    lock_faceplayer
    special(GetPlayerBigGuyGirlString)
    msgbox(ThreeIsland_House1_Text_YoureAlwaysSoCool)
    release_end
}

script ThreeIsland_House1_EventScript_DisplayCase {
    msgbox(ThreeIsland_House1_Text_RareRocksGemsDisplayed, MSGBOX_SIGN)
    end
}

text ThreeIsland_House1_Text_YoureAlwaysSoCool {
	"LOSTELLE: Hi, {PLAYER}!
	You're always so cool!

	I'll make lunch for you, too, one
	day, {PLAYER}."
}

text ThreeIsland_House1_Text_RareRocksGemsDisplayed {
	"Rare rocks and gems are displayed."
}
