mapscripts Route110_TrickHousePuzzle1_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_TRICK_HOUSE_PUZZLE_1_STATE) == 2) {
			setmetatile(13, 1, METATILE_TrickHousePuzzle_Stairs_Down, FALSE)
		}
		end
    }
}

script Route110_TrickHousePuzzle1_EventScript_Scroll {
    lockall
    if (var(VAR_TRICK_HOUSE_PUZZLE_1_STATE) == 0) {
        setvar(VAR_TRICK_HOUSE_PUZZLE_1_STATE, 1)
    	goto(Route110_TrickHousePuzzle_EventScript_FoundScroll)
    }
    goto(Route110_TrickHousePuzzle_EventScript_ReadScrollAgain)
    end
}

script Route110_TrickHousePuzzle1_EventScript_Sally {
    trainerbattle_single(TRAINER_SALLY, Route110_TrickHousePuzzle1_Text_SallyIntro, Route110_TrickHousePuzzle1_Text_SallyDefeat)
    msgbox(Route110_TrickHousePuzzle1_Text_SallyPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route110_TrickHousePuzzle1_EventScript_Eddie {
    trainerbattle_single(TRAINER_EDDIE, Route110_TrickHousePuzzle1_Text_EddieIntro, Route110_TrickHousePuzzle1_Text_EddieDefeat)
    msgbox(Route110_TrickHousePuzzle1_Text_EddiePostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route110_TrickHousePuzzle1_EventScript_Robin {
    trainerbattle_single(TRAINER_ROBIN, Route110_TrickHousePuzzle1_Text_RobinIntro, Route110_TrickHousePuzzle1_Text_RobinDefeat)
    msgbox(Route110_TrickHousePuzzle1_Text_RobinPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text Route110_TrickHousePuzzle1_Text_WroteSecretCodeLockOpened {
	"{PLAYER} wrote down the secret code
	on the door.

	“TRICK MASTER is fabulous.”
	… … … … … … … …

	The lock clicked open!"
}

text Route110_TrickHousePuzzle1_Text_SallyIntro {
	"I'll hack and slash my way to victory
	with the CUT we just learned!"
}

text Route110_TrickHousePuzzle1_Text_SallyDefeat {
	"Why are you so serious?"
}

text Route110_TrickHousePuzzle1_Text_SallyPostBattle {
	"I never get tired of hacking
	and slashing!"
}

text Route110_TrickHousePuzzle1_Text_EddieIntro {
	"I wandered into this weird house
	by accident…"
}

text Route110_TrickHousePuzzle1_Text_EddieDefeat {
	"And now I've lost…"
}

text Route110_TrickHousePuzzle1_Text_EddiePostBattle {
	"I lost my way, I lost a battle, and I'm
	now even more lost… I can't get out…"
}

text Route110_TrickHousePuzzle1_Text_RobinIntro {
	"Just who is the TRICK MASTER?"
}

text Route110_TrickHousePuzzle1_Text_RobinDefeat {
	"I lost while I was lost in thought!"
}

text Route110_TrickHousePuzzle1_Text_RobinPostBattle {
	"You're strong!
	Just who are you?"
}
