mapscripts VerdanturfTown_Mart_MapScripts {}

script VerdanturfTown_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(VerdanturfTown_Mart_Pokemart)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart VerdanturfTown_Mart_Pokemart {
    ITEM_GREAT_BALL
    ITEM_NEST_BALL
    ITEM_SUPER_POTION
    ITEM_ANTIDOTE
    ITEM_PARALYZE_HEAL
    ITEM_AWAKENING
    ITEM_BURN_HEAL
    ITEM_ICE_HEAL
    ITEM_REPEL
    ITEM_X_SP_ATK
    ITEM_FLUFFY_TAIL
}

script VerdanturfTown_Mart_EventScript_Boy {
    msgbox(VerdanturfTown_Mart_Text_XSpecialIsCrucial, MSGBOX_NPC)
    end
}

script VerdanturfTown_Mart_EventScript_ExpertF {
    msgbox(VerdanturfTown_Mart_Text_NoStrategyGuidesForBattleTent, MSGBOX_NPC)
    end
}

script VerdanturfTown_Mart_EventScript_Lass {
    msgbox(VerdanturfTown_Mart_Text_NestBallOnWeakenedPokemon, MSGBOX_NPC)
    end
}

text VerdanturfTown_Mart_Text_XSpecialIsCrucial {
	"For any POKéMON match, X SPECIAL
	is crucial.

	It jacks up the power of some moves
	even though it's only for one battle."
}

text VerdanturfTown_Mart_Text_NoStrategyGuidesForBattleTent {
	"They don't seem to sell any winning
	strategy guides for the BATTLE TENT…

	It seems one must rely on one's
	own wits after all…"
}

text VerdanturfTown_Mart_Text_NestBallOnWeakenedPokemon {
	"The NEST BALL works better on
	weakened POKéMON.

	VERDANTURF is the only place you can
	buy it."
}
