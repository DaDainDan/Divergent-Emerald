    trainerbattle_single(TRAINER_GRUNT_MT_PYRE_1, MtPyre_Summit_Text_Grunt1Intro, MtPyre_Summit_Text_Grunt1Defeat)
    msgbox(MtPyre_Summit_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

