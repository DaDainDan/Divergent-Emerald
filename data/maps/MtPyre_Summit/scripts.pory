mapscripts MtPyre_Summit_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_MT_PYRE_STATE) == 2) {
			setobjectxyperm(LOCALID_MT_PYRE_SUMMIT_MAXIE, 23, 6)
			setobjectxyperm(LOCALID_MT_PYRE_SUMMIT_ARCHIE, 22, 6)
		}
		end
    }
}

script MtPyre_Summit_EventScript_FogTrigger {
    setweather(WEATHER_FOG_HORIZONTAL)
    doweather
    end
}

script MtPyre_Summit_EventScript_SnowTrigger {
    setweather(WEATHER_SNOW)
    doweather
    end
}

script MtPyre_Summit_EventScript_TeamAquaTrigger0 {
    lockall
    setvar(VAR_0x8008, 0)
    goto(MtPyre_Summit_EventScript_TeamAquaExits)
    end
}

script MtPyre_Summit_EventScript_TeamAquaTrigger1 {
    lockall
    setvar(VAR_0x8008, 1)
    goto(MtPyre_Summit_EventScript_TeamAquaExits)
    end
}

script MtPyre_Summit_EventScript_TeamAquaTrigger2 {
    lockall
    setvar(VAR_0x8008, 2)
    goto(MtPyre_Summit_EventScript_TeamAquaExits)
    end
}

script MtPyre_Summit_EventScript_TeamAquaExits {
    playbgm(MUS_ENCOUNTER_AQUA, FALSE)
    applymovement(LOCALID_PLAYER, Common_Movement_FaceUp)
    waitmovement(0)
    applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(50)
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(walk_left,  step_faster_down))
		case 2: applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(walk_right,  step_faster_down))
	}
	waitmovement(0)
    msgbox(MtPyre_Summit_Text_ArchieWeGotTheOrbLetsGo, MSGBOX_DEFAULT)
    closemessage
    fadescreenswapbuffers(FADE_TO_BLACK)
    removeobject(LOCALID_MT_PYRE_SUMMIT_ARCHIE)
    removeobject(LOCALID_MT_PYRE_SUMMIT_GRUNT_1)
    removeobject(LOCALID_MT_PYRE_SUMMIT_GRUNT_2)
    removeobject(LOCALID_MT_PYRE_SUMMIT_GRUNT_3)
    removeobject(LOCALID_MT_PYRE_SUMMIT_GRUNT_4)
    setflag(FLAG_HIDE_MT_PYRE_SUMMIT_ARCHIE)
    setflag(FLAG_HIDE_MT_PYRE_SUMMIT_TEAM_AQUA)
    fadedefaultbgm
    fadescreenswapbuffers(FADE_FROM_BLACK)
    delay(20)
    setvar(VAR_MT_PYRE_STATE, 1)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_MT_PYRE_SUMMIT_OLD_LADY, moves(walk_down * 2,  step_faster_left))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
		case 1: 
			applymovement(LOCALID_MT_PYRE_SUMMIT_OLD_LADY, Common_Movement_WalkDown)
		case 2:
			applymovement(LOCALID_MT_PYRE_SUMMIT_OLD_LADY, moves(walk_down * 2,  step_faster_right))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
	}
    msgbox(MtPyre_Summit_Text_BothOrbsTakenMagmaLeftThis, MSGBOX_DEFAULT)
    giveitem(ITEM_MAGMA_EMBLEM)
    setflag(FLAG_RECEIVED_RED_OR_BLUE_ORB)
    setflag(FLAG_HIDE_JAGGED_PASS_MAGMA_GUARD)
    releaseall
    end
}

script MtPyre_Summit_EventScript_OldMan {
    lock_faceplayer
    if (flag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)) {
        msgbox(MtPyre_Summit_Text_HearTheNewLegendOfHoenn, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			msgbox(MtPyre_Summit_Text_HoennTrioTale, MSGBOX_DEFAULT)
		}
    } else {
		msgbox(MtPyre_Summit_Text_WillYouHearOutMyTale, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			msgbox(MtPyre_Summit_Text_GroudonKyogreTale, MSGBOX_DEFAULT)
		}
	}
	if (var(VAR_RESULT) == NO) {
		msgbox(MtPyre_Summit_Text_WellThatTooIsFine, MSGBOX_DEFAULT)
	}
    release_end
}

script MtPyre_Summit_EventScript_OldLady {
    lock_faceplayer
    if (flag(FLAG_RETURNED_RED_OR_BLUE_ORB)) {
        msgbox(MtPyre_Summit_Text_SuperAncientPokemonTaughtUs, MSGBOX_DEFAULT)
    }
    elif (var(VAR_MT_PYRE_STATE) >= 3) {
        msgbox(MtPyre_Summit_Text_ThoseTwoMenReturnedOrbs, MSGBOX_DEFAULT)
    	setflag(FLAG_RETURNED_RED_OR_BLUE_ORB)
    }
    elif (flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN)) {
        msgbox(MtPyre_Summit_Text_GroudonKyogreAwakened, MSGBOX_DEFAULT)
    }
	else {
		msgbox(MtPyre_Summit_Text_OrbsHaveBeenTaken, MSGBOX_DEFAULT)
	}
    release_end
}

script MtPyre_Summit_EventScript_ArchieMaxieTrigger0 {
    lockall
    setvar(VAR_0x8008, 0)
    goto(MtPyre_Summit_EventScript_ArchieMaxieReturnOrbs)
    end
}

script MtPyre_Summit_EventScript_ArchieMaxieTrigger1 {
    lockall
    setvar(VAR_0x8008, 1)
    goto(MtPyre_Summit_EventScript_ArchieMaxieReturnOrbs)
    end
}

script MtPyre_Summit_EventScript_ArchieMaxieTrigger2 {
    lockall
    setvar(VAR_0x8008, 2)
    goto(MtPyre_Summit_EventScript_ArchieMaxieReturnOrbs)
    end
}

script MtPyre_Summit_EventScript_ArchieMaxieReturnOrbs {
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    delay(60)
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_PLAYER, moves(delay_16,  delay_8,  walk_left,  step_faster_right,  delay_16,  step_faster_down))
		case 1: applymovement(LOCALID_PLAYER, moves(delay_16,  delay_8,  walk_right,  step_faster_left,  delay_16,  step_faster_down))
		case 2: applymovement(LOCALID_PLAYER, moves(delay_16,  delay_8,  step_faster_left,  delay_16,  step_faster_down))
	}
	applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(walk_down * 6))
	applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_down * 6))
	waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, Common_Movement_Delay48)
    waitmovement(0)
    delay(30)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  step_faster_right))
			applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(delay_16,  step_faster_up))
			applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_up * 3,  walk_left))
		case 1:
			applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  step_faster_left))
			applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(delay_16,  step_faster_up))
			applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_up * 3,  step_faster_right))
		case 2:
			applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  step_faster_left))
			applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(delay_16,  step_faster_up))
			applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_up * 3,  step_faster_right))
	}
	waitmovement(0)
    msgbox(MtPyre_Summit_Text_MaxieSilence, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down))
    		applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_down,  walk_right,  walk_down * 2,  step_faster_left))
		case 1:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down))
    		applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_down * 3,  step_faster_left))
		case 2:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down))
    		applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_down * 3,  step_faster_left))
	}
	waitmovement(0)
    applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(30)
    applymovement(LOCALID_MT_PYRE_SUMMIT_ARCHIE, moves(walk_down * 6))
    applymovement(LOCALID_MT_PYRE_SUMMIT_MAXIE, moves(walk_down * 6))
    waitmovement(0)
    removeobject(LOCALID_MT_PYRE_SUMMIT_ARCHIE)
    removeobject(LOCALID_MT_PYRE_SUMMIT_MAXIE)
    setvar(VAR_MT_PYRE_STATE, 3)
    releaseall
    end
}

