script LilycoveCity_ContestLobby_EventScript_LinkContestReceptionist {
    special(ClearLinkContestFlags)
    lock_faceplayer
    msgbox(LilycoveCity_ContestLobby_Text_LinkContestReception, MSGBOX_DEFAULT)
    goto(LilycoveCity_ContestLobby_EventScript_AskEnterLinkContest)
    end
}

script LilycoveCity_ContestLobby_EventScript_AskEnterLinkContest {
    message(LilycoveCity_ContestLobby_Text_EnterContest3)
    waitmessage
    multichoice(0, 0, MULTI_ENTERINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(LilycoveCity_ContestLobby_EventScript_TryEnterLinkContest)
        case 1: goto(LilycoveCity_ContestLobby_EventScript_LinkContestInfo)
        case 2:
        case MULTI_B_PRESSED: 
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    end
}

script LilycoveCity_ContestLobby_EventScript_TryEnterLinkContest {
    msgbox(LilycoveCity_ContestLobby_Text_ProgressWillBeSaved, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    call(Common_EventScript_SaveGame)
    if (var(VAR_RESULT) == FALSE) {
        goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    message(LilycoveCity_ContestLobby_Text_WhichContestMode)
    waitmessage
    specialvar(VAR_TEMP_D, IsWirelessAdapterConnected)
    multichoice(0, 0, MULTI_LINK_CONTEST_MODE, FALSE)
    switch (var(VAR_RESULT)) {
        case 0:
            setvar(VAR_TEMP_C, 0)
        case 1:
            setvar(VAR_TEMP_C, 1)
            if (var(VAR_TEMP_D) == 1) {
                special(CloseLink)
                msgbox(LilycoveCity_ContestLobby_Text_NoWirelessAdapterInGMode, MSGBOX_DEFAULT)
                release_end
            }
        case 2:
        case MULTI_B_PRESSED: 
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
            end
    }
    goto(LilycoveCity_ContestLobby_EventScript_ChooseLinkContestType)
    end
}

script LilycoveCity_ContestLobby_EventScript_ChooseLinkContestType {
    message(LilycoveCity_ContestLobby_Text_EnterWhichContest3)
    waitmessage
    multichoice(0, 0, MULTI_CONTEST_TYPE, FALSE)
    if (var(VAR_RESULT) == CONTEST_CATEGORIES_COUNT || var(VAR_RESULT) == MULTI_B_PRESSED) {
        goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    copyvar(VAR_CONTEST_CATEGORY, VAR_RESULT)
    goto(LilycoveCity_ContestLobby_EventScript_ChooseLinkContestMon)
    end
}

script LilycoveCity_ContestLobby_EventScript_LinkContestInfo {
    message(LilycoveCity_ContestLobby_Text_WhichTopic2)
    waitmessage
    multichoice(0, 0, MULTI_LINK_CONTEST_INFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(LilycoveCity_ContestLobby_Text_ExplainLinkContest, MSGBOX_DEFAULT)
        case 1: msgbox(LilycoveCity_ContestLobby_Text_ExplainEMode, MSGBOX_DEFAULT)
        case 2: msgbox(LilycoveCity_ContestLobby_Text_ExplainGMode, MSGBOX_DEFAULT)
        case 3:
        case MULTI_B_PRESSED:
            goto(LilycoveCity_ContestLobby_EventScript_AskEnterLinkContest)
            end
    }
    goto(LilycoveCity_ContestLobby_EventScript_LinkContestInfo)
    end
}

script LilycoveCity_ContestLobby_EventScript_CancelLinkContest {
    special(CloseLink)
    msgbox(LilycoveCity_ContestLobby_Text_ParticipateAnotherTime, MSGBOX_DEFAULT)
    release_end
}

script LilycoveCity_ContestLobby_EventScript_ChooseLinkContestMon {
    msgbox(LilycoveCity_ContestLobby_Text_EnterWhichPokemon3, MSGBOX_DEFAULT)
    setvar(VAR_CONTEST_RANK, 0)
    if (choosecontestmon == PARTY_NOTHING_CHOSEN) {
        goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    special(TryEnterContestMon)
    switch (var(VAR_RESULT)) {
        case CAN_ENTER_CONTEST_EQUAL_RANK:
        case CAN_ENTER_CONTEST_HIGH_RANK:
            copyvar(VAR_0x8008, VAR_0x8004)
            goto(LilycoveCity_ContestLobby_EventScript_TrySetUpLinkContest)
            end
        case CANT_ENTER_CONTEST: msgbox(LilycoveCity_ContestLobby_Text_MonNotQualifiedForRank, MSGBOX_DEFAULT)
        case CANT_ENTER_CONTEST_EGG: msgbox(LilycoveCity_ContestLobby_Text_EggCannotTakePart2, MSGBOX_DEFAULT)
        case CANT_ENTER_CONTEST_FAINTED: msgbox(LilycoveCity_ContestLobby_Text_MonInNoCondition2, MSGBOX_DEFAULT)
    }
    goto(LilycoveCity_ContestLobby_EventScript_ChooseLinkContestMon)
    end
}

script LilycoveCity_ContestLobby_EventScript_TrySetUpLinkContest {
    if (var(VAR_TEMP_D) == 1) {
        goto(LilycoveCity_ContestLobby_EventScript_SetLinkGroupType)
    }
    if (var(VAR_TEMP_D) >= 2) {
        goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    message(LilycoveCity_ContestLobby_Text_PleaseWaitBButtonCancel)
    waitmessage
    copyvar(VAR_0x8004, VAR_RESULT)
    switch (var(VAR_TEMP_C)) {
        case 0: special(TryContestEModeLinkup)
        case 1: special(TryContestGModeLinkup)
        default: goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    switch (var(VAR_RESULT)) {
        case LINKUP_FAILED: goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
        case LINKUP_WRONG_NUM_PLAYERS:
        case LINKUP_DIFF_SELECTIONS:
            msgbox(LilycoveCity_ContestLobby_Text_PlayersMadeDifferentChoice, MSGBOX_DEFAULT)
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
        case LINKUP_CONNECTION_ERROR:
            special(CloseLink)
            msgbox(Text_LinkErrorPleaseReset, MSGBOX_DEFAULT)
            release_end
        case LINKUP_FAILED_CONTEST_GMODE: 
            msgbox(LilycoveCity_ContestLobby_Text_PlayerAt4PCounterUseGMode, MSGBOX_DEFAULT)
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    messageinstant(LilycoveCity_ContestLobby_Text_Transmitting)
    contestlinktransfer
    switch (var(VAR_0x8004)) {
        case 0: goto(LilycoveCity_ContestLobby_EventScript_StartLinkContest)
        case 1: 
            msgbox(LilycoveCity_ContestLobby_Text_PlayersChoseDifferentContest, MSGBOX_DEFAULT)
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
        case 2: 
            msgbox(LilycoveCity_ContestLobby_Text_TransmissionError, MSGBOX_DEFAULT)
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    end
}

script LilycoveCity_ContestLobby_EventScript_StartLinkContest {
    special(GetContestPlayerId)
    addvar(VAR_0x8004, 1)
    buffernumberstring(STR_VAR_2, VAR_0x8004)
    messageautoscroll(LilycoveCity_ContestLobby_Text_YourMonIsEntryNumX)
    waitmessage
    subvar(VAR_0x8004, 1)
    call(LilycoveCity_ContestLobby_EventScript_LeadToLinkContestHall)
    setvar(VAR_CONTEST_HALL_STATE, 1)
    special(SetLinkContestPlayerGfx)
    setvar(VAR_CONTEST_TYPE, CONTEST_TYPE_LINK)
    setvar(VAR_CONTEST_RANK, CONTEST_RANK_MASTER)
    call(LilycoveCity_ContestLobby_EventScript_WarpToContestHall)
    end
}

script LilycoveCity_ContestLobby_EventScript_SetLinkGroupType {
	switch (var(VAR_CONTEST_CATEGORY)) {
		case CONTEST_CATEGORY_COOL: setvar(VAR_0x8004, LINK_GROUP_COOL_CONTEST)
		case CONTEST_CATEGORY_BEAUTY: setvar(VAR_0x8004, LINK_GROUP_BEAUTY_CONTEST)
		case CONTEST_CATEGORY_CUTE: setvar(VAR_0x8004, LINK_GROUP_CUTE_CONTEST)
		case CONTEST_CATEGORY_SMART: setvar(VAR_0x8004, LINK_GROUP_SMART_CONTEST)
		case CONTEST_CATEGORY_TOUGH: setvar(VAR_0x8004, LINK_GROUP_TOUGH_CONTEST)
	}
    goto(LilycoveCity_ContestLobby_EventScript_DecideLinkLeader)
    end
}

script LilycoveCity_ContestLobby_EventScript_DecideLinkLeader {
    message(LilycoveCity_ContestLobby_Text_PleaseDecideLinkLeader)
    waitmessage
    multichoice(16, 6, MULTI_LINK_LEADER, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(LilycoveCity_ContestLobby_EventScript_TryJoinGroup)
        case 1: goto(LilycoveCity_ContestLobby_EventScript_TryLeadGroup)
        case 2:
        case MULTI_B_PRESSED: 
            goto(LilycoveCity_ContestLobby_EventScript_CancelLinkContest)
    }
    end
}

script LilycoveCity_ContestLobby_EventScript_TryLeadGroup {
    special(TryBecomeLinkLeader)
	switch (var(VAR_RESULT)) {
		case LINKUP_SUCCESS: goto(LilycoveCity_ContestLobby_EventScript_LinkLeaderDecided)
		case LINKUP_FAILED: goto(LilycoveCity_ContestLobby_EventScript_DecideLinkLeader)
		case LINKUP_RETRY_ROLE_ASSIGN: goto(LilycoveCity_ContestLobby_EventScript_TryLeadGroup)
	}
    release_end
}

script LilycoveCity_ContestLobby_EventScript_TryJoinGroup {
    special(TryJoinLinkGroup)
	switch (var(VAR_RESULT)) {
		case LINKUP_SUCCESS: goto(LilycoveCity_ContestLobby_EventScript_LinkLeaderDecided)
		case LINKUP_FAILED: goto(LilycoveCity_ContestLobby_EventScript_DecideLinkLeader)
		case LINKUP_RETRY_ROLE_ASSIGN: goto(LilycoveCity_ContestLobby_EventScript_TryJoinGroup)
	}
    release_end
}

script LilycoveCity_ContestLobby_EventScript_LinkLeaderDecided {
    messageinstant(LilycoveCity_ContestLobby_Text_Transmitting)
    contestlinktransfer
    goto(LilycoveCity_ContestLobby_EventScript_StartLinkContest)
    end
}

script LilycoveCity_ContestLobby_EventScript_LeadToLinkContestHall {
    messageautoscroll(LilycoveCity_ContestLobby_Text_ContestBeginShortly)
    waitmessage
    delay(20)
    closemessage
    applymovement(LOCALID_CONTEST_LOBBY_LINK_RECEPTIONIST, moves(walk_right,  step_faster_down))
    waitmovement(0)
    playse(SE_BRIDGE_WALK)
    setmetatile(17, 2, METATILE_Contest_WallShadow, TRUE)
    setmetatile(17, 3, METATILE_Contest_FloorShadow, TRUE)
    special(DrawWholeMapView)
    applymovement(LOCALID_CONTEST_LOBBY_LINK_RECEPTIONIST, moves(walk_down * 2,  step_faster_down))
    waitmovement(0)
    playse(SE_BRIDGE_WALK)
    setmetatile(17, 2, METATILE_Contest_CounterFlap_Top, TRUE)
    setmetatile(17, 3, METATILE_Contest_CounterFlap_Bottom, TRUE)
    special(DrawWholeMapView)
    delay(20)
    applymovement(LOCALID_CONTEST_LOBBY_LINK_RECEPTIONIST, Common_Movement_StepFasterLeft)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_WalkRight)
    waitmovement(0)
    messageautoscroll(LilycoveCity_ContestLobby_Text_ComeThroughHere)
    waitmessage
    delay(20)
    closemessage
    call(LilycoveCity_ContestLobby_EventScript_DelayIfContestWithRSPlayer)
    applymovement(LOCALID_CONTEST_LOBBY_LINK_RECEPTIONIST, moves(walk_right * 4,  walk_up * 3,  delay_8,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_right * 5,  walk_up * 3,  delay_8,  set_invisible))
    waitmovement(0)
    release
    return
}

script LilycoveCity_ContestLobby_EventScript_LittleGirl {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_POKEBLOCK_CASE)) {
        msgbox(LilycoveCity_ContestLobby_Text_MakePokeblocksDifferentBerries, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_ContestLobby_Text_LadyGaveMePokeblockCase, MSGBOX_DEFAULT)
    release_end
}

text LilycoveCity_ContestLobby_Text_LadyGaveMePokeblockCase {
	"Yippee!

	The lady at the reception counter
	gave me a case for {POKEBLOCK}S!"
}

text LilycoveCity_ContestLobby_Text_MakePokeblocksDifferentBerries {
	"Make {POKEBLOCK}S and put them in there.

	When you make a {POKEBLOCK}, everyone
	has to put in a different BERRY."
}

text LilycoveCity_ContestLobby_Text_YourPokemonSpurredMeToPaint {
	"Congratulations!

	I did a painting of your POKéMON to
	commemorate its victory…

	Well, your POKéMON's appeals were
	so fantastic, it spurred me into
	painting better than I usually do.
	Look, see?"
}

text LilycoveCity_ContestLobby_Text_ShouldITakePaintingToMuseum {
	"What do you think? I'm confident in
	what I've done, but do you like it?

	A work of this caliber, it wouldn't look
	out of place in an art museum.

	Huh? An art museum really is looking
	for paintings?

	Do you think I should take this there?"
}

text LilycoveCity_ContestLobby_Text_IllTakePaintingToMuseum {
	"What, really? Then, sure, I will take
	this painting there right now.

	I'll give it a proper title, too.

	I hope they'll like it and consider
	exhibiting this.

	Please check if they did accept this.
	Thank you!"
}

text LilycoveCity_ContestLobby_Text_TakeMementoOfPainting {
	"Oh, that's right!

	As a memento of me painting your
	POKéMON, please take this."
}

text LilycoveCity_ContestLobby_Text_ReceivedARibbon {
	"{PLAYER} received a RIBBON."
}

text LilycoveCity_ContestLobby_Text_PutTheRibbonOnMon {
	"{PLAYER} put the RIBBON on
	{STR_VAR_1}."
}

text LilycoveCity_ContestLobby_Text_OkaySeeYou {
	"Okay, see you!"
}

text LilycoveCity_ContestLobby_Text_TakeHomeButIdLikeToTakeToMuseum {
	"Oh… Then, I guess I'll just take
	this home with me…

	But, you know, I would like to take
	this to the art museum… Okay?"
}

text LilycoveCity_ContestLobby_Text_FineThatsTheWayItIs {
	"Oh, fine, that's the way it is.
	I will hang this in my own house.

	I'll just have to try harder next time.
	Well, be seeing you."
}

text LilycoveCity_ContestLobby_Text_MasterRankHereICome {
	"Hoo, boy… Master Rank CONTESTS,
	here I come.

	The world will know that my dearest
	POKéMON is the cutest being in all
	existence. The time has come!
	Uheheheh."
}

text LilycoveCity_ContestLobby_Text_WholeVarietyOfPokemonHere {
	"You can see a whole variety of
	POKéMON here.

	That's why I make this place a regular
	part of my daily stroll."
}

text LilycoveCity_ContestLobby_Text_ContestFeastForEyes {
	"Wow, coming out to a CONTEST is
	a feast for these eyes!

	Would you look at all the POKéMON
	that just scream to be painted?"
}

text LilycoveCity_ContestLobby_Text_ToughContestIsExtreme {
	"The TOUGHNESS CONTEST is like
	extreme, man!

	Those muscular appeals…
	Cascading sweat… I swoon!"
}

text LilycoveCity_ContestLobby_Text_LavishedCareOnMon {
	"Day in and day out, I lavished my care
	on this POKéMON.

	Its condition is peaking.
	Today, victory is mine!"
}

text LilycoveCity_ContestLobby_Text_MadePokeblocksWithFamily {
	"I made {POKEBLOCK}S with Mom, Dad, and
	Big Sister. They turned out great!

	I bet you can make smoother, better
	{POKEBLOCK}S if you have more people."
}
