mapscripts VerdanturfTown_WandasHouse_MapScripts {}

script VerdanturfTown_WandasHouse_EventScript_Wally {
    lock_faceplayer
    if (flag(FLAG_WALLY_SPEECH)) {
        msgbox(VerdanturfTown_WandasHouse_Text_StrongerSpeechShort, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(VerdanturfTown_WandasHouse_Text_StrongerSpeech, MSGBOX_DEFAULT)
    setflag(FLAG_WALLY_SPEECH)
    release_end
}

script VerdanturfTown_WandasHouse_EventScript_WallysUncle {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_WALLY_VICTORY_ROAD)) {
        msgbox(VerdanturfTown_WandasHouse_Text_WallyGoneThatFar, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_DEFEATED_LAVARIDGE_GYM)) {
        msgbox(VerdanturfTown_WandasHouse_Text_WallySlippedOff, MSGBOX_DEFAULT)
    }
	else {
		msgbox(VerdanturfTown_WandasHouse_Text_WallysNextDoor, MSGBOX_DEFAULT)
	}
    release_end
}

script VerdanturfTown_WandasHouse_EventScript_WandasBoyfriend {
    msgbox(VerdanturfTown_WandasHouse_Text_CanSeeGirlfriendEveryDay, MSGBOX_NPC)
    end
}

script VerdanturfTown_WandasHouse_EventScript_Wanda {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_WALLY_MAUVILLE) && !flag(FLAG_DEFEATED_LAVARIDGE_GYM)) {
        msgbox(VerdanturfTown_WandasHouse_Text_MeetWanda, MSGBOX_DEFAULT)
    } else {
		msgbox(VerdanturfTown_WandasHouse_Text_DontWorryAboutWally, MSGBOX_DEFAULT)
	}
    release_end
}

script VerdanturfTown_WandasHouse_EventScript_WallysAunt {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_WALLY_VICTORY_ROAD)) {
        msgbox(VerdanturfTown_WandasHouse_Text_WallyWasInEverGrande, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_DEFEATED_LAVARIDGE_GYM)) {
        msgbox(VerdanturfTown_WandasHouse_Text_IfAnythingHappenedToWally, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_RUSTURF_TUNNEL_OPENED)) {
        msgbox(VerdanturfTown_WandasHouse_Text_DaughtersBoyfriendWasDigging, MSGBOX_DEFAULT)
    }
	else {
		msgbox(VerdanturfTown_WandasHouse_Text_DaughtersBoyfriendDriven, MSGBOX_DEFAULT)
	}
    release_end
}

text VerdanturfTown_WandasHouse_Text_StrongerSpeech {
	"{SPEAKER NAME_WALLY}I lost to you, {PLAYER}, but I'm
	not feeling down anymore.

	Because I have a new purpose in life.
	Together with my RALTS, I'm going
	to challenge POKéMON GYMS and become
	a great TRAINER.

	Please watch me, {PLAYER}.
	I'm going to be stronger than you.

	When I do, I'm going to challenge you
	to another battle."
}

text VerdanturfTown_WandasHouse_Text_StrongerSpeechShort {
	"{SPEAKER NAME_WALLY}Please watch me, {PLAYER}.
	I'm going to get stronger than you.

	When I do, I'm going to challenge you
	to another battle."
}

text VerdanturfTown_WandasHouse_Text_WallysNextDoor {
	"{SPEAKER NAME_WADE}Oh! {PLAYER}{KUN}!
	WALLY's next door.

	But, boy, there's something I have to
	tell you.

	This natural environment is doing
	wonders for WALLY's health.

	Maybe it's not just the environment.
	It could be POKéMON that are giving
	the boy hope."
}

text VerdanturfTown_WandasHouse_Text_WallySlippedOff {
	"WALLY's gone away…
	He slipped off on his own…"
}

text VerdanturfTown_WandasHouse_Text_WallyGoneThatFar {
	"{SPEAKER NAME_WADE}Is that right?
	WALLY's gone away that far all by
	himself…

	Well, I have to give him credit--he is
	my little brother's son."
}

text VerdanturfTown_WandasHouse_Text_MeetWanda {
	"{SPEAKER NAME_WANDA}You are?
	Oh, right, I get it!

	You're the {PLAYER} who WALLY was
	telling me about.

	I'm WALLY's cousin.
	Glad to meet you!

	I think WALLY's become a lot more lively
	and healthy since he came here."
}

text VerdanturfTown_WandasHouse_Text_DontWorryAboutWally {
	"{SPEAKER NAME_WANDA}Don't worry about WALLY.
	He'll be just fine.

	I know my little cousin, and he has
	POKéMON with him, too."
}

text VerdanturfTown_WandasHouse_Text_CanSeeGirlfriendEveryDay {
	"Thanks to you, I can see my girlfriend
	every day.
	Happy? You bet I am!"
}

text VerdanturfTown_WandasHouse_Text_DaughtersBoyfriendDriven {
	"My daughter's boyfriend is a very
	driven and passionate sort of person.

	He's been digging a tunnel nonstop
	just so he can see my daughter.

	My daughter's a little concerned,
	so she goes out to the tunnel a lot."
}

text VerdanturfTown_WandasHouse_Text_DaughtersBoyfriendWasDigging {
	"It's amazing. My daughter's boyfriend
	was digging the tunnel by hand!

	It's so incredible!"
}

text VerdanturfTown_WandasHouse_Text_IfAnythingHappenedToWally {
	"If anything were to happen to WALLY,
	I would never be able to look his
	parents in PETALBURG in the eye…"
}

text VerdanturfTown_WandasHouse_Text_WallyWasInEverGrande {
	"WALLY was in EVER GRANDE?

	His parents in PETALBURG would be
	astonished to hear that!"
}
