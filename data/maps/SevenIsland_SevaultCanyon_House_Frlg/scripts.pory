const DID_CHANSEY_DANCE = FLAG_TEMP_2

mapscripts SevenIsland_SevaultCanyon_House_Frlg_MapScripts {}

script SevenIsland_SevaultCanyon_House_EventScript_ChanseyDanceMan {
    lock
    if (flag(DID_CHANSEY_DANCE)) {
        applymovement(LOCALID_CHANSEY_DANCE_MAN, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(SevenIsland_SevaultCanyon_House_Text_ChanseyDanceJoinIn)
		release_end
    }
    playbgm(MUS_SCHOOL, 0)
    applymovement(LOCALID_CHANSEY_DANCE_MAN, SevenIsland_SevaultCanyon_House_Movement_ChanseyDance)
    waitmovement(0)
    fadedefaultbgm
    delay(30)
    applymovement(LOCALID_CHANSEY_DANCE_MAN, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(SevenIsland_SevaultCanyon_House_Text_ChanseyDanceJoinIn)
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    msgbox(SevenIsland_SevaultCanyon_House_Text_WouldYouLikeToDance, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        textcolor(NPC_TEXT_COLOR_MALE)
		msgbox(SevenIsland_SevaultCanyon_House_Text_ComeOnDance)
		release_end
    }
    msgbox(SevenIsland_SevaultCanyon_House_Text_DancedChanseyDance)
    closemessage
    call(EventScript_RestorePrevTextColor)
    if (var(VAR_FACING) != DIR_SOUTH) {
        applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    	waitmovement(0)
    }
    delay(30)
    playbgm(MUS_SCHOOL, 0)
    applymovement(LOCALID_PLAYER, SevenIsland_SevaultCanyon_House_Movement_ChanseyDance)
    waitmovement(0)
    fadedefaultbgm
    delay(30)
    call(Common_EventScript_OutOfCenterPartyHeal)
    msgbox(SevenIsland_SevaultCanyon_House_Text_YoureAllChipperNow)
    setflag(DID_CHANSEY_DANCE)
    release_end
}

movement SevenIsland_SevaultCanyon_House_Movement_ChanseyDance {
    // moves(step_down,  delay_16,  step_down,  delay_16,  step_down,  delay_16,  step_down,  delay_16,  step_faster_right,  delay_4,  step_faster_up,  delay_4,  step_faster_left,  delay_4,  step_faster_down,  delay_4)
    step_down
    delay_16
    step_down
    delay_16
    step_down
    delay_16
    step_down
    delay_16
    step_faster_right
    delay_4
    step_faster_up
    delay_4
    step_faster_left
    delay_4
    step_faster_down
    delay_4
}

script SevenIsland_SevaultCanyon_House_EventScript_Chansey {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_CHANSEY, CRY_MODE_NORMAL)
    msgbox(SevenIsland_SevaultCanyon_House_Text_Chansey)
    waitmoncry
    release_end
}

text SevenIsland_SevaultCanyon_House_Text_ChanseyDanceJoinIn {
	"Dance, dance!
	CHANSEY Dance!

	You join in, too!
	Dance, dance!"
}

text SevenIsland_SevaultCanyon_House_Text_WouldYouLikeToDance {
	"Would you like to dance?"
}

text SevenIsland_SevaultCanyon_House_Text_ComeOnDance {
	"Come on, dance!"
}

text SevenIsland_SevaultCanyon_House_Text_DancedChanseyDance {
	"{PLAYER} danced the CHANSEY Dance!"
}

text SevenIsland_SevaultCanyon_House_Text_YoureAllChipperNow {
	"Ahahahaha!

	There, you're all chipper now!
	Lucky!"
}

text SevenIsland_SevaultCanyon_House_Text_Chansey {
	"CHANSEY: Chansi! Chansi!"
}
