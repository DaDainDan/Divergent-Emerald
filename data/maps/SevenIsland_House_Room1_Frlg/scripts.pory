const TRAINER_VISITING = VAR_TEMP_1

mapscripts SevenIsland_House_Room1_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        special(ValidateEReaderTrainer)
		if (var(VAR_RESULT) == 0) {
			setvar(TRAINER_VISITING, TRUE)
			setobjectxyperm(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN, 4, 2)
			setobjectmovementtype(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN, MOVEMENT_TYPE_FACE_DOWN)
			setmaplayoutindex(LAYOUT_SEVEN_ISLAND_HOUSE_ROOM1_DOOR_OPEN)
		}
		if (var(VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1) != 0) {
			setobjectxyperm(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN, 3, 2)
			setobjectmovementtype(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN, MOVEMENT_TYPE_FACE_RIGHT)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1, 1: SevenIsland_House_Room1_EventScript_OldWomanCommentOnBattle
    	VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1, 2: SevenIsland_House_Room1_EventScript_OldWomanCommentOnBattle
    	VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1, 3: SevenIsland_House_Room1_EventScript_OldWomanCommentOnBattle
    ]
}

script SevenIsland_House_Room1_EventScript_OldWomanCommentOnBattle {
    lockall
    textcolor(NPC_TEXT_COLOR_FEMALE)
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    applymovement(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN, moves(walk_right,  step_faster_down))
    waitmovement(0)
    copyobjectxytoperm(LOCALID_SEVEN_ISLAND_HOUSE_OLD_WOMAN)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
	switch (var(VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1)) {
		case 1: msgbox(SevenIsland_House_Room1_Text_AstoundingBattle)
		case 2: msgbox(SevenIsland_House_Room1_Text_FeelYourDisappointment)
		case 3: msgbox(SevenIsland_House_Room1_Text_DrawWasIt)
	}
    special(LoadPlayerParty)
    setvar(VAR_MAP_SCENE_SEVEN_ISLAND_HOUSE_ROOM1, 0)
    releaseall
    end
}

script SevenIsland_House_Room1_EventScript_OldWoman {
    lock_faceplayer
    special(ValidateEReaderTrainer)
    if (var(VAR_RESULT) == 1) {
        msgbox(SevenIsland_House_Room1_Text_OnlyEnjoymentWatchingBattles)
    	release_end
    }
    if (var(TRAINER_VISITING) == TRUE) {
        goto(SevenIsland_House_Room1_EventScript_TrainerVisiting)
    }
    msgbox(SevenIsland_House_Room1_Text_OnlyEnjoymentWatchingBattles)
    release_end
}

script SevenIsland_House_Room1_EventScript_TrainerVisiting {
    special(SavePlayerParty)
    special(BufferEReaderTrainerName)
    msgbox(SevenIsland_House_Room1_Text_ChallengeVisitingTrainer, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SevenIsland_House_Room1_EventScript_DeclineBattle)
    }
    msgbox(SevenIsland_House_Room1_Text_LimitThreeMonsPerSide)
    fadescreen(FADE_TO_BLACK)
    special(ChooseHalfPartyForBattle)
    if (var(VAR_RESULT) == 0) {
        goto(SevenIsland_House_Room1_EventScript_DeclineBattle)
    }
    msgbox(SevenIsland_House_Room1_Text_SaveProgressBeforeBattle, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SevenIsland_House_Room1_EventScript_DeclineBattle)
    }
    special(LoadPlayerParty)
    call(Common_EventScript_SaveGame)
    if (var(VAR_RESULT) == 0) {
        goto(SevenIsland_House_Room1_EventScript_DeclineBattle)
    }
    special(SavePlayerParty)
    special(ReducePlayerPartyToSelectedMons)
    msgbox(SevenIsland_House_Room1_Text_DontHoldAnythingBack)
    closemessage
	switch (var(VAR_FACING)) {
		case DIR_NORTH: 
			applymovement(VAR_LAST_TALKED, moves(walk_left,  step_faster_right))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_up * 2))
		case DIR_EAST:
			applymovement(VAR_LAST_TALKED, moves(walk_right,  step_faster_left))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_right,  walk_up))
		case DIR_WEST:
			applymovement(VAR_LAST_TALKED, moves(walk_left,  step_faster_right))
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_left,  walk_up))
	}
	waitmovement(0)
    warp(MAP_SEVEN_ISLAND_HOUSE_ROOM2, 3, 1)
    waitstate
    release_end
}

script SevenIsland_House_Room1_EventScript_DeclineBattle {
    special(LoadPlayerParty)
    msgbox(SevenIsland_House_Room1_Text_OhYouWontBattle)
    release_end
}

script SevenIsland_House_Room1_EventScript_Box {
    msgbox(SevenIsland_House_Room1_Text_SlightBreezeAroundBox, MSGBOX_SIGN)
    end
}

text SevenIsland_House_Room1_Text_OnlyEnjoymentWatchingBattles {
	"I may not look like much now,
	but when I was younger…

	I flew everywhere, challenging
	TRAINERS wherever I found them.

	Now, my only source of enjoyment
	is reminiscing about the past while
	watching battles."
}

text SevenIsland_House_Room1_Text_SlightBreezeAroundBox {
	"There is a slight breeze blowing
	around the box."
}

text SevenIsland_House_Room1_Text_ChallengeVisitingTrainer {
	"Ah!
	Welcome, my friend!

	Let me tell you something. There's
	a hidden room in the basement.

	A TRAINER named {STR_VAR_1} is
	waiting there now.

	Tell me, you did come to challenge
	{STR_VAR_1}, am I right?"
}

text SevenIsland_House_Room1_Text_OhYouWontBattle {
	"Oh…
	You won't battle…

	I see, I see.
	… …

	Well, perhaps if you change your
	mind, do come back."
}

text SevenIsland_House_Room1_Text_LimitThreeMonsPerSide {
	"Ah!
	You will battle for me?

	It was worth my time moving the
	box aside, then.

	… …
	But there is one slight problem.

	This hidden room is not built very
	sturdy.

	Can I get you to limit it to
	battles of three POKéMON per side?"
}

text SevenIsland_House_Room1_Text_SaveProgressBeforeBattle {
	"Fine! Before your battle, would
	you like to save your game?"
}

text SevenIsland_House_Room1_Text_DontHoldAnythingBack {
	"All right.
	Don't hold anything back!"
}

// Unused
text SevenIsland_House_Room1_Text_StrVar1_1 {
	"{STR_VAR_1}"
}

text SevenIsland_House_Room2_Text_MatchEndedUpDraw {
	"The match ended up a draw."
}

text SevenIsland_House_Room1_Text_DrawWasIt {
	"A draw, was it?

	However, let me say that it was
	a worthy spectacle.

	I'd say it was a wonderful battle
	with a real sense of depth!"
}

// Unused
text SevenIsland_House_Room1_Text_StrVar1_2 {
	"{STR_VAR_1}"
}

text SevenIsland_House_Room1_Text_AstoundingBattle {
	"Bravo!

	Bravo, indeed!
	What an astounding battle!

	It was so astounding, why, it keeps
	filling my eyes with tears!

	The thrust and parry of expertly
	used techniques!

	The clash of power upon power!

	Yes!
	It was sheer magnificence!"
}

// Unused
text SevenIsland_House_Room1_Text_StrVar1_3 {
	"{STR_VAR_1}"
}

text SevenIsland_House_Room1_Text_FeelYourDisappointment {
	"Too bad!
	I feel your disappointment.

	However, that disappointment is
	what will make you better.

	Use it, learn from it, and make it
	motivate you to seek greatness.

	Forget not this disappointment
	and redouble your training!"
}
