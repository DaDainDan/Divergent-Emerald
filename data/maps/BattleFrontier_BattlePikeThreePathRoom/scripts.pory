mapscripts BattleFrontier_BattlePikeThreePathRoom_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        // BattleFrontier_BattlePikeRoom_OnResume
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_CHALLENGE_STATUS, 0 {
			frontier_getstatus
			end
		}
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING {
			warp(MAP_BATTLE_FRONTIER_BATTLE_PIKE_LOBBY, 5, 6)
			waitstate
			end
		}
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_PAUSED: BattleFrontier_BattlePikeThreePathRoom_EventScript_ResumeChallenge
		VAR_TEMP_5, 0 {
			pike_sethintroom
			if (var(VAR_RESULT) == TRUE) {
				setvar(VAR_TEMP_5, 1)
			} else {
				setvar(VAR_TEMP_5, 255)
			}
			end
		}
		VAR_TEMP_5, 1 {
			applymovement(LOCALID_PIKE_HINT_GIVER, moves(walk_left * 2,  walk_down * 4))
			waitmovement(0)
			lockall
			msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_TerrifyingEvent, MSGBOX_DEFAULT)
			releaseall
			applymovement(LOCALID_PIKE_HINT_GIVER, moves(walk_up * 4,  walk_right * 2,  face_down))
			waitmovement(0)
			setvar(VAR_TEMP_5, 255)
			end
		}
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_4, 0 {
			setvar(VAR_TEMP_4, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script BattleFrontier_BattlePikeThreePathRoom_EventScript_ResumeChallenge {
    lockall
    message(BattleFrontier_BattlePikeThreePathRoom_Text_AwaitingReturnSaveBeforeResume)
    waitmessage
    pike_save(CHALLENGE_STATUS_SAVING)
    playse(SE_SAVE)
    waitse
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    special(SavePlayerParty)
    frontier_setpartyorder(FRONTIER_PARTY_SIZE)
    msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_PleaseEnjoyChallenge, MSGBOX_DEFAULT)
    closemessage
    releaseall
    frontier_settrainers
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 99)
    end
}

script BattleFrontier_BattlePikeThreePathRoom_EventScript_Attendant {
    frontier_get(FRONTIER_DATA_BATTLE_NUM) // Room number
	lock_faceplayer
    switch (var(VAR_RESULT)) {
        case 1: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom1, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom3, MSGBOX_DEFAULT)
        case 5: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom5, MSGBOX_DEFAULT)
        case 7: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom7, MSGBOX_DEFAULT)
        case 9: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom9, MSGBOX_DEFAULT)
        case 11: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom11, MSGBOX_DEFAULT)
        case 13: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_CurrentlyInRoom13, MSGBOX_DEFAULT)
    }
    msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_ContinueWithChallenge, MSGBOX_YESNO)
	if (var(VAR_RESULT) != YES) {
		msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_SaveChallengeAndQuit, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			frontier_saveparty
			message(BattleFrontier_BattlePikeThreePathRoom_Text_SavingYourData)
			waitmessage
			special(LoadPlayerParty)
			pike_save(CHALLENGE_STATUS_PAUSED)
			playse(SE_SAVE)
			waitse
			fadescreen(FADE_TO_BLACK)
			frontier_reset
			end
		} else {
			message(BattleFrontier_BattlePikeThreePathRoom_Text_RetireFromChallenge)
			waitmessage
			multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
			if (var(VAR_RESULT) == 0) {
				goto(BattleFrontier_BattlePike_EventScript_Retire)
			}
		}
	}
    release_end
}

script BattleFrontier_BattlePikeThreePathRoom_EventScript_HintGiver {
    pike_gethint
    if (var(VAR_RESULT) == PIKE_HINT_BRAIN) {
        lock_faceplayer
		msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_DreadfulPresence, MSGBOX_DEFAULT)
		release_end
    }
    lock_faceplayer
    msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_FindingItDifficultToChoose, MSGBOX_YESNO)
	if (var(VAR_RESULT) == NO) {
		msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_ApologizeForImpertinence, MSGBOX_DEFAULT)
	} else {
		pike_gethintroomid
		switch (var(VAR_RESULT)) {
			case PIKE_ROOM_LEFT: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_SomethingAboutLeftPath, MSGBOX_DEFAULT)
			case PIKE_ROOM_CENTER: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_SomethingAboutCenterPath, MSGBOX_DEFAULT)
			case PIKE_ROOM_RIGHT: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_SomethingAboutRightPath, MSGBOX_DEFAULT)
		}
		pike_gethint
		switch (var(VAR_RESULT)) {
			case PIKE_HINT_NOSTALGIA: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_WaveOfNostaliga, MSGBOX_DEFAULT)
			case PIKE_HINT_WHISPERING: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_HeardWhispering, MSGBOX_DEFAULT)
			case PIKE_HINT_POKEMON: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_AromaOfPokemon, MSGBOX_DEFAULT)
			case PIKE_HINT_PEOPLE: msgbox(BattleFrontier_BattlePikeThreePathRoom_Text_PresenceOfPeople, MSGBOX_DEFAULT)
		}
	}
	release_end
}

