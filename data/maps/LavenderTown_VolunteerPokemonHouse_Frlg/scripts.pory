mapscripts LavenderTown_VolunteerPokemonHouse_Frlg_MapScripts {}

script LavenderTown_VolunteerPokemonHouse_EventScript_MrFuji {
    lock_faceplayer
    if (flag(FLAG_GOT_POKE_FLUTE)) {
        msgbox(LavenderTown_VolunteerPokemonHouse_Text_HasPokeFluteHelpedYou)
    	release_end
    }
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_IdLikeYouToHaveThis)
    if (checkitemspace(ITEM_POKE_FLUTE) == FALSE) {
        msgbox(LavenderTown_VolunteerPokemonHouse_Text_MustMakeRoomForThis)
    	release_end
    }
    setflag(FLAG_GOT_POKE_FLUTE)
    giveitem_msg(LavenderTown_VolunteerPokemonHouse_Text_ReceivedPokeFluteFromMrFuji, ITEM_POKE_FLUTE, 1, MUS_RG_OBTAIN_KEY_ITEM)
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_ExplainPokeFlute)
    release_end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_LittleGirl {
    lock_faceplayer
    famechecker(FAMECHECKER_MRFUJI, 0)
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_MrFujiLooksAfterOrphanedMons)
    release_end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_LittleBoy {
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_MonsNiceToHug, MSGBOX_NPC)
    end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_Youngster {
    lock_faceplayer
    if (flag(FLAG_RESCUED_MR_FUJI)) {
        msgbox(LavenderTown_VolunteerPokemonHouse_Text_MrFujiWasPrayingForCubonesMother)
    	release_end
    }
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_WhereDidMrFujiGo)
    release_end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_Nidorino {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_NIDORINO, CRY_MODE_NORMAL)
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_Nidorino)
    waitmoncry
    release_end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_Psyduck {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PSYDUCK, CRY_MODE_NORMAL)
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_Psyduck)
    waitmoncry
    release_end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_PokemonFanMagazine {
    lockall
    famechecker(FAMECHECKER_MRFUJI, 2)
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_GrandPrizeDrawingClipped)
    releaseall
    end
}

script LavenderTown_VolunteerPokemonHouse_EventScript_Bookshelf {
    msgbox(LavenderTown_VolunteerPokemonHouse_Text_PokemonMagazinesLineShelf, MSGBOX_SIGN)
    end
}

text LavenderTown_PokemonCenter_1F_Text_HearMrFujiNotFromAroundHere {
	"I recently moved to this town.

	I hear that MR. FUJI's not from
	these parts originally, either."
}

text LavenderTown_VolunteerPokemonHouse_Text_WhereDidMrFujiGo {
	"That's odd, MR. FUJI isn't here.
	Where'd he go?"
}

text LavenderTown_VolunteerPokemonHouse_Text_MrFujiWasPrayingForCubonesMother {
	"MR. FUJI had been praying alone
	for CUBONE's mother."
}

text LavenderTown_VolunteerPokemonHouse_Text_MrFujiLooksAfterOrphanedMons {
	"This is really MR. FUJI's house.

	He's really kind.

	He looks after abandoned and
	orphaned POKéMON."
}

text LavenderTown_VolunteerPokemonHouse_Text_MonsNiceToHug {
	"It's so warm!
	POKéMON are so nice to hug."
}

text LavenderTown_VolunteerPokemonHouse_Text_Nidorino {
	"NIDORINO: Gaoo!"
}

text LavenderTown_VolunteerPokemonHouse_Text_Psyduck {
	"PSYDUCK: Gwappa!"
}

text LavenderTown_VolunteerPokemonHouse_Text_IdLikeYouToHaveThis {
	"MR. FUJI: {PLAYER}…

	Your POKéDEX quest is one that
	requires strong dedication.

	Without deep love for POKéMON,
	your quest may fail.

	I'm not sure if this will help you,
	but I'd like you to have it."
}

text LavenderTown_VolunteerPokemonHouse_Text_ReceivedPokeFluteFromMrFuji {
	"{PLAYER} received a POKé FLUTE
	from MR. FUJI."
}

text LavenderTown_VolunteerPokemonHouse_Text_ExplainPokeFlute {
	"Upon hearing the POKé FLUTE,
	sleeping POKéMON will spring awake.

	Try using it on POKéMON that are
	sleeping obstacles."
}

text LavenderTown_VolunteerPokemonHouse_Text_MustMakeRoomForThis {
	"You must make room for this!"
}

text LavenderTown_VolunteerPokemonHouse_Text_HasPokeFluteHelpedYou {
	"MR. FUJI: Has my POKé FLUTE
	helped you?"
}

text LavenderTown_VolunteerPokemonHouse_Text_GrandPrizeDrawingClipped {
	"POKéMON FAN MAGAZINE
	Monthly Grand Prize Drawing!

	The application form is…

	Gone! It's been clipped out.
	Someone must have applied already."
}

text LavenderTown_VolunteerPokemonHouse_Text_PokemonMagazinesLineShelf {
	"POKéMON magazines line the shelf.

	POKéMON INSIDER…

	POKéMON FAN…"
}
