mapscripts FuchsiaCity_House1_Frlg_MapScripts {}

script FuchsiaCity_House1_EventScript_Woman {
    msgbox(FuchsiaCity_House1_Text_WardenIsOldHasFalseTeeth, MSGBOX_NPC)
    end
}

script FuchsiaCity_House1_EventScript_OldMan {
    lock_faceplayer
    famechecker(FAMECHECKER_BILL, 2)
    msgbox(FuchsiaCity_House1_Text_BillIsMyGrandson)
    release_end
}

script FuchsiaCity_House1_EventScript_LittleBoy {
    msgbox(FuchsiaCity_House1_Text_BillFilesHisOwnMonData, MSGBOX_NPC)
    end
}

text FuchsiaCity_House1_Text_WardenIsOldHasFalseTeeth {
	"The SAFARI ZONE's WARDEN is old, 
	but he's still very much active.

	All his teeth are false, though."
}

text FuchsiaCity_House1_Text_BillIsMyGrandson {
	"Hmm?
	You've met BILL?

	He's my grandson!

	He always liked collecting things,
	even as a child!"
}

text FuchsiaCity_House1_Text_BillFilesHisOwnMonData {
	"BILL files his own POKéMON data on
	his PC.

	Did he show you?"
}
