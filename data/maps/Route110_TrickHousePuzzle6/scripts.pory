mapscripts Route110_TrickHousePuzzle6_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        special(RotatingGate_InitPuzzle)
    	end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		// NOTE: This rotating gate puzzle makes use of VAR_TEMP_0 - VAR_TEMP_5
		VAR_TEMP_0, VAR_TEMP_0 {
			special(RotatingGate_InitPuzzleAndGraphics)
    		end
		}
    ]
}

script Route110_TrickHousePuzzle6_EventScript_Scroll {
    lockall
    if (var(VAR_TRICK_HOUSE_PUZZLE_6_STATE) == 0) {
        setvar(VAR_TRICK_HOUSE_PUZZLE_6_STATE, 1)
    	goto(Route110_TrickHousePuzzle_EventScript_FoundScroll)
    }
    goto(Route110_TrickHousePuzzle_EventScript_ReadScrollAgain)
    end
}

script Route110_TrickHousePuzzle6_EventScript_Sophia {
    trainerbattle_single(TRAINER_SOPHIA, Route110_TrickHousePuzzle6_Text_SophiaIntro, Route110_TrickHousePuzzle6_Text_SophiaDefeat)
    msgbox(Route110_TrickHousePuzzle6_Text_SophiaPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route110_TrickHousePuzzle6_EventScript_Benny {
    trainerbattle_single(TRAINER_BENNY, Route110_TrickHousePuzzle6_Text_BennyIntro, Route110_TrickHousePuzzle6_Text_BennyDefeat)
    msgbox(Route110_TrickHousePuzzle6_Text_BennyPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route110_TrickHousePuzzle6_EventScript_Sebastian {
    trainerbattle_single(TRAINER_SEBASTIAN, Route110_TrickHousePuzzle6_Text_SebastianIntro, Route110_TrickHousePuzzle6_Text_SebastianDefeat)
    msgbox(Route110_TrickHousePuzzle6_Text_SebastianPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text Route110_TrickHousePuzzle6_Text_WroteSecretCodeLockOpened {
	"{PLAYER} wrote down the secret code
	on the door.

	“TRICK MASTER is my life.”
	… … … … … … … …

	The lock clicked open!"
}

text Route110_TrickHousePuzzle6_Text_SophiaIntro {
	"When I heard there was a strange
	house, I had to check it out."
}

text Route110_TrickHousePuzzle6_Text_SophiaDefeat {
	"I've discovered a tough TRAINER!"
}

text Route110_TrickHousePuzzle6_Text_SophiaPostBattle {
	"I'm sure having a good time checking
	this place out.

	It's a challenge I've found worth
	repeating!"
}

text Route110_TrickHousePuzzle6_Text_BennyIntro {
	"Maybe I could get my BIRD POKéMON
	to fly over the wall…"
}

text Route110_TrickHousePuzzle6_Text_BennyDefeat {
	"Gwaaah! I blew it!"
}

text Route110_TrickHousePuzzle6_Text_BennyPostBattle {
	"Ehehehe… I guess I lost because
	I was trying to cheat."
}

text Route110_TrickHousePuzzle6_Text_SebastianIntro {
	"I'm getting dizzy from these rotating
	doors…"
}

text Route110_TrickHousePuzzle6_Text_SebastianDefeat {
	"Everything's spinning around and
	around. I can't take this anymore…"
}

text Route110_TrickHousePuzzle6_Text_SebastianPostBattle {
	"You don't seem to be affected at all.
	Or do you have your poker face on?"
}
