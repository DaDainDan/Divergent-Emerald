const REQUIRED_CAUGHT_MONS = 30

mapscripts Route11_EastEntrance_2F_Frlg_MapScripts {}

script Route11_EastEntrance_2F_EventScript_LeftBinoculars {
    lockall
    if (flag(FLAG_WOKE_UP_ROUTE_12_SNORLAX)) {
        msgbox(Route11_EastEntrance_2F_Text_WhatABreathtakingView)
    } else {
		msgbox(Route11_EastEntrance_2F_Text_BigMonAsleepOnRoad)
	}
    releaseall
    end
}

script Route11_EastEntrance_2F_EventScript_RightBinoculars {
    msgbox(Route11_EastEntrance_2F_Text_RockTunnelGoodRouteToLavender, MSGBOX_SIGN)
    end
}

script Route11_EastEntrance_2F_EventScript_Turner {
    lock_faceplayer
    setvar(VAR_0x8008, INGAME_TRADE_NIDORINOA)
    call(EventScript_GetInGameTradeSpeciesInfo)
    if (flag(FLAG_DID_NINA_TRADE)) {
        msgbox(Trade_Text_IsntMyOldMonGreat)
    	release_end
    }
    msgbox(Trade_Text_LookingForMonWannaTradeForMon, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(Route11_EastEntrance_2F_EventScript_DeclineTrade)
    }
    call(EventScript_ChooseMonForInGameTrade)
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(Route11_EastEntrance_2F_EventScript_DeclineTrade)
    }
    call(EventScript_GetInGameTradeSpecies)
    if (var(VAR_RESULT) != VAR_0x8009) {
        bufferspeciesname(STR_VAR_1, VAR_0x8009)
		msgbox(Trade_Text_WhatThatsNoMon)
		release_end
    }
    call(EventScript_DoInGameTrade)
    msgbox(Trade_Text_HeyThanks)
    setflag(FLAG_DID_NINA_TRADE)
    release_end
}

script Route11_EastEntrance_2F_EventScript_DeclineTrade {
    msgbox(Trade_Text_AwwOhWell)
    release_end
}

script Route11_EastEntrance_2F_EventScript_Aide {
    lock_faceplayer
    call(Route11_EastEntrance_2F_EventScript_GetAideRequestInfo)
    if (flag(FLAG_GOT_ITEMFINDER)) {
        msgbox(Route11_EastEntrance_2F_Text_ExplainItemfinder)
    	release_end
    }
    msgbox(Route11_EastEntrance_2F_Text_GiveItemfinderIfCaught30, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(Aide_EventScript_DeclineCheckMons)
    }
    setvar(VAR_0x8004, 0)
    specialvar(VAR_RESULT, GetFrlgPokedexCount)
    buffernumberstring(STR_VAR_3, VAR_0x8006)
    call(Route11_EastEntrance_2F_EventScript_GetAideRequestInfo)
    if (var(VAR_0x8006) < REQUIRED_CAUGHT_MONS) {
        goto(Aide_EventScript_HaventCaughtEnough)
    }
    msgbox(Route11_EastEntrance_2F_Text_GreatHereYouGo)
    if (checkitemspace(ITEM_ITEMFINDER) == FALSE) {
        goto(Aide_EventScript_NoRoomForItem)
    }
    giveitem_msg(Route11_EastEntrance_2F_Text_ReceivedItemfinderFromAide, ITEM_ITEMFINDER)
    setflag(FLAG_GOT_ITEMFINDER)
    msgbox(Route11_EastEntrance_2F_Text_ExplainItemfinder)
    release_end
}

script Route11_EastEntrance_2F_EventScript_GetAideRequestInfo {
    buffernumberstring(STR_VAR_1, REQUIRED_CAUGHT_MONS)
    bufferitemname(STR_VAR_2, ITEM_ITEMFINDER)
    return
}

text Route11_EastEntrance_2F_Text_GiveItemfinderIfCaught30 {
	"Hi! Remember me?
	I'm one of PROF. OAK's AIDES.

	If your POKéDEX has complete data
	on {STR_VAR_1} species, I'm supposed to
	give you a reward.

	PROF. OAK entrusted me with the
	{STR_VAR_2} for you.

	So, {PLAYER}, let me ask you.

	Have you gathered data on at least
	{STR_VAR_1} kinds of POKéMON?"
}

text Route11_EastEntrance_2F_Text_GreatHereYouGo {
	"Great! You have caught or owned
	{STR_VAR_3} kinds of POKéMON!

	Congratulations!
	Here you go!"
}

text Route11_EastEntrance_2F_Text_ReceivedItemfinderFromAide {
	"{PLAYER} received the {STR_VAR_2}
	from the AIDE."
}

text Route11_EastEntrance_2F_Text_ExplainItemfinder {
	"There are items on the ground that
	may be hidden from view.

	Use the ITEMFINDER to detect any
	hidden items close to you.

	The machine is a bit limited.
	It can't pinpoint item locations.

	What it does is show the direction
	where the item is.

	Use it to get your bearings, then
	search the suspect area by hand."
}

text Route11_EastEntrance_2F_Text_BigMonAsleepOnRoad {
	"Let's see what the binoculars have
	to show…

	A big POKéMON is asleep on a road!"
}

text Route11_EastEntrance_2F_Text_WhatABreathtakingView {
	"Let's see what the binoculars have
	to show…

	What a breathtaking view!"
}

text Route11_EastEntrance_2F_Text_RockTunnelGoodRouteToLavender {
	"Let's see what the binoculars have
	to show…

	To get to LAVENDER TOWN from
	CERULEAN CITY…

	ROCK TUNNEL appears to be a good
	route to take."
}
