mapscripts SootopolisCity_House3_MapScripts {}

script SootopolisCity_House3_EventScript_Woman {
    lock_faceplayer
    msgbox(SootopolisCity_House3_Text_JuanHasManyFansDoYou, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(SootopolisCity_House3_Text_YouMustBePrettyStrong, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_House3_Text_LonesomeTryWorkingHarder, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_House3_EventScript_Girl {
    msgbox(SootopolisCity_House3_Text_TrainerFanClubWasWild, MSGBOX_NPC)
    end
}

text SootopolisCity_House3_Text_JuanHasManyFansDoYou {
	"You're a POKéMON TRAINER, aren't you?

	SOOTOPOLIS's JUAN has many fans.
	Even more than his student WALLACE!

	Do you have any?"
}

text SootopolisCity_House3_Text_YouMustBePrettyStrong {
	"Oh, then you must be pretty strong."
}

text SootopolisCity_House3_Text_LonesomeTryWorkingHarder {
	"Oh, dear…
	That's a little lonesome.

	Try working a little harder to get
	a fan following."
}

text SootopolisCity_House3_Text_TrainerFanClubWasWild {
	"Dedicated fans come over from even
	outside of HOENN.

	It was really wild when I went to the
	TRAINER FAN CLUB in LILYCOVE."
}
