script SaffronCity_Gym_EventScript_GymGuy {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_SABRINA)) {
        msgbox(SaffronCity_Gym_Text_GymGuyPostVictory)
    	release_end
    }
    msgbox(SaffronCity_Gym_Text_GymGuyAdvice)
    release_end
}

script SaffronCity_Gym_EventScript_GymStatue {
    lockall
    if (flag(FLAG_BADGE06_GET)) {
        msgbox(SaffronCity_Gym_Text_GymStatuePlayerWon)
    } else {
		msgbox(SaffronCity_Gym_Text_GymStatue)
	}
    releaseall
    end
}

text SaffronCity_Gym_Text_SabrinaIntro {
	"I had a vision of your arrival.

	I have had psychic powers since
	I was a child.

	It started when a spoon I
	carelessly tossed, bent.

	I dislike battling, but if you wish,
	I will show you my powers!{PLAY_BGM}{MUS_RG_ENCOUNTER_GYM_LEADER}"
}

text SaffronCity_Gym_Text_SabrinaDefeat {
	"This loss shocks me!
	But, a loss is a loss.

	I admit, I didn't work hard enough
	to win.

	Your victory has earned you the
	MARSHBADGE."
}

text SaffronCity_Gym_Text_SabrinaPostBattle {
	"Psychic power isn't something that
	only a few people have.

	Everyone has psychic power.
	People just don't realize it."
}

text SaffronCity_Gym_Text_ExplainMarshBadgeTakeThis {
	"The MARSHBADGE makes POKéMON up
	to Lv. 70 obey you.

	Stronger POKéMON will become wild,
	ignoring your orders in battle.

	Just don't raise your POKéMON too
	much to avoid that problem.

	Wait, please take this TM with you."
}

text SaffronCity_Gym_Text_ReceivedTM04FromSabrina {
	"{PLAYER} received TM04 from
	SABRINA."
}

text SaffronCity_Gym_Text_ExplainTM04 {
	"TM04 is CALM MIND.

	It makes the POKéMON concentrate
	to raise both SP. ATK and SP. DEF."
}

text SaffronCity_Gym_Text_BagFullOfOtherItems {
	"Your BAG is full of other items."
}

text SaffronCity_Gym_Text_AmandaIntro {
	"SABRINA is far younger than I,
	but she has earned my respect."
}

text SaffronCity_Gym_Text_AmandaDefeat {
	"Not good enough!"
}

text SaffronCity_Gym_Text_AmandaPostBattle {
	"In a battle of equals, the one
	with the stronger will wins.

	If you wish to beat SABRINA, focus
	and will yourself to victory."
}

text SaffronCity_Gym_Text_JohanIntro {
	"Does our unseen power scare you?"
}

text SaffronCity_Gym_Text_JohanDefeat {
	"I never foresaw this!"
}

text SaffronCity_Gym_Text_JohanPostBattle {
	"PSYCHIC POKéMON fear only ghosts
	and bugs!"
}

text SaffronCity_Gym_Text_StacyIntro {
	"POKéMON take on the appearance of
	their TRAINERS.

	Your POKéMON must be tough, then!"
}

text SaffronCity_Gym_Text_StacyDefeat {
	"I knew it!"
}

text SaffronCity_Gym_Text_StacyPostBattle {
	"I have much to learn still…

	I must master PSYCHIC and teach it
	to my POKéMON…"
}

text SaffronCity_Gym_Text_TyronIntro {
	"You understand, don't you?

	That power alone isn't enough to
	win in the world of POKéMON?"
}

text SaffronCity_Gym_Text_TyronDefeat {
	"I don't believe this!"
}

text SaffronCity_Gym_Text_TyronPostBattle {
	"SABRINA just wiped out the KARATE
	MASTER next door."
}

text SaffronCity_Gym_Text_TashaIntro {
	"You and I, our POKéMON shall
	battle!"
}

text SaffronCity_Gym_Text_TashaDefeat {
	"I lost after all!"
}

text SaffronCity_Gym_Text_TashaPostBattle {
	"I knew that this was going to take
	place."
}

text SaffronCity_Gym_Text_CameronIntro {
	"SABRINA is young, but she's also
	our highly skilled LEADER.

	You won't reach her easily!"
}

text SaffronCity_Gym_Text_CameronDefeat {
	"Ow!
	Down and out!"
}

text SaffronCity_Gym_Text_CameronPostBattle {
	"There used to be two POKéMON GYMS
	in SAFFRON.

	The FIGHTING DOJO next door lost
	its GYM status, though.

	We simply creamed them when we
	decided to have just one GYM."
}

text SaffronCity_Gym_Text_PrestonIntro {
	"SAFFRON POKéMON GYM is famous for
	training psychics.

	You want to see SABRINA, don't
	you? I can tell!"
}

text SaffronCity_Gym_Text_PrestonDefeat {
	"Arrrgh!"
}

text SaffronCity_Gym_Text_PrestonPostBattle {
	"That's right! I used telepathy to
	read your mind!"
}

text SaffronCity_Gym_Text_GymGuyAdvice {
	"Yo!
	Champ in the making!

	SABRINA's POKéMON use psychic
	power instead of force.

	FIGHTING POKéMON are especially
	weak against PSYCHIC POKéMON.

	They'll get destroyed before they
	can even aim a punch!"
}

text SaffronCity_Gym_Text_GymGuyPostVictory {
	"Psychic power, huh?

	If I had that, I'd make a bundle
	at the slots!"
}

text SaffronCity_Gym_Text_GymStatue {
	"SAFFRON POKéMON GYM
	LEADER: SABRINA

	WINNING TRAINERS:
	{RIVAL}"
}

text SaffronCity_Gym_Text_GymStatuePlayerWon {
	"SAFFRON POKéMON GYM
	LEADER: SABRINA

	WINNING TRAINERS:
	{RIVAL}, {PLAYER}"
}
