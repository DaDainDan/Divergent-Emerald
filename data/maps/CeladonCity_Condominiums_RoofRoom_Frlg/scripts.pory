mapscripts CeladonCity_Condominiums_RoofRoom_Frlg_MapScripts {}

script CeladonCity_Condominiums_RoofRoom_EventScript_BlackBelt {
    msgbox(CeladonCity_Condominiums_RoofRoom_Text_TheresNothingIDontKnow, MSGBOX_NPC)
    end
}

script CeladonCity_Condominiums_RoofRoom_EventScript_EeveeBall {
    lock_faceplayer
    setvar(VAR_TEMP_1, SPECIES_EEVEE)
    if (givemon(SPECIES_EEVEE, 25) == MON_CANT_GIVE) {
		goto(Common_EventScript_NoMoreRoomForPokemon)
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	removeobject(LOCALID_EEVEE_POKEBALL)
    playfanfare(MUS_LEVEL_UP)
    message(CeladonCity_Condominiums_RoofRoom_Text_ObtainedAnEevee)
    waitmessage
    waitfanfare
    bufferspeciesname(STR_VAR_1, SPECIES_EEVEE)
    msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_GetGiftMonPartySlot)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
    setflag(FLAG_GOT_EEVEE)
    release_end
}

script CeladonCity_Condominiums_RoofRoom_EventScript_TMsPamphlet {
    msgbox(CeladonCity_Condominiums_RoofRoom_Text_PamphletOnTMs, MSGBOX_SIGN)
    end
}

script CeladonCity_Condominiums_RoofRoom_EventScript_Blackboard {
    lockall
    msgbox(CeladonCity_Condominiums_RoofRoom_Text_WirelessAdapterLecture)
	setvar(VAR_0x8004, 4)
    goto(CeladonCity_Condominiums_RoofRoom_EventScript_ReadAnotherHeading)
    end
}

script CeladonCity_Condominiums_RoofRoom_EventScript_ReadAnotherHeading {
    message(CeladonCity_Condominiums_RoofRoom_Text_ReadWhichHeading)
    waitmessage
    multichoice(0, 0, MULTI_LINKED_DIRECT_UNION, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(CeladonCity_Condominiums_RoofRoom_Text_ExplainWirelessClub)
        case 1: msgbox(CeladonCity_Condominiums_RoofRoom_Text_ExplainDirectCorner)
        case 2: msgbox(CeladonCity_Condominiums_RoofRoom_Text_ExplainUnionRoom)
        case 3:
        case MULTI_B_PRESSED:
			releaseall
    		end
    }
    goto(CeladonCity_Condominiums_RoofRoom_EventScript_ReadAnotherHeading)
    end
}

text CeladonCity_Condominiums_RoofRoom_Text_TheresNothingIDontKnow {
	"There is nothing that I don't know,
	like I wrote on the blackboard.

	I know about the world of POKéMON
	in your GAME BOY ADVANCE!

	Get together with your friends and
	enjoy trading POKéMON!"
}

text CeladonCity_Condominiums_RoofRoom_Text_ObtainedAnEevee {
	"{PLAYER} obtained an EEVEE!"
}

text CeladonCity_Condominiums_RoofRoom_Text_BoxIsFull {
	"ポケモンが　いっぱいだ
	ボックスを　かえて　きなさい"
}

text CeladonCity_Condominiums_RoofRoom_Text_WirelessAdapterLecture {
	"POKéMON Lecture

	Playing with the Wireless Adapter"
}

text CeladonCity_Condominiums_RoofRoom_Text_ReadWhichHeading {
	"Which heading do you want to read?"
}

text CeladonCity_Condominiums_RoofRoom_Text_ExplainWirelessClub {
	"The POKéMON WIRELESS CLUB is
	upstairs at any POKéMON CENTER.

	Visit one to link up with friend(s)
	using your Wireless Adapter."
}

text CeladonCity_Condominiums_RoofRoom_Text_ExplainDirectCorner {
	"To link only with a friend, go to
	the DIRECT CORNER.

	It is the right counter at the
	POKéMON WIRELESS CLUB.

	Go into the TRADE CORNER or the
	COLOSSEUM with your friend."
}

text CeladonCity_Condominiums_RoofRoom_Text_ExplainUnionRoom {
	"To link and communicate with
	anyone, go to the UNION ROOM.

	It is the left counter at the
	POKéMON WIRELESS CLUB.

	Go to the UNION ROOM and enjoy
	meeting other TRAINERS."
}

text CeladonCity_Condominiums_RoofRoom_Text_PamphletOnTMs {
	"It's a pamphlet on TMs.

	… …

	There are fifty TMs in all.

	There are also seven HMs that
	can be used repeatedly.

	SILPH CO."
}
