mapscripts FiveIsland_ResortGorgeous_Frlg_MapScripts {
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_MAP_SCENE_FIVE_ISLAND_RESORT_GORGEOUS, 1 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_FIVE_ISLAND_RESORT_GORGEOUS, 1: FiveIsland_ResortGorgeous_EventScript_SelphyReturnHomeScene
    ]
}

script FiveIsland_ResortGorgeous_EventScript_SelphyReturnHomeScene {
    lockall
    textcolor(NPC_TEXT_COLOR_FEMALE)
    msgbox(FiveIsland_ResortGorgeous_Text_SelphyThanksYouMayGoNow)
    closemessage
    applymovement(LOCALID_RESORT_GORGEOUS_SELPHY, Common_Movement_StepFasterUp)
    waitmovement(0)
    opendoor(39, 8)
    waitdooranim
    applymovement(LOCALID_RESORT_GORGEOUS_SELPHY, moves(walk_up,  set_invisible))
    waitmovement(0)
    closedoor(39, 8)
    waitdooranim
    removeobject(LOCALID_RESORT_GORGEOUS_SELPHY)
    clearflag(FLAG_HIDE_RESORT_GORGEOUS_INSIDE_SELPHY)
    setvar(VAR_MAP_SCENE_FIVE_ISLAND_RESORT_GORGEOUS, 2)
    releaseall
    end
}

script FiveIsland_ResortGorgeous_EventScript_SelphysHouseSign {
    msgbox(FiveIsland_ResortGorgeous_Text_SelphysHouse, MSGBOX_SIGN)
    end
}

text FiveIsland_ResortGorgeous_Text_DaisyIntro {
	"With these hands, I will create
	my victory!"
}

text FiveIsland_ResortGorgeous_Text_DaisyDefeat {
	"The shame of this…
	I'm red-faced…"
}

text FiveIsland_ResortGorgeous_Text_DaisyPostBattle {
	"Uh-oh, my paint tubes have
	scattered everywhere!"
}

text FiveIsland_ResortGorgeous_Text_CelinaIntro {
	"Excuse me!
	I'm trying to paint.
	Please keep out of my sight!"
}

text FiveIsland_ResortGorgeous_Text_CelinaDefeat {
	"This loss…
	I feel like I'm whiting out…"
}

text FiveIsland_ResortGorgeous_Text_CelinaPostBattle {
	"GILLIAN?
	Please tilt your head slightly…
	There! That's the look I want!"
}

text FiveIsland_ResortGorgeous_Text_RaynaIntro {
	"Hmm…
	The angle, it is not quite there…"
}

text FiveIsland_ResortGorgeous_Text_RaynaDefeat {
	"Oh…
	My feelings, they are blue…"
}

text FiveIsland_ResortGorgeous_Text_RaynaPostBattle {
	"The sky and the sea…
	They are so fickle.

	Their changing expressions make
	them difficult to capture."
}

text FiveIsland_ResortGorgeous_Text_JackiIntro {
	"I am visiting my friend's retreat,
	if you must know."
}

text FiveIsland_ResortGorgeous_Text_JackiDefeat {
	"Oh, my, so strong."
}

text FiveIsland_ResortGorgeous_Text_JackiPostBattle {
	"I find it pleasurable to leisurely
	battle in the gentle sea breeze."
}

text FiveIsland_ResortGorgeous_Text_GillianIntro {
	"I'm thinking of having a pool
	made specially for POKéMON."
}

text FiveIsland_ResortGorgeous_Text_GillianDefeat {
	"Oh, my goodness gracious!"
}

text FiveIsland_ResortGorgeous_Text_GillianPostBattle {
	"A pool would be nice, but I must
	say, a sun-room may be sublime."
}

text FiveIsland_ResortGorgeous_Text_DestinIntro {
	"I'm a good runner.
	I'm really fast!"
}

text FiveIsland_ResortGorgeous_Text_DestinDefeat {
	"Oops!
	I rushed things!"
}

text FiveIsland_ResortGorgeous_Text_DestinPostBattle {
	"When I run with the wind, it feels
	like I could fly!"
}

text FiveIsland_ResortGorgeous_Text_TobyIntro {
	"I say, this marine life here at
	this resort agrees with me."
}

text FiveIsland_ResortGorgeous_Text_TobyDefeat {
	"That's a shocker!
	You must be joking."
}

text FiveIsland_ResortGorgeous_Text_TobyPostBattle {
	"Getting so serious over this…
	How nonsensical."
}

text FiveIsland_ResortGorgeous_Text_SelphyThanksYouMayGoNow {
	"SELPHY: Thank you.

	You may go now."
}

text FiveIsland_ResortGorgeous_Text_SelphysHouse {
	"SELPHY'S HOUSE"
}
