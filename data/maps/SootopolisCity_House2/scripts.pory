mapscripts SootopolisCity_House2_MapScripts {}

script SootopolisCity_House2_EventScript_ExpertF {
    lock_faceplayer
    msgbox(SootopolisCity_House2_Text_DidYouKnowAboutMtPyreOrbs, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(SootopolisCity_House2_Text_YesTwoOrbsSideBySide, MSGBOX_DEFAULT)
    } else {
		msgbox(SootopolisCity_House2_Text_OughtToVisitAndSee, MSGBOX_DEFAULT)
	}
    release_end
}

text SootopolisCity_House2_Text_DidYouKnowAboutMtPyreOrbs {
	"MT. PYRE…

	At its peak are two orbs placed side
	by side. Did you know?"
}

text SootopolisCity_House2_Text_YesTwoOrbsSideBySide {
	"Yes, two orbs side by side…

	The sight of them together…
	It is somehow soothing…"
}

text SootopolisCity_House2_Text_OughtToVisitAndSee {
	"Is that so?
	Perhaps you ought to visit and see…"
}
