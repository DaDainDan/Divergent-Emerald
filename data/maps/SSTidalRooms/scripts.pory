script SSTidalRooms_EventScript_Naomi {
    trainerbattle_single(TRAINER_NAOMI, SSTidalRooms_Text_NaomiIntro, SSTidalRooms_Text_NaomiDefeat)
    msgbox(SSTidalRooms_Text_NaomiPostBattle, MSGBOX_AUTOCLOSE)
