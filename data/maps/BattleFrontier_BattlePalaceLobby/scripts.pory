mapscripts BattleFrontier_BattlePalaceLobby_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_CHALLENGE_STATUS, 0 {
			frontier_getstatus
			end
		}
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING: BattleFrontier_BattlePalaceLobby_EventScript_QuitWithoutSaving
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_PAUSED: BattleFrontier_BattlePalaceLobby_EventScript_ResumeChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_WON: BattleFrontier_BattlePalaceLobby_EventScript_WonChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST: BattleFrontier_BattlePalaceLobby_EventScript_LostChallenge
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script BattleFrontier_BattlePalaceLobby_EventScript_QuitWithoutSaving {
    lockall
    msgbox(BattleFrontier_BattlePalaceLobby_Text_FailedToSaveBeforeEndingChallenge, MSGBOX_DEFAULT)
    closemessage
    palace_set(PALACE_DATA_WIN_STREAK, 0)
    palace_set(PALACE_DATA_WIN_STREAK_ACTIVE, FALSE)
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    releaseall
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_WonChallenge {
    lockall
    frontier_isbrain
    if (var(VAR_RESULT) == TRUE) {
        msgbox(BattleFrontier_BattlePalaceLobby_Text_ToDefeatMavenAnd7Trainers, MSGBOX_DEFAULT)
    } else {
		msgbox(BattleFrontier_BattlePalaceLobby_Text_FirmTrueBondsFor7WinStreak, MSGBOX_DEFAULT)
	}
    msgbox(BattleFrontier_BattlePalaceLobby_Text_PresentYouWithBattlePoints, MSGBOX_DEFAULT)
    frontier_givepoints
    msgbox(BattleFrontier_Text_ObtainedXBattlePoints, MSGBOX_GETPOINTS)
    message(BattleFrontier_BattlePalaceLobby_Text_FeatWillBeRecorded)
    waitmessage
    goto(BattleFrontier_BattlePalaceLobby_EventScript_ChallengeEnded)
	end
}

script BattleFrontier_BattlePalaceLobby_EventScript_LostChallenge {
    lockall
    message(BattleFrontier_BattlePalaceLobby_Text_ResultsWillBeRecorded)
    waitmessage
    palace_set(PALACE_DATA_WIN_STREAK_ACTIVE, FALSE)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_ChallengeEnded)
	end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ChallengeEnded {
	frontier_checkairshow
    special(LoadPlayerParty)
    special(HealPlayerParty)
    callnative(UpdateFollowingPokemon)
    palace_save(0)
    playse(SE_SAVE)
    waitse
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == FALSE) {
        message(BattleFrontier_BattlePalaceLobby_Text_LikeToRecordMatch)
		waitmessage
		multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
		if (var(VAR_RESULT) == 0) {
			call(BattleFrontier_EventScript_SaveBattle)
		}
    }
    msgbox(BattleFrontier_BattlePalaceLobby_Text_ReturnWhenFortified, MSGBOX_DEFAULT)
    closemessage
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    releaseall
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ResumeChallenge {
    lockall
    msgbox(BattleFrontier_BattlePalaceLobby_Text_WeHaveBeenWaiting, MSGBOX_DEFAULT)
    message(BattleFrontier_BattlePalaceLobby_Text_MustSaveBeforeChallenge)
    waitmessage
    palace_save(CHALLENGE_STATUS_SAVING)
    playse(SE_SAVE)
    waitse
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_EnterChallenge)
}

script BattleFrontier_BattlePalaceLobby_EventScript_SinglesAttendant {
    lock_faceplayer
    setvar(VAR_FRONTIER_FACILITY, FRONTIER_FACILITY_PALACE)
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_SINGLES)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_Attendant)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_DoublesAttendant {
    lock_faceplayer
    setvar(VAR_FRONTIER_FACILITY, FRONTIER_FACILITY_PALACE)
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_DOUBLES)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_Attendant)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_Attendant {
    palace_get(PALACE_DATA_PRIZE)
    if (var(VAR_RESULT) != ITEM_NONE) {
        goto(BattleFrontier_BattlePalaceLobby_EventScript_WonChallenge)
    }
    special(SavePlayerParty)
	switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: msgbox(BattleFrontier_BattlePalaceLobby_Text_WelcomeForSingleBattle, MSGBOX_DEFAULT)
		case FRONTIER_MODE_DOUBLES: msgbox(BattleFrontier_BattlePalaceLobby_Text_WelcomeForDoubleBattle, MSGBOX_DEFAULT)
	}
    goto(BattleFrontier_BattlePalaceLobby_EventScript_AskTakeChallenge)
	end
}

script BattleFrontier_BattlePalaceLobby_EventScript_AskTakeChallenge {
	switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: message(BattleFrontier_BattlePalaceLobby_Text_TakeSingleBattleChallenge)
		case FRONTIER_MODE_DOUBLES: message(BattleFrontier_BattlePalaceLobby_Text_TakeDoubleBattleChallenge)
	}
    waitmessage
    multichoice(17, 6, MULTI_CHALLENGEINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattlePalaceLobby_EventScript_TryEnterChallenge)
        case 1: goto(BattleFrontier_BattlePalaceLobby_EventScript_ExplainChallenge)
        case 2:
        case MULTI_B_PRESSED: goto(BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge)
    }
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_TryEnterChallenge {
    message(BattleFrontier_BattlePalaceLobby_Text_WhichChallenge)
    waitmessage
    multichoice(17, 6, MULTI_LEVEL_MODE, FALSE)
    switch (var(VAR_RESULT)) {
        case FRONTIER_LVL_TENT: goto(BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge)
    }
    frontier_checkineligible
    if (var(VAR_0x8004) == TRUE) {
        switch (var(VAR_RESULT)) {
			case FRONTIER_LVL_50: msgbox(BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsLv50, MSGBOX_DEFAULT)
			case FRONTIER_LVL_OPEN: msgbox(BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsLvOpen, MSGBOX_DEFAULT)
		}
		call(BattleFrontier_ShowCaughtBannedSpecies)
		msgbox(BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsEnd, MSGBOX_DEFAULT)
		release_end
    }
    frontier_set(FRONTIER_DATA_LVL_MODE, VAR_RESULT)
    msgbox(BattleFrontier_BattlePalaceLobby_Text_NowSelectThreeMons, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    callnative(RemoveFollowingPokemon)
    frontier_get(FRONTIER_DATA_LVL_MODE)
    copyvar(VAR_0x8004, VAR_RESULT)
    setvar(VAR_0x8005, FRONTIER_PARTY_SIZE)
    special(ChoosePartyForBattleFrontier)
    if (var(VAR_RESULT) != 0) {
        msgbox(BattleFrontier_BattlePalaceLobby_Text_MustSaveBeforeChallenge2, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
			frontier_set(FRONTIER_DATA_SELECTED_MON_ORDER)
			palace_init
			palace_set(PALACE_DATA_WIN_STREAK_ACTIVE, TRUE)
			frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING)
			frontier_set(FRONTIER_DATA_PAUSED, FALSE)
			special(LoadPlayerParty)
			closemessage
			delay(2)
			call(Common_EventScript_SaveGame)
			setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
			if (var(VAR_RESULT) == 0) {
				frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
				goto(BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge)
			}
			goto(BattleFrontier_BattlePalaceLobby_EventScript_EnterChallenge)
		}
    }
	goto(BattleFrontier_BattlePalaceLobby_EventScript_LoadPartyAndCancelChallenge)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_EnterChallenge {
    special(SavePlayerParty)
    frontier_setpartyorder(FRONTIER_PARTY_SIZE)
    msgbox(BattleFrontier_BattlePalaceLobby_Text_FollowMe, MSGBOX_DEFAULT)
    closemessage
    switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: setvar(VAR_LAST_TALKED, LOCALID_PALACE_ATTENDANT_SINGLES)
		case FRONTIER_MODE_DOUBLES: setvar(VAR_LAST_TALKED, LOCALID_PALACE_ATTENDANT_DOUBLES)
	}
    applymovement(VAR_LAST_TALKED, Common_Movement_WalkUp)
    applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
    waitmovement(0)
	switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: opendoor(5, 4)
		case FRONTIER_MODE_DOUBLES: opendoor(19, 4)
	}
    waitdooranim
    applymovement(VAR_LAST_TALKED, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
	switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: closedoor(5, 4)
		case FRONTIER_MODE_DOUBLES: closedoor(19, 4)
	}
    waitdooranim
    warp(MAP_BATTLE_FRONTIER_BATTLE_PALACE_CORRIDOR, 8, 13)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    waitstate
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ExplainChallenge {
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_DOUBLES) {
        msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainDoubleBattleChallenge, MSGBOX_DEFAULT)
    } else {
		msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainSingleBattleChallenge, MSGBOX_DEFAULT)
	}
    goto(BattleFrontier_BattlePalaceLobby_EventScript_AskTakeChallenge)
	end
}

script BattleFrontier_BattlePalaceLobby_EventScript_LoadPartyAndCancelChallenge {
    special(LoadPlayerParty)
    callnative(LoadPlayerParty)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge)
}

script BattleFrontier_BattlePalaceLobby_EventScript_CancelChallenge {
    msgbox(BattleFrontier_BattlePalaceLobby_Text_ReturnWhenFortified, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ShowSinglesResults {
    lockall
    frontier_results(FRONTIER_FACILITY_PALACE, FRONTIER_MODE_SINGLES)
    waitbuttonpress
    special(RemoveRecordsWindow)
    releaseall
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ShowDoublesResults {
    lockall
    frontier_results(FRONTIER_FACILITY_PALACE, FRONTIER_MODE_DOUBLES)
    waitbuttonpress
    special(RemoveRecordsWindow)
    releaseall
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_BlackBelt {
    msgbox(BattleFrontier_BattlePalaceLobby_Text_LadyCanTellWhatMonsThink, MSGBOX_NPC)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_Man {
    msgbox(BattleFrontier_BattlePalaceLobby_Text_NatureAndMovesKeyHere, MSGBOX_NPC)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_Beauty {
    msgbox(BattleFrontier_BattlePalaceLobby_Text_MonDocileButTransforms, MSGBOX_NPC)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_Maniac {
    msgbox(BattleFrontier_BattlePalaceLobby_Text_WhatNatureFavorsChippingAway, MSGBOX_NPC)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_RulesBoard {
    lockall
    msgbox(BattleFrontier_BattlePalaceLobby_Text_RulesAreListed, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattlePalaceLobby_EventScript_ReadRulesBoard)
    end
}

script BattleFrontier_BattlePalaceLobby_EventScript_ReadRulesBoard {
    message(BattleFrontier_BattlePalaceLobby_Text_ReadWhichHeading)
    waitmessage
    multichoice(16, 0, MULTI_BATTLE_PALACE_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainRulesBasics, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainRulesNature, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainRulesMoves, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainRulesUnderpowered, MSGBOX_DEFAULT)
        case 4: msgbox(BattleFrontier_BattlePalaceLobby_Text_ExplainRulesWhenInDanger, MSGBOX_DEFAULT)
        case 5:
        case MULTI_B_PRESSED:
			releaseall
			end
    }
	goto(BattleFrontier_BattlePalaceLobby_EventScript_ReadRulesBoard)
    end
}

text BattleFrontier_BattlePalaceLobby_Text_WelcomeForSingleBattle {
	"Where the hearts of TRAINERS
	are put to the test.

	I welcome you to the BATTLE PALACE.

	I accept challenges to the SINGLE
	BATTLE HALLS."
}

text BattleFrontier_BattlePalaceLobby_Text_TakeSingleBattleChallenge {
	"Do you wish to take
	the SINGLE BATTLE HALL challenge?"
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainSingleBattleChallenge {
	"In the BATTLE PALACE, there are
	several auditoriums for SINGLE BATTLES
	that are named SINGLE BATTLE HALLS.

	The SINGLE BATTLES are conducted in
	the usual way, except with one crucial
	rule that must be obeyed.

	TRAINERS are permitted only to switch
	their POKéMON in and out.

	TRAINERS are otherwise forbidden to
	command their POKéMON.

	The POKéMON are to behave according
	to their nature and battle on their own.

	You must put your trust in your
	POKéMON and watch over them.

	If you achieve the honor of beating
	seven TRAINERS in succession,
	we will present you with Battle Points.

	If you want to interrupt your
	challenge, you must save the game.

	If you don't save before interrupting,
	you will be disqualified."
}

text BattleFrontier_BattlePalaceLobby_Text_ReturnWhenFortified {
	"When you have fortified your heart
	and POKéMON, you must return."
}

text BattleFrontier_BattlePalaceLobby_Text_WhichChallenge {
	"There are two BATTLE HALLS,
	Level 50 and Open Level.
	Which is your choice of a challenge?"
}

text BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsLv50 {
	"Sigh…

	You do not have the three POKéMON
	required for the challenge.

	To enter, you must provide three
	different kinds of POKéMON.

	These POKéMON must all be of
	Level 50 or lower.

	They also must not be holding
	the same kinds of items.

	EGGS{STR_VAR_1}."
}

text BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsEnd {
	"Come back when you have made
	your preparations."
}

text BattleFrontier_BattlePalaceLobby_Text_NotEnoughValidMonsLvOpen {
	"Sigh…

	You do not have the three POKéMON
	required for the challenge.

	To enter, you must provide three
	different kinds of POKéMON.

	They also must not be holding
	the same kinds of items.

	EGGS{STR_VAR_1}."
}

text BattleFrontier_BattlePalaceLobby_Text_NowSelectThreeMons {
	"Good. Now, you must select your
	three POKéMON."
}

text BattleFrontier_BattlePalaceLobby_Text_MustSaveBeforeChallenge2 {
	"I must save before I show you to
	the BATTLE HALL. Is that okay?"
}

text BattleFrontier_BattlePalaceLobby_Text_FollowMe {
	"Good.
	Now, follow me."
}

text BattleFrontier_BattlePalaceLobby_Text_ResultsWillBeRecorded {
	"I feel privileged for having seen
	your POKéMON's exploits.

	The results will be recorded.
	I must ask you to briefly wait."
}

text BattleFrontier_BattlePalaceLobby_Text_FirmTrueBondsFor7WinStreak {
	"To achieve a 7-win streak…

	The bonds that bind your heart with
	your POKéMON seem firm and true."
}

text BattleFrontier_BattlePalaceLobby_Text_FeatWillBeRecorded {
	"Your feat will be recorded.
	I must ask you to briefly wait."
}
// Unused

text BattleFrontier_BattlePalaceLobby_Text_BattlePointsFor7WinStreak {
	"For the feat of your 7-win streak,
	we present you with Battle Point(s)."
}

text BattleFrontier_BattlePalaceLobby_Text_NoSpaceForPrize {
	"You seem to have no space for
	our prize.

	You should return when you have
	organized your BAG."
}

text BattleFrontier_BattlePalaceLobby_Text_WeHaveBeenWaiting {
	"We have been waiting for you…"
}

text BattleFrontier_BattlePalaceLobby_Text_MustSaveBeforeChallenge {
	"I must save before I show you to
	the BATTLE HALL. Is that okay?"
}

text BattleFrontier_BattlePalaceLobby_Text_FailedToSaveBeforeEndingChallenge {
	"Sigh…

	You failed to save before you ended
	your challenge the last time.

	As a result, your challenge has been
	disqualified. It is most unfortunate."
}
// Unused

text BattleFrontier_BattlePalaceLobby_Text_ReceivedPrize {
	"{PLAYER} received the prize
	{STR_VAR_1}."
}

text BattleFrontier_BattlePalaceLobby_Text_LadyCanTellWhatMonsThink {
	"For a hardy fellow like me,
	hardy POKéMON are the best.

	Offense is the best defense!
	A relentless attack is the ultimate!

	But that's not what I wanted to chat
	about.

	Every so often a really cute lady
	swings by here.

	She says that she can tell what
	POKéMON are thinking.

	I don't know about that part,
	but she is really cute.

	Huh?
	Why are you looking at me like that?"
}

text BattleFrontier_BattlePalaceLobby_Text_NatureAndMovesKeyHere {
	"Hmm…

	It appears that the nature of POKéMON
	and the moves that they have been
	taught are the keys to battle here.

	To be more precise, it's how well
	the moves match the nature of
	the POKéMON.

	If your POKéMON is in trouble and
	unable to live up to its potential,
	you may need to examine how well
	its moves match its nature."
}

text BattleFrontier_BattlePalaceLobby_Text_MonDocileButTransforms {
	"My POKéMON is usually very docile.

	But when it's in a BATTLE HALL,
	it sometimes seems to become
	transformed into something wicked!

	It becomes totally intimidating.
	It's shocking, even."
}

text BattleFrontier_BattlePalaceLobby_Text_WhatNatureFavorsChippingAway {
	"I wonder what sort of nature a POKéMON
	would have if it favored enfeebling its
	opponents and chipping away slowly.

	I'd be surprised if it was a LAX nature.

	But, nah, that can't be right."
}

text BattleFrontier_BattlePalaceLobby_Text_WelcomeForDoubleBattle {
	"Where the hearts of TRAINERS
	are put to the test.

	I welcome you to the BATTLE PALACE.

	I accept challenges to the DOUBLE
	BATTLE HALLS."
}

text BattleFrontier_BattlePalaceLobby_Text_TakeDoubleBattleChallenge {
	"Do you wish to take
	the DOUBLE BATTLE HALL challenge?"
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainDoubleBattleChallenge {
	"In the BATTLE PALACE, there are
	several auditoriums for DOUBLE BATTLES
	that are named DOUBLE BATTLE HALLS.

	The DOUBLE BATTLES are conducted in
	the usual way, except with one crucial
	rule that must be obeyed.

	TRAINERS are permitted only to switch
	their POKéMON in and out.

	TRAINERS are otherwise forbidden to
	command their POKéMON.

	The POKéMON are to behave according
	to their nature and battle on their own.

	You must put your trust in your
	POKéMON and watch over them.

	If you achieve the honor of beating
	seven TRAINERS in succession,
	we will present you with Battle Points.

	If you want to interrupt your
	challenge, please save the game.

	If you don't save before interrupting,
	you will be disqualified."
}

text BattleFrontier_BattlePalaceLobby_Text_ToDefeatMavenAnd7Trainers {
	"To defeat the PALACE MAVEN
	and seven TRAINERS in a row…"
}

text BattleFrontier_BattlePalaceLobby_Text_PresentYouWithBattlePoints {
	"In honor of the bond you share with
	your POKéMON, we present you with
	these Battle Point(s)."
}

text BattleFrontier_BattlePalaceLobby_Text_LikeToRecordMatch {
	"Would you like to record your latest
	BATTLE PALACE match on your
	FRONTIER PASS?"
}

text BattleFrontier_BattlePalaceLobby_Text_RulesAreListed {
	"The BATTLE HALL rules are listed."
}

text BattleFrontier_BattlePalaceLobby_Text_ReadWhichHeading {
	"Which heading do you want to read?"
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainRulesBasics {
	"Here, POKéMON are required to think
	and battle by themselves.

	Unlike in the wild, POKéMON that live
	with people behave differently
	depending on their nature."
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainRulesNature {
	"Depending on its nature, a POKéMON
	may prefer to attack no matter what.

	Another POKéMON may prefer to protect
	itself from any harm.

	Yet another may enjoy vexing or
	confounding its foes.

	Due to its nature, a POKéMON
	will have favorite moves that it is good
	at using.

	It may also dislike certain moves that
	it has trouble using."
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainRulesMoves {
	"There are offensive moves that inflict
	direct damage on the foe.

	There are defensive moves that are
	used to prepare for enemy attacks or
	used to heal HP and so on.

	There are also other somewhat-odd
	moves that may enfeeble the foes with
	stat problems including poison and 
	paralysis.

	POKéMON will consider using moves in
	these three categories."
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainRulesUnderpowered {
	"When not under command by its TRAINER,
	a POKéMON may be unable to effectively
	use certain moves.

	A POKéMON is not good at using any
	move that it dislikes.

	If a POKéMON only knows moves that
	do not match its nature, it will often
	be unable to live up to its potential."
}

text BattleFrontier_BattlePalaceLobby_Text_ExplainRulesWhenInDanger {
	"Depending on its nature, a POKéMON may
	start using moves that don't match its
	nature when it is in trouble.

	If a POKéMON begins behaving oddly
	in a pinch, watch it carefully."
}
