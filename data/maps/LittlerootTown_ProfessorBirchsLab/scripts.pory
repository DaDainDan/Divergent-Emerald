    end
}

script LittlerootTown_ProfessorBirchsLab_EventScript_Book {
    msgbox(LittlerootTown_ProfessorBirchsLab_Text_BookTooHardToRead, MSGBOX_SIGN)
    end
}

script LittlerootTown_ProfessorBirchsLab_EventScript_ScottAboardSSTidalCall {
    lockall
    pokenavcall(LittlerootTown_ProfessorBirchsLab_Text_ScottAboardSSTidalCall)
    waitmessage
    clearflag(FLAG_SCOTT_CALL_BATTLE_FRONTIER)
    releaseall
    end
}

text LittlerootTown_ProfessorBirchsLab_Text_BirchAwayOnFieldwork {
	"Hunh? PROF. BIRCH?

	The PROF's away on fieldwork.
	Ergo, he isn't here.

	Oh, let me explain what fieldwork is.

	It is to study things in the natural
	environment, like fields and mountains,
	instead of a laboratory.

	The PROF isn't one for doing desk work.
	He's the type of person who would
	rather go outside and experience
	things than read about them here."
}

text LittlerootTown_ProfessorBirchsLab_Text_BirchIsntOneForDeskWork {
	"The PROF isn't one for doing desk work.
	He's the type of person who would
	rather go outside and experience
	things than read about them here."
}

text LittlerootTown_ProfessorBirchsLab_Text_BirchEnjoysRivalsHelpToo {
	"PROF. BIRCH is studying the habitats
	and distribution of POKéMON.

	The PROF enjoys {RIVAL}'s help, too.
	There's a lot of love there."
}

text LittlerootTown_ProfessorBirchsLab_Text_LikeYouToHavePokemon {
	"PROF. BIRCH: So, {PLAYER}{KUN}.

	I've heard so much about you from
	your father.

	I've heard that you don't have your
	own POKéMON yet.

	But the way you battled earlier,
	you pulled it off with aplomb!

	I guess you have your father's blood
	in your veins after all!

	Oh, yes. As thanks for rescuing me,
	I'd like you to have the POKéMON you
	used earlier.

	{PLAYER} received the {STR_VAR_1}!"
}

text LittlerootTown_ProfessorBirchsLab_Text_WhyNotGiveNicknameToMon {
	"PROF. BIRCH: While you're at it, why not
	give a nickname to that {STR_VAR_1}?"
}

text LittlerootTown_ProfessorBirchsLab_Text_MightBeGoodIdeaToGoSeeRival {
	"PROF. BIRCH: If you work at POKéMON
	and gain experience, I think you'll make
	an extremely good TRAINER.

	My kid, {RIVAL}, is also studying
	POKéMON while helping me out.

	{PLAYER}{KUN}, don't you think it might be
	a good idea to go see {RIVAL}?"
}

text LittlerootTown_ProfessorBirchsLab_Text_GetRivalToTeachYou {
	"PROF. BIRCH: Great!
	{RIVAL} should be happy, too.

	Get {RIVAL} to teach you what it
	means to be a TRAINER."
}

text LittlerootTown_ProfessorBirchsLab_Text_DontBeThatWay {
	"PROF. BIRCH: Oh, don't be that way.
	You should go meet my kid."
}

text LittlerootTown_ProfessorBirchsLab_Text_BirchRivalGoneHome {
	"PROF. BIRCH: {RIVAL}?
	Gone home, I think.

	Or maybe that kid's scrabbling around
	in tall grass again somewhere…

	If you or your POKéMON get tired,
	you should get some rest at home."
}

text LittlerootTown_ProfessorBirchsLab_Text_HeardYouBeatRivalTakePokedex {
	"PROF. BIRCH: Oh, hi, {PLAYER}{KUN}!

	I heard you beat {RIVAL} on
	your first try. That's excellent!

	{RIVAL}'s been helping with my research
	for a long time.

	{RIVAL} has an extensive history as
	a TRAINER already.

	Here, {PLAYER}{KUN}, I ordered this for my
	research, but I think you should have
	this POKéDEX."
}

text LittlerootTown_ProfessorBirchsLab_Text_ReceivedPokedex {
	"{PLAYER} received the POKéDEX!"
}

text LittlerootTown_ProfessorBirchsLab_Text_ExplainPokedex {
	"PROF. BIRCH: The POKéDEX is a high-tech
	tool that automatically makes a record
	of any POKéMON you meet or catch.

	My kid, {RIVAL}, goes everywhere
	with it.

	Whenever my kid catches a rare POKéMON
	and records its data in the POKéDEX,
	why, {RIVAL} looks for me while I'm out
	doing fieldwork, and shows me."
}

text LittlerootTown_ProfessorBirchsLab_Text_CountlessPokemonAwait {
	"PROF. BIRCH: Countless POKéMON
	await you!

	Argh, I'm getting the itch to get out
	and do fieldwork again!"
}

text LittlerootTown_ProfessorBirchsLab_Text_MayGotPokedexTooTakeThese {
	"MAY: Oh, wow, {PLAYER}{KUN}!
	You got a POKéDEX, too!

	That's great! Just like me!
	I've got something for you, too!"
}

text LittlerootTown_ProfessorBirchsLab_Text_CatchCutePokemonWithPokeBalls {
	"MAY: It's fun if you can get a lot of
	POKéMON!

	I'm going to look all over the place
	because I want different POKéMON.

	If I find any cute POKéMON, I'll catch
	them with POKé BALLS!"
}

text LittlerootTown_ProfessorBirchsLab_Text_OhYourBagsFull {
	"Oh? Your BAG's full."
}

text LittlerootTown_ProfessorBirchsLab_Text_MayWhereShouldIGoNext {
	"MAY: I wonder where I should go look
	for POKéMON next?"
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanGotPokedexTooTakeThese {
	"BRENDAN: Huh…
	So you got a POKéDEX, too.

	Well then, here.
	I'll give you these."
}

text LittlerootTown_ProfessorBirchsLab_Text_CatchCoolPokemonWithPokeBalls {
	"BRENDAN: You know it's more fun to
	have a whole bunch of POKéMON.

	I'm going to explore all over the place
	to find different POKéMON.

	If I find any cool POKéMON, you bet
	I'll try to get them with POKé BALLS."
}

text LittlerootTown_ProfessorBirchsLab_Text_HeyYourBagsFull {
	"Hey, your BAG's full."
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanWhereShouldIGoNext {
	"BRENDAN: Where should I look for
	POKéMON next…"
}

text LittlerootTown_ProfessorBirchsLab_Text_SeriousLookingMachine {
	"It's a serious-looking machine.
	The PROF must use this for research."
}

text LittlerootTown_ProfessorBirchsLab_Text_PCUsedForResearch {
	"It's a PC used for research.
	Better not mess around with it."
}

text LittlerootTown_ProfessorBirchsLab_Text_CrammedWithBooksOnPokemon {
	"It's crammed with books on POKéMON."
}

text LittlerootTown_ProfessorBirchsLab_Text_BookTooHardToRead {
	"It's a book that's too hard to read."
}

text LittlerootTown_ProfessorBirchsLab_Text_OtherRegionsUpgradeToNational {
	"PROF. BIRCH: Now…

	{PLAYER}{KUN} and {RIVAL}, I've had the two
	of you help me study POKéMON.

	Thanks to your help, new facts
	are coming to light.

	It appears that in the HOENN region,
	there are also POKéMON from other
	regions.

	It goes to show how rich and varied
	the natural environments of HOENN
	happen to be.

	That's why I think it's necessary for
	me to upgrade your POKéDEX to
	the NATIONAL Mode.

	Here, let me see your POKéDEX units."
}

text LittlerootTown_ProfessorBirchsLab_Text_MayUpgradeSoCool {
	"MAY: Eheheh!

	It's so cool that even my POKéDEX
	is getting updated!

	It's because you went out and caught
	so many POKéMON, {PLAYER}{KUN}!"
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanYouCanThankMe {
	"BRENDAN: I went out all over HOENN
	and checked out POKéMON.

	You can thank me for getting
	the NATIONAL Mode POKéDEX.

	Yep, you're lucky, {PLAYER}!"
}

text LittlerootTown_ProfessorBirchsLab_Text_OkayAllDone {
	"PROF. BIRCH: Okay, all done!"
}

text LittlerootTown_ProfessorBirchsLab_Text_PokedexUpgradedToNational {
	"{PLAYER}'s POKéDEX was upgraded
	to the NATIONAL Mode!"
}

text LittlerootTown_ProfessorBirchsLab_Text_GrassyPatchWaiting2 {
	"PROF. BIRCH: But listen.
	You've become the CHAMPION,
	but your POKéMON journey isn't over.

	There is no end to the road
	that is POKéMON.

	Somewhere, there is a grassy patch
	that's waiting for you!"
}

text LittlerootTown_ProfessorBirchsLab_Text_MayTakeBreakFromFieldwork {
	"MAY: I think I'll take a short break
	from fieldwork.

	I think I'll help the PROF here for
	a while."
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanTakeBreakFromFieldwork {
	"BRENDAN: For the time being,
	I'm taking a break from fieldwork.

	I'll be helping out the PROF here
	for a while."
}

text LittlerootTown_ProfessorBirchsLab_Text_CompletedDexChoosePokemon {
	"PROF. BIRCH: Oh, {PLAYER}{KUN}!
	Let's have a look at your POKéDEX.

	… … … … … …
	… … … … … …

	Yes, there's no doubt about it.

	You really have completed the HOENN
	region's POKéDEX.

	That's more than just impressive.

	I have a gift for you.

	Consider it my show of appreciation
	for the fantastic work you've done.

	My gift is a rare POKéMON only found
	in another region!

	You can have any one of these
	three POKéMON!"
}

text LittlerootTown_ProfessorBirchsLab_Text_CanHaveAnyOneOfRarePokemon {
	"PROF. BIRCH: These are rare POKéMON
	only found in another region!

	You can have any one of these
	three POKéMON!"
}

text LittlerootTown_ProfessorBirchsLab_Text_YoullTakeCyndaquil {
	"PROF. BIRCH: The FIRE POKéMON
	CYNDAQUIL caught your eye!

	You're as sharp as ever!

	So the CYNDAQUIL is your choice?"
}

text LittlerootTown_ProfessorBirchsLab_Text_YoullTakeTotodile {
	"PROF. BIRCH: The WATER POKéMON
	TOTODILE is your choice!

	You know how to pick a good one.

	So, you'll take the TOTODILE?"
}

text LittlerootTown_ProfessorBirchsLab_Text_YoullTakeChikorita {
	"PROF. BIRCH: The GRASS POKéMON
	CHIKORITA is your choice!

	You sure know what you're doing.

	So, you'll take the CHIKORITA?"
}

text LittlerootTown_ProfessorBirchsLab_Text_TakeYourTimeAllInvaluable {
	"PROF. BIRCH: Take your time before
	you decide.

	They're all invaluable POKéMON."
}

text LittlerootTown_ProfessorBirchsLab_Text_PickedFinePokemon {
	"PROF. BIRCH: I see!
	You picked a fine POKéMON!"
}

text LittlerootTown_ProfessorBirchsLab_Text_ReceivedJohtoStarter {
	"{PLAYER} received the {STR_VAR_1}
	from PROF. BIRCH!"
}

text LittlerootTown_ProfessorBirchsLab_Text_NicknameJohtoStarter {
	"Want to give a nickname to
	the {STR_VAR_1} you received?"
}

text LittlerootTown_ProfessorBirchsLab_Text_GrassyPatchWaiting {
	"PROF. BIRCH: Listen, {PLAYER}{KUN}.
	You've completed the HOENN POKéDEX,
	but your POKéMON journey isn't over.

	There is no end to the road
	that is POKéMON.

	Somewhere, there is a grassy patch
	that's waiting for you!"
}

text LittlerootTown_ProfessorBirchsLab_Text_BetterLeaveOthersAlone {
	"You received the promised POKéMON.
	Better leave the others alone."
}

text LittlerootTown_ProfessorBirchsLab_Text_DontHaveAnyRoomForPokemon {
	"Oh, you don't have any room for
	this POKéMON."
}

text LittlerootTown_ProfessorBirchsLab_Text_MayWhatNextImStayingHere {
	"MAY: {PLAYER}{KUN}, after this…
	What are you going to do?

	Are you going to keep battling
	and sharpening your skills?

	Or are you going to try filling
	the NATIONAL POKéDEX?

	I'm staying here to help the PROF."
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanPreferCollectingSlowly {
	"BRENDAN: Rather than collecting
	POKéMON, I prefer slowly and 
	steadily raising the one I chose."
}

text LittlerootTown_ProfessorBirchsLab_Text_MayHaveYouGoneToBattleFrontier {
	"MAY: Oh, hi, {PLAYER}{KUN}!
	Have you gone to that place,
	the BATTLE FRONTIER?"
}

text LittlerootTown_ProfessorBirchsLab_Text_BrendanHaveYouGoneToBattleFrontier {
	"BRENDAN: Hey, {PLAYER}!
	Have you gone out to that place,
	the BATTLE FRONTIER?"
}

text LittlerootTown_ProfessorBirchsLab_Text_ScottAboardSSTidalCall {
	"… … … … … …
	… … … … … Beep!

	SCOTT: Hi, hi, {PLAYER}!
	It's me, SCOTT.

	I'm aboard the S.S. TIDAL now.
	It feels great to be on the sea!

	By the way…

	There's this place that I'd like to
	invite you to for a visit.

	If you're interested, board a ferry
	at either SLATEPORT or LILYCOVE.

	I'll fill you in on the details when
	we meet. I'll be waiting!

	… … … … … …
	… … … … … Click!"
}
