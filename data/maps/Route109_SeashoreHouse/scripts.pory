mapscripts Route109_SeashoreHouse_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_LANDMARK_SEASHORE_HOUSE)
    	end
    }
}

script Route109_SeashoreHouse_EventScript_Owner {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_6_SODA_POP)) {
        showmoneybox(0, 0)
		msgbox(Route109_SeashoreHouse_Text_WantToBuySodaPop, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			goto(Route109_SeashoreHouse_EventScript_BuySodaPop)
		}
		msgbox(Route109_SeashoreHouse_Text_ThatsTooBad, MSGBOX_DEFAULT)
		hidemoneybox
    }
    elif (flag(FLAG_DEFEATED_SEASHORE_HOUSE)) {
        msgbox(Route109_SeashoreHouse_Text_TakeTheseSodaPopBottles, MSGBOX_DEFAULT)
		if (giveitem(ITEM_SODA_POP, 6) == FALSE) {
			msgbox(Route109_SeashoreHouse_Text_BagFull, MSGBOX_DEFAULT)
    		release_end
		}
		setflag(FLAG_RECEIVED_6_SODA_POP)
    }
    elif (flag(FLAG_TEMP_2)) {
        msgbox(Route109_SeashoreHouse_Text_ShowMeSomeHotMatches, MSGBOX_DEFAULT)
    }
	else {
		msgbox(Route109_SeashoreHouse_Text_SeashoreHouseIntro, MSGBOX_DEFAULT)
    	setflag(FLAG_TEMP_2)
	}
    release_end
}

script Route109_SeashoreHouse_EventScript_BuySodaPop {
	if (checkmoney(300) == FALSE) {
		msgbox(Route109_SeashoreHouse_Text_NotEnoughMoney, MSGBOX_DEFAULT)
		hidemoneybox
		release_end
	}
	if (checkitemspace(ITEM_SODA_POP) == TRUE) {
		msgbox(gText_TooBadBagIsFull, MSGBOX_DEFAULT)
		hidemoneybox
		release_end
	}
	msgbox(Route109_SeashoreHouse_Text_HereYouGo, MSGBOX_DEFAULT)
	removemoney(300)
	updatemoneybox
	goto(Route109_SeashoreHouse_EventScript_GiveSodaPop)
	end
}

raw `
Route109_SeashoreHouse_EventScript_GiveSodaPop::
.if OW_SHOW_ITEM_DESCRIPTIONS != OW_ITEM_DESCRIPTIONS_OFF
	hidemoneybox
	giveitem ITEM_SODA_POP
.else
	giveitem ITEM_SODA_POP
	hidemoneybox
.endif
	release_end
`

script Route109_SeashoreHouse_EventScript_Dwayne {
    trainerbattle_single(TRAINER_DWAYNE, Route109_SeashoreHouse_Text_DwayneIntro, Route109_SeashoreHouse_Text_DwayneDefeated, Route109_SeashoreHouse_EventScript_CheckTrainersCompletion)
    msgbox(Route109_SeashoreHouse_Text_DwaynePostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route109_SeashoreHouse_EventScript_Johanna {
    trainerbattle_single(TRAINER_JOHANNA, Route109_SeashoreHouse_Text_JohannaIntro, Route109_SeashoreHouse_Text_JohannaDefeated, Route109_SeashoreHouse_EventScript_CheckTrainersCompletion)
    msgbox(Route109_SeashoreHouse_Text_JohannaPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route109_SeashoreHouse_EventScript_Simon {
    trainerbattle_single(TRAINER_SIMON, Route109_SeashoreHouse_Text_SimonIntro, Route109_SeashoreHouse_Text_SimonDefeated, Route109_SeashoreHouse_EventScript_CheckTrainersCompletion)
    msgbox(Route109_SeashoreHouse_Text_SimonPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script Route109_SeashoreHouse_EventScript_CheckTrainersCompletion {
    if (defeated(TRAINER_DWAYNE) && defeated(TRAINER_JOHANNA) && defeated(TRAINER_SIMON)) {
        setflag(FLAG_DEFEATED_SEASHORE_HOUSE)
    }
    release_end
}

text Route109_SeashoreHouse_Text_SeashoreHouseIntro {
	"I'm the owner of the SEASHORE HOUSE.
	But you can call me MR. SEA!

	What I love above all is to see hot
	POKéMON battles.

	Let me see that your heart burns hot!

	If you can defeat all the TRAINERS
	here, I'll reward your efforts."
}

text Route109_SeashoreHouse_Text_ShowMeSomeHotMatches {
	"Show me some hot matches!

	I run this SEASHORE HOUSE just for
	that reason alone!"
}

text Route109_SeashoreHouse_Text_TakeTheseSodaPopBottles {
	"You're scorching hot!
	Those battles blazed!
	I'm more than just satisfied!

	As thanks for showing me your hot
	streak, I want you to take these.

	It's half a dozen bottles of SODA POP!"
}

text Route109_SeashoreHouse_Text_BagFull {
	"Oh, but hey, your BAG's jammed full.
	I'll hang on to these for you."
}

text Route109_SeashoreHouse_Text_WantToBuySodaPop {
	"Want to buy some SODA POP?
	POKéMON love it!

	Just ¥300 a bottle!
	Buy some!"
}

text Route109_SeashoreHouse_Text_HereYouGo {
	"Here you go!"
}

text Route109_SeashoreHouse_Text_NotEnoughMoney {
	"You don't have the money."
}

text Route109_SeashoreHouse_Text_ThatsTooBad {
	"No?
	That's too bad."
}

text Route109_SeashoreHouse_Text_DwayneIntro {
	"If you're looking for a battle in the
	SEASHORE HOUSE, you'll find no
	hotter TRAINER than me, matey!"
}

text Route109_SeashoreHouse_Text_DwayneDefeated {
	"That was a hot battle!
	I can accept that loss, matey!"
}

text Route109_SeashoreHouse_Text_DwaynePostBattle {
	"Whenever I'm in SLATEPORT, I enjoy
	hot battles and ice-cold SODA POP!"
}

text Route109_SeashoreHouse_Text_JohannaIntro {
	"Boring battles aren't worth the effort.

	Fiery hot battles are what toughen up
	TRAINERS and POKéMON!"
}

text Route109_SeashoreHouse_Text_JohannaDefeated {
	"That's hot!"
}

text Route109_SeashoreHouse_Text_JohannaPostBattle {
	"Whew, I'm all thirsty.
	Maybe I'll have a SODA POP."
}

text Route109_SeashoreHouse_Text_SimonIntro {
	"I'm going to show you how great
	my POKéMON are, but don't cry!"
}

text Route109_SeashoreHouse_Text_SimonDefeated {
	"…I lost, but I won't cry…"
}

text Route109_SeashoreHouse_Text_SimonPostBattle {
	"If one of my POKéMON knew the move
	for carrying me across water on its
	back, I could get rid of this inner tube."
}
