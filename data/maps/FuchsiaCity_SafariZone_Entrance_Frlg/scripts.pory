mapscripts FuchsiaCity_SafariZone_Entrance_Frlg_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_FUCHSIA_CITY_SAFARI_ZONE_ENTRANCE, 1: FuchsiaCity_SafariZone_Entrance_EventScript_ExitWarpIn
    	VAR_MAP_SCENE_FUCHSIA_CITY_SAFARI_ZONE_ENTRANCE, 2: FuchsiaCity_SafariZone_Entrance_EventScript_ExitEarly
    	VAR_MAP_SCENE_FUCHSIA_CITY_SAFARI_ZONE_ENTRANCE, 3: FuchsiaCity_SafariZone_Entrance_EventScript_ExitWalkIn
    ]
}

// When player runs out of balls mid-battle
script FuchsiaCity_SafariZone_Entrance_EventScript_ExitWalkIn {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_PLAYER, moves(walk_down,  delay_8))
    waitmovement(0)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_CatchFairShareComeAgain)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_ExitEnd)
	end
}

// When player runs of out balls after catching a pokemon, or runs out of steps
script FuchsiaCity_SafariZone_Entrance_EventScript_ExitWarpIn {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_CatchFairShareComeAgain)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_ExitEnd)
	end
}

// When player re-enters the entrance building with balls/steps remaining
script FuchsiaCity_SafariZone_Entrance_EventScript_ExitEarly {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_GoingToLeaveSafariZoneEarly, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(FuchsiaCity_SafariZone_Entrance_Text_GoodLuck)
		closemessage
		applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
		waitmovement(0)
		warp(MAP_SAFARI_ZONE_CENTER, 26, 30)
		waitstate
		end
    }
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_PleaseReturnSafariBalls)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_ExitEnd)
	end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_ExitEnd {
	closemessage
    applymovement(LOCALID_PLAYER, moves(walk_down * 2))
    waitmovement(0)
    special(ExitSafariMode)
    setvar(VAR_MAP_SCENE_FUCHSIA_CITY_SAFARI_ZONE_ENTRANCE, 0)
    releaseall
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_EntryTriggerMid {
    lockall
    setvar(VAR_TEMP_2, 0)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_AskEnterSafariZone)
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_EntryTriggerRight {
    lockall
    setvar(VAR_TEMP_2, 1)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_AskEnterSafariZone)
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_EntryTriggerLeft {
    lockall
    setvar(VAR_TEMP_2, 2)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_AskEnterSafariZone)
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_AskEnterSafariZone {
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_WelcomeToSafariZone)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    showmoneybox(0, 0)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_PlaySafariGameFor500, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(FuchsiaCity_SafariZone_Entrance_EventScript_TryEnterSafariZone)
    }
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_OkayPleaseComeAgain)
    goto(FuchsiaCity_SafariZone_Entrance_EventScript_ForcePlayerBack)
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_TryEnterSafariZone {
    getpartysize
    if (var(VAR_RESULT) == PARTY_SIZE && specialvar(VAR_RESULT, ScriptCheckFreePokemonStorageSpace) == FALSE) {
        msgbox(Route121_SafariZoneEntrance_Text_PCIsFull)
    	goto(FuchsiaCity_SafariZone_Entrance_EventScript_ForcePlayerBack)
    }
    elif (checkmoney(500) == FALSE) {
        msgbox(FuchsiaCity_SafariZone_Entrance_Text_OopsNotEnoughMoney)
    	goto(FuchsiaCity_SafariZone_Entrance_EventScript_ForcePlayerBack)
    }
    removemoney(500)
    updatemoneybox
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_ThatllBe500WeOnlyUseSpecialBalls)
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_LEVEL_UP)
    message(FuchsiaCity_SafariZone_Entrance_Text_PlayerReceived30SafariBalls)
    waitfanfare
    call(EventScript_RestorePrevTextColor)
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_CallYouOnPAWhenYouRunOut)
    closemessage
    hidemoneybox
	switch (var(VAR_TEMP_2)) {
		case 0: applymovement(LOCALID_PLAYER, moves(walk_up * 2))
		case 1: applymovement(LOCALID_PLAYER, moves(walk_up,  walk_left,  walk_up))
		case 2: applymovement(LOCALID_PLAYER, moves(walk_up,  walk_right,  walk_up))
	}
	waitmovement(0)
    special(EnterSafariMode)
    setvar(VAR_MAP_SCENE_FUCHSIA_CITY_SAFARI_ZONE_ENTRANCE, 2)
    warp(MAP_SAFARI_ZONE_CENTER, 255, 26, 30)
    waitstate
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_ForcePlayerBack {
    closemessage
    hidemoneybox
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    releaseall
    end
}

script FuchsiaCity_SafariZone_Entrance_EventScript_InfoAttendant {
    lock_faceplayer
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_FirstTimeAtSafariZone, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(FuchsiaCity_SafariZone_Entrance_Text_ExplainSafariZone)
    	release_end
    }
    msgbox(FuchsiaCity_SafariZone_Entrance_Text_SorryYoureARegularHere)
    release_end
}

text FuchsiaCity_SafariZone_Entrance_Text_WelcomeToSafariZone {
	"Welcome to the SAFARI ZONE!"
}

text FuchsiaCity_SafariZone_Entrance_Text_PlaySafariGameFor500 {
	"For just ¥500, you can play the
	SAFARI GAME.

	You can roam the wide-open safari
	and catch what you like.

	Would you like to play?"
}

text FuchsiaCity_SafariZone_Entrance_Text_ThatllBe500WeOnlyUseSpecialBalls {
	"That'll be ¥500, please!

	We only use a special kind of 
	POKé BALLS here."
}

text FuchsiaCity_SafariZone_Entrance_Text_PlayerReceived30SafariBalls {
	"{PLAYER} received 30 SAFARI BALLS
	from the attendant."
}

text FuchsiaCity_SafariZone_Entrance_Text_CallYouOnPAWhenYouRunOut {
	"We'll call you on the PA when you
	run out of time or SAFARI BALLS.

	Well, I'll wish you the best of
	luck!"
}

text FuchsiaCity_SafariZone_Entrance_Text_OkayPleaseComeAgain {
	"Okay.
	Please come again!"
}

text FuchsiaCity_SafariZone_Entrance_Text_OopsNotEnoughMoney {
	"Oops!
	Not enough money!"
}

text FuchsiaCity_SafariZone_Entrance_Text_GoingToLeaveSafariZoneEarly {
	"Are you going to leave the
	SAFARI ZONE early?"
}

text FuchsiaCity_SafariZone_Entrance_Text_PleaseReturnSafariBalls {
	"Please return any SAFARI BALLS
	you may have left."
}

text FuchsiaCity_SafariZone_Entrance_Text_GoodLuck {
	"Good luck!"
}

text FuchsiaCity_SafariZone_Entrance_Text_CatchFairShareComeAgain {
	"Did you catch your fair share?
	Come again!"
}

text FuchsiaCity_SafariZone_Entrance_Text_FirstTimeAtSafariZone {
	"Hi! Is it your first time here at
	the SAFARI ZONE?"
}

text FuchsiaCity_SafariZone_Entrance_Text_ExplainSafariZone {
	"The SAFARI ZONE actually has
	four zones in it.

	Each zone has different kinds of
	POKéMON, even some rare ones.

	Use the supplied SAFARI BALLS to
	catch them.

	You can also throw BAIT or ROCKS
	besides the SAFARI BALLS.

	If you throw BAIT, the POKéMON
	becomes less likely to flee, but
	harder to catch.

	If you throw ROCKS, the POKéMON
	becomes more likely to flee, but
	easier to catch.

	When you run out of time or SAFARI
	BALLS, it's game over for you!"
}

text FuchsiaCity_SafariZone_Entrance_Text_SorryYoureARegularHere {
	"Sorry, you're a regular here!"
}
