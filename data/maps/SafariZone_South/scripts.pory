mapscripts SafariZone_South_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_SAFARI_ZONE_STATE) == 2) {
			setobjectxyperm(LOCALID_SAFARI_EXIT_ATTENDANT, 31, 34)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SAFARI_ZONE_STATE, 2 {
			lockall
			applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
			waitmovement(0)
			applymovement(LOCALID_SAFARI_EXIT_ATTENDANT, moves(walk_right,  step_faster_down))
			waitmovement(0)
			setobjectxyperm(LOCALID_SAFARI_EXIT_ATTENDANT, 32, 34)
			setvar(VAR_SAFARI_ZONE_STATE, 0)
			releaseall
			end
		}
    ]
}

script SafariZone_South_EventScript_Boy {
    msgbox(SafariZone_South_Text_Boy, MSGBOX_NPC)
    end
}

script SafariZone_South_EventScript_Man {
    msgbox(SafariZone_South_Text_Man, MSGBOX_NPC)
    end
}

script SafariZone_South_EventScript_Youngster {
    msgbox(SafariZone_South_Text_Youngster, MSGBOX_NPC)
    end
}

script SafariZone_South_EventScript_ExitAttendant {
    lock_faceplayer
    if (!flag(FLAG_GOOD_LUCK_SAFARI_ZONE)) {
        setflag(FLAG_GOOD_LUCK_SAFARI_ZONE)
		msgbox(SafariZone_South_Text_GoodLuck, MSGBOX_DEFAULT)
		release_end
    }
    msgbox(SafariZone_South_Text_StillHaveTimeExit, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(SafariZone_South_EventScript_ExitEarly)
    }
    msgbox(SafariZone_South_Text_EnjoyTheRestOfYourAdventure, MSGBOX_DEFAULT)
    release_end
}

script SafariZone_South_EventScript_ExitEarly {
    msgbox(SafariZone_South_Text_ExitEarlyThankYouForPlaying, MSGBOX_DEFAULT)
    closemessage
    switch (var(VAR_FACING)) {
        case DIR_NORTH:
			applymovement(LOCALID_SAFARI_EXIT_ATTENDANT, moves(walk_left,  step_faster_right))
    		waitmovement(0)
    		applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
        case DIR_EAST:
			applymovement(LOCALID_SAFARI_EXIT_ATTENDANT, moves(walk_down,  step_faster_up))
    		waitmovement(0)
    		applymovement(LOCALID_PLAYER, moves(walk_right,  step_faster_up))
    }
	waitmovement(0)
    setvar(VAR_SAFARI_ZONE_STATE, 1)
    special(ExitSafariMode)
    warpdoor(MAP_ROUTE121_SAFARI_ZONE_ENTRANCE, 2, 5)
    waitstate
    end
}

