mapscripts BattleFrontier_BattlePikeCorridor_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattlePikeCorridor_EventScript_EnterCorridor
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script BattleFrontier_BattlePikeCorridor_EventScript_EnterCorridor {
    delay(16)
    frontier_set(FRONTIER_DATA_BATTLE_NUM, 1)
    pike_cleartrainerids
    pike_nohealing(TRUE)
    applymovement(LOCALID_PLAYER, moves(walk_up * 2))
    applymovement(LOCALID_PIKE_CORRIDOR_ATTENDANT, moves(walk_up * 2,  walk_left,  face_down))
    waitmovement(0)
    lockall
    msgbox(BattleFrontier_BattlePikeCorridor_Text_YourChallengeHasBegun, MSGBOX_DEFAULT)
    closemessage
    releaseall
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 99)
    call(BattleFrontier_BattlePike_EventScript_CloseCurtain)
    warpsilent(MAP_BATTLE_FRONTIER_BATTLE_PIKE_THREE_PATH_ROOM, 6, 10)
    waitstate
    end
}

text BattleFrontier_BattlePikeCorridor_Text_YourChallengeHasBegun {
	"Your Battle Choice challenge
	has now begun…"
}
