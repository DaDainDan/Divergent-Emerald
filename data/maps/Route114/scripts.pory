mapscripts Route114_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_SHOULD_END_ABNORMAL_WEATHER) == 1) {
			call(AbnormalWeather_EventScript_HideMapNamePopup)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_114_NORTH || var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_114_SOUTH) {
			call(AbnormalWeather_StartGroudonWeather)
		}
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_114_NORTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute114North)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_114_SOUTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute114South)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SHOULD_END_ABNORMAL_WEATHER, 1: AbnormalWeather_EventScript_EndEventAndCleanup_1
    ]
}

script Route114_EventScript_Man {
    lock_faceplayer
    dotimebasedevents
    if (flag(FLAG_DAILY_ROUTE_114_RECEIVED_BERRY)) {
        msgbox(Route114_Text_FunToThinkAboutBerries, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(Route114_Text_LoveUsingBerryCrushShareBerry, MSGBOX_DEFAULT)
    giverandomberry(BERRY_ID_RAZZ, BERRY_ID_PINAP)
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_DAILY_ROUTE_114_RECEIVED_BERRY)
    msgbox(Route114_Text_TryBerryCrushWithFriends, MSGBOX_DEFAULT)
    release_end
}

script Route114_EventScript_RoarGentleman {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_TM_ROAR)) {
        msgbox(Route114_Text_ExplainRoar, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(Route114_Text_AllMyMonDoesIsRoarTakeThis, MSGBOX_DEFAULT)
    if (giveitem(ITEM_TM_ROAR) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_TM_ROAR)
    msgbox(Route114_Text_ExplainRoar, MSGBOX_DEFAULT)
    release_end
}

script Route114_EventScript_Poochyena {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_POOCHYENA, CRY_MODE_ENCOUNTER)
    msgbox(Route114_Text_Poochyena, MSGBOX_DEFAULT)
    waitmoncry
    release_end
}

