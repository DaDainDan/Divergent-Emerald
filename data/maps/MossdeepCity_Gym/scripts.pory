    lock_faceplayer
    if (flag(FLAG_DEFEATED_MOSSDEEP_GYM)) {
        msgbox(MossdeepCity_Gym_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MossdeepCity_Gym_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

