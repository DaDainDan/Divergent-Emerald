    goto(MossdeepCity_Gym_EventScript_GymStatue)
	end
}

script MossdeepCity_Gym_EventScript_GymStatue {
    if (flag(FLAG_BADGE07_GET)) {
        msgbox(MossdeepCity_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(MossdeepCity_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

script MossdeepCity_Gym_EventScript_YellowFloorSwitch {
	setvar(VAR_0x8007, 0)
    goto(MossdeepCity_Gym_EventScript_ActivateSwitch)
	end
}

script MossdeepCity_Gym_EventScript_BlueFloorSwitch {
	setvar(VAR_0x8007, 1)
    goto(MossdeepCity_Gym_EventScript_ActivateSwitch)
	end
}

script MossdeepCity_Gym_EventScript_GreenFloorSwitch {
	setvar(VAR_0x8007, 2)
    goto(MossdeepCity_Gym_EventScript_ActivateSwitch)
	end
}

script MossdeepCity_Gym_EventScript_PurpleFloorSwitch {
	setvar(VAR_0x8007, 3)
    goto(MossdeepCity_Gym_EventScript_ActivateSwitch)
	end
}

script MossdeepCity_Gym_EventScript_RedFloorSwitch {
	setvar(VAR_0x8007, 4)
	goto(MossdeepCity_Gym_EventScript_ActivateSwitch)
	end
}

script MossdeepCity_Gym_EventScript_ActivateSwitch {
	playse(SE_SWITCH)
    waitse
    playse(SE_REPEL)
    initrotatingtilepuzzle(FALSE)
	switch (var(VAR_0x8007)) {
		case 0: moverotatingtileobjects(0)
		case 1: moverotatingtileobjects(1)
		case 2: moverotatingtileobjects(2)
		case 3: moverotatingtileobjects(3)
		case 4: moverotatingtileobjects(4)
	}
	waitmovement(0)
    turnrotatingtileobjects
    waitmovement(0)
    freerotatingtilepuzzle
    end
}

text MossdeepCity_Gym_Text_GymGuideAdvice {
	"Yo, how's it going, CHAMPION-bound
	{PLAYER}?

	The GYM LEADERS here use
	PSYCHIC-type POKéMON.

	If you go up against them with
	FIGHTING- or POISON-type POKéMON,
	they'll inflict horrible damage!

	Plus, they'll come at you with
	outstanding combination attacks.

	If you want to win, you'll need to show
	them how tight you are with your
	POKéMON. Go for it!"
}

text MossdeepCity_Gym_Text_GymGuidePostVictory {
	"Wow, you're astounding!
	You're one great TRAINER!"
}

text MossdeepCity_Gym_Text_PrestonIntro {
	"Battles hinge on the strength of your
	spirit! The weak-spirited will never win!"
}

text MossdeepCity_Gym_Text_PrestonDefeat {
	"I lost!
	I must temper my spirit again!"
}

text MossdeepCity_Gym_Text_PrestonPostBattle {
	"The indecisive lose.
	That's my warning to you."
}

text MossdeepCity_Gym_Text_VirgilIntro {
	"Let me see your talent!"
}

text MossdeepCity_Gym_Text_VirgilDefeat {
	"You possess spectacular talent!"
}

text MossdeepCity_Gym_Text_VirgilPostBattle {
	"If there are prodigies in the world,
	then our GYM LEADERS are them!

	However, you may be even more talented
	than them…"
}

text MossdeepCity_Gym_Text_BlakeIntro {
	"Fufufufu… Watch me levitate a POKé
	BALL telekinetically!

	Wrooooooooaaaar!
	… … … … … … …

	Sometimes, I'm out of sync…"
}

text MossdeepCity_Gym_Text_BlakeDefeat {
	"My POKéMON battling skills are out
	of sync, too!"
}

text MossdeepCity_Gym_Text_BlakePostBattle {
	"A POKé BALL was too heavy to lift
	psychically. But this dust bunny…

	Whoooooooooooooooh!
	… … … … … …

	No, I'm not cheating!
	I didn't blow on it! Honestly!"
}

text MossdeepCity_Gym_Text_HannahIntro {
	"When you lose to me, don't be too hard
	on yourself.

	It's not that you're weak--I'm just
	too strong!"
}

text MossdeepCity_Gym_Text_HannahDefeat {
	"You're just too strong!"
}

text MossdeepCity_Gym_Text_HannahPostBattle {
	"I'm not going to get down on myself for
	losing. I just need to train harder.

	Positive thinking--that's my strong
	point!"
}

text MossdeepCity_Gym_Text_SamanthaIntro {
	"I see it…
	I see your future…

	If you can beat me, I will tell you
	your future!"
}

text MossdeepCity_Gym_Text_SamanthaDefeat {
	"I surrender!"
}

text MossdeepCity_Gym_Text_SamanthaPostBattle {
	"You will wage a terrifically intense
	battle with our GYM LEADERS…

	The result…
	You won't hear it from me!"
}

text MossdeepCity_Gym_Text_MauraIntro {
	"The roads you have traveled…
	What you have experienced…

	Come at me with everything you've
	learned!"
}

text MossdeepCity_Gym_Text_MauraDefeat {
	"You've traveled a path of greatness!"
}

text MossdeepCity_Gym_Text_MauraPostBattle {
	"A bright future awaits those who have
	worked diligently.

	For those who lazed idly, there is
	only despair at the end.

	What goes around comes around…"
}

text MossdeepCity_Gym_Text_SylviaIntro {
	"Even at the risk of life, I will win
	this battle!"
}

text MossdeepCity_Gym_Text_SylviaDefeat {
	"What you do…
	It horrifies me…"
}

text MossdeepCity_Gym_Text_SylviaPostBattle {
	"How dare you beat me…

	It won't be my fault if something
	horrible befalls you…"
}

text MossdeepCity_Gym_Text_NateIntro {
	"Hohoho.

	You need me to show you how tenacious
	the PSYCHIC type can be."
}

text MossdeepCity_Gym_Text_NateDefeat {
	"Oh! My, my!
	Your battle style is fantastic!"
}

text MossdeepCity_Gym_Text_NatePostBattle {
	"I… I don't let defeat rattle m-me,
	however b-badly."
}

text MossdeepCity_Gym_Text_KathleenIntro {
	"Let me show you a perfectly awful,
	horrifying time!"
}

text MossdeepCity_Gym_Text_KathleenDefeat {
	"N-nooooo!"
}

text MossdeepCity_Gym_Text_KathleenPostBattle {
	"Your vitality is contagious!
	Get away from me quickly!"
}

text MossdeepCity_Gym_Text_CliffordIntro {
	"I may be past my prime, but I suggest
	you not patronize me."
}

text MossdeepCity_Gym_Text_CliffordDefeat {
	"Ah, you overflow with the power
	of youth!"
}

text MossdeepCity_Gym_Text_CliffordPostBattle {
	"It seems that I could not overcome
	your youthful energy."
}

text MossdeepCity_Gym_Text_MaceyIntro {
	"You're not getting through to the end!
	Not if I can help it!"
}

text MossdeepCity_Gym_Text_MaceyDefeat {
	"How could you be so ludicrously
	strong?"
}

text MossdeepCity_Gym_Text_MaceyPostBattle {
	"Humph! You may be strong, but you're
	not suitable for the PSYCHIC type!

	The way you battle is somehow brutal!"
}

text MossdeepCity_Gym_Text_NicholasIntro {
	"Wroooar! Have a taste of my super
	POKéMON hard-battling power!"
}

text MossdeepCity_Gym_Text_NicholasDefeat {
	"Oh!
	Done in!"
}

text MossdeepCity_Gym_Text_NicholasPostBattle {
	"All right! I think I'll develop a special
	invincible POKéMON power next."
}

text MossdeepCity_Gym_Text_TateAndLizaIntro {
	"TATE: Hehehe… Were you surprised?

	LIZA: Fufufu… Were you surprised?

	TATE: That there are two GYM LEADERS?
	LIZA: That there are two GYM LEADERS?

	TATE: We're twins!
	LIZA: We're twins!

	TATE: We don't need to talk because…
	LIZA: We can each determine what…

	TATE: The other is thinking…
	LIZA: All in our minds!

	TATE: This combination of ours…
	LIZA: Can you beat it?"
}

text MossdeepCity_Gym_Text_TateAndLizaDefeat {
	"TATE: What?! Our combination…
	LIZA: Was shattered!

	TATE: It can't be helped. You've won…
	LIZA: So, in recognition, take this."
}

text MossdeepCity_Gym_Text_ReceivedMindBadge {
	"{PLAYER} received the MIND BADGE
	from TATE and LIZA."
}

text MossdeepCity_Gym_Text_ExplainMindBadgeTakeThis {
	"TATE: The MIND BADGE enhances the
	SP. ATK and SP. DEF of POKéMON.

	LIZA: It also lets you use the HM move
	DIVE outside of battle.

	TATE: You should also take this, too."
}

text MossdeepCity_Gym_Text_ExplainCalmMind {
	"TATE: That TM04 contains…
	LIZA: CALM MIND!

	TATE: It raises SP. ATK and…
	LIZA: It raises SP. DEF!

	TATE: It's a move that's perfect…
	LIZA: For PSYCHIC POKéMON!

	… … … … … …"
}

text MossdeepCity_Gym_Text_RegisteredTateAndLiza {
	"Registered GYM LEADERS TATE & LIZA
	in the POKéNAV."
}

text MossdeepCity_Gym_Text_TateAndLizaPostBattle {
	"TATE: Looks like the bond between you
	and your POKéMON is far stronger than
	the bond that we share as twins.

	LIZA: You will become even stronger!
	We've battled you, so we know."
}

text MossdeepCity_Gym_Text_TateAndLizaNeedTwoMons {
	"TATE: Hehehe… Were you surprised?

	LIZA: That there are two GYM LEADERS?

	TATE: Oops, you have only one…
	LIZA: POKéMON that can battle.

	TATE: We can't battle that way!

	LIZA: If you want to challenge us,
	bring some more POKéMON."
}

text MossdeepCity_Gym_Text_GymStatue {
	"MOSSDEEP CITY POKéMON GYM"
}

text MossdeepCity_Gym_Text_GymStatueCertified {
	"MOSSDEEP CITY POKéMON GYM

	LIZA AND TATE'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text MossdeepCity_Gym_Text_TateAndLizaPreRematch {
	"TATE: POKéMON…
	LIZA: POKéMON…

	TATE: By changing the party's mix…
	LIZA: The battle style changes.

	TATE: But me…
	LIZA: But me…

	TATE: I'll always be with LIZA!
	LIZA: I'll always be with TATE!

	TATE: Our combination…
	LIZA: We'll show you again and again!"
}

text MossdeepCity_Gym_Text_TateAndLizaRematchDefeat {
	"TATE: You and your POKéMON…
	LIZA: It's as if you were siblings!"
}

text MossdeepCity_Gym_Text_TateAndLizaPostRematch {
	"TATE: You can knock us down,
	but we'll never stay down!

	LIZA: Because the two of us,
	we always support each other!"
}

text MossdeepCity_Gym_Text_TateAndLizaRematchNeedTwoMons {
	"TATE: You're back again…
	LIZA: You're back again…

	TATE: To give us a rematch.
	LIZA: To give us a rematch.

	TATE: But…
	LIZA: For our match…

	TATE: You brought just one POKéMON!
	LIZA: You brought just one POKéMON!

	TATE: We need you to bring at least…
	LIZA: Two POKéMON when you come back."
}
