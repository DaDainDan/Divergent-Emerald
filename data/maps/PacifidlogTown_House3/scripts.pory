mapscripts PacifidlogTown_House3_MapScripts {}

script PacifidlogTown_House3_EventScript_Trader {
    lock_faceplayer
    if (flag(FLAG_PACIFIDLOG_NPC_TRADE_COMPLETED)) {
        msgbox(PacifidlogTown_House3_Text_ReallyWantedToGetBagon, MSGBOX_DEFAULT)
    	release_end
    }
    ingame_trade(INGAME_TRADE_HORSEA, PacifidlogTown_House3_Text_WillingToTradeIt, PacifidlogTown_House3_EventScript_DeclineTrade, PacifidlogTown_House3_EventScript_NotRequestedMon, PacifidlogTown_House3_Text_ItsSubtlyDifferentThankYou)
    setflag(FLAG_PACIFIDLOG_NPC_TRADE_COMPLETED)
    release_end
}

script PacifidlogTown_House3_EventScript_DeclineTrade {
    msgbox(PacifidlogTown_House3_Text_NotDesperateOrAnything, MSGBOX_DEFAULT)
    release_end
}

script PacifidlogTown_House3_EventScript_NotRequestedMon {
    bufferspeciesname(STR_VAR_1, VAR_0x8009)
    msgbox(PacifidlogTown_House3_Text_WontAcceptAnyLessThanRealMon, MSGBOX_DEFAULT)
    release_end
}

script PacifidlogTown_House3_EventScript_Girl {
    msgbox(PacifidlogTown_House3_Text_IsThatAPokedex, MSGBOX_NPC)
    end
}

text PacifidlogTown_House3_Text_WillingToTradeIt {
	"Check out this {STR_VAR_2}!

	It's the {STR_VAR_2} that I caught
	yesterday to celebrate my birthday!

	Oh, I can see that you want it!
	After all, it's priceless!

	I'll tell you what. I might be willing
	to trade it for a {STR_VAR_1}."
}

text PacifidlogTown_House3_Text_ItsSubtlyDifferentThankYou {
	"Oh, so this is a {STR_VAR_1}?

	It's sort of like a {STR_VAR_2},
	and yet it's subtly different.

	Thank you!"
}

text PacifidlogTown_House3_Text_WontAcceptAnyLessThanRealMon {
	"No, no, no! I won't accept any
	less than a real {STR_VAR_1}!"
}

text PacifidlogTown_House3_Text_NotDesperateOrAnything {
	"Oh, so you're not going to go through
	with this?

	That's cool. I'm not desperate to make
	a trade or anything."
}

text PacifidlogTown_House3_Text_ReallyWantedToGetBagon {
	"I know I could go looking for one
	on my own, but…

	But I really wanted to get a BAGON
	that another TRAINER caught…"
}

text PacifidlogTown_House3_Text_IsThatAPokedex {
	"Is that a POKéDEX?

	Did you get to meet a lot of different
	POKéMON?

	I wish I was like you."
}
