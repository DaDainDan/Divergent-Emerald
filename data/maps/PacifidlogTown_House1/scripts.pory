mapscripts PacifidlogTown_House1_MapScripts {}

script PacifidlogTown_House1_EventScript_Man {
    msgbox(PacifidlogTown_House1_Text_RegiStory, MSGBOX_NPC)
    end
}

script PacifidlogTown_House1_EventScript_Woman {
    msgbox(PacifidlogTown_House1_Text_SixDotsOpenThreeDoors, MSGBOX_NPC)
    end
}

text PacifidlogTown_House1_Text_RegiStory {
	"In the HOENN region, there are three
	POKéMON that represent the power of
	rock, ice, and steel.

	Each of them is said to hide away deep
	inside caves.

	That's the story I heard when I was
	just a little kid."
}

text PacifidlogTown_House1_Text_SixDotsOpenThreeDoors {
	"“Six dots open three doors.”

	Grandpa used to say that, but I don't
	know what he meant."
}
