script Route113_EventScript_Jaylen {
    trainerbattle_single(TRAINER_JAYLEN, Route113_Text_JaylenIntro, Route113_Text_JaylenDefeat)
    msgbox(Route113_Text_JaylenPostBattle, MSGBOX_AUTOCLOSE)
    end
}

