text Route113_Text_AshCanBeFashionedIntoGlass {
	"Wahahaha! Today's technology is a
	wondrous thing!

	Take this volcanic ash here.
	It can be fashioned into glass."
}

text Route113_Text_FunWalkingThroughAsh {
	"It's fun walking through the volcano's
	ashes on the ground and grass.

	You can see where you walked--it's
	really neat!"
}

text Route113_Text_RouteSign111 {
	"ROUTE 113
	{RIGHT_ARROW} ROUTE 111"
}

text Route113_Text_RouteSignFallarbor {
	"ROUTE 113
	{LEFT_ARROW} FALLARBOR TOWN"
}

text Route113_Text_TrainerTipsRegisterKeyItems {
	"TRAINER TIPS

	You may register one of the KEY ITEMS
	in your BAG as SELECT.

	Simply press SELECT to use
	the registered item conveniently."
}

text Route113_Text_GlassWorkshopSign {
	"GLASS WORKSHOP
	“Turning Volcanic Ash into Glass Items”"
}
