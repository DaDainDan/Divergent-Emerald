text SaffronCity_Text_WhatDoYouWantGetLost {
	"What do you want?
	Get lost!"
}

text SaffronCity_Text_BossTakeTownForTeamRocket {
	"BOSS said he'll take this town
	in the name of TEAM ROCKET!"
}

text SaffronCity_Text_DontGetDefiantOrIllHurtYou {
	"Don't get defiant!
	Or I'll have to hurt you!"
}

text SaffronCity_Text_SaffronBelongsToTeamRocket {
	"SAFFRON belongs to TEAM ROCKET!"
}

text SaffronCity_Text_CriminalLifeMakesMeFeelAlive {
	"My life as a criminal makes me feel
	so alive!"
}

text SaffronCity_Text_WatchWhereYoureWalking {
	"Ow!
	Watch where you're walking!"
}

text SaffronCity_Text_WeCanExploitMonsAroundWorld {
	"With SILPH under control, we can
	exploit POKéMON around the world!

	We'll get stinking rich, yeahah!"
}

text SaffronCity_Text_YouBeatTeamRocket {
	"You beat TEAM ROCKET all alone?
	That's amazing!"
}

text SaffronCity_Text_SafeToGoOutAgain {
	"Yeah! TEAM ROCKET is gone!
	It's safe to go out again!"
}

text SaffronCity_Text_PeopleComingBackToSaffron {
	"People fled from here in droves
	when those ROCKETS came.

	They should be flocking back to
	SAFFRON now."
}

text SaffronCity_Text_FlewHereOnPidgeot {
	"I flew here on my PIDGEOT when
	I read about SILPH.

	It's already over?
	I missed the media action…"
}

text SaffronCity_Text_Pidgeot {
	"PIDGEOT: Bi bibii!"
}

text SaffronCity_Text_SawRocketBossEscaping {
	"I saw the ROCKET BOSS escaping
	SILPH's building."
}

text SaffronCity_Text_ImASecurityGuard {
	"I'm a security guard.

	Suspicious kids I don't allow in!"
}

text SaffronCity_Text_HesTakingASnooze {
	"…
	Snore…

	Hah! He's taking a snooze!"
}

text SaffronCity_Text_CitySign {
	"SAFFRON CITY
	Shining, Golden Land of Commerce"
}

text SaffronCity_Text_FightingDojo {
	"FIGHTING DOJO"
}

text SaffronCity_Text_GymSign {
	"SAFFRON CITY POKéMON GYM
	LEADER: SABRINA
	The Master of PSYCHIC POKéMON!"
}

text SaffronCity_Text_FullHealCuresStatus {
	"TRAINER TIPS

	FULL HEAL cures all ailments like
	burns, paralysis, poisoning,
	freezing, and sleep.

	It costs a bit more, but it's more
	convenient than buying other items."
}

text SaffronCity_Text_GreatBallImprovedCatchRate {
	"TRAINER TIPS

	The new GREAT BALL offers improved
	catching rates.

	Try it on those hard-to-catch
	POKéMON."
}

text SaffronCity_Text_SilphCoSign {
	"SILPH CO. OFFICE BUILDING"
}

text SaffronCity_Text_MrPsychicsHouse {
	"MR. PSYCHIC'S HOUSE"
}

text SaffronCity_Text_SilphsLatestProduct {
	"SILPH's latest product!
	Release to be determined…"
}

text SaffronCity_Text_TrainerFanClubSign {
	"POKéMON TRAINER FAN CLUB

	Many TRAINERS have scribbled their
	names on this sign."
}

text SaffronCity_Text_HowCanClubNotRecognizeLance {
	"This FAN CLUB…
	No one here has a clue!

	How could they not recognize
	the brilliance that is LANCE?

	He stands for justice!
	He's cool, and yet passionate!
	He's the greatest, LANCE!"
}
