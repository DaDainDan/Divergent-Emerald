script SaffronCity_EventScript_Pidgeot {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PIDGEOT, CRY_MODE_NORMAL)
    msgbox(SaffronCity_Text_Pidgeot)
    waitmoncry
    release_end
}

