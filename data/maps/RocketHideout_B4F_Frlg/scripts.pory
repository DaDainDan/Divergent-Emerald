const NUM_DOOR_GRUNTS_DEFEATED = VAR_TEMP_1

mapscripts RocketHideout_B4F_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        setvar(NUM_DOOR_GRUNTS_DEFEATED, 0)
		if (defeated(TRAINER_TEAM_ROCKET_GRUNT_16)) {
			addvar(NUM_DOOR_GRUNTS_DEFEATED, 1)
		}
		if (defeated(TRAINER_TEAM_ROCKET_GRUNT_17)) {
			addvar(NUM_DOOR_GRUNTS_DEFEATED, 1)
		}
		if (var(NUM_DOOR_GRUNTS_DEFEATED) != 2) {
			setmetatile(17, 12, METATILE_SilphCo_HideoutBarrier_TopLeft_Floor, 1)
			setmetatile(18, 12, METATILE_SilphCo_HideoutBarrier_TopRight_Floor, 1)
			setmetatile(17, 13, METATILE_SilphCo_HideoutBarrier_BottomLeft, 1)
			setmetatile(18, 13, METATILE_SilphCo_HideoutBarrier_BottomRight, 1)
			setmetatile(17, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0)
			setmetatile(18, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0)
		}
		end
    }
}

script RocketHideout_B4F_EventScript_Giovanni {
    lock_faceplayer
    famechecker(FAMECHECKER_GIOVANNI, 0)
    message(RocketHideout_B4F_Text_GiovanniIntro)
    waitmessage
    playbgm(MUS_RG_ENCOUNTER_ROCKET, 0)
    waitbuttonpress
    trainerbattle_no_intro(TRAINER_BOSS_GIOVANNI, RocketHideout_B4F_Text_GiovanniDefeat)
    msgbox(RocketHideout_B4F_Text_GiovanniPostBattle)
    fadescreen(FADE_TO_BLACK)
    closemessage
    removeobject(LOCALID_HIDEOUT_GIOVANNI)
    addobject(LOCALID_SILPH_SCOPE)
    clearflag(FLAG_HIDE_SILPH_SCOPE)
    setflag(FLAG_HIDE_CELADON_ROCKETS)
    famechecker(FAMECHECKER_GIOVANNI, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    fadescreen(FADE_FROM_BLACK)
    release_end
}

script RocketHideout_B4F_EventScript_SilphScope {
    lock_faceplayer
    removeobject(LOCALID_SILPH_SCOPE)
    if (giveitem(ITEM_SILPH_SCOPE) == FALSE) {
        goto(EventScript_BagIsFull)
    }
    release_end
}

script RocketHideout_B4F_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_18, RocketHideout_B4F_Text_Grunt1Intro, RocketHideout_B4F_Text_Grunt1Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt1)
    msgbox(RocketHideout_B4F_Text_Grunt1PostBattle)
    release_end
}

script RocketHideout_B4F_EventScript_DefeatedGrunt1 {
    msgbox(RocketHideout_B4F_Text_Grunt1PostBattle)
    addobject(LOCALID_LIFT_KEY)
    clearflag(FLAG_HIDE_LIFT_KEY)
    release_end
}

script RocketHideout_B4F_EventScript_LiftKey {
    lock_faceplayer
    setflag(FLAG_CAN_USE_ROCKET_HIDEOUT_LIFT)
    removeobject(LOCALID_LIFT_KEY)
    if (giveitem(ITEM_LIFT_KEY) == FALSE) {
        goto(EventScript_BagIsFull)
    }
    release_end
}

script RocketHideout_B4F_EventScript_Grunt2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_16, RocketHideout_B4F_Text_Grunt2Intro, RocketHideout_B4F_Text_Grunt2Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt)
    msgbox(RocketHideout_B4F_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RocketHideout_B4F_EventScript_Grunt3 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_17, RocketHideout_B4F_Text_Grunt3Intro, RocketHideout_B4F_Text_Grunt3Defeat, RocketHideout_B4F_EventScript_DefeatedGrunt)
    msgbox(RocketHideout_B4F_Text_Grunt3PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RocketHideout_B4F_EventScript_DefeatedGrunt {
    setvar(NUM_DOOR_GRUNTS_DEFEATED, 0)
    if (defeated(TRAINER_TEAM_ROCKET_GRUNT_16)) {
        addvar(NUM_DOOR_GRUNTS_DEFEATED, 1)
    }
    if (defeated(TRAINER_TEAM_ROCKET_GRUNT_17)) {
        addvar(NUM_DOOR_GRUNTS_DEFEATED, 1)
    }
    if (var(NUM_DOOR_GRUNTS_DEFEATED) == 2) {
        setmetatile(17, 12, METATILE_SilphCo_HideoutFloor_ShadeFull, 0)
		setmetatile(18, 12, METATILE_SilphCo_HideoutFloor, 0)
		setmetatile(17, 13, METATILE_SilphCo_HideoutFloor_ShadeFull, 0)
		setmetatile(18, 13, METATILE_SilphCo_HideoutFloor, 0)
		setmetatile(17, 14, METATILE_SilphCo_HideoutFloor_ShadeFull, 0)
		setmetatile(18, 14, METATILE_SilphCo_HideoutFloor, 0)
		playse(SE_UNLOCK)
		special(DrawWholeMapView)
		waitse
    }
    release_end
}

text RocketHideout_B4F_Text_GiovanniIntro {
	"So! I must say, I am impressed you
	got here.

	TEAM ROCKET captures POKéMON from
	around the world.

	They're important tools for keeping
	our criminal enterprise going.

	I am the leader, GIOVANNI!

	For your insolence, you will feel a
	world of pain!"
}

text RocketHideout_B4F_Text_GiovanniDefeat {
	"WHAT!
	This can't be!"
}

text RocketHideout_B4F_Text_GiovanniPostBattle {
	"I see that you raise POKéMON with
	utmost care.

	A child like you would never
	understand what I hope to achieve.

	I shall step aside this time!

	I hope we meet again…"
}

text RocketHideout_B4F_Text_Grunt2Intro {
	"I know you!
	You ruined our plans at MT. MOON!"
}

text RocketHideout_B4F_Text_Grunt2Defeat {
	"Burned again!"
}

text RocketHideout_B4F_Text_Grunt2PostBattle {
	"Do you have something against TEAM
	ROCKET?"
}

text RocketHideout_B4F_Text_Grunt3Intro {
	"How can you not see the beauty of
	our evil?"
}

text RocketHideout_B4F_Text_Grunt3Defeat {
	"Ayaya!"
}

text RocketHideout_B4F_Text_Grunt3PostBattle {
	"BOSS!
	I'm sorry I failed you!"
}

text RocketHideout_B4F_Text_Grunt1Intro {
	"The elevator doesn't work?
	Who has the LIFT KEY?"
}

text RocketHideout_B4F_Text_Grunt1Defeat {
	"No!"
}

text RocketHideout_B4F_Text_Grunt1PostBattle {
	"Oh, no!
	I dropped the LIFT KEY!"
}
