mapscripts VermilionCity_House1_Frlg_MapScripts {}

script VermilionCity_House1_EventScript_FishingGuru {
    lock_faceplayer
    if (flag(FLAG_GOT_OLD_ROD)) {
        msgbox(VermilionCity_House1_Text_HowAreTheFishBiting)
    	release_end
    }
    msgbox(VermilionCity_House1_Text_ImFishingGuruDoYouLikeToFish, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        if (checkitemspace(ITEM_OLD_ROD) == FALSE) {
			msgbox(VermilionCity_House1_Text_NoRoomForNiceGift)
    		release_end
		}
		additem(ITEM_OLD_ROD)
		msgbox(VermilionCity_House1_Text_TakeThisAndFish)
		msgreceiveditem(VermilionCity_House1_Text_ReceivedOldRodFromFishingGuru, ITEM_OLD_ROD)
		setflag(FLAG_GOT_OLD_ROD)
		msgbox(VermilionCity_House1_Text_FishingIsAWayOfLife)
		release_end
    }
    msgbox(VermilionCity_House1_Text_OhThatsSoDisappointing)
    release_end
}

text VermilionCity_House1_Text_ImFishingGuruDoYouLikeToFish {
	"I'm the FISHING GURU!

	I simply looove fishing!
	I can't bear to go without.

	Tell me, do you like to fish?"
}

text VermilionCity_House1_Text_TakeThisAndFish {
	"Grand! I like your style.
	I think we can be friends.

	Take this and fish, young friend!"
}

text VermilionCity_House1_Text_ReceivedOldRodFromFishingGuru {
	"{PLAYER} received an OLD ROD from
	the FISHING GURU."
}

text VermilionCity_House1_Text_FishingIsAWayOfLife {
	"Fishing is a way of life!
	It is like the finest poetry.

	From the seas to rivers, go out
	and land the big one, my friend."
}

text VermilionCity_House1_Text_OhThatsSoDisappointing {
	"Oh…
	That's so disappointing…"
}

text VermilionCity_House1_Text_HowAreTheFishBiting {
	"Hello there, {PLAYER}!

	How are the fish biting?"
}

text VermilionCity_House1_Text_NoRoomForNiceGift {
	"Oh, no!

	I had a nice gift for you, but you
	have no room for it!"
}
