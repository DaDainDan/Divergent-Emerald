mapscripts SafariZone_North_RestHouse_Frlg_MapScripts {}

script SafariZone_North_RestHouse_EventScript_Fisher {
    msgbox(SafariZone_East_Text_PrizeInDeepestPartOfSafariZone, MSGBOX_NPC)
    end
}

script SafariZone_North_RestHouse_EventScript_Scientist {
    msgbox(SafariZone_East_Text_KeepAnyItemFoundOnSafari, MSGBOX_NPC)
    end
}

script SafariZone_North_RestHouse_EventScript_Gentleman {
    msgbox(SafariZone_East_Text_MyEeveeEvolvedIntoFlareon, MSGBOX_NPC)
    end
}

text SafariZone_East_Text_KeepAnyItemFoundOnSafari {
	"You can keep any item you find in
	the SAFARI ZONE.

	But, you'll run out of time if you
	try for all of them at once."
}

text SafariZone_East_Text_PrizeInDeepestPartOfSafariZone {
	"Go to the deepest part of the
	SAFARI ZONE. You will win a prize!"
}

text SafariZone_East_Text_MyEeveeEvolvedIntoFlareon {
	"My EEVEE evolved into FLAREON.

	But, a friend's EEVEE turned into a
	VAPOREON. I wonder why?"
}
