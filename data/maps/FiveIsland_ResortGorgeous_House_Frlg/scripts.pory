const SHOWN_REQUESTED_MON = FLAG_TEMP_2

mapscripts FiveIsland_ResortGorgeous_House_Frlg_MapScripts {}

script FiveIsland_ResortGorgeous_House_EventScript_Selphy {
    lock_faceplayer
    if (flag(SHOWN_REQUESTED_MON)) {
        msgbox(FiveIsland_ResortGorgeous_House_Text_SelphyWishYouBestOfLuck)
    	release_end
    }
    if (var(VAR_RESORT_GORGEOUS_REQUESTED_MON) == 0xFFFF) {
        msgbox(FiveIsland_ResortGorgeous_House_Text_OhImTiredOfWaiting)
    }
    elif (var(VAR_RESORT_GORGEOUS_REQUESTED_MON) != SPECIES_NONE) {
        copyvar(VAR_0x8004, VAR_RESORT_GORGEOUS_REQUESTED_MON)
		if (specialvar(VAR_RESULT, DoesPlayerPartyContainSpecies) == TRUE) {
			goto(FiveIsland_ResortGorgeous_House_EventScript_ShowRequestedMon)
		}
    }
	else {
		msgbox(FiveIsland_ResortGorgeous_House_Text_PleaseHearMyWish)
	}
    special(SampleResortGorgeousMonAndReward)
    msgbox(FiveIsland_ResortGorgeous_House_Text_WishToSeeMonPlease)
    release_end
}

script FiveIsland_ResortGorgeous_House_EventScript_ShowRequestedMon {
    special(SampleResortGorgeousMonAndReward)
    msgbox(FiveIsland_ResortGorgeous_House_Text_MonYouCaughtForMeThankYou)
    addobject(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER)
    applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER, Common_Movement_StepDown)
    waitmovement(0)
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(FiveIsland_ResortGorgeous_House_Text_ButlerYesMyLady)
    applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_SELPHY, Common_Movement_StepFasterUp)
    waitmovement(0)
    textcolor(NPC_TEXT_COLOR_FEMALE)
    msgbox(FiveIsland_ResortGorgeous_House_Text_SelphyGiveTokenOfAppreciation)
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(FiveIsland_ResortGorgeous_House_Text_ButlerIShallDoAsYouBid)
    closemessage
	switch (var(VAR_FACING)) {
		// Very odd. If the player is talking to Selphy facing West, then the player has clipped through the table
		// In this case rather than approach the player the Butler walks up, which clips the Butler into a wall
		case DIR_WEST: applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER, Common_Movement_WalkUp)
		case DIR_NORTH:
			applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_SELPHY, Common_Movement_StepFasterDown)
			applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER, moves(walk_left * 3,  walk_down * 3,  step_faster_right))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
		case DIR_SOUTH:
			applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER, moves(walk_left * 2,  step_faster_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
		case DIR_EAST:
			applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_SELPHY, Common_Movement_StepFasterLeft)
			applymovement(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER, moves(walk_left * 3,  walk_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
	}
	waitmovement(0)
    copyobjectxytoperm(LOCALID_RESORT_GORGEOUS_HOUSE_BUTLER)
    msgbox(FiveIsland_ResortGorgeous_House_Text_ButlerPleaseAcceptThisAsHerThanks)
    if (giveitem(VAR_RESORT_GORGEOUS_REWARD) == FALSE) {
        textcolor(NPC_TEXT_COLOR_MALE)
		msgbox(FiveIsland_ResortGorgeous_House_Text_ButlerBagAppearsToBeFull)
		textcolor(NPC_TEXT_COLOR_FEMALE)
		msgbox(FiveIsland_ResortGorgeous_House_Text_OhHowDisappointing)
		setflag(SHOWN_REQUESTED_MON)
		setvar(VAR_RESORT_GORGEOUS_REQUESTED_MON, SPECIES_NONE)
		release_end
    }
    setflag(SHOWN_REQUESTED_MON)
    setvar(VAR_RESORT_GORGEOUS_REQUESTED_MON, SPECIES_NONE)
    release_end
}

// Addressed as "Sebastian" but speaks only as "Butler"
script FiveIsland_ResortGorgeous_House_EventScript_Butler {
    msgbox(FiveIsland_ResortGorgeous_House_Text_LadySelphySmileHasBrillianceOfSun, MSGBOX_NPC)
    end
}

text FiveIsland_ResortGorgeous_House_Text_PleaseHearMyWish {
	"SELPHY: Oh?
	Do I know you from somewhere?

	Oh, but that doesn't matter.

	I am exquisitely bored.
	Please, hear my wish."
}

text FiveIsland_ResortGorgeous_House_Text_WishToSeeMonPlease {
	"I wish to see a POKéMON.
	A darling {STR_VAR_1}.

	I want to see one right away.
	Please, make my wish come true."
}

text FiveIsland_ResortGorgeous_House_Text_OhImTiredOfWaiting {
	"SELPHY: Oh, I'm tired of this.
	I'm tired of waiting for you.

	I'll forgive you this time, but
	please don't fail me next time."
}

text FiveIsland_ResortGorgeous_House_Text_MonYouCaughtForMeThankYou {
	"SELPHY: Oh, hello, there.

	Oh, my gracious. That must be the
	{STR_VAR_1} you caught for me.

	Giggle…
	I see a resemblance to you.

	Thank you so kindly.

	… …  … …  … …
	Is something the matter?

	You may leave.

	… …  … …  … …
	Oh, fine. I understand now.

	SEBASTIAN!
	I need you here this instant!"
}

text FiveIsland_ResortGorgeous_House_Text_ButlerYesMyLady {
	"Butler: Yes, my lady."
}

text FiveIsland_ResortGorgeous_House_Text_SelphyGiveTokenOfAppreciation {
	"SELPHY: See to it that this person
	is given a token of appreciation."
}

text FiveIsland_ResortGorgeous_House_Text_ButlerIShallDoAsYouBid {
	"Butler: I shall do as you bid,
	my lady."
}

text FiveIsland_ResortGorgeous_House_Text_ButlerPleaseAcceptThisAsHerThanks {
	"Butler: I sincerely thank you for
	pleasing Lady SELPHY.

	Please accept this as her thanks…"
}

text FiveIsland_ResortGorgeous_House_Text_ButlerBagAppearsToBeFull {
	"Butler: Your BAG appears to be
	unfortunately full."
}

text FiveIsland_ResortGorgeous_House_Text_OhHowDisappointing {
	"Oh…
	How disappointing."
}

text FiveIsland_ResortGorgeous_House_Text_SelphyWishYouBestOfLuck {
	"SELPHY: I wish you the best of
	luck."
}

text FiveIsland_ResortGorgeous_House_Text_LadySelphySmileHasBrillianceOfSun {
	"Butler: The smile of Lady SELPHY
	has the brilliance of the sun.

	Please, I beg you to bring joy
	to Lady SELPHY."
}
