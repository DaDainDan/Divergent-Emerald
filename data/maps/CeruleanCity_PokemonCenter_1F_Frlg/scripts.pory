mapscripts CeruleanCity_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_CERULEAN_CITY)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script CeruleanCity_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script CeruleanCity_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(CeruleanCity_PokemonCenter_1F_Text_EveryoneCallsBillPokemaniac, MSGBOX_NPC)
    end
}

script CeruleanCity_PokemonCenter_1F_EventScript_Rocker {
    msgbox(CeruleanCity_PokemonCenter_1F_Text_BillDoesWhateverForRareMons, MSGBOX_NPC)
    end
}

script CeruleanCity_PokemonCenter_1F_EventScript_Youngster {
    lock_faceplayer
    famechecker(FAMECHECKER_BILL, 1)
    msgbox(CeruleanCity_PokemonCenter_1F_Text_BillCollectsRareMons)
    release_end
}

script CeruleanCity_PokemonCenter_1F_EventScript_Lass {
    msgbox(CeruleanCity_PokemonCenter_1F_Text_TryTradingUpstairs, MSGBOX_NPC)
    end
}

text CeruleanCity_PokemonCenter_1F_Text_BillDoesWhateverForRareMons {
	"That BILL!

	I heard that he'll do whatever it
	takes to get rare POKéMON.

	He's not above doing all sorts
	of things, I've heard."
}

text CeruleanCity_PokemonCenter_1F_Text_EveryoneCallsBillPokemaniac {
	"Have you heard about BILL?

	Everyone calls him a POKéMANIAC!

	I think people are just jealous of
	BILL, though.

	Who wouldn't want to boast about
	their POKéMON?"
}

text CeruleanCity_PokemonCenter_1F_Text_BillCollectsRareMons {
	"BILL has lots of POKéMON!
	He collects rare ones, too!"
}

text CeruleanCity_PokemonCenter_1F_Text_TryTradingUpstairs {
	"Why don't you go upstairs and try
	trading POKéMON with your friends?

	You could get a lot more variety
	by trading.

	The POKéMON you get in trades grow
	quickly, too."
}
