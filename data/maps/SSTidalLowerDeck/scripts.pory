mapscripts SSTidalLowerDeck_MapScripts {}

script SSTidalLowerDeck_EventScript_Phillip {
    trainerbattle_single(TRAINER_PHILLIP, SSTidalLowerDeck_Text_PhillipIntro, SSTidalLowerDeck_Text_PhillipDefeat)
    msgbox(SSTidalLowerDeck_Text_PhillipPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SSTidalLowerDeck_EventScript_Leonard {
    trainerbattle_single(TRAINER_LEONARD, SSTidalLowerDeck_Text_LeonardIntro, SSTidalLowerDeck_Text_LeonardDefeat)
    msgbox(SSTidalLowerDeck_Text_LeonardPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SSTidalLowerDeck_Text_PhillipIntro {
	"Arrrgh! I'm fed up and dog-tired of
	cleaning this huge place!

	Let's have a quick battle!"
}

text SSTidalLowerDeck_Text_PhillipDefeat {
	"Little bro, I lost!"
}

text SSTidalLowerDeck_Text_PhillipPostBattle {
	"We're the CLEANUP BROTHERS!

	The old one dumps the detergent,
	and the young one does the scrubbing!"
}

text SSTidalLowerDeck_Text_LeonardIntro {
	"This is the bottom of the ship's hull.
	There's plenty of room.
	It'll be alright for a POKéMON battle."
}

text SSTidalLowerDeck_Text_LeonardDefeat {
	"Big bro, I lost!"
}

text SSTidalLowerDeck_Text_LeonardPostBattle {
	"We're the CLEANUP BROTHERS!

	The old one dumps the detergent,
	and the young one does the scrubbing!"
}
