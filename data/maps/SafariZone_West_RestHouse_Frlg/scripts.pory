mapscripts SafariZone_West_RestHouse_Frlg_MapScripts {}

script SafariZone_West_RestHouse_EventScript_Man {
    msgbox(SafariZone_West_Text_BaitMakesMonStickAround, MSGBOX_NPC)
    end
}

script SafariZone_West_RestHouse_EventScript_Scientist {
    msgbox(SafariZone_West_Text_RocksMakeMonRunButEasierCatch, MSGBOX_NPC)
    end
}

script SafariZone_West_RestHouse_EventScript_CooltrainerF {
    msgbox(SafariZone_West_Text_HikedLotsDidntSeeMonIWanted, MSGBOX_NPC)
    end
}

text SafariZone_West_Text_KogaPatrolsSafariEverySoOften {
	"The SAFARI ZONE's huge, wouldn't
	you say?

	FUCHSIA's GYM LEADER, KOGA, 
	patrols the grounds every so often.

	Thanks to him, we can play here
	knowing that we're safe."
}

text SafariZone_West_Text_RocksMakeMonRunButEasierCatch {
	"Tossing ROCKS at POKéMON might
	make them run, but they'll be
	easier to catch."
}

text SafariZone_West_Text_BaitMakesMonStickAround {
	"Using BAIT will make POKéMON more
	likely to stick around if they get
	busy eating."
}

text SafariZone_West_Text_HikedLotsDidntSeeMonIWanted {
	"I hiked a lot, but I didn't see any
	POKéMON I wanted."
}
