mapscripts RustboroCity_Flat1_2F_MapScripts {}

script RustboroCity_Flat1_2F_EventScript_WaldasDad {
    lock_faceplayer
    if (specialvar(VAR_RESULT, TryBufferWaldaPhrase) == FALSE) {
		msgbox(RustboroCity_Flat1_2F_Text_HelloDoYouKnowFunnyPhrase, MSGBOX_YESNO)
	} else {
		msgbox(RustboroCity_Flat1_2F_Text_BeenSayingXDoYouKnowBetterPhrase, MSGBOX_YESNO)
	}
    if (var(VAR_RESULT) == NO) {
        msgbox(RustboroCity_Flat1_2F_Text_OhIsThatRight, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_Flat1_2F_Text_WonderfulLetsHearSuggestion, MSGBOX_DEFAULT)
    goto(RustboroCity_Flat1_2F_EventScript_GivePhrase)
}

script RustboroCity_Flat1_2F_EventScript_GivePhrase {
    special(DoWaldaNamingScreen)
	switch (var(VAR_0x8004)) {
		case 1:
			msgbox(RustboroCity_Flat1_2F_Text_OhYouDontKnowAny, MSGBOX_DEFAULT)
    		release_end
		case 2:
			msgbox(RustboroCity_Flat1_2F_Text_ThinkOfMyOwnPhrase, MSGBOX_DEFAULT)
			turnobject(LOCALID_WALDAS_DAD, DIR_EAST)
			msgbox(RustboroCity_Flat1_2F_Text_ShesNotSmilingAtAll2, MSGBOX_DEFAULT)
			release_end
	}
    if (specialvar(VAR_RESULT, TryGetWallpaperWithWaldaPhrase) == TRUE) {
        msgbox(RustboroCity_Flat1_2F_Text_LetsGiveItATry2, MSGBOX_DEFAULT)
		turnobject(LOCALID_WALDAS_DAD, DIR_EAST)
		msgbox(RustboroCity_Flat1_2F_Text_OhShesLaughing, MSGBOX_DEFAULT)
		applymovement(LOCALID_WALDAS_DAD, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(RustboroCity_Flat1_2F_Text_ThankYouIllGiveYouWallpaper, MSGBOX_DEFAULT)
    } else {
		msgbox(RustboroCity_Flat1_2F_Text_LetsGiveItATry, MSGBOX_DEFAULT)
		turnobject(LOCALID_WALDAS_DAD, DIR_EAST)
		msgbox(RustboroCity_Flat1_2F_Text_ShesNotSmilingAtAll, MSGBOX_DEFAULT)
	}
    release_end
}

script RustboroCity_Flat1_2F_EventScript_WaldasMom {
    msgbox(RustboroCity_Flat1_2F_Text_ComingUpWithMealsIsHard, MSGBOX_NPC)
    end
}

script RustboroCity_Flat1_2F_EventScript_PokeDoll {
    msgbox(RustboroCity_Flat1_2F_Text_ItsAPokemonPlushDoll, MSGBOX_SIGN)
    end
}

text RustboroCity_Flat1_2F_Text_ComingUpWithMealsIsHard {
	"Oh, it's so hard every day…

	What's hard?
	You need to ask?

	It's trying to figure out what to
	make for meals every day.

	It really isn't easy coming up with
	meals every day."
}

text RustboroCity_Flat1_2F_Text_HelloDoYouKnowFunnyPhrase {
	"Oh, hello!
	Welcome to the PEPPER household.

	I have a question for you.
	Have you ever baby-sat?

	You see, I'm a new father, so raising
	a child is all new to me.

	And I have a problem. My daughter
	WALDA doesn't laugh enough.

	I think she'd laugh for me if I told
	her something funny.

	Do you know of a funny word or
	phrase you can tell me?"
}

text RustboroCity_Flat1_2F_Text_BeenSayingXDoYouKnowBetterPhrase {
	"I've been saying “{STR_VAR_1}”
	to amuse her lately.

	Do you know of a better word or
	a phrase that might work?"
}

text RustboroCity_Flat1_2F_Text_WonderfulLetsHearSuggestion {
	"Oh, that's wonderful.
	So, let's hear it, your suggestion."
}

text RustboroCity_Flat1_2F_Text_OhIsThatRight {
	"Oh, is that right?

	Well, if you come up with a good
	suggestion, I'm all ears."
}

text RustboroCity_Flat1_2F_Text_LetsGiveItATry2 {
	"Ah, I see.
	Well, let's give it a try, shall we?"
}

text RustboroCity_Flat1_2F_Text_OhShesLaughing {
	"{STR_VAR_1}.
	{STR_VAR_1}.

	Oh, yes! She's laughing!
	Oh, I am as delighted as she!"
}

text RustboroCity_Flat1_2F_Text_LetsGiveItATry {
	"Ah, I see.
	Well, let's give it a try, shall we?"
}

text RustboroCity_Flat1_2F_Text_ShesNotSmilingAtAll {
	"{STR_VAR_1}.
	{STR_VAR_1}.

	Hmmm… She's not smiling at all.
	Maybe WALDA is one serious child…"
}

text RustboroCity_Flat1_2F_Text_ThinkOfMyOwnPhrase {
	"Oh, so you don't know any good words.
	I'd better think for myself, then.

	Hmm…
	How about “{STR_VAR_1}”?
	Let's see if that will work."
}

text RustboroCity_Flat1_2F_Text_ShesNotSmilingAtAll2 {
	"{STR_VAR_1}.
	{STR_VAR_1}.

	Hmmm… She's not smiling at all.
	Maybe WALDA is one serious child…"
}

text RustboroCity_Flat1_2F_Text_OhYouDontKnowAny {
	"Oh, so you don't know any good words.
	I guess I'll try to amuse her with
	the saying I used before.

	Anyways, if you have a good suggestion,
	don't hesitate in telling me, okay?"
}

text RustboroCity_Flat1_2F_Text_ThankYouIllGiveYouWallpaper {
	"Thank you!

	Thanks to you, my darling WALDA
	laughed for me!

	Actually, I may not look all that
	special, but I'm one of DEVON
	CORPORATION's top researchers.

	So, how about I do something in return
	for you?

	I know, I'll add some new wallpaper
	patterns for the BOXES in the PC
	POKéMON Storage System.

	In the wallpaper pattern menu,
	select “FRIENDS.”

	That will give you access to the new
	wallpaper patterns."
}

text RustboroCity_Flat1_2F_Text_ItsAPokemonPlushDoll {
	"It's a POKéMON plush DOLL!"
}
