mapscripts Route123_BerryMastersHouse_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_LANDMARK_BERRY_MASTERS_HOUSE)
    	end
    }
}

script Route123_BerryMastersHouse_EventScript_BerryMaster {
    lock_faceplayer
    dotimebasedevents
    if (flag(FLAG_DAILY_BERRY_MASTER_RECEIVED_BERRY)) {
        msgbox(Route123_BerryMastersHouse_Text_DoneForToday, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(Route123_BerryMastersHouse_Text_YoureDeservingOfBerry, MSGBOX_DEFAULT)
    giverandomberry(BERRY_ID_POMEG, BERRY_ID_NOMEL)
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_DAILY_BERRY_MASTER_RECEIVED_BERRY)
    msgbox(Route123_BerryMastersHouse_Text_WhyBeStingyTakeAnother, MSGBOX_DEFAULT)
    giverandomberry(BERRY_ID_POMEG, BERRY_ID_NOMEL)
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    msgbox(Route123_BerryMastersHouse_Text_VisitPrettyPetalFlowerShop, MSGBOX_DEFAULT)
    release_end
}

script Route123_BerryMastersHouse_EventScript_BerryMastersWife {
    lock_faceplayer
    dotimebasedevents
    if (flag(FLAG_DAILY_BERRY_MASTERS_WIFE)) {
        msgbox(Route123_BerryMastersHouse_Text_JoyNeverGoesOutOfMyLife, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(Route123_BerryMastersHouse_Text_HeardAGoodSayingLately, MSGBOX_DEFAULT)
    setvar(VAR_0x8004, EASY_CHAT_TYPE_GOOD_SAYING)
    call(Common_ShowEasyChatScreen)
    lock_faceplayer
    if (var(VAR_RESULT) == TRUE) {
        goto(Route123_BerryMastersHouse_EventScript_GavePhrase)
    }
    msgbox(Route123_BerryMastersHouse_Text_Ah, MSGBOX_DEFAULT)
    msgbox(Route123_BerryMastersHouse_Text_JoyNeverGoesOutOfMyLife, MSGBOX_DEFAULT)
    release_end
}

script Route123_BerryMastersHouse_EventScript_GavePhrase {
	switch (var(VAR_0x8004)) {
		case NOT_SPECIAL_PHRASE: goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
		case PHRASE_GREAT_BATTLE: 
			if (flag(FLAG_RECEIVED_SPELON_BERRY)) {
				goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
			}
			setvar(VAR_GIFT_ITEM, ITEM_SPELON_BERRY)
		case PHRASE_CHALLENGE_CONTEST: 
			if (flag(FLAG_RECEIVED_PAMTRE_BERRY)) {
				goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
			}
			setvar(VAR_GIFT_ITEM, ITEM_PAMTRE_BERRY)
		case PHRASE_OVERWHELMING_LATIAS: 
			if (flag(FLAG_RECEIVED_WATMEL_BERRY)) {
				goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
			}
			setvar(VAR_GIFT_ITEM, ITEM_WATMEL_BERRY)
		case PHRASE_COOL_LATIOS: 
			if (flag(FLAG_RECEIVED_DURIN_BERRY)) {
				goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
			}
			setvar(VAR_GIFT_ITEM, ITEM_DURIN_BERRY)
		case PHRASE_SUPER_HUSTLE: 
			if (flag(FLAG_RECEIVED_BELUE_BERRY)) {
				goto(Route123_BerryMastersHouse_EventScript_GiveNormalBerry)
			}
			setvar(VAR_GIFT_ITEM, ITEM_BELUE_BERRY)
	}
	goto(Route123_BerryMastersHouse_EventScript_GiveSpecialBerry)
    end
}

script Route123_BerryMastersHouse_EventScript_GiveNormalBerry {
    msgbox(Route123_BerryMastersHouse_Text_GoodSayingTakeThis, MSGBOX_DEFAULT)
    giverandomberry(BERRY_ID_CHERI, BERRY_ID_SITRUS)
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_DAILY_BERRY_MASTERS_WIFE)
    msgbox(Route123_BerryMastersHouse_Text_JoyNeverGoesOutOfMyLife, MSGBOX_DEFAULT)
    release_end
}

script Route123_BerryMastersHouse_EventScript_GiveSpecialBerry {
    msgbox(Route123_BerryMastersHouse_Text_InspirationalTakeThis, MSGBOX_DEFAULT)
    if (giveitem(VAR_GIFT_ITEM) == FALSE) {
		goto(Common_EventScript_ShowBagIsFull)
	}
	switch (var(VAR_GIFT_ITEM)) {
		case ITEM_SPELON_BERRY: setflag(FLAG_RECEIVED_SPELON_BERRY)
		case ITEM_PAMTRE_BERRY: setflag(FLAG_RECEIVED_PAMTRE_BERRY)
		case ITEM_WATMEL_BERRY: setflag(FLAG_RECEIVED_WATMEL_BERRY)
		case ITEM_DURIN_BERRY: setflag(FLAG_RECEIVED_DURIN_BERRY)
		case ITEM_BELUE_BERRY: setflag(FLAG_RECEIVED_BELUE_BERRY)
	}
    setflag(FLAG_DAILY_BERRY_MASTERS_WIFE)
    msgbox(Route123_BerryMastersHouse_Text_JoyNeverGoesOutOfMyLife, MSGBOX_DEFAULT)
    release_end
}
