const PLAYER_X_POS = VAR_0x8004
const PLAYER_Y_POS = VAR_0x8005

mapscripts FiveIsland_RocketWarehouse_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (defeated(TRAINER_TEAM_ROCKET_ADMIN)) {
			call(FiveIsland_RocketWarehouse_EventScript_SetArrowsForReEntry)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_FIVE_ISLAND_ROCKET_WAREHOUSE)
    	end
    }
}

script FiveIsland_RocketWarehouse_EventScript_SetArrowsForReEntry {
    setmetatile(26, 20, METATILE_SilphCo_Arrow_Up, 0)
    setmetatile(27, 20, METATILE_SilphCo_Arrow_Up, 0)
    return
}

script FiveIsland_RocketWarehouse_EventScript_Cage {
    lockall
    if (flag(FLAG_DEFEATED_ROCKETS_IN_WAREHOUSE)) {
        msgbox(FiveIsland_RocketWarehouse_Text_PenUnlockedMonsFled)
    } else {
		msgbox(FiveIsland_RocketWarehouse_Text_ManyMonsLockedInPen)
	}
    releaseall
    end
}

script FiveIsland_RocketWarehouse_EventScript_Computer {
    msgbox(FiveIsland_RocketWarehouse_Text_ReportWithGraphsAndText, MSGBOX_SIGN)
    end
}

script FiveIsland_RocketWarehouse_EventScript_Admin2Trigger {
    lockall
    applymovement(LOCALID_WAREHOUSE_ADMIN2, Common_Movement_StepFasterLeft)
    waitmovement(0)
    setvar(VAR_MAP_SCENE_ROCKET_WAREHOUSE, 1)
    releaseall
    end
}

script FiveIsland_RocketWarehouse_EventScript_Gideon {
    trainerbattle_single(TRAINER_SCIENTIST_GIDEON, FiveIsland_RocketWarehouse_Text_GideonIntro, FiveIsland_RocketWarehouse_Text_GideonDefeat, FiveIsland_RocketWarehouse_EventScript_DefeatedGideon)
    if (flag(FLAG_IS_CHAMPION)) {
        famechecker(FAMECHECKER_GIOVANNI, 5)
		msgbox(FiveIsland_RocketWarehouse_Text_GiovannisKidHasRedHair, MSGBOX_AUTOCLOSE)
		end
    }
    msgbox(FiveIsland_RocketWarehouse_Text_GetLostLeaveMeBe, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_DefeatedGideon {
    msgbox(FiveIsland_RocketWarehouse_Text_GideonPostBattle)
    setflag(FLAG_RECOVERED_SAPPHIRE)
    giveitem(ITEM_SAPPHIRE)
    release_end
}

script FiveIsland_RocketWarehouse_EventScript_Grunt2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_47, FiveIsland_RocketWarehouse_Text_Grunt2Intro, FiveIsland_RocketWarehouse_Text_Grunt2Defeat)
    msgbox(FiveIsland_RocketWarehouse_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_Grunt3 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_48, FiveIsland_RocketWarehouse_Text_Grunt3Intro, FiveIsland_RocketWarehouse_Text_Grunt3Defeat)
    msgbox(FiveIsland_RocketWarehouse_Text_Grunt3PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_Admin2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_ADMIN_2, FiveIsland_RocketWarehouse_Text_Admin2Intro, FiveIsland_RocketWarehouse_Text_Admin2Defeat, FiveIsland_RocketWarehouse_EventScript_DefeatedAdmin2)
    msgbox(FiveIsland_RocketWarehouse_Text_Admin2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_DefeatedAdmin2 {
    getplayerxy(PLAYER_X_POS, PLAYER_Y_POS)
    if (var(PLAYER_X_POS) <= 24) {
        applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    	waitmovement(0)
    }
    msgbox(FiveIsland_RocketWarehouse_Text_Admin2PostBattle)
    closemessage
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_WAREHOUSE_GRUNT2)
    removeobject(LOCALID_WAREHOUSE_GRUNT3)
    removeobject(LOCALID_WAREHOUSE_ADMIN2)
    removeobject(LOCALID_WAREHOUSE_ADMIN1)
    setflag(FLAG_HIDE_FIVE_ISLAND_ROCKETS)
    fadescreen(FADE_FROM_BLACK)
    setvar(VAR_MAP_SCENE_ROCKET_WAREHOUSE, 1)
    setflag(FLAG_DEFEATED_ROCKETS_IN_WAREHOUSE)
    release_end
}

script FiveIsland_RocketWarehouse_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_42, FiveIsland_RocketWarehouse_Text_Grunt1Intro, FiveIsland_RocketWarehouse_Text_Grunt1Defeat)
    msgbox(FiveIsland_RocketWarehouse_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_Admin1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_ADMIN, FiveIsland_RocketWarehouse_Text_Admin1Intro, FiveIsland_RocketWarehouse_Text_Admin1Defeat, FiveIsland_RocketWarehouse_EventScript_DefeatedAdmin1)
    msgbox(FiveIsland_RocketWarehouse_Text_MadeItSoYouCanComeBackThrough, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_RocketWarehouse_EventScript_DefeatedAdmin1 {
    getplayerxy(PLAYER_X_POS, PLAYER_Y_POS)
    if (specialvar(VAR_RESULT, GetPlayerFacingDirection) == DIR_NORTH && var(PLAYER_X_POS) != 27) {
        applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    	waitmovement(0)
    }
    msgbox(FiveIsland_RocketWarehouse_Text_Admin1PostBattle)
    closemessage
	switch (var(PLAYER_X_POS)) {
		default: applymovement(LOCALID_WAREHOUSE_ADMIN1, moves(walk_right * 2,  step_faster_up))
		case 25: applymovement(LOCALID_WAREHOUSE_ADMIN1, moves(walk_right,  step_faster_up))
		case 26:
		case 27: applymovement(LOCALID_WAREHOUSE_ADMIN1, Common_Movement_StepFasterUp)
	}
	waitmovement(0)
    playse(SE_PIN)
    call(FiveIsland_RocketWarehouse_EventScript_SetArrowsForReEntry)
    special(DrawWholeMapView)
    waitse
	if (var(PLAYER_X_POS) <= 27) {
		applymovement(LOCALID_WAREHOUSE_ADMIN1, Common_Movement_StepFasterLeft)
	} else {
		applymovement(LOCALID_WAREHOUSE_ADMIN1, Common_Movement_StepFasterDown)
	}
	waitmovement(0)
    msgbox(FiveIsland_RocketWarehouse_Text_MadeItSoYouCanComeBackThrough)
    release_end
}

text FiveIsland_RocketWarehouse_Text_ManyMonsLockedInPen {
	"There are many POKéMON locked
	away in the pen…"
}

text FiveIsland_RocketWarehouse_Text_PenUnlockedMonsFled {
	"The pen door is unlocked.
	The POKéMON appear to have fled."
}

text FiveIsland_RocketWarehouse_Text_Grunt2Intro {
	"Did you come here knowing it's
	TEAM ROCKET's WAREHOUSE?"
}

text FiveIsland_RocketWarehouse_Text_Grunt2Defeat {
	"What do you think you're doing?!"
}

text FiveIsland_RocketWarehouse_Text_Grunt2PostBattle {
	"TEAM ROCKET broke up?
	What planet are you from?"
}

text FiveIsland_RocketWarehouse_Text_Grunt1Intro {
	"Oh, now your POKéMON look strong.
	You're willing to sell them?

	Oh?
	You wanted to battle?"
}

text FiveIsland_RocketWarehouse_Text_Grunt1Defeat {
	"Oh, but…
	Too much!"
}

text FiveIsland_RocketWarehouse_Text_Grunt1PostBattle {
	"We can give you a great price.
	Sell us your POKéMON!"
}

text FiveIsland_RocketWarehouse_Text_Grunt3Intro {
	"I got word about you from the
	others.

	But there's no way a kid like you'd
	know our BOSS GIOVANNI!"
}

text FiveIsland_RocketWarehouse_Text_Grunt3Defeat {
	"Don't…you…dare…laugh…"
}

text FiveIsland_RocketWarehouse_Text_Grunt3PostBattle {
	"Don't mess in the doings of adults,
	you jumped-up pip-squeak!"
}

text FiveIsland_RocketWarehouse_Text_Admin1Intro {
	"I don't know or care if what I'm
	doing is right or wrong…

	I just put my faith in GIOVANNI
	and do as I am told."
}

text FiveIsland_RocketWarehouse_Text_Admin1Defeat {
	"I…
	I'm shattered…"
}

text FiveIsland_RocketWarehouse_Text_Admin1PostBattle {
	"You're doing things according to
	your beliefs and morals.

	I understand now…"
}

text FiveIsland_RocketWarehouse_Text_MadeItSoYouCanComeBackThrough {
	"I've made it so you can come back
	in through there.

	Why don't you go get rested and
	refreshed for what lies ahead?

	The ADMIN after me outranks me
	thoroughly as a TRAINER.

	You'd better steel yourself for one
	harsh challenge."
}

text FiveIsland_RocketWarehouse_Text_Admin2Intro {
	"That's quite enough of you 
	playing the hero, kid.

	Spreading lies about how TEAM
	ROCKET has disbanded…

	It's such an obvious attempt to
	cause confusion in our ranks.

	Fortunately, we're not so ignorant
	to fall for the lies of a child!

	And now, I'll show you how scary
	an angry adult can be!"
}

text FiveIsland_RocketWarehouse_Text_Admin2Defeat {
	"Urgh…
	You were too strong…

	…
	Th-that's GIOVANNI's BADGE!

	So it's true?
	TEAM ROCKET really has disbanded?"
}

text FiveIsland_RocketWarehouse_Text_Admin2PostBattle {
	"We will abandon this WAREHOUSE…

	But don't think this is over.
	I won't let this be the end.

	I will find GIOVANNI.
	And I will resurrect TEAM ROCKET!
	I will…

	Until then, farewell!"
}

text FiveIsland_RocketWarehouse_Text_ReportWithGraphsAndText {
	"A report with graphs and text is on
	the PC monitor.

	“The Influence of Magnetic Waves
	on POKéMON Evolution”…

	… … … … … …

	It's too difficult to understand…"
}

text FiveIsland_RocketWarehouse_Text_GideonIntro {
	"I almost managed to sell the
	SAPPHIRE for huge money…

	Then, you just had to come along
	and blow the whole deal apart!

	Fufu… Fufufufu…
	There's no forgiveness for you!"
}

text FiveIsland_RocketWarehouse_Text_GideonDefeat {
	"Gah! Darn!
	Darn! Darn!"
}

text FiveIsland_RocketWarehouse_Text_GideonPostBattle {
	"If I can't sell it, it's worthless!
	Go ahead, take it!"
}

text FiveIsland_RocketWarehouse_Text_GetLostLeaveMeBe {
	"What do you want now?
	Go on, get lost, leave me be."
}

text FiveIsland_RocketWarehouse_Text_GiovannisKidHasRedHair {
	"What, you again?

	You… You're not GIOVANNI's kid,
	are you?

	No, that can't be right!
	GIOVANNI's kid has red hair.

	You don't have any reasons for
	bugging me. Leave me alone!"
}
