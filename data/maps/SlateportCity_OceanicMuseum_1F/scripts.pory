script SlateportCity_OceanicMuseum_1F_EventScript_FamiliarGrunt {
    lock_faceplayer
    delay(8)
    playse(SE_PIN)
    applymovement(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(SlateportCity_OceanicMuseum_1F_Text_RememberMeTakeThis, MSGBOX_DEFAULT)
    if (giveitem(ITEM_TM_THIEF) == FALSE) {
        msgbox(SlateportCity_OceanicMuseum_1F_Text_YouHaveToTakeThis, MSGBOX_DEFAULT)
    	release_end
    }
    setflag(FLAG_RECEIVED_TM_THIEF)
    msgbox(SlateportCity_OceanicMuseum_1F_Text_HopeINeverSeeYouAgain, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement(LOCALID_PLAYER, moves(delay_16,  delay_8,  delay_4,  step_faster_down))
    		applymovement(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT, moves(run_right,  run_down * 4,  delay_8))
		case DIR_SOUTH:
			applymovement(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT, moves(face_down,  run_down * 4,  delay_8))
		case DIR_WEST:
		case DIR_EAST:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down))
    		applymovement(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT, moves(face_down,  run_down * 4,  delay_8))
	}
    waitmovement(0)
    setflag(FLAG_HIDE_SLATEPORT_CITY_OCEANIC_MUSEUM_FAMILIAR_AQUA_GRUNT)
    playse(SE_EXIT)
    removeobject(LOCALID_OCEANIC_MUSEUM_FAMILIAR_GRUNT)
    release_end
}

text SlateportCity_OceanicMuseum_1F_Text_WouldYouLikeToEnter {
	"Welcome to the OCEANIC MUSEUM.

	The entrance fee is ¥50.
	Would you like to enter?"
}

text SlateportCity_OceanicMuseum_1F_Text_PleaseEnjoyYourself {
	"Please enjoy yourself."
}

text SlateportCity_OceanicMuseum_1F_Text_NotEnoughMoney {
	"Oh? I'm sorry, but you don't seem to
	have enough money."
}

text SlateportCity_OceanicMuseum_1F_Text_CatchUpWithYourGroup {
	"Oh? You're with that group that
	went in earlier?

	You're the only one who's late.
	You'd better go catch up to them!"
}

text SlateportCity_OceanicMuseum_1F_Text_AquaExistForGoodOfAll {
	"We, TEAM AQUA, exist for the good
	of all!"
}

text SlateportCity_OceanicMuseum_1F_Text_OurBossIsntHere {
	"We were told to assemble here,
	so we did, but…

	Our BOSS, the linchpin, isn't here."
}

text SlateportCity_OceanicMuseum_1F_Text_WouldStuffHereMakeMeRich {
	"If I ripped off the stuff here,
	would it make me rich?"
}

text SlateportCity_OceanicMuseum_1F_Text_CanLearnForNefariousDeeds {
	"What I learn here, I can put to use on
	nefarious deeds…"
}

text SlateportCity_OceanicMuseum_1F_Text_RustboroBungled {
	"If our goons didn't bungle things
	in RUSTBORO, we wouldn't be here!"
}

text SlateportCity_OceanicMuseum_1F_Text_DidntHaveMoney {
	"I didn't have ¥50, so it took a long
	time getting by the receptionist."
}

text SlateportCity_OceanicMuseum_1F_Text_LearnAboutSeaForBattling {
	"I want to learn about the sea and
	use that knowledge for battling."
}

text SlateportCity_OceanicMuseum_1F_Text_SternIsRoleModel {
	"I get all giddy and gooey when
	I see the sea!

	For me, CAPT. STERN is the number
	one role model!"
}

text SlateportCity_OceanicMuseum_1F_Text_MustBePokemonWeDontKnow {
	"The sea is vast without end, and
	infinitely deep…

	There must be many POKéMON that
	we don't know about."
}

text SlateportCity_OceanicMuseum_1F_Text_WantSeaPokemon {
	"I want a sea POKéMON.

	I think it would feel cool and nice
	to hug."
}

text SlateportCity_OceanicMuseum_1F_Text_RememberMeTakeThis {
	"Aiyeeeh!
	What are you doing here?

	Me? I'm the TEAM AQUA member
	you thumped before, remember?
	Back in RUSTURF TUNNEL?

	Here, take this!
	You have to forgive me!"
}

text SlateportCity_OceanicMuseum_1F_Text_HopeINeverSeeYouAgain {
	"That TM, it suits you more than it
	does me.

	Hope I never see you again!
	Wahahaha!"
}

text SlateportCity_OceanicMuseum_1F_Text_YouHaveToTakeThis {
	"Awww, come on!
	You have to take this and let me go!"
}

text SlateportCity_OceanicMuseum_1F_Text_WhirlpoolExperiment {
	"A blue fluid is spiraling inside
	a glass vessel.

	“This is an experiment to create a
	WHIRLPOOL artificially using wind.”"
}

text SlateportCity_OceanicMuseum_1F_Text_WaterfallExperiment {
	"A red ball is bobbing up and down
	inside a glass vessel.

	“This is an experiment simulating a
	WATERFALL using the ball's buoyancy.”"
}

text SlateportCity_OceanicMuseum_1F_Text_OceanSoilDisplay {
	"It's a sample of soil from the ocean
	floor.

	“Over many years, the remains of
	life-forms settle at the bottom of
	the sea, making sedimentary layers.

	“By analyzing these layers, the
	ancient past is revealed.”"
}

text SlateportCity_OceanicMuseum_1F_Text_BeachSandDisplay {
	"It's a sample of beach sand.

	“Stones from mountains are washed
	down by rivers where they are
	chipped and ground down.

	“They are reduced to grains and end
	up as sand on beaches.”"
}

text SlateportCity_OceanicMuseum_1F_Text_OceanicMinifact1 {
	"“OCEANIC MINIFACT 1
	Why is seawater blue?

	“Light is composed of many colors.

	“When light passes through water,
	most kinds of light lose color.

	“However, blue light retains its
	color, making the sea appear blue.”"
}

text SlateportCity_OceanicMuseum_1F_Text_OceanicMinifact2 {
	"“OCEANIC MINIFACT 2
	Why is the sea salty?

	“Seawater contains dissolved salt in
	the form of sodium and chlorine ions.

	“These ions leech out of rocks
	and are carried out to sea by rain.

	“The concentration of dissolved salt
	makes the sea salty.”"
}

text SlateportCity_OceanicMuseum_1F_Text_OceanicMinifact3 {
	"“OCEANIC MINIFACT 3
	Which is bigger? The sea or land?

	“The sea covers about 70% of
	the planet, and the rest is land.

	“The sea is therefore more than twice
	the size of land.”"
}

text SlateportCity_OceanicMuseum_1F_Text_FossilDisplay {
	"It's a fossil with wavy ridges on it.

	“Soil on the ocean floor gets scoured
	by the tide.

	“The flowing seawater marks the soil
	with small ridges and valleys.

	“If this soil becomes fossilized, it is
	called a ripple mark.”"
}

text SlateportCity_OceanicMuseum_1F_Text_DepthMeasuringMachine {
	"A strange machine is rotating under
	a glass dome.

	Maybe it's for measuring the depth
	of something…"
}
