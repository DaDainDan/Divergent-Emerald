mapscripts SlateportCity_OceanicMuseum_1F_MapScripts {}

script SlateportCity_OceanicMuseum_1F_EventScript_EntranceAttendant {
    msgbox(SlateportCity_OceanicMuseum_1F_Text_PleaseEnjoyYourself, MSGBOX_NPC)
    end
}

script SlateportCity_OceanicMuseum_1F_EventScript_PayEntranceFeeLeft {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    goto(SlateportCity_OceanicMuseum_1F_EventScript_PayEntranceFee)
    end
}

script SlateportCity_OceanicMuseum_1F_EventScript_PayEntranceFeeRight {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    goto(SlateportCity_OceanicMuseum_1F_EventScript_PayEntranceFee)
    end
}

script SlateportCity_OceanicMuseum_1F_EventScript_PayEntranceFee {
    showmoneybox(0, 0)
    msgbox(SlateportCity_OceanicMuseum_1F_Text_WouldYouLikeToEnter, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(SlateportCity_OceanicMuseum_1F_EventScript_CheckMoneyForFee)
    }
    closemessage
    hidemoneybox
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    releaseall
    end
}

script SlateportCity_OceanicMuseum_1F_EventScript_CheckMoneyForFee {
    if (checkmoney(50) == FALSE) {
		if (!flag(FLAG_DELIVERED_DEVON_GOODS)) {
			msgbox(SlateportCity_OceanicMuseum_1F_Text_CatchUpWithYourGroup, MSGBOX_DEFAULT)
			setvar(VAR_SLATEPORT_MUSEUM_1F_STATE, 1)
			hidemoneybox
		} else {
			msgbox(SlateportCity_OceanicMuseum_1F_Text_NotEnoughMoney, MSGBOX_DEFAULT)
			closemessage
			hidemoneybox
			applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
			waitmovement(0)
		}
	} else {
		playse(SE_SHOP)
		removemoney(50)
		updatemoneybox
		msgbox(SlateportCity_OceanicMuseum_1F_Text_PleaseEnjoyYourself, MSGBOX_DEFAULT)
		setvar(VAR_SLATEPORT_MUSEUM_1F_STATE, 1)
		hidemoneybox
	}
    releaseall
    end
}

