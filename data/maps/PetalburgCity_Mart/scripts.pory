mapscripts PetalburgCity_Mart_MapScripts {}

script PetalburgCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    if (flag(FLAG_PETALBURG_MART_EXPANDED_ITEMS)) {
        pokemart(PetalburgCity_Mart_Pokemart_Expanded)
    } else {
		pokemart(PetalburgCity_Mart_Pokemart_Basic)
	}
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

script PetalburgCity_Mart_EventScript_EnhancementClerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(PetalburgCity_Mart_Pokemart_Enhancement)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart PetalburgCity_Mart_Pokemart_Basic {
    ITEM_POKE_BALL
    ITEM_POTION
    ITEM_FULL_HEAL
    ITEM_MAX_ETHER
    ITEM_REPEL
    ITEM_LURE
}

mart PetalburgCity_Mart_Pokemart_Expanded {
    ITEM_GREAT_BALL
    ITEM_HYPER_POTION
    ITEM_FULL_HEAL
    ITEM_REVIVE
    ITEM_MAX_ELIXIR
    ITEM_SUPER_REPEL
    ITEM_SUPER_LURE
}

mart PetalburgCity_Mart_Pokemart_Enhancement {
    ITEM_EXP_CANDY_M
    ITEM_HP_UP
    ITEM_PROTEIN
    ITEM_IRON
    ITEM_CARBOS
    ITEM_CALCIUM
    ITEM_ZINC
    ITEM_PP_UP
}

script PetalburgCity_Mart_EventScript_Woman {
    msgbox(PetalburgCity_Mart_Text_WeakWillGrowStronger, MSGBOX_NPC)
    end
}

script PetalburgCity_Mart_EventScript_Boy {
    msgbox(PetalburgCity_Mart_Text_RepelIsUseful, MSGBOX_NPC)
    end
}

script PetalburgCity_Mart_EventScript_Man {
    msgbox(PetalburgCity_Mart_Text_TakeSomeAntidotesWithYou, MSGBOX_NPC)
    end
}

text PetalburgCity_Mart_Text_WeakWillGrowStronger {
	"Even if a POKéMON is weak now,
	it will grow stronger.

	The most important thing is love!
	Love for your POKéMON!"
}

text PetalburgCity_Mart_Text_RepelIsUseful {
	"Do you use REPEL?
	It keeps POKéMON away, so it's
	useful when you're in a hurry."
}

text PetalburgCity_Mart_Text_TakeSomeAntidotesWithYou {
	"Do you have any ANTIDOTES with
	you?

	If you walk around with a poisoned
	POKéMON, it will lose HP until it faints.
	Take some ANTIDOTES with you."
}
