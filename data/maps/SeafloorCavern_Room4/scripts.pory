text SeafloorCavern_Room4_Text_Grunt3Intro {
	"Who are you?
	Where did you come in from?"
}

text SeafloorCavern_Room4_Text_Grunt3Defeat {
	"Lost it…"
}

text SeafloorCavern_Room4_Text_Grunt3PostBattle {
	"I can't find the way out!

	I'm not afraid. Don't get me wrong!"
}

text SeafloorCavern_Room4_Text_Grunt4Intro {
	"Who are you?
	Where do you think you're going?"
}

text SeafloorCavern_Room4_Text_Grunt4Defeat {
	"I failed to win!"
}

text SeafloorCavern_Room4_Text_Grunt4PostBattle {
	"My partner forgot the map in that
	submarine!

	How's that for being useless?"
}
