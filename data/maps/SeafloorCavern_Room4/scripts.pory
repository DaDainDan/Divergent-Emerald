}

script SeafloorCavern_Room4_EventScript_Grunt4 {
    trainerbattle_single(TRAINER_GRUNT_SEAFLOOR_CAVERN_4, SeafloorCavern_Room4_Text_Grunt4Intro, SeafloorCavern_Room4_Text_Grunt4Defeat)
