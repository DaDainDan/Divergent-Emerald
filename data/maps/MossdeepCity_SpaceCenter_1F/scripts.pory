mapscripts MossdeepCity_SpaceCenter_1F_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_MOSSDEEP_CITY_STATE) <= 2) {
			setmetatile(2, 5, METATILE_Facility_DataPad, TRUE)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
			setobjectxyperm(LOCALID_SPACE_CENTER_1F_SAILOR, 1, 9)
			setobjectmovementtype(LOCALID_SPACE_CENTER_1F_SAILOR, MOVEMENT_TYPE_FACE_RIGHT)
			setobjectxyperm(LOCALID_SPACE_CENTER_1F_WOMAN, 0, 8)
			setobjectmovementtype(LOCALID_SPACE_CENTER_1F_WOMAN, MOVEMENT_TYPE_FACE_RIGHT)
			setobjectxyperm(LOCALID_SPACE_CENTER_1F_OLD_MAN, 1, 6)
			setobjectmovementtype(LOCALID_SPACE_CENTER_1F_OLD_MAN, MOVEMENT_TYPE_FACE_RIGHT)
			setobjectxyperm(LOCALID_SPACE_CENTER_1F_SCIENTIST_1, 3, 4)
			setobjectmovementtype(LOCALID_SPACE_CENTER_1F_SCIENTIST_1, MOVEMENT_TYPE_FACE_RIGHT)
			setobjectmovementtype(LOCALID_SPACE_CENTER_1F_SCIENTIST_2, MOVEMENT_TYPE_FACE_RIGHT)
			switch (var(VAR_MOSSDEEP_SPACE_CENTER_STAIR_GUARD_STATE)) {
				case 1: setobjectxyperm(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, 12, 2)
				case 2: setobjectxyperm(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, 13, 3)
				case 3: setobjectxyperm(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, 14, 2)
			}
		}
		end
    }
}

script MossdeepCity_SpaceCenter_1F_EventScript_RocketLaunchCounter {
    lock_faceplayer
    dotimebasedevents
    specialvar(VAR_RESULT, GetWeekCount)
    buffernumberstring(STR_VAR_1, VAR_RESULT)
    if (var(VAR_RESULT) == 0) {
		if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
			msgbox(MossdeepCity_SpaceCenter_1F_Text_HaywireButRocketLaunchImminent, MSGBOX_DEFAULT)
		} else {
			msgbox(MossdeepCity_SpaceCenter_1F_Text_RocketLaunchImminent, MSGBOX_DEFAULT)
		}
    } else {
		if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
			msgbox(MossdeepCity_SpaceCenter_1F_Text_HaywireButSuccessfulLaunchNumber, MSGBOX_DEFAULT)
		} else {
			msgbox(MossdeepCity_SpaceCenter_1F_Text_SuccessfulLaunchNumber, MSGBOX_DEFAULT)
		}
    }
    closemessage
	if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
		applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterRight)
	} else {
		applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
	}
    waitmovement(0)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Scientist {
    lock_faceplayer
    if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_MagmaHaveSightsOnSpaceCenter, MSGBOX_DEFAULT)
		applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterRight)
		waitmovement(0)
		release_end
    }
    msgbox(MossdeepCity_SpaceCenter_1F_Text_RocketLaunchDemandsPerfection, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_SunStoneMan {
    lock_faceplayer
    if (var(VAR_MOSSDEEP_CITY_STATE) == 2) {
        goto(MossdeepCity_SpaceCenter_1F_EventScript_SunStoneManMagma)
    }
    if (flag(FLAG_RECEIVED_SUN_STONE_MOSSDEEP)) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_HoennFamousForMeteorShowers, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MossdeepCity_SpaceCenter_1F_Text_FoundThisYouCanHaveIt, MSGBOX_DEFAULT)
    if (giveitem(ITEM_SUN_STONE) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_SUN_STONE_MOSSDEEP)
    msgbox(MossdeepCity_SpaceCenter_1F_Text_HoennFamousForMeteorShowers, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_SunStoneManMagma {
    if (flag(FLAG_RECEIVED_SUN_STONE_MOSSDEEP)) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_CantStrollOnBeachWithMagma, MSGBOX_DEFAULT)

    } else {
		msgbox(MossdeepCity_SpaceCenter_1F_Text_MagmaCantStealFuelTakeThis, MSGBOX_DEFAULT)
		if (giveitem(ITEM_SUN_STONE) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		setflag(FLAG_RECEIVED_SUN_STONE_MOSSDEEP)
		msgbox(MossdeepCity_SpaceCenter_1F_Text_CantStrollOnBeachWithMagma, MSGBOX_DEFAULT)
	}
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterRight)
    waitmovement(0)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Woman {
    lock_faceplayer
    if (flag(FLAG_SYS_GAME_CLEAR) || var(VAR_MOSSDEEP_CITY_STATE) < 2) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_DidPokemonComeFromSpace, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MossdeepCity_SpaceCenter_1F_Text_AquaShouldBeatMagma, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_OldMan {
    lock_faceplayer
    if (flag(FLAG_SYS_GAME_CLEAR) || var(VAR_MOSSDEEP_CITY_STATE) < 2) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_RocketsBoggleMyMind, MSGBOX_DEFAULT)
    } else {
		msgbox(MossdeepCity_SpaceCenter_1F_Text_MagmaWantsToSpoilMyDream, MSGBOX_DEFAULT)
	}
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Steven {
    lock_faceplayer
    msgbox(MossdeepCity_SpaceCenter_1F_Text_StevenMagmaCantBeAllowedToTakeFuel, MSGBOX_DEFAULT)
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release_end
}

script MossdeepCity_SpaceCenter_1F_EventScript_MagmaNote {
    lockall
    msgbox(MossdeepCity_SpaceCenter_1F_Text_MagmaIntentToStealNotice, MSGBOX_DEFAULT)
    releaseall
    end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Grunt3 {
    trainerbattle_single(TRAINER_GRUNT_SPACE_CENTER_3, MossdeepCity_SpaceCenter_1F_Text_Grunt3Intro, MossdeepCity_SpaceCenter_1F_Text_Grunt3Defeat)
    msgbox(MossdeepCity_SpaceCenter_1F_Text_Grunt3PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_GRUNT_SPACE_CENTER_1, MossdeepCity_SpaceCenter_1F_Text_Grunt1Intro, MossdeepCity_SpaceCenter_1F_Text_Grunt1Defeat)
    msgbox(MossdeepCity_SpaceCenter_1F_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Grunt4 {
    trainerbattle_single(TRAINER_GRUNT_SPACE_CENTER_4, MossdeepCity_SpaceCenter_1F_Text_Grunt4Intro, MossdeepCity_SpaceCenter_1F_Text_Grunt4Defeat)
    msgbox(MossdeepCity_SpaceCenter_1F_Text_Grunt4PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script MossdeepCity_SpaceCenter_1F_EventScript_Grunt2 {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_GRUNT_SPACE_CENTER_1F)) {
        msgbox(MossdeepCity_SpaceCenter_1F_Text_Grunt2PostBattle, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MossdeepCity_SpaceCenter_1F_Text_Grunt2Intro, MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_GRUNT_SPACE_CENTER_2, MossdeepCity_SpaceCenter_1F_Text_Grunt2Defeat)
    setflag(FLAG_DEFEATED_GRUNT_SPACE_CENTER_1F)
    copyobjectxytoperm(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT)
    call(MossdeepCity_SpaceCenter_1F_EventScript_Grunt2_HandleMovement)
    setvar(VAR_MOSSDEEP_SPACE_CENTER_STAIR_GUARD_STATE, 2)
    release_end
}

raw `
MossdeepCity_SpaceCenter_1F_EventScript_Grunt2_HandleMovement::
	switch VAR_FACING
	case DIR_WEST, MossdeepCity_SpaceCenter_1F_EventScript_MoveGruntFromStairsWest
#ifdef BUGFIX
	case DIR_EAST, MossdeepCity_SpaceCenter_1F_EventScript_MoveGruntFromStairsEast
#else
	case DIR_WEST, MossdeepCity_SpaceCenter_1F_EventScript_MoveGruntFromStairsEast
#endif
	applymovement LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, MossdeepCity_SpaceCenter_1F_Movement_MoveGruntFromStairs
	waitmovement 0
	return
`

script MossdeepCity_SpaceCenter_1F_EventScript_MoveGruntFromStairsWest {
    applymovement(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, moves(lock_look,  walk_left,  unlock_look))
    waitmovement(0)
    setvar(VAR_MOSSDEEP_SPACE_CENTER_STAIR_GUARD_STATE, 1)
    release_end
}

// Functionally unused by mistake. The movement is handled anyway after the switch (see above)
// This also means VAR_MOSSDEEP_SPACE_CENTER_STAIR_GUARD_STATE can never be 3
script MossdeepCity_SpaceCenter_1F_EventScript_MoveGruntFromStairsEast {
    applymovement(LOCALID_SPACE_CENTER_1F_STAIR_GRUNT, moves(lock_look,  walk_right,  unlock_look))
    waitmovement(0)
    setvar(VAR_MOSSDEEP_SPACE_CENTER_STAIR_GUARD_STATE, 3)
    release_end
}

// This was meant to only handle the player facing North, but by mistake(?) it also handles the player facing East
movement MossdeepCity_SpaceCenter_1F_Movement_MoveGruntFromStairs {
    // moves(face_left,  lock_look,  walk_right,  unlock_look)
    face_left
    lock_look
    walk_right
    unlock_look
}

text MossdeepCity_SpaceCenter_1F_Text_RocketLaunchImminent {
	"The rocket's launch is imminent!"
}

text MossdeepCity_SpaceCenter_1F_Text_SuccessfulLaunchNumber {
	"The rocket launched safely!
	That's successful launch no. {STR_VAR_1}!"
}

text MossdeepCity_SpaceCenter_1F_Text_HaywireButRocketLaunchImminent {
	"I know that things are a little
	haywire right now, but…

	The rocket's launch is imminent!"
}

text MossdeepCity_SpaceCenter_1F_Text_HaywireButSuccessfulLaunchNumber {
	"I know that things are a little
	haywire right now, but…

	The rocket launched safely!
	That's successful launch no. {STR_VAR_1}!"
}

text MossdeepCity_SpaceCenter_1F_Text_RocketLaunchDemandsPerfection {
	"A rocket launch demands perfection.
	Not even a 1% margin of error is allowed.

	Even if it's 99% okay, the whole thing
	is useless if 1% happens to be no good.

	Despite that, we never stop trying.
	Why? It's a dream that never ends."
}

text MossdeepCity_SpaceCenter_1F_Text_MagmaHaveSightsOnSpaceCenter {
	"Those MAGMA thugs have their sights
	set on our SPACE CENTER.

	But we can't allow anything that minor
	to interfere with our rocket launch!"
}

text MossdeepCity_SpaceCenter_1F_Text_FoundThisYouCanHaveIt {
	"I was taking a stroll down the beach
	when I found this.

	It's not anything I need, so you can
	have it."
}

text MossdeepCity_SpaceCenter_1F_Text_HoennFamousForMeteorShowers {
	"The HOENN region has been famous for 
	its meteor showers for a long time."
}

text MossdeepCity_SpaceCenter_1F_Text_MagmaCantStealFuelTakeThis {
	"TEAM MAGMA can't be allowed to steal
	the rocket fuel.

	Oh, by the way, you can have this stone
	I found on the beach."
}

text MossdeepCity_SpaceCenter_1F_Text_CantStrollOnBeachWithMagma {
	"With TEAM MAGMA around, I guess
	strolls on the beach aren't safe."
}

text MossdeepCity_SpaceCenter_1F_Text_DidPokemonComeFromSpace {
	"Some people claim that POKéMON came
	from space. Could it be true?"
}

text MossdeepCity_SpaceCenter_1F_Text_AquaShouldBeatMagma {
	"TEAM AQUA should take care of
	TEAM MAGMA!

	But if they did that, TEAM AQUA will
	become bold and brazen, won't they?"
}

text MossdeepCity_SpaceCenter_1F_Text_RocketsBoggleMyMind {
	"A giant chunk of metal bursts through
	the skies and flies into space…

	It boggles my mind!"
}

text MossdeepCity_SpaceCenter_1F_Text_MagmaWantsToSpoilMyDream {
	"A giant chunk of metal bursts through
	the skies and flies into space…

	But TEAM MAGMA wants to spoil
	that dream of mine!

	I'm not having any of that!"
}

text MossdeepCity_SpaceCenter_1F_Text_StevenMagmaCantBeAllowedToTakeFuel {
	"STEVEN: {PLAYER}{KUN}, have you read that
	proclamation already?

	TEAM MAGMA is coming after the rocket
	fuel on this island.

	I don't know what they'd need it for,
	but they can't be allowed to take it.

	I'll keep an eye on things for
	a while longer.

	In the meantime, why don't you go
	check out the town?"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt3Intro {
	"As promised, we've come for
	the rocket fuel!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt3Defeat {
	"Ran out of fuel…"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt3PostBattle {
	"Don't think you're on a roll just
	because you've beaten me!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt1Intro {
	"We gave you fair warning!
	There's nothing sneaky about us!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt1Defeat {
	"Grrr…
	We should've used sneaky treachery…"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt1PostBattle {
	"Okay, I get it already! The next time,
	we'll come unannounced."
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt4Intro {
	"The rocket fuel the SPACE CENTER has
	in storage--that's what we're after.

	We mean to take every last bit of it!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt4Defeat {
	"Please, can you spare some fuel?
	Even a chintzy cup will do!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt4PostBattle {
	"What are we going to do with
	the rocket fuel?

	How would I know?
	Ask our leader upstairs!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt2Intro {
	"Our leader said no one, but no one,
	gets past me!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt2Defeat {
	"Ack! Ack! Aaack!"
}

text MossdeepCity_SpaceCenter_1F_Text_Grunt2PostBattle {
	"Please, tell our leader that
	I never abandoned my post.
	That I stayed to the bitter end…"
}

text MossdeepCity_SpaceCenter_1F_Text_MagmaIntentToStealNotice {
	"This is…
	An intent-to-steal notice?

	“To the staff of the SPACE CENTER:
	How are you? We are doing fine.

	“We will soon visit you to take your
	rocket fuel.

	“Please don't try to stop us.
	We will take the fuel no matter what.

	“Let there be more land!
	                                          TEAM MAGMA”"
}
