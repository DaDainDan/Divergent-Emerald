mapscripts VermilionCity_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_VERMILION_CITY)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script VermilionCity_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script VermilionCity_PokemonCenter_1F_EventScript_Man {
    msgbox(VermilionCity_PokemonCenter_1F_Text_PoisonedMonFaintedWhileWalking, MSGBOX_NPC)
    end
}

script VermilionCity_PokemonCenter_1F_EventScript_Hiker {
    msgbox(VermilionCity_PokemonCenter_1F_Text_TrainerMonsStrongerThanWild, MSGBOX_NPC)
    end
}

script VermilionCity_PokemonCenter_1F_EventScript_Youngster {
    msgbox(VermilionCity_PokemonCenter_1F_Text_AllMonWeakToSpecificTypes, MSGBOX_NPC)
    end
}

script VermilionCity_PokemonCenter_1F_EventScript_VSSeekerWoman {
    lock_faceplayer
    if (flag(FLAG_GOT_VS_SEEKER)) {
        msgbox(VermilionCity_PokemonCenter_1F_Text_ExplainVSSeeker)
    	release_end
    }
    msgbox(VermilionCity_PokemonCenter_1F_Text_UrgeToBattleSomeoneAgain)
    setflag(FLAG_GOT_VS_SEEKER)
    if (giveitem(ITEM_VS_SEEKER) == FALSE) {
        goto(EventScript_BagIsFull)
    }
    msgbox(VermilionCity_PokemonCenter_1F_Text_UseDeviceForRematches)
    release_end
}

text VermilionCity_PokemonCenter_1F_Text_TrainerMonsStrongerThanWild {
	"Even if they are the same level,
	POKéMON can have very different
	stats and abilities.

	A POKéMON raised by a TRAINER is
	stronger than one in the wild."
}

text VermilionCity_PokemonCenter_1F_Text_PoisonedMonFaintedWhileWalking {
	"My POKéMON was poisoned!
	It fainted while we were walking!"
}

text VermilionCity_PokemonCenter_1F_Text_AllMonWeakToSpecificTypes {
	"It is true that a higher-level
	POKéMON will be more powerful…

	But, all POKéMON will have weak
	points against specific types.

	So, there appears to be no
	universally strong POKéMON."
}

text VermilionCity_PokemonCenter_1F_Text_UrgeToBattleSomeoneAgain {
	"The urge to battle with someone
	you've tangled with before…

	Have you ever had that urge?
	I'm sure you have.

	I wanted to battle certain people
	again over and over, too.

	So, I've been giving these away.
	Please, take one!"
}

text VermilionCity_PokemonCenter_1F_Text_UseDeviceForRematches {
	"Use that device and you'll find
	TRAINERS looking for a rematch.

	You have to charge its battery to
	use it, though."
}

text VermilionCity_PokemonCenter_1F_Text_ExplainVSSeeker {
	"How do you use the VS SEEKER?
	There's nothing to it.

	Use it like beep-beep-beep, and
	TRAINERS around you will notice.

	If any TRAINER wants a rematch,
	it will let you know immediately.

	Charge its battery and use it
	while you're on a road."
}
