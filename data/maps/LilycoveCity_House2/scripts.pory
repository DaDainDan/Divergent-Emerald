mapscripts LilycoveCity_House2_MapScripts {}

script LilycoveCity_House2_EventScript_FatMan {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_TM_REST)) {
        msgbox(LilycoveCity_House2_Text_SleepIsEssential, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_House2_Text_NotAwakeYetHaveThis, MSGBOX_DEFAULT)
    if (giveitem(ITEM_TM_REST) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_TM_REST)
    msgbox(LilycoveCity_House2_Text_SleepIsEssential, MSGBOX_DEFAULT)
    release_end
}

text LilycoveCity_House2_Text_NotAwakeYetHaveThis {
	"Huh? What? What's that?

	I'm not near awake yet…
	You can have this…"
}

text LilycoveCity_House2_Text_SleepIsEssential {
	"Yawn…

	Sleep is essential for good health…
	Sleep and regain health…"
}
