script LilycoveCity_EventScript_Rival {
    lock_faceplayer
    if (checkplayergender == MALE) {
        goto(LilycoveCity_EventScript_May)
    } else {
        goto(LilycoveCity_EventScript_Brendan)
    }
    end
}

script LilycoveCity_EventScript_May {
    playbgm(MUS_ENCOUNTER_MAY, TRUE)
    if (flag(FLAG_DECLINED_RIVAL_BATTLE_LILYCOVE)) {
        msgbox(LilycoveCity_Text_MayBattleMe, MSGBOX_YESNO)
    } else {
        msgbox(LilycoveCity_Text_MayShoppingLetsBattle, MSGBOX_YESNO)
    }
    if (var(VAR_RESULT) == NO) {
        setflag(FLAG_DECLINED_RIVAL_BATTLE_LILYCOVE)
		msgbox(LilycoveCity_Text_MayNotRaisingPokemon, MSGBOX_DEFAULT)
		savebgm(MUS_DUMMY)
		fadedefaultbgm
		release_end
    }
    msgbox(LilycoveCity_Text_MayWontBeBeaten, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case 0: trainerbattle_no_intro(TRAINER_MAY_LILYCOVE_TREECKO, LilycoveCity_Text_MayDefeat)
        case 1: trainerbattle_no_intro(TRAINER_MAY_LILYCOVE_TORCHIC, LilycoveCity_Text_MayDefeat)
        case 2: trainerbattle_no_intro(TRAINER_MAY_LILYCOVE_MUDKIP, LilycoveCity_Text_MayDefeat)
    }
    goto(LilycoveCity_EventScript_DefeatedMay)
    end
}

script LilycoveCity_EventScript_Brendan {
    playbgm(MUS_ENCOUNTER_BRENDAN, TRUE)
    if (flag(FLAG_DECLINED_RIVAL_BATTLE_LILYCOVE)) {
        msgbox(LilycoveCity_Text_BrendanBattleMe, MSGBOX_YESNO)
    } else {
        msgbox(LilycoveCity_Text_BrendanShoppingLetsBattle, MSGBOX_YESNO)
    }
    if (var(VAR_RESULT) == NO) {
        setflag(FLAG_DECLINED_RIVAL_BATTLE_LILYCOVE)
		msgbox(LilycoveCity_Text_BrendanNoConfidence, MSGBOX_DEFAULT)
		savebgm(MUS_DUMMY)
		fadedefaultbgm
		release_end
    }
    msgbox(LilycoveCity_Text_BrendanWontBeBeaten, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case CHOSE_TREECKO: trainerbattle_no_intro(TRAINER_BRENDAN_LILYCOVE_TREECKO, LilycoveCity_Text_BrendanDefeat)
        case CHOSE_TORCHIC: trainerbattle_no_intro(TRAINER_BRENDAN_LILYCOVE_TORCHIC, LilycoveCity_Text_BrendanDefeat)
        case CHOSE_MUDKIP: trainerbattle_no_intro(TRAINER_BRENDAN_LILYCOVE_MUDKIP, LilycoveCity_Text_BrendanDefeat)
    }
    goto(LilycoveCity_EventScript_DefeatedBrendan)
    end
}

script LilycoveCity_EventScript_DefeatedMay {
    msgbox(LilycoveCity_Text_MayGoingBackToLittleroot, MSGBOX_DEFAULT)
    setvar(VAR_RESULT, FALSE)
    if (flag(FLAG_BADGE06_GET)) {
        call(LilycoveCity_EventScript_CheckFinalBadge)
    }
    if (var(VAR_RESULT) == FALSE) {
        msgbox(LilycoveCity_Text_MayYouGoingToCollectBadges, MSGBOX_DEFAULT)
    } else {
        if (flag(FLAG_SYS_GAME_CLEAR)) {
			msgbox(LilycoveCity_Text_MayYouGoingToBattleFrontier, MSGBOX_DEFAULT)
		} else {
			msgbox(LilycoveCity_Text_MayYouGoingToPokemonLeague, MSGBOX_DEFAULT)
		}
    }
    clearflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_RIVAL_BEDROOM)
    clearflag(FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_2F_PICHU_DOLL)
    goto(LilycoveCity_EventScript_RivalFlyAway)
    end
}

script LilycoveCity_EventScript_CheckFinalBadge {
    if (flag(FLAG_BADGE08_GET)) {
        setvar(VAR_RESULT, TRUE)
    }
    return
}

script LilycoveCity_EventScript_DefeatedBrendan {
    msgbox(LilycoveCity_Text_BrendanGoingBackToLittleroot, MSGBOX_DEFAULT)
    setvar(VAR_RESULT, FALSE)
    if (flag(FLAG_BADGE06_GET)) {
        call(LilycoveCity_EventScript_CheckFinalBadge)
    }
    if (var(VAR_RESULT) == FALSE) {
        msgbox(LilycoveCity_Text_BrendanYouGoingToCollectBadges, MSGBOX_DEFAULT)
    }
    if (var(VAR_RESULT) == TRUE) {
        if (flag(FLAG_SYS_GAME_CLEAR)) {
			msgbox(LilycoveCity_Text_BrendanYouGoingToBattleFrontier, MSGBOX_DEFAULT)
		} else {
			msgbox(LilycoveCity_Text_BrendanYouGoingToPokemonLeague, MSGBOX_DEFAULT)
		}
    }
    clearflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_RIVAL_BEDROOM)
    clearflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENDANS_HOUSE_2F_SWABLU_DOLL)
    goto(LilycoveCity_EventScript_RivalFlyAway)
    end
}

script LilycoveCity_EventScript_RivalFlyAway {
    closemessage
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(50)
    setfieldeffectargument(0, 1)
    dofieldeffect(FLDEFF_NPCFLY_OUT)
    delay(15)
    removeobject(VAR_LAST_TALKED)
    waitfieldeffect(FLDEFF_NPCFLY_OUT)
    savebgm(MUS_DUMMY)
    fadedefaultbgm
    setflag(FLAG_MET_RIVAL_LILYCOVE)
    release_end
}

script LilycoveCity_EventScript_SchoolKidM {
    lock_faceplayer
    msgbox(LilycoveCity_Text_DoYouKnowAboutBerryBlender, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
		msgbox(LilycoveCity_Text_ExplainBerryBlender, MSGBOX_DEFAULT)
        
    } else {
        msgbox(LilycoveCity_Text_FasterSpinBetterPokeblocks, MSGBOX_DEFAULT)
    }
    release_end
}

text LilycoveCity_Text_MayShoppingLetsBattle {
	"MAY: Oh, hey?
	{PLAYER}{KUN}, are you shopping, too?

	I bought a whole bunch of DOLLS and
	POSTERS.

	Of course, I've also caught a lot of
	POKéMON, and I'm raising them
	properly, too.

	Actually, I'm more worried if you're
	raising POKéMON properly, {PLAYER}{KUN}.

	I'll battle with you, so you can show
	me your POKéMON, {PLAYER}{KUN}."
}

text LilycoveCity_Text_MayNotRaisingPokemon {
	"MAY: Oh, why? {PLAYER}{KUN}, haven't you
	been raising your POKéMON?

	That's not a very good showing as a
	TRAINER…"
}

text LilycoveCity_Text_MayBattleMe {
	"MAY: Come on, battle with me, so I can
	check out your POKéMON!"
}

text LilycoveCity_Text_MayWontBeBeaten {
	"MAY: The POKéMON I raised won't be
	beaten by your POKéMON, {PLAYER}{KUN}!"
}

text LilycoveCity_Text_MayDefeat {
	"… … … … … … … …

	I remember the battle I had with you,
	{PLAYER}{KUN}, on ROUTE 103.

	That battle helped you become this
	strong, {PLAYER}{KUN}, didn't it?"
}

text LilycoveCity_Text_MayGoingBackToLittleroot {
	"MAY: I'm thinking of going back to
	LITTLEROOT soon.

	I've caught a decent group of POKéMON,
	and my POKéDEX is coming along, so
	I'm going home to show my dad."
}

text LilycoveCity_Text_MayYouGoingToCollectBadges {
	"{PLAYER}{KUN}, what are you going to do?

	Collect all the GYM BADGES and take
	the POKéMON LEAGUE challenge?

	Well, while you're collecting BADGES,
	{PLAYER}{KUN}, I'm going to work on my
	POKéDEX. I'll complete it before you!

	See you!"
}

text LilycoveCity_Text_MayYouGoingToPokemonLeague {
	"{PLAYER}{KUN}, what are you going to do?

	Are you taking the POKéMON LEAGUE
	challenge?

	Or, are you going to complete your
	POKéDEX?

	I might've lost to you in battling,
	but I'll finish my POKéDEX before you!

	See you!"
}

text LilycoveCity_Text_MayYouGoingToBattleFrontier {
	"{PLAYER}{KUN}, what are you going to do?

	Are you taking the BATTLE FRONTIER
	challenge?

	Or, are you going to complete your
	POKéDEX?

	I might've lost to you in battling,
	but I'll finish my POKéDEX before you!

	See you!"
}

text LilycoveCity_Text_BrendanShoppingLetsBattle {
	"BRENDAN: Oh, hey, it's {PLAYER}.

	I'm running an errand for my dad.
	No, I'm not buying any DOLLS.

	Anyways, it's been a while.

	Want to have a battle to see who's been
	raising POKéMON better?"
}

text LilycoveCity_Text_BrendanNoConfidence {
	"BRENDAN: Oh, what's the matter?
	Don't have the confidence?"
}

text LilycoveCity_Text_BrendanBattleMe {
	"BRENDAN: Want to battle to see who's
	been raising POKéMON better?"
}

text LilycoveCity_Text_BrendanWontBeBeaten {
	"BRENDAN: Aww, but you know I'm not
	going to lose to no {PLAYER}."
}

text LilycoveCity_Text_BrendanDefeat {
	"Humph…
	You've done a lot of raising.

	That stings a bit--I had a head start
	on you as a TRAINER…"
}

text LilycoveCity_Text_BrendanGoingBackToLittleroot {
	"BRENDAN: I…
	I plan on going home to LITTLEROOT.

	You know I'm helping out my dad on his
	POKéDEX. It's coming together pretty
	decently, so I should go show him."
}

text LilycoveCity_Text_BrendanYouGoingToCollectBadges {
	"{PLAYER}, what are you going to do?

	Collect all the GYM BADGES and take
	the POKéMON LEAGUE challenge?

	Maybe I'll do that, too…

	Well, anyway, hang in there!"
}

text LilycoveCity_Text_BrendanYouGoingToPokemonLeague {
	"{PLAYER}, what are you going to do?

	Since you're that strong, are you
	taking the POKéMON LEAGUE challenge?

	Heh, even me--if I trained my POKéMON
	a bit more, I should be stronger than
	you, {PLAYER}.

	Well, anyway, hang in there!"
}

text LilycoveCity_Text_BrendanYouGoingToBattleFrontier {
	"{PLAYER}, what are you going to do?

	Are you taking the BATTLE FRONTIER
	challenge?

	Or, are you going to complete your
	POKéDEX?

	Since you're that strong, you should
	consider the BATTLE FRONTIER.

	Heh, if I train my POKéMON a bit more,
	I'll get stronger than you, {PLAYER}.

	Maybe I should go to the BATTLE
	FRONTIER.

	Well, anyway, hang in there!"
}

text LilycoveCity_Text_MovedLootIntoHideoutToday {
	"Fufufu…

	We moved more loot into our secret
	HIDEOUT today…

	Wh-who are you?!
	I was just talking to myself!"
}

text LilycoveCity_Text_ChanceToDoBigThings {
	"I'm just a GRUNT, so I don't know what
	the BOSS is thinking…

	But being on TEAM AQUA, I know I'll get
	the chance to do big things!

	Wh-who are you?!
	I was just talking to myself!"
}

text LilycoveCity_Text_DontGoNearCaveInCove {
	"Hey, you!

	Don't go near the cave in the cove!

	Why? You don't need a reason why!
	I'm an adult, so you just listen to me!"
}

text LilycoveCity_Text_IfWorldBecomesOurs {
	"If this whole wide world becomes ours,
	TEAM AQUA's, it will be a happier
	place for POKéMON, too."
}

text LilycoveCity_Text_WailmerLeapOutOfWater {
	"There! WAILMER!
	Leap out of the water now!"
}

text LilycoveCity_Text_GetLostMessingUpTraining {
	"Hunh? What do you want?

	You're messing up our training,
	so can you, like, get lost?"
}

text LilycoveCity_Text_ContestHallInTown {
	"There's a POKéMON CONTEST HALL
	right in this here town. 

	That means well-raised POKéMON will
	come from all over the country.

	My heart swells with excitement!"
}

text LilycoveCity_Text_StrangeCaveInCove {
	"Have you seen that strange cave in
	the cove at the edge of town?"
}

text LilycoveCity_Text_GoingToMoveDeleterForHMs {
	"I'm going to teach my POKéMON some new
	moves for entering a CONTEST.

	So, I'm going to see the MOVE DELETER
	and make it forget HM moves."
}

text LilycoveCity_Text_ImFromKanto {
	"I came from KANTO.

	The HOENN region is beautiful with
	all its water and verdant nature.

	Hunh? Wait a second…

	Could there be rare POKéMON that live
	only in this area?"
}

text LilycoveCity_Text_TeamAquaBeenTrainingWailmer {
	"TEAM AQUA's been training their
	WAILMER in the cove.

	We SAILORS can't get our boats out
	to sea with them in the way!"
}

text LilycoveCity_Text_SomeonePuntedTeamAquaOut {
	"Ahoy, did you know?

	Someone punted TEAM AQUA out of
	the way for us!

	That got the WAILMER out of the cove,
	so we can get our boats out again."
}

text LilycoveCity_Text_SomeoneStoleMyPokemon {
	"I was taking a relaxing snooze at the
	seaside inn to the sound of waves…

	When someone stole my POKéMON!

	Who's the abductor?
	TEAM AQUA? Is it TEAM AQUA?"
}

text LilycoveCity_Text_MissingPokemonCameBack {
	"My missing POKéMON…
	It came back without me noticing!"
}

text LilycoveCity_Text_ImArtDealer {
	"I'm an ART DEALER.

	I am a buyer and seller of fine art,
	especially paintings.

	I've heard that the MUSEUM here has
	magnificent works on exhibit…"
}

text LilycoveCity_Text_SeaRemainsForeverYoung {
	"Even as we grow old and wrinkled,
	the sea remains forever young with
	the vivid brilliance of life…

	Fwohoho fwohohohoho…"
}

text LilycoveCity_Text_SixtyYearsAgoHusbandProposed {
	"It was sixty years ago that my husband
	proposed to me here.
	The sea remains as beautiful as ever.

	Mufufufu mufufufufufu…"
}

text LilycoveCity_Text_TeamAquaRenovatedCavern {
	"Hm, you know of the peculiar cavern
	in this cove?

	That had been a natural formation,
	but then that TEAM AQUA lot came
	along and made their renovations.

	They call themselves
	the “nature-loving TEAM AQUA”!

	But what they do and what they say
	don't match at all!"
}

text LilycoveCity_Text_TeamAquaLotGoneForGood {
	"That cave in the cove…

	I didn't notice it right away,
	but it's completely empty now.

	That TEAM AQUA lot, they must
	have gone away for good."
}

text LilycoveCity_Text_CitySign {
	"LILYCOVE CITY

	“Where the land ends and the
	sea begins.”"
}

text LilycoveCity_Text_ContestHallSign {
	"POKéMON CONTEST HALL
	“The gathering place for TRAINERS!”"
}

text LilycoveCity_Text_MotelSign {
	"COVE LILY MOTEL

	“Remember us as COVE LILY of
	LILYCOVE.”"
}

text LilycoveCity_Text_MuseumSign {
	"LILYCOVE MUSEUM

	“POKéMON Masterpiece Collection
	on exhibit!”"
}

text LilycoveCity_Text_MuseumSignPlayersExhibit {
	"LILYCOVE MUSEUM

	“{PLAYER}'s POKéMON Collection
	on exhibit!”"
}

text LilycoveCity_Text_HarborSignUnderConstruction {
	"LILYCOVE CITY HARBOR

	“The ferry S.S. TIDAL is under
	construction in SLATEPORT CITY.

	“Service is scheduled to begin
	shortly.”"
}

text LilycoveCity_Text_HarborSign {
	"LILYCOVE CITY HARBOR

	“Enjoy a delightful cruise on
	the ferry S.S. TIDAL.”"
}

text LilycoveCity_Text_TrainerFanClubSign {
	"POKéMON TRAINER FAN CLUB

	The names of TRAINERS are scribbled
	all over the sign…"
}

text LilycoveCity_Text_DepartmentStoreSign {
	"LILYCOVE DEPARTMENT STORE

	“Overflowing with great merchandise
	and excitement!

	“A great place to find that something
	you need!”"
}

text LilycoveCity_Text_MoveDeletersHouseSign {
	"MOVE DELETER'S HOUSE

	“Unwanted POKéMON moves deleted.”"
}

text LilycoveCity_Text_DoYouKnowAboutBerryBlender {
	"Do you know about the machine
	BERRY BLENDER?"
}

text LilycoveCity_Text_FasterSpinBetterPokeblocks {
	"People have to work together to get it
	to spin faster.

	The faster you can make it spin, the
	better {POKEBLOCK}S you can get, I've heard."
}

text LilycoveCity_Text_ExplainBerryBlender {
	"It's used for making a kind of candy
	called a {POKEBLOCK}.

	If you give a good {POKEBLOCK} to a POKéMON,
	its condition will improve by a lot."
}

text LilycoveCity_Text_HeardTowerCalledSkyPillar {
	"I heard there's a tower somewhere out
	on the sea routes.

	It's called the SKY PILLAR, I hear."
}

text LilycoveCity_Text_SawTallTowerOnRoute131 {
	"I saw this tall tower somewhere
	around ROUTE 131.

	Could that possibly be…?"
}

text LilycoveCity_Text_JustArrivedAndSawRarePokemon {
	"We just arrived here on our
	honeymoon vacation.

	We happened to see a DRAGON-type
	POKéMON flying way up in the sky.

	Do cool POKéMON like that live in
	the HOENN region?"
}

text LilycoveCity_Text_HoneymoonVowToSeeRarePokemon {
	"On our honeymoon, we vowed to see as
	many rare POKéMON as we can.

	So we were delighted to see a rare
	POKéMON as soon as we arrived.

	I mean, we are totally happy!"
}
