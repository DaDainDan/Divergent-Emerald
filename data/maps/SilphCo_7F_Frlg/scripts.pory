mapscripts SilphCo_7F_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_SILPH_7F_DOOR_1)) {
			call(EventScript_Close7FDoor1)
		}
		if (!flag(FLAG_SILPH_7F_DOOR_2)) {
			call(EventScript_Close7FDoor2)
		}
		if (!flag(FLAG_SILPH_7F_DOOR_3)) {
			call(EventScript_Close7FDoor3)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
			setobjectmovementtype(LOCALID_SILPH_CO_7F_WORKER_M2, MOVEMENT_TYPE_FACE_UP)
		}
		end
    }
}

script SilphCo_7F_EventScript_RivalTriggerTop {
    lockall
    setvar(VAR_TEMP_1, 0)
    goto(SilphCo_7F_EventScript_RivalScene)
    end
}

script SilphCo_7F_EventScript_RivalTriggerBottom {
    lockall
    setvar(VAR_TEMP_1, 1)
    goto(SilphCo_7F_EventScript_RivalScene)
    end
}

script SilphCo_7F_EventScript_RivalScene {
    textcolor(NPC_TEXT_COLOR_MALE)
    playbgm(MUS_RG_ENCOUNTER_RIVAL, 0)
    applymovement(LOCALID_SILPH_CO_RIVAL, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    applymovement(LOCALID_SILPH_CO_RIVAL, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(SilphCo_7F_Text_RivalWhatKeptYou)
    if (var(VAR_TEMP_1) == 0) {
        closemessage
		applymovement(LOCALID_SILPH_CO_RIVAL, Common_Movement_WalkUp)
		waitmovement(0)
    }
    msgbox(SilphCo_7F_Text_RivalIntro)
    setvar(VAR_LAST_TALKED, LOCALID_SILPH_CO_RIVAL)
	switch (var(VAR_STARTER_MON)) {
		case PC_CHOSE_BULBASAUR: trainerbattle_no_intro(TRAINER_RIVAL_SILPH_CHARMANDER, SilphCo_7F_Text_RivalDefeat)
		case PC_CHOSE_SQUIRTLE: trainerbattle_no_intro(TRAINER_RIVAL_SILPH_BULBASAUR, SilphCo_7F_Text_RivalDefeat)
		case PC_CHOSE_CHARMANDER: trainerbattle_no_intro(TRAINER_RIVAL_SILPH_SQUIRTLE, SilphCo_7F_Text_RivalDefeat)
	}
    msgbox(SilphCo_7F_Text_RivalPostBattle)
    closemessage
    playbgm(MUS_RG_RIVAL_EXIT, 0)
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_SILPH_CO_RIVAL, moves(walk_right * 3,  walk_up,  delay_16))
		case 1: applymovement(LOCALID_SILPH_CO_RIVAL, moves(walk_left,  walk_up * 2,  walk_right * 4,  delay_16))
	}
	waitmovement(0)
    playse(SE_WARP_IN)
    fadedefaultbgm
    removeobject(LOCALID_SILPH_CO_RIVAL)
    waitse
    setvar(VAR_MAP_SCENE_SILPH_CO_7F, 1)
    releaseall
    end
}

script SilphCo_7F_EventScript_LaprasGuy {
    lock_faceplayer
    if (flag(FLAG_GOT_LAPRAS_FROM_SILPH)) {
        msgbox(SilphCo_7F_Text_RocketBossWentToBoardroom)
    	release_end
    }
    msgbox(SilphCo_7F_Text_HaveMonForSavingUs)
    setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_LAPRAS)
    if (givemon(SPECIES_LAPRAS, 25) == MON_CANT_GIVE) {
		goto(Common_EventScript_NoMoreRoomForPokemon)
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_LEVEL_UP)
    message(SilphCo_7F_Text_ObtainedLaprasFromEmployee)
    waitmessage
    waitfanfare
    bufferspeciesname(STR_VAR_1, SPECIES_LAPRAS)
	msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_GetGiftMonPartySlot)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
	textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(SilphCo_7F_Text_ExplainLapras)
    setflag(FLAG_GOT_LAPRAS_FROM_SILPH)
    release_end
}

script SilphCo_7F_EventScript_WorkerM1 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_7F_Text_CanceledMasterBallProject)
    	release_end
    }
    msgbox(SilphCo_7F_Text_RocketsAfterMasterBall)
    release_end
}

