mapscripts PacifidlogTown_House4_MapScripts {}

script PacifidlogTown_House4_EventScript_LittleGirl {
    msgbox(PacifidlogTown_House4_Text_SkyPokemon, MSGBOX_NPC)
    end
}

script PacifidlogTown_House4_EventScript_Woman {
    msgbox(PacifidlogTown_House4_Text_PeopleSawHighFlyingPokemon, MSGBOX_NPC)
    end
}

script PacifidlogTown_House4_EventScript_Boy {
    lock_faceplayer
    msgbox(PacifidlogTown_House4_Text_WhereDidYouComeFrom, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(PacifidlogTown_House4_Text_YesTown, MSGBOX_DEFAULT)
    } else {
        msgbox(PacifidlogTown_House4_Text_YouHaveToComeFromSomewhere, MSGBOX_DEFAULT)
    }
    release_end
}

text PacifidlogTown_House4_Text_PeopleSawHighFlyingPokemon {
	"People were saying they saw a POKéMON
	flying high above HOENN.

	Is it flying around all the time?
	Doesn't it need to rest somewhere?"
}

text PacifidlogTown_House4_Text_SkyPokemon {
	"A sky POKéMON!
	A sky POKéMON!"
}

text PacifidlogTown_House4_Text_WhereDidYouComeFrom {
	"Where did you come from?"
}

text PacifidlogTown_House4_Text_YesTown {
	"Yes?
	YES TOWN?

	I've never heard of a place like that."
}

text PacifidlogTown_House4_Text_YouHaveToComeFromSomewhere {
	"No? That doesn't make any sense.
	You have to come from somewhere.

	Oh! Wait! You're not going to say you
	were born at the bottom of the sea?"
}
