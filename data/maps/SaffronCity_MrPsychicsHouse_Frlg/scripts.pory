mapscripts SaffronCity_MrPsychicsHouse_Frlg_MapScripts {}

script SaffronCity_MrPsychicsHouse_EventScript_MrPsychic {
    lock_faceplayer
    if (flag(FLAG_GOT_TM29_FROM_MR_PSYCHIC)) {
        msgbox(SaffronCity_MrPsychicsHouse_Text_ExplainTM29)
    	release_end
    }
    msgbox(SaffronCity_MrPsychicsHouse_Text_YouWantedThis)
    if (checkitemspace(ITEM_TM29) == FALSE) {
        msgbox(SaffronCity_MrPsychicsHouse_Text_YouveNoRoom)
    	release_end
    }
    giveitem_msg(SaffronCity_MrPsychicsHouse_Text_ReceivedTM29FromMrPsychic, ITEM_TM29)
    msgbox(SaffronCity_MrPsychicsHouse_Text_ExplainTM29)
    setflag(FLAG_GOT_TM29_FROM_MR_PSYCHIC)
    release_end
}

text SaffronCity_MrPsychicsHouse_Text_YouWantedThis {
	"…Wait! Don't say a word!

	You wanted this!"
}

text SaffronCity_MrPsychicsHouse_Text_ReceivedTM29FromMrPsychic {
	"{PLAYER} received TM29
	from MR. PSYCHIC."
}

text SaffronCity_MrPsychicsHouse_Text_ExplainTM29 {
	"You already know, don't you?
	TM29 is PSYCHIC.

	It's an attack that may also lower
	the target's special stats."
}

text SaffronCity_MrPsychicsHouse_Text_YouveNoRoom {
	"Where do you plan to put this?
	You've no room."
}
