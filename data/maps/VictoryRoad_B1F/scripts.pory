script VictoryRoad_B1F_EventScript_Halle {
    trainerbattle_single(TRAINER_HALLE, VictoryRoad_B1F_Text_HalleIntro, VictoryRoad_B1F_Text_HalleDefeat)
    msgbox(VictoryRoad_B1F_Text_HallePostBattle, MSGBOX_AUTOCLOSE)
    end
