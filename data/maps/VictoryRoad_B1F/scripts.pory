    trainerbattle_single(TRAINER_SHANNON, VictoryRoad_B1F_Text_ShannonIntro, VictoryRoad_B1F_Text_ShannonDefeat)
    msgbox(VictoryRoad_B1F_Text_ShannonPostBattle, MSGBOX_AUTOCLOSE)
    end
}

