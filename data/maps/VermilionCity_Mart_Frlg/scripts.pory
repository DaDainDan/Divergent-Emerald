mapscripts VermilionCity_Mart_Frlg_MapScripts {}

script VermilionCity_Mart_EventScript_CooltrainerF {
    msgbox(VermilionCity_Mart_Text_MonsGoodOrBadDependingOnTrainer, MSGBOX_NPC)
    end
}

script VermilionCity_Mart_EventScript_BaldingMan {
    msgbox(VermilionCity_Mart_Text_TeamRocketAreWickedPeople, MSGBOX_NPC)
    end
}

script VermilionCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(VermilionCity_Mart_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart VermilionCity_Mart_Items {
    ITEM_POKE_BALL
    ITEM_SUPER_POTION
    ITEM_ANTIDOTE
    ITEM_PARALYZE_HEAL
    ITEM_AWAKENING
    ITEM_ICE_HEAL
    ITEM_REPEL
}

text VermilionCity_Mart_Text_TeamRocketAreWickedPeople {
	"There are wicked people who will
	use POKéMON for criminal acts.

	TEAM ROCKET traffics in rare
	POKéMON, for example.

	They also abandon POKéMON that
	they consider unpopular or useless.

	That's the sort of horrid people
	they are, TEAM ROCKET."
}

text VermilionCity_Mart_Text_MonsGoodOrBadDependingOnTrainer {
	"I think POKéMON can be good or
	bad. It depends on the TRAINER."
}
