mapscripts ViridianCity_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_VIRIDIAN_CITY)
		switch (var(VAR_MAP_SCENE_VIRIDIAN_CITY_OLD_MAN)) {
			case 0:
				setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_OLD_MAN_LYING_DOWN)
				setobjectxyperm(LOCALID_TUTORIAL_MAN, 21, 11)
				setobjectmovementtype(LOCALID_TUTORIAL_MAN, MOVEMENT_TYPE_FACE_DOWN)
			case 1:
				setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_OLD_MAN_1)
				setobjectxyperm(LOCALID_TUTORIAL_MAN, 21, 8)
				setobjectmovementtype(LOCALID_TUTORIAL_MAN, MOVEMENT_TYPE_LOOK_AROUND)
			default: setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_OLD_MAN_1)
		}
		if (var(VAR_MAP_SCENE_VIRIDIAN_CITY_GYM_DOOR) == 0) {
			if (flag(FLAG_BADGE02_GET) || flag(FLAG_BADGE03_GET) || flag(FLAG_BADGE04_GET) 
			|| flag(FLAG_BADGE05_GET) || flag(FLAG_BADGE06_GET) || flag(FLAG_BADGE07_GET)) {
				setvar(VAR_MAP_SCENE_VIRIDIAN_CITY_GYM_DOOR, 1)
			}
		}
		end
    }
}

script ViridianCity_EventScript_GymDoorLocked {
    lockall
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    delay(20)
    msgbox(ViridianCity_Text_GymDoorsAreLocked)
    closemessage
    applymovement(LOCALID_PLAYER, moves(jump_2_down))
    waitmovement(0)
    releaseall
    end
}

script ViridianCity_EventScript_CitySign {
    msgbox(ViridianCity_Text_CitySign, MSGBOX_SIGN)
    end
}

script ViridianCity_EventScript_TrainerTips1 {
    msgbox(ViridianCity_Text_CatchMonsForEasierBattles, MSGBOX_SIGN)
    end
}

script ViridianCity_EventScript_TrainerTips2 {
    msgbox(ViridianCity_Text_MovesLimitedByPP, MSGBOX_SIGN)
    end
}

script ViridianCity_EventScript_GymSign {
    msgbox(ViridianCity_Text_GymSign, MSGBOX_SIGN)
    end
}

script ViridianCity_EventScript_GymDoor {
    msgbox(ViridianCity_Text_GymDoorsAreLocked, MSGBOX_SIGN)
    end
}

script ViridianCity_EventScript_Boy {
    msgbox(ViridianCity_Text_CanCarryMonsAnywhere, MSGBOX_NPC)
    end
}

// Other old man, not the tutorial old man
script ViridianCity_EventScript_OldMan {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_VIRIDIAN_CITY_GYM_DOOR) == 1) {
        msgbox(ViridianCity_Text_ViridiansGymLeaderReturned)
    	release_end
    }
    msgbox(ViridianCity_Text_GymClosedWonderWhoLeaderIs)
    goto(Common_EventScript_FaceOriginalDirection)
	end
}

script ViridianCity_EventScript_TutorialOldMan {
    lock_faceplayer
    if (flag(FLAG_BADGE01_GET)) {
        msgbox(ViridianCity_Text_HowsTeachyTVHelping, MSGBOX_YESNO)
		if (var(VAR_RESULT) == NO) {
			msgbox(ViridianCity_Text_TooBusyForTeachyTV)
			release_end
		}
		msgbox(ViridianCity_Text_MyGrandsonOnTheShow)
		release_end
    }
	switch (var(VAR_MAP_SCENE_VIRIDIAN_CITY_OLD_MAN)) {
		case 0:
			msgbox(ViridianCity_Text_ThisIsPrivateProperty)
			closemessage
		case 1: call(ViridianCity_EventScript_DoTutorialBattle)
		default: msgbox(ViridianCity_Text_WeakenMonsFirstToCatch)
	}
    release_end
}

// Unused
script ViridianCity_EventScript_WatchToLearnBasics {
    msgbox(ViridianCity_Text_WatchThatToLearnBasics)
    release_end
}

// Unused. Starts battle after the post battle text, which is odd.
script ViridianCity_EventScript_TutorialUnused {
    msgbox(ViridianCity_Text_ThatWasEducationalTakeThis)
    special(StartOldManTutorialBattle)
    waitstate
    release_end
}

script ViridianCity_EventScript_Youngster {
    lock_faceplayer
    msgbox(ViridianCity_Text_WantToKnowAboutCaterpillarMons, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(ViridianCity_Text_ExplainCaterpieWeedle)
    	release_end
    }
    msgbox(ViridianCity_Text_OhOkayThen)
    release_end
}

script ViridianCity_EventScript_Woman {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_VIRIDIAN_CITY_OLD_MAN) == 0) {
        msgbox(ViridianCity_Text_GrandpaHasntHadCoffeeYet)
    	goto(Common_EventScript_FaceOriginalDirection)
    }
    msgbox(ViridianCity_Text_GoShoppingInPewterOccasionally)
    release_end
}

script ViridianCity_EventScript_DreamEaterTutor {
    goto(EventScript_DreamEaterTutor)
    end
}

script ViridianCity_EventScript_RoadBlocked {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(ViridianCity_Text_ThisIsPrivateProperty)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    releaseall
    end
}

script ViridianCity_EventScript_TutorialTriggerLeft {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_TUTORIAL_MAN, Common_Movement_StepFasterLeft)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    call(ViridianCity_EventScript_DoTutorialBattle)
    release_end
}

script ViridianCity_EventScript_TutorialTriggerRight {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_TUTORIAL_MAN, Common_Movement_StepFasterRight)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    call(ViridianCity_EventScript_DoTutorialBattle)
    release_end
}

script ViridianCity_EventScript_DoTutorialBattle {
    msgbox(ViridianCity_Text_ShowYouHowToCatchMons)
    closemessage
    special(StartOldManTutorialBattle)
    waitstate
    lock_faceplayer
    msgbox(ViridianCity_Text_ThatWasEducationalTakeThis)
    setvar(VAR_MAP_SCENE_VIRIDIAN_CITY_OLD_MAN, 2)
    giveitem(ITEM_TEACHY_TV)
    msgbox(ViridianCity_Text_WatchThatToLearnBasics)
    return
}

text ViridianCity_Text_CanCarryMonsAnywhere {
	"Those POKé BALLS at your waist!
	You have POKéMON, don't you?

	It's great that you can carry and
	use POKéMON anytime, anywhere."
}

text ViridianCity_Text_GymClosedWonderWhoLeaderIs {
	"This POKéMON GYM is always closed.

	I wonder who the LEADER is?"
}

text ViridianCity_Text_ViridiansGymLeaderReturned {
	"VIRIDIAN GYM's LEADER returned!"
}

text ViridianCity_Text_WantToKnowAboutCaterpillarMons {
	"You want to know about the two
	kinds of caterpillar POKéMON?"
}

text ViridianCity_Text_OhOkayThen {
	"Oh, okay then!"
}

text ViridianCity_Text_ExplainCaterpieWeedle {
	"CATERPIE has no poison,
	but WEEDLE does.

	Watch that your POKéMON aren't
	stabbed by WEEDLE's POISON STING."
}

text ViridianCity_Text_GrandpaHasntHadCoffeeYet {
	"Oh, Grandpa!
	Don't be so mean!

	I'm so sorry.
	He hasn't had his coffee yet."
}

text ViridianCity_Text_GoShoppingInPewterOccasionally {
	"I go shopping in PEWTER CITY
	occasionally.

	I have to take the winding trail in
	VIRIDIAN FOREST when I go."
}

text ViridianCity_Text_ThisIsPrivateProperty {
	"I absolutely forbid you from
	going through here!

	This is private property!"
}

text ViridianCity_Text_ShowYouHowToCatchMons {
	"Well, now, I've had my coffee, and
	that's what I need to get going!

	Hm?
	What is that red box you have?

	Ah, so you're working on your
	POKéDEX.

	Then let me give you a word of
	advice.

	Whenever you catch a POKéMON,
	the POKéDEX automatically updates
	its data.

	…You don't know how to catch
	a POKéMON?

	I suppose I had better show you
	then!"
}

text ViridianCity_Text_ThatWasEducationalTakeThis {
	"There! Now tell me, that was
	educational, was it not?

	And here, take this, too."
}

text ViridianCity_Text_WatchThatToLearnBasics {
	"If there's something you don't
	understand, watch that.

	It will teach you about the basics
	of being a POKéMON TRAINER."
}

text ViridianCity_Text_WeakenMonsFirstToCatch {
	"Well, now, I've had my coffee, and
	that's what I need to get going!

	But I made it too strong.
	It gave me a headache…

	Incidentally, are you filling your
	POKéDEX?

	At first, focus on weakening the
	POKéMON before trying to catch it."
}

text ViridianCity_Text_HowsTeachyTVHelping {
	"Well, now, I've had my coffee, and
	that's what I need to get going!

	But I made it too strong.
	It gave me a headache…

	Incidentally, is my old TEACHY TV
	helping you?"
}

text ViridianCity_Text_MyGrandsonOnTheShow {
	"Wahaha!
	It's my grandson on the show!

	Since he's the one doing the
	teaching, you're bound to learn."
}

text ViridianCity_Text_TooBusyForTeachyTV {
	"Hm… You're too busy to not even
	have the time for TEACHY TV…

	Time is money, and neither should
	be ill spent…"
}

text ViridianCity_Text_CitySign {
	"VIRIDIAN CITY 
	The Eternally Green Paradise"
}

text ViridianCity_Text_CatchMonsForEasierBattles {
	"TRAINER TIPS

	Catch POKéMON and expand your
	collection.

	The more you have, the easier it
	is to battle."
}

text ViridianCity_Text_MovesLimitedByPP {
	"TRAINER TIPS

	The battle moves of POKéMON are
	limited by their POWER POINTS, PP.

	To replenish PP, rest your tired
	POKéMON at a POKéMON CENTER."
}

text ViridianCity_Text_GymSign {
	"VIRIDIAN CITY POKéMON GYM"
}

text ViridianCity_Text_GymDoorsAreLocked {
	"VIRIDIAN GYM's doors are locked…"
}
