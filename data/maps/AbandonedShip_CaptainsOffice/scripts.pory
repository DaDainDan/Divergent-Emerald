mapscripts AbandonedShip_CaptainsOffice_MapScripts {}

script AbandonedShip_CaptainsOffice_EventScript_CaptSternAide {
    lock_faceplayer
    if (!flag(FLAG_EXCHANGED_SCANNER) && checkitem(ITEM_SCANNER) == TRUE) {
        msgbox(AbandonedShip_CaptainsOffice_Text_OhCanYouDeliverScanner, MSGBOX_DEFAULT)
    } 
	elif (flag(FLAG_EXCHANGED_SCANNER) || flag(FLAG_ITEM_ABANDONED_SHIP_HIDDEN_FLOOR_ROOM_2_SCANNER)) {
        msgbox(AbandonedShip_CaptainsOffice_Text_ThisIsSSCactus, MSGBOX_DEFAULT)
    } 
	else {
        msgbox(AbandonedShip_CaptainsOffice_Text_NoSuccessFindingScanner, MSGBOX_DEFAULT)
    }
    release_end
}

text AbandonedShip_CaptainsOffice_Text_NoSuccessFindingScanner {
	"I'm investigating this ship on behalf
	of CAPT. STERN.
	He also asked me to find a SCANNER,
	but I haven't had any success…"
}

text AbandonedShip_CaptainsOffice_Text_OhCanYouDeliverScanner {
	"Oh! That's a SCANNER!
	Listen, can I get you to deliver that
	to CAPT. STERN?
	I want to investigate this ship a
	little more."
}

text AbandonedShip_CaptainsOffice_Text_ThisIsSSCactus {
	"This ship is called S.S. CACTUS.
	It seems to be from an earlier era."
}
