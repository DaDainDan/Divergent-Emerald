mapscripts PalletTown_PlayersHouse_2F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_MAP_SCENE_PALLET_TOWN_PLAYERS_HOUSE_2F) == 0) {
			setrespawn(HEAL_LOCATION_PALLET_TOWN)
		}
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_MAP_SCENE_PALLET_TOWN_PLAYERS_HOUSE_2F, 0 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			setvar(VAR_MAP_SCENE_PALLET_TOWN_PLAYERS_HOUSE_2F, 1)
			end
		}
    ]
}

script PalletTown_PlayersHouse_2F_EventScript_NES {
    msgbox(PalletTown_PlayersHouse_2F_Text_PlayedWithNES, MSGBOX_SIGN)
    end
}

script PalletTown_PlayersHouse_2F_EventScript_Sign {
    msgbox(PalletTown_PlayersHouse_2F_Text_PressLRForHelp, MSGBOX_SIGN)
    end
}

text PalletTown_PlayersHouse_2F_Text_PlayedWithNES {
	"{PLAYER} played with the NES.

	…Okay!
	It's time to go!"
}

text PalletTown_PlayersHouse_2F_Text_PressLRForHelp {
	"It's a posted notice…

	If you're confused, ask for HELP!
	Press the L or R Button!"
}
