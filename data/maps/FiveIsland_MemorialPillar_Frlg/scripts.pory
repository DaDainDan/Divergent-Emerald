mapscripts FiveIsland_MemorialPillar_Frlg_MapScripts {}

script FiveIsland_MemorialPillar_EventScript_MemorialMan {
    lock
    if (flag(FLAG_GOT_TM42_AT_MEMORIAL_PILLAR)) {
        msgbox(FiveIsland_MemorialPillar_Text_ScrubScrubTectonix)
    }
    elif (flag(FLAG_NO_ROOM_FOR_TM42_AT_MEMORIAL_PILLAR)) {
        msgbox(FiveIsland_MemorialPillar_Text_StillHaveThingAsMyThanks)
		call(FiveIsland_MemorialPillar_EventScript_GiveTM42)
    }
	else {
		msgbox(FiveIsland_MemorialPillar_Text_ScrubScrub)
		closemessage
		applymovement(LOCALID_MEMORIAL_MAN, Common_Movement_FacePlayer)
		waitmovement(0)
		delay(45)
		msgbox(FiveIsland_MemorialPillar_Text_YourMonsLookHealthy)
		applymovement(LOCALID_MEMORIAL_MAN, Common_Movement_StepFasterUp)
		waitmovement(0)
		msgbox(FiveIsland_MemorialPillar_Text_ThisIsWhereIBuriedMyOnix)
	}
    release_end
}

script FiveIsland_MemorialPillar_EventScript_Memorial {
    lockall
    if (flag(FLAG_GOT_TM42_AT_MEMORIAL_PILLAR) || flag(FLAG_NO_ROOM_FOR_TM42_AT_MEMORIAL_PILLAR)) {
        msgbox(FiveIsland_MemorialPillar_Text_HereLiesTectonix)
		releaseall
		end
    }
    msgbox(FiveIsland_MemorialPillar_Text_HereLiesTectonixLemonadeOffering)
    if (checkitem(ITEM_LEMONADE) == TRUE) {
        msgbox(FiveIsland_MemorialPillar_Text_LeaveAnotherLemonadeOffering, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			removeitem(ITEM_LEMONADE)
			msgbox(FiveIsland_MemorialPillar_Text_PlacedCanOfLemonade)
			closemessage
			applymovement(LOCALID_MEMORIAL_MAN, Common_Movement_StepFasterRight)
			waitmovement(0)
			delay(45)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
			waitmovement(0)
			textcolor(NPC_TEXT_COLOR_MALE)
			msgbox(FiveIsland_MemorialPillar_Text_ThankYouPleaseTakeThis)
			call(FiveIsland_MemorialPillar_EventScript_GiveTM42)
		}
    }
    releaseall
    end
}

script FiveIsland_MemorialPillar_EventScript_GiveTM42 {
	if (giveitem(ITEM_TM42) == FALSE) {
        setflag(FLAG_NO_ROOM_FOR_TM42_AT_MEMORIAL_PILLAR)
		msgbox(FiveIsland_MemorialPillar_Text_DontHaveRoomForIt)
		releaseall
		end
    }
    msgbox(FiveIsland_MemorialPillar_Text_BeGoodToYourMonsToo)
    applymovement(LOCALID_MEMORIAL_MAN, Common_Movement_StepFasterUp)
    waitmovement(0)
    setflag(FLAG_GOT_TM42_AT_MEMORIAL_PILLAR)
    return
}

text FiveIsland_MemorialPillar_Text_MiloIntro {
	"I'm the eldest of the BIRD
	BROTHERS.

	The best thing about birds…
	It has to be the beak."
}

text FiveIsland_MemorialPillar_Text_MiloDefeat {
	"Oh, so sharp!"
}

text FiveIsland_MemorialPillar_Text_MiloPostBattle {
	"You can fly to FOUR ISLAND from
	here."
}

text FiveIsland_MemorialPillar_Text_ChazIntro {
	"I'm the middle kid of the BIRD
	BROTHERS.

	The best thing about birds…
	It has to be the wings."
}

text FiveIsland_MemorialPillar_Text_ChazDefeat {
	"Flap, flap!"
}

text FiveIsland_MemorialPillar_Text_ChazPostBattle {
	"There was a really somber guy
	over that way."
}

text FiveIsland_MemorialPillar_Text_HaroldIntro {
	"I'm the youngest of the BIRD
	BROTHERS.

	The best thing about birds…
	It has to be the down."
}

text FiveIsland_MemorialPillar_Text_HaroldDefeat {
	"Down is so comfy…
	It makes me drowsy…"
}

text FiveIsland_MemorialPillar_Text_HaroldPostBattle {
	"It fills me with happiness when
	bird POKéMON beg playfully…"
}

text FiveIsland_MemorialPillar_Text_ScrubScrub {
	"Scrub, scrub…"
}

text FiveIsland_MemorialPillar_Text_YourMonsLookHealthy {
	"Hello…
	Your POKéMON look healthy…"
}

text FiveIsland_MemorialPillar_Text_ThisIsWhereIBuriedMyOnix {
	"This is where I buried my ONIX…
	It was named TECTONIX…"
}

text FiveIsland_MemorialPillar_Text_HereLiesTectonixLemonadeOffering {
	"“Here lies TECTONIX” is engraved
	on a boulder.

	There is a LEMONADE placed as an
	offering in front of the grave."
}

text FiveIsland_MemorialPillar_Text_LeaveAnotherLemonadeOffering {
	"Would you like to leave another
	LEMONADE as an offering?"
}

text FiveIsland_MemorialPillar_Text_PlacedCanOfLemonade {
	"{PLAYER} placed a can of LEMONADE
	in front of the grave."
}

text FiveIsland_MemorialPillar_Text_ThankYouPleaseTakeThis {
	"Th-thank you…

	That was my TECTONIX's favorite
	drink…

	I don't even know you, but your
	act of kindness…

	It's uplifted me a little.

	Can you please take this as my
	thanks?"
}

text FiveIsland_MemorialPillar_Text_BeGoodToYourMonsToo {
	"Please be good to your POKéMON,
	too."
}

text FiveIsland_MemorialPillar_Text_DontHaveRoomForIt {
	"If you don't have room for it,
	I'll hold it for you till next time."
}

text FiveIsland_MemorialPillar_Text_StillHaveThingAsMyThanks {
	"Oh, it's you from that time…

	I still have that thing I wanted
	you to have as my thanks."
}

text FiveIsland_MemorialPillar_Text_ScrubScrubTectonix {
	"Scrub, scrub…

	… … …
	TECTONIX…"
}

text FiveIsland_MemorialPillar_Text_HereLiesTectonix {
	"Boulders and rocks are neatly piled
	up as a cairn.

	“Here lies TECTONIX” is engraved
	on a boulder."
}
