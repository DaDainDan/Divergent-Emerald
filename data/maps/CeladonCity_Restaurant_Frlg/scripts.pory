mapscripts CeladonCity_Restaurant_Frlg_MapScripts {}

script CeladonCity_Restaurant_EventScript_Chef {
    msgbox(CeladonCity_Restaurant_Text_TakingBreakRightNow, MSGBOX_NPC)
    end
}

script CeladonCity_Restaurant_EventScript_Woman {
    msgbox(CeladonCity_Restaurant_Text_OftenGoToDrugstore, MSGBOX_NPC)
    end
}

script CeladonCity_Restaurant_EventScript_CoinCaseMan {
    lock_faceplayer
    if (flag(FLAG_GOT_COIN_CASE)) {
        msgbox(CeladonCity_Restaurant_Text_ThoughtIdWinItBack)
    	release_end
    }
    msgbox(CeladonCity_Restaurant_Text_TakeThisImBusted)
    if (checkitemspace(ITEM_COIN_CASE) == FALSE) {
        msgbox(CeladonCity_Restaurant_Text_MakeRoomForThis)
    	release_end
    }
    giveitem_msg(CeladonCity_Restaurant_Text_ReceivedCoinCaseFromMan, ITEM_COIN_CASE)
    setflag(FLAG_GOT_COIN_CASE)
    release_end
}

script CeladonCity_Restaurant_EventScript_WorkerM {
    msgbox(CeladonCity_Restaurant_Text_PsstBasementUnderGameCorner, MSGBOX_NPC)
    end
}

script CeladonCity_Restaurant_EventScript_FatMan {
    msgbox(CeladonCity_Restaurant_Text_ManLostItAllAtSlots, MSGBOX_NPC)
    end
}

text CeladonCity_Restaurant_Text_TakingBreakRightNow {
	"Hi!

	Sorry, but we're taking a break
	right now."
}

text CeladonCity_Restaurant_Text_OftenGoToDrugstore {
	"My POKéMON are weak, so I often
	have to go to the DRUGSTORE."
}

text CeladonCity_Restaurant_Text_PsstBasementUnderGameCorner {
	"Psst! There's a basement under the
	GAME CORNER, I hear."
}

text CeladonCity_Restaurant_Text_ManLostItAllAtSlots {
	"Munch…

	The man at that table lost it all
	at the slots."
}

text CeladonCity_Restaurant_Text_TakeThisImBusted {
	"Go ahead! Laugh!
	I'm flat-out busted!

	No more slots for me!
	I'm going straight!

	Here!
	I won't be needing this anymore!"
}

text CeladonCity_Restaurant_Text_ReceivedCoinCaseFromMan {
	"{PLAYER} received a COIN CASE
	from the man."
}

text CeladonCity_Restaurant_Text_MakeRoomForThis {
	"Make room for this!"
}

text CeladonCity_Restaurant_Text_ThoughtIdWinItBack {
	"I always thought I was going to
	win it back…"
}
