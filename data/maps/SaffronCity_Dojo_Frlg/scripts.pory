mapscripts SaffronCity_Dojo_Frlg_MapScripts {}

script SaffronCity_Dojo_EventScript_TriggerMasterBattleLeft {
    lockall
    setvar(VAR_MAP_SCENE_SAFFRON_CITY_DOJO, 1)
    applymovement(LOCALID_KARATE_MASTER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    releaseall
    end
}

script SaffronCity_Dojo_EventScript_TriggerMasterBattleRight {
    lockall
    setvar(VAR_MAP_SCENE_SAFFRON_CITY_DOJO, 1)
    applymovement(LOCALID_KARATE_MASTER, Common_Movement_StepFasterRight)
    waitmovement(0)
    releaseall
    end
}

script SaffronCity_Dojo_EventScript_HitmonleeBall {
    lock_faceplayer
    if (flag(FLAG_GOT_HITMON_FROM_DOJO)) {
        goto(SaffronCity_Dojo_EventScript_AlreadyGotHitmon)
    }
	setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_HITMONLEE)
	goto(SaffronCity_Dojo_EventScript_GiveHitmon)
	end
}

script SaffronCity_Dojo_EventScript_AlreadyGotHitmon {
    msgbox(SaffronCity_Dojo_Text_BetterNotGetGreedy)
    release_end
}

script SaffronCity_Dojo_EventScript_HitmonchanBall {
    lock_faceplayer
    if (flag(FLAG_GOT_HITMON_FROM_DOJO)) {
        goto(SaffronCity_Dojo_EventScript_AlreadyGotHitmon)
    }
	setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_HITMONCHAN)
    goto(SaffronCity_Dojo_EventScript_GiveHitmon)
	end
}

script SaffronCity_Dojo_EventScript_GiveHitmon {
	showmonpic(VAR_TEMP_TRANSFERRED_SPECIES, 10, 3)
    applymovement(LOCALID_KARATE_MASTER, Common_Movement_StepFasterUp)
    waitmovement(0)
    textcolor(NPC_TEXT_COLOR_MALE)
	switch (var(VAR_TEMP_TRANSFERRED_SPECIES)) {
		case SPECIES_HITMONLEE: msgbox(SaffronCity_Dojo_Text_YouWantHitmonlee, MSGBOX_YESNO)
		case SPECIES_HITMONCHAN: msgbox(SaffronCity_Dojo_Text_YouWantHitmonchan, MSGBOX_YESNO)
	}
    call(EventScript_RestorePrevTextColor)
    if (var(VAR_RESULT) == NO) {
		hidemonpic
    	release_end
    }
    hidemonpic
    if (givemon(VAR_TEMP_TRANSFERRED_SPECIES, 25) == MON_CANT_GIVE) {
		goto(Common_EventScript_NoMoreRoomForPokemon)
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	removeobject(VAR_LAST_TALKED)
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    playfanfare(MUS_LEVEL_UP)
    message(SaffronCity_Dojo_Text_ReceivedMonFromKarateMaster)
    waitmessage
    waitfanfare
    setflag(FLAG_GOT_HITMON_FROM_DOJO)
    msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_GetGiftMonPartySlot)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
    release_end
}

