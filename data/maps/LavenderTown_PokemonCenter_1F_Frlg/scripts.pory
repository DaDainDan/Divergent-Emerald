mapscripts LavenderTown_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_LAVENDER_TOWN)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script LavenderTown_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script LavenderTown_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(LavenderTown_PokemonCenter_1F_Text_RocketsDoAnythingForMoney, MSGBOX_NPC)
    end
}

script LavenderTown_PokemonCenter_1F_EventScript_Lass {
    msgbox(LavenderTown_PokemonCenter_1F_Text_CubonesMotherKilledByRockets, MSGBOX_NPC)
    end
}

script LavenderTown_PokemonCenter_1F_EventScript_Youngster {
    msgbox(LavenderTown_PokemonCenter_1F_Text_PeoplePayForCuboneSkulls, MSGBOX_NPC)
    end
}

text LavenderTown_PokemonCenter_1F_Text_RocketsDoAnythingForMoney {
	"TEAM ROCKET will do anything for
	the sake of money!

	There is no job too dirty, no deed
	too heinous, no crime too wicked!"
}

text LavenderTown_PokemonCenter_1F_Text_CubonesMotherKilledByRockets {
	"I saw CUBONE's mother trying to
	escape from TEAM ROCKET.

	She was killed trying to get away…"
}

text LavenderTown_PokemonCenter_1F_Text_PeoplePayForCuboneSkulls {
	"You know how the CUBONE species
	wears skulls, right?

	People will pay a lot for one."
}
