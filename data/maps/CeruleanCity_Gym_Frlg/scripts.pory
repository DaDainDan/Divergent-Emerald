mapscripts CeruleanCity_Gym_Frlg_MapScripts {}

script CeruleanCity_Gym_EventScript_Misty {
    famechecker(FAMECHECKER_MISTY, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    trainerbattle_single(TRAINER_LEADER_MISTY, CeruleanCity_Gym_Text_MistyIntro, CeruleanCity_Gym_Text_MistyDefeat, CeruleanCity_Gym_EventScript_MistyDefeated, NO_MUSIC)
    if (!flag(FLAG_GOT_TM03_FROM_MISTY)) {
        goto(CeruleanCity_Gym_EventScript_GiveTM03)
    }
    msgbox(CeruleanCity_Gym_Text_ExplainTM03)
    release_end
}

script CeruleanCity_Gym_EventScript_MistyDefeated {
    famechecker(FAMECHECKER_MISTY, 1)
    setflag(FLAG_DEFEATED_MISTY)
    setflag(FLAG_BADGE02_GET)
    setrespawn(HEAL_LOCATION_CERULEAN_CITY)
    set_gym_trainers_frlg(2)
    goto(CeruleanCity_Gym_EventScript_GiveTM03)
    end
}

script CeruleanCity_Gym_EventScript_GiveTM03 {
    msgbox(CeruleanCity_Gym_Text_ExplainCascadeBadge)
    if (checkitemspace(ITEM_TM03) == FALSE) {
        msgbox(CeruleanCity_Gym_Text_BetterMakeRoomForThis)
    	release_end
    }
    giveitem_msg(CeruleanCity_Gym_Text_ReceivedTM03FromMisty, ITEM_TM03)
    setflag(FLAG_GOT_TM03_FROM_MISTY)
    msgbox(CeruleanCity_Gym_Text_ExplainTM03)
    release_end
}

script CeruleanCity_Gym_EventScript_Diana {
    trainerbattle_single(TRAINER_PICNICKER_DIANA, CeruleanCity_Gym_Text_DianaIntro, CeruleanCity_Gym_Text_DianaDefeat)
    msgbox(CeruleanCity_Gym_Text_DianaPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script CeruleanCity_Gym_EventScript_Luis {
    trainerbattle_single(TRAINER_SWIMMER_MALE_LUIS, CeruleanCity_Gym_Text_LuisIntro, CeruleanCity_Gym_Text_LuisDefeat)
    famechecker(FAMECHECKER_MISTY, 2)
    msgbox(CeruleanCity_Gym_Text_LuisPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script CeruleanCity_Gym_EventScript_GymGuy {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_MISTY)) {
        msgbox(CeruleanCity_Gym_Text_WeMakePrettyGoodTeam)
    	release_end
    }
    msgbox(CeruleanCity_Gym_Text_GymGuyAdvice)
    release_end
}

script CeruleanCity_Gym_EventScript_GymStatue {
    lockall
    if (flag(FLAG_BADGE02_GET)) {
        msgbox(CeruleanCity_Gym_Text_GymStatuePlayerWon)
    } else {
		msgbox(CeruleanCity_Gym_Text_GymStatue)
	}
    releaseall
    end
}

text CeruleanCity_Gym_Text_MistyIntro {
	"Hi, you're a new face!

	Only those TRAINERS who have a
	policy about POKéMON can turn pro.

	What is your approach when you
	catch and train POKéMON?

	My policy is an all-out offensive
	with WATER-type POKéMON!{PLAY_BGM}{MUS_RG_ENCOUNTER_GYM_LEADER}"
}

text CeruleanCity_Gym_Text_ExplainTM03 {
	"TM03 teaches WATER PULSE.

	Use it on an aquatic POKéMON!"
}

text CeruleanCity_Gym_Text_ExplainCascadeBadge {
	"The CASCADEBADGE makes all
	POKéMON up to Lv. 30 obey.

	That includes even outsiders you
	got in trades.

	There's more. You can now use CUT
	anytime, even out of battle.

	You can CUT down small trees to
	open new pathways.

	You can also have my favorite TM."
}

text CeruleanCity_Gym_Text_ReceivedTM03FromMisty {
	"{PLAYER} received TM03
	from MISTY."
}

text CeruleanCity_Gym_Text_BetterMakeRoomForThis {
	"You better make room for this!"
}

text CeruleanCity_Gym_Text_MistyDefeat {
	"Wow!
	You're too much!

	All right!

	You can have the CASCADEBADGE to
	show you beat me."
}

text CeruleanCity_Gym_Text_DianaIntro {
	"What? You?
	I'm more than good enough for you!

	MISTY won't have to be bothered."
}

text CeruleanCity_Gym_Text_DianaDefeat {
	"You overwhelmed me!"
}

text CeruleanCity_Gym_Text_DianaPostBattle {
	"You have to face other TRAINERS
	to see how good you really are."
}

text CeruleanCity_Gym_Text_LuisIntro {
	"Splash!

	I'm first up!
	Let's do it!"
}

text CeruleanCity_Gym_Text_LuisDefeat {
	"That can't be!"
}

text CeruleanCity_Gym_Text_LuisPostBattle {
	"MISTY is a TRAINER who's going to
	keep improving.

	She won't lose to someone like you!"
}

text CeruleanCity_Gym_Text_GymGuyAdvice {
	"Yo!
	Champ in the making!

	Let me give you some advice!

	The LEADER, MISTY, is a pro who
	uses WATER-type POKéMON.

	You can drain all their water with
	GRASS-type POKéMON.

	Or, you might use ELECTRIC-type
	POKéMON and zap them!"
}

text CeruleanCity_Gym_Text_WeMakePrettyGoodTeam {
	"You beat MISTY!
	See, what'd I tell ya?

	You and me, kid, we make a pretty
	darn-good team!"
}

text CeruleanCity_Gym_Text_GymStatue {
	"CERULEAN POKéMON GYM
	LEADER: MISTY

	WINNING TRAINERS:
	{RIVAL}"
}

text CeruleanCity_Gym_Text_GymStatuePlayerWon {
	"CERULEAN POKéMON GYM
	LEADER: MISTY

	WINNING TRAINERS:
	{RIVAL}, {PLAYER}"
}
