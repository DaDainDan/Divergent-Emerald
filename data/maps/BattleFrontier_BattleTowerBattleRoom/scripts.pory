text BattleFrontier_BattleTowerBattleRoom_Text_SalonMaidenOnHerWay {
	"Excuse me, but…

	Our leader, the SALON MAIDEN, is on
	her way here in hopes of battling you.

	She should be arriving very shortly."
}

text BattleFrontier_BattleTowerBattleRoom_Text_ReadyForSalonMaiden {
	"You will be facing the SALON MAIDEN.
	Are you prepared?"
}

text BattleFrontier_BattleTowerBattleRoom_Text_GreetingsImAnabel {
	"Greetings…
	My name is ANABEL.

	I am the SALON MAIDEN, and I am in
	charge of running the BATTLE TOWER…

	I have heard several rumors
	about you…

	In all honesty, what I have heard does
	not seem attractive in any way…

	The reason I've come to see you…
	Well, there is but one reason…"
}

text BattleFrontier_BattleTowerBattleRoom_Text_LetMeSeeYourTalent {
	"Let me see your talent in
	its entirety…"
}

text BattleFrontier_BattleTowerBattleRoom_Text_AnabelTalentShallBeRecognized {
	"ANABEL: Fufufu, nicely done…

	Your FRONTIER PASS, please…
	Your talent shall be recognized."
}

text BattleFrontier_BattleTowerBattleRoom_Text_ReceivedAbilitySymbol {
	"The Ability Symbol was embossed on
	the FRONTIER PASS!"
}

text BattleFrontier_BattleTowerBattleRoom_Text_UntilNextTime {
	"… … … … … …

	You have confidence in your POKéMON
	battling talent, don't you?

	I urge you to keep battling and
	keep on winning.

	I will be waiting for you.
	Until the next time we meet…"
}

text BattleFrontier_BattleTowerBattleRoom_Text_AnabelYouCameBack {
	"ANABEL: You really did come back to
	see me…

	… … … … … …

	You've won straight matches to see me…
	I won't have to hold back against you…

	It's been too long now…

	Too long since I've been able to battle
	without thinking about anything…"
}

text BattleFrontier_BattleTowerBattleRoom_Text_LetsBeginShallWe {
	"Let's begin, shall we?"
}

text BattleFrontier_BattleTowerBattleRoom_Text_AnabelCongratsYourPassPlease {
	"ANABEL: Fufu, congratulations…
	Your FRONTIER PASS, please…"
}

text BattleFrontier_BattleTowerBattleRoom_Text_AbilitySymbolTookGoldenShine {
	"The Ability Symbol took on
	a golden shine!"
}

text BattleFrontier_BattleTowerBattleRoom_Text_WishICouldBattleYouAgain {
	"That was fun…

	I have never had a POKéMON battle
	so enjoyable before…

	I wish I could battle with you again…"
}
