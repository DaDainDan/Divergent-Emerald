mapscripts BattleFrontier_BattleTowerBattleRoom_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0 {
			setvar(VAR_TEMP_0, 1)
			applymovement(LOCALID_PLAYER, moves(walk_up * 3,  face_right))
			waitmovement(0)
			frontier_get(FRONTIER_DATA_BATTLE_NUM)
			if (var(VAR_RESULT) == 0) {
				goto(BattleFrontier_BattleTowerBattleRoom_EventScript_OpponentEnter)
			}
			applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, moves(walk_right * 3,  walk_up))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_FaceDown)
			waitmovement(0)
			setvar(VAR_TEMP_2, 1)
			frontier_set(FRONTIER_DATA_RECORD_DISABLED, TRUE)
			goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
			end
		}
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_2, Common_Movement_SetInvisible)
			end
		}
    ]
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_OpponentEnter {
    tower_setopponent
    addobject(LOCALID_TOWER_BATTLE_OPPONENT)
    applymovement(LOCALID_TOWER_BATTLE_OPPONENT, moves(walk_down * 4,  face_left))
    waitmovement(0)
    tower_getopponentintro(0)
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    waitmessage
    call(BattleFrontier_BattleTowerBattleRoom_EventScript_DoTowerBattle)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		frontier_incrementstreak
		tower_setbattlewon
		if (var(VAR_RESULT) == 7) {
			goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobbyWon)
		}
		applymovement(LOCALID_TOWER_BATTLE_OPPONENT, moves(walk_up * 4))
		waitmovement(0)
		removeobject(LOCALID_TOWER_BATTLE_OPPONENT)
		frontier_getbrainstatus
		if (var(VAR_RESULT) != FRONTIER_BRAIN_NOT_READY) {
			call(BattleFrontier_BattleTowerBattleRoom_EventScript_SecondAttendantEnter)
		}
		applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, moves(walk_right * 3,  walk_up))
		waitmovement(0)
		applymovement(LOCALID_PLAYER, Common_Movement_FaceDown)
		waitmovement(0)
		msgbox(BattleFrontier_BattleTowerBattleRoom_Text_RestoreMonsToFullHealth, MSGBOX_DEFAULT)
		playfanfare(MUS_HEAL)
		waitfanfare
		special(HealPlayerParty)
		goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
	}
    goto(BattleFrontier_BattleTower_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_SecondAttendantEnter {
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_2, moves(set_visible,  delay_16,  walk_up,  walk_left * 2,  delay_8))
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_2, Common_Movement_StepLeft)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, Common_Movement_Delay48)
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_2, moves(delay_16 * 4))
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, moves(face_right,  delay_16 * 4,  step_right))
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_2, moves(walk_right * 2,  walk_down,  set_invisible))
    waitmovement(0)
    return
}

script BattleFrontier_BattleTower_EventScript_WarpToLobbyLost {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST)
    tower_set(TOWER_DATA_LVL_MODE)
    setvar(VAR_0x8004, FANCOUNTER_USED_BATTLE_TOWER)
    special(Script_TryGainNewFanFromCounter)
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobby)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent {
    frontier_getbrainstatus
    copyvar(VAR_TEMP_F, VAR_RESULT)
    if (var(VAR_RESULT) != FRONTIER_BRAIN_NOT_READY) {
        goto(BattleFrontier_BattleTowerBattleRoom_EventScript_MaidenUpNext)
    }
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    copyvar(VAR_TEMP_F, VAR_RESULT)
    switch (var(VAR_TEMP_F)) {
        case 1: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor2ndOpponent)
        case 2: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor3rdOpponent)
        case 3: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor4thOpponent)
        case 4: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor5thOpponent)
        case 5: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor6thOpponent)
        case 6: message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyFor7thOpponent)
    }
	waitmessage
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponentNoRecord)
    }
    multichoice(19, 4, MULTI_GO_ON_RECORD_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_ContinueChallenge)
        case 1: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRecordBattle)
        case 2: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskPauseChallenge)
        case 3: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
    }
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponentNoRecord {
    multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_ContinueChallenge)
        case 1: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskPauseChallenge)
        case 2: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
    }
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskRecordBattle {
    message(BattleFrontier_BattleTowerBattleRoom_Text_RecordYourBattle)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		call(BattleFrontier_EventScript_SaveBattle)
	}
	goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattleTowerBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		message(BattleFrontier_BattleTowerBattleRoom_Text_SavingPleaseWait)
		waitmessage
		tower_save(CHALLENGE_STATUS_PAUSED)
		playse(SE_SAVE)
		waitse
		fadescreen(FADE_TO_BLACK)
		frontier_reset
		end
	}
	goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattleTowerBattleRoom_Text_CancelYourChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		setflag(FLAG_CANCEL_BATTLE_ROOM_CHALLENGE)
    	goto(BattleFrontier_BattleTower_EventScript_WarpToLobbyLost)
	}
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForOpponent)
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_ContinueChallenge {
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, moves(walk_down,  walk_left * 3,  face_right))
    waitmovement(0)
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_OpponentEnter)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobbyWon {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_WON)
    tower_set(TOWER_DATA_LVL_MODE)
    setvar(VAR_0x8004, FANCOUNTER_USED_BATTLE_TOWER)
    special(Script_TryGainNewFanFromCounter)
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobby)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_MaidenUpNext {
    if (var(VAR_TEMP_2) != 1) {
        msgbox(BattleFrontier_BattleTowerBattleRoom_Text_SalonMaidenOnHerWay, MSGBOX_DEFAULT)
    	setvar(VAR_TEMP_2, 1)
    }
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForMaiden)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForMaiden {
    message(BattleFrontier_BattleTowerBattleRoom_Text_ReadyForSalonMaiden)
    waitmessage
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabel)
			case 1: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskPauseChallenge)
			case 2: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRetireChallenge)
			case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForMaiden)
		}
    } else {
		multichoice(19, 4, MULTI_GO_ON_RECORD_REST_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabel)
			case 1: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRecordBattle)
			case 2: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskPauseChallenge)
			case 3: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskRetireChallenge)
			case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AskReadyForMaiden)
		}
	}
    end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabel {
    frontier_setbrainobj
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    waitmovement(0)
    applymovement(LOCALID_TOWER_BATTLE_ATTENDANT_1, moves(walk_down,  walk_left * 3,  face_right))
    waitmovement(0)
    addobject(LOCALID_TOWER_BATTLE_OPPONENT)
    applymovement(LOCALID_TOWER_BATTLE_OPPONENT, moves(creep_down * 4,  face_left))
    waitmovement(0)
    switch (var(VAR_TEMP_F)) {
        case FRONTIER_BRAIN_GOLD: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_AnabelGoldIntro)
        case FRONTIER_BRAIN_STREAK: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelSilver)
        case FRONTIER_BRAIN_STREAK_LONG: goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelGold)
    }
    frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(BattleFrontier_BattleTowerBattleRoom_Text_GreetingsImAnabel, MSGBOX_DEFAULT)
    	frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    }
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelSilver)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelSilver {
    msgbox(BattleFrontier_BattleTowerBattleRoom_Text_LetMeSeeYourTalent, MSGBOX_DEFAULT)
    call(BattleFrontier_BattleTowerBattleRoom_EventScript_DoTowerBattle)
    if (var(VAR_RESULT) == B_OUTCOME_WON) {
        frontier_incrementstreak
		frontier_getsymbols
		if (var(VAR_RESULT) == 0) {
			msgbox(BattleFrontier_BattleTowerBattleRoom_Text_AnabelTalentShallBeRecognized, MSGBOX_DEFAULT)
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattleTowerBattleRoom_Text_ReceivedAbilitySymbol)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattleTowerBattleRoom_Text_UntilNextTime, MSGBOX_DEFAULT)
		}
		goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobbyWon)
    }
    goto(BattleFrontier_BattleTower_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_AnabelGoldIntro {
    frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(BattleFrontier_BattleTowerBattleRoom_Text_AnabelYouCameBack, MSGBOX_DEFAULT)
    	frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    }
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelGold)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_BattleAnabelGold {
    msgbox(BattleFrontier_BattleTowerBattleRoom_Text_LetsBeginShallWe, MSGBOX_DEFAULT)
    call(BattleFrontier_BattleTowerBattleRoom_EventScript_DoTowerBattle)
    if (var(VAR_RESULT) == B_OUTCOME_WON) {
        frontier_incrementstreak
		frontier_getsymbols
		if (var(VAR_RESULT) != 2) {
			msgbox(BattleFrontier_BattleTowerBattleRoom_Text_AnabelCongratsYourPassPlease, MSGBOX_DEFAULT)
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattleTowerBattleRoom_Text_AbilitySymbolTookGoldenShine)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattleTowerBattleRoom_Text_WishICouldBattleYouAgain, MSGBOX_DEFAULT)
		}
		goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobbyWon)
    }
    goto(BattleFrontier_BattleTower_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_DoTowerBattle {
    closemessage
    setvar(VAR_TEMP_2, 0)
    frontier_set(FRONTIER_DATA_RECORD_DISABLED, FALSE)
    special(HealPlayerParty)
    dofacilitytrainerbattle(FACILITY_BATTLE_TOWER)
    waitstate
    copyvar(VAR_0x8004, VAR_FRONTIER_BATTLE_MODE)
    if (var(VAR_0x8004) != FRONTIER_MODE_LINK_MULTIS) {
        frontier_restorehelditems
		special(HealPlayerParty)
		frontier_resetsketch
    }
    tower_setinterviewdata
    frontier_get(FRONTIER_DATA_BATTLE_OUTCOME)
    return
}

script BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobby {
    copyvar(VAR_RESULT, VAR_FRONTIER_BATTLE_MODE)
	switch (var(VAR_RESULT)) {
		case FRONTIER_MODE_DOUBLES: warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_LOBBY, 10, 6)
		case FRONTIER_MODE_MULTIS: warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_LOBBY, 14, 6)
		case FRONTIER_MODE_LINK_MULTIS:
			tower_closelink
    		warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_LOBBY, 18, 6)
		default: warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_LOBBY, 6, 6)
	}
    waitstate
    end
}

