mapscripts VerdanturfTown_FriendshipRatersHouse_MapScripts {}

script VerdanturfTown_FriendshipRatersHouse_EventScript_FriendshipRater {
    lock_faceplayer
    msgbox(VerdanturfTown_FriendshipRatersHouse_Text_SeeHowMuchPokemonLikesYou, MSGBOX_DEFAULT)
    specialvar(VAR_RESULT, GetLeadMonFriendshipScore)
    switch (var(VAR_RESULT)) {
        case FRIENDSHIP_NONE: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_DetestsYou, MSGBOX_DEFAULT)
        case FRIENDSHIP_1_TO_49: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_VeryWary, MSGBOX_DEFAULT)
        case FRIENDSHIP_50_TO_99: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_NotUsedToYou, MSGBOX_DEFAULT)
        case FRIENDSHIP_100_TO_149: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_GettingUsedToYou, MSGBOX_DEFAULT)
        case FRIENDSHIP_150_TO_199: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_LikesYouQuiteALot, MSGBOX_DEFAULT)
        case FRIENDSHIP_200_TO_254: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_VeryHappy, MSGBOX_DEFAULT)
        case FRIENDSHIP_MAX: msgbox(VerdanturfTown_FriendshipRatersHouse_Text_AdoresYou, MSGBOX_DEFAULT)
    }
    release_end
}

script VerdanturfTown_FriendshipRatersHouse_EventScript_Pikachu {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PIKACHU, CRY_MODE_NORMAL)
    msgbox(VerdanturfTown_FriendshipRatersHouse_Text_Pikachu, MSGBOX_DEFAULT)
    waitmoncry
    release_end
}

text VerdanturfTown_FriendshipRatersHouse_Text_SeeHowMuchPokemonLikesYou {
	"Let me see your POKéMON.
	I'll check to see how much it likes you.

	Oh.
	Your POKéMON…"
}

text VerdanturfTown_FriendshipRatersHouse_Text_AdoresYou {
	"It adores you.
	It can't possibly love you any more.
	I even feel happy seeing it."
}

text VerdanturfTown_FriendshipRatersHouse_Text_VeryHappy {
	"It seems to be very happy.
	It obviously likes you a whole lot."
}

text VerdanturfTown_FriendshipRatersHouse_Text_LikesYouQuiteALot {
	"It likes you quite a lot.
	It seems to want to be babied a little."
}

text VerdanturfTown_FriendshipRatersHouse_Text_GettingUsedToYou {
	"It's getting used to you.
	It seems to believe in you."
}

text VerdanturfTown_FriendshipRatersHouse_Text_NotUsedToYou {
	"It's not very used to you yet.
	It neither loves nor hates you."
}

text VerdanturfTown_FriendshipRatersHouse_Text_VeryWary {
	"It's very wary.
	It has scary viciousness in its eyes.
	It doesn't like you much at all."
}

text VerdanturfTown_FriendshipRatersHouse_Text_DetestsYou {
	"This is a little hard for me to say…

	Your POKéMON simply detests you.
	Doesn't that make you uncomfortable?"
}

text VerdanturfTown_FriendshipRatersHouse_Text_Pikachu {
	"PIKACHU: Pika pika!"
}
