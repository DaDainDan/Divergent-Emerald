mapscripts SixIsland_WaterPath_Frlg_MapScripts {}

script SixIsland_WaterPath_EventScript_HornWantedSign {
    msgbox(SixIsland_WaterPath_Text_WantedUltimateHorn, MSGBOX_SIGN)
    end
}

script SixIsland_WaterPath_EventScript_RouteSign {
    msgbox(SixIsland_WaterPath_Text_RouteSign, MSGBOX_SIGN)
    end
}

text SixIsland_WaterPath_Text_RoseIntro {
	"I let a pleasant breeze lead me
	all the way here."
}

text SixIsland_WaterPath_Text_RoseDefeat {
	"Giggle… You're so cute when you're
	determined."
}

text SixIsland_WaterPath_Text_RosePostBattle {
	"I want to go to the woods over
	there, but…

	There are lots of BUG POKéMON.
	They scare me a little."
}

text SixIsland_WaterPath_Text_EdwardIntro {
	"I'm practicing in secret so no one
	can see me."
}

text SixIsland_WaterPath_Text_EdwardDefeat {
	"Nobody saw me losing, right?"
}

text SixIsland_WaterPath_Text_EdwardPostBattle {
	"As a performer, I don't want people
	to know about the effort I put in."
}

text SixIsland_WaterPath_Text_SamirIntro {
	"What, you're suggesting that you're
	sick of seeing SWIMMERS like me?

	Aww, don't be hatin'!"
}

text SixIsland_WaterPath_Text_SamirDefeat {
	"Oh, no, no, no."
}

text SixIsland_WaterPath_Text_SamirPostBattle {
	"I couldn't lift the stigma of being
	a SWIMMER…"
}

text SixIsland_WaterPath_Text_DeniseIntro {
	"My boyfriend's always busy, so I
	come swimming by myself."
}

text SixIsland_WaterPath_Text_DeniseDefeat {
	"Awww, I knew this would happen!"
}

text SixIsland_WaterPath_Text_DenisePostBattle {
	"When I can't be with my boyfriend,
	I spend time with the POKéMON he
	gave me."
}

text SixIsland_WaterPath_Text_EarlIntro {
	"Tell me, where are the mountains
	around these parts?"
}

text SixIsland_WaterPath_Text_EarlDefeat {
	"I lost my way while I was busy
	battling!"
}

text SixIsland_WaterPath_Text_EarlPostBattle {
	"Aren't there any mountains around
	these parts?"
}

text SixIsland_WaterPath_Text_MiuIntro {
	"MIU: Hello, POKéMON!
	It's time to play!"
}

text SixIsland_WaterPath_Text_MiuDefeat {
	"MIU: Oh, no!
	Mommy!"
}

text SixIsland_WaterPath_Text_MiuPostBattle {
	"MIU: It makes me all sad inside
	when we lose…"
}

text SixIsland_WaterPath_Text_MiuNotEnoughMons {
	"MIU: MIA and I are TWINS.
	We want to battle together."
}

text SixIsland_WaterPath_Text_MiaIntro {
	"MIA: Hello, POKéMON!
	It's time to battle!"
}

text SixIsland_WaterPath_Text_MiaDefeat {
	"MIA: You're mean!
	You're bad for winning!"
}

text SixIsland_WaterPath_Text_MiaPostBattle {
	"MIA: Ohh…
	I'm sorry, my POKéMON…"
}

text SixIsland_WaterPath_Text_MiaNotEnoughMons {
	"MIA: Oh, you only have one
	POKéMON?

	Don't you feel lonesome?"
}

text SixIsland_WaterPath_Text_WantedUltimateHorn {
	"Wanted!
	The Ultimate Horn!"
}

text SixIsland_WaterPath_Text_RouteSign {
	"WATER PATH
	Leads to RUIN VALLEY"
}
