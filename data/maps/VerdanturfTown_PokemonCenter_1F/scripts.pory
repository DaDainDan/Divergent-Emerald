mapscripts VerdanturfTown_PokemonCenter_1F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_VERDANTURF_TOWN)
		call(Common_EventScript_UpdateBrineyLocation)
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script VerdanturfTown_PokemonCenter_1F_EventScript_Nurse {
    setvar(VAR_0x800B, LOCALID_VERDANTURF_NURSE)
    call(Common_EventScript_PkmnCenterNurse)
    waitmessage
    waitbuttonpress
    release_end
}

script VerdanturfTown_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(VerdanturfTown_PokemonCenter_1F_Text_FaithInYourPokemon, MSGBOX_NPC)
    end
}

script VerdanturfTown_PokemonCenter_1F_EventScript_ExpertM {
    msgbox(VerdanturfTown_PokemonCenter_1F_Text_VisitForBattleTent, MSGBOX_NPC)
    end
}

text VerdanturfTown_PokemonCenter_1F_Text_FaithInYourPokemon {
	"You can't consider yourself a real
	TRAINER if you don't have faith
	in your POKéMON.

	Only those people who can believe
	in their battling POKéMON can win
	through to the very end."
}

text VerdanturfTown_PokemonCenter_1F_Text_VisitForBattleTent {
	"The reason why anyone would visit
	VERDANTURF…

	It's the BATTLE TENT. It goes without
	saying.

	Or is there somebody here that you
	came to see?"
}
