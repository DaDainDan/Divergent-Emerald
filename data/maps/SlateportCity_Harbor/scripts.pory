mapscripts SlateportCity_Harbor_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setescapewarp(MAP_SLATEPORT_CITY, 28, 13)
		setvar(VAR_TEMP_1, 0)
		if (var(VAR_SLATEPORT_HARBOR_STATE) == 1) {
			savebgm(MUS_ENCOUNTER_AQUA)
			setobjectxyperm(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, 12, 13)
			setobjectmovementtype(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, MOVEMENT_TYPE_FACE_LEFT)
			setflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_PATRONS)
		}
		if (flag(FLAG_SYS_GAME_CLEAR)) {
			clearflag(FLAG_HIDE_SLATEPORT_CITY_HARBOR_SS_TIDAL)
		}
		end
    }
}

script SlateportCity_Harbor_EventScript_AquaEscapeTrigger0 {
    lockall
    setvar(VAR_0x8008, 0)
    goto(SlateportCity_Harbor_EventScript_AquaEscapeScene)
    end
}

script SlateportCity_Harbor_EventScript_AquaEscapeTrigger1 {
    lockall
    setvar(VAR_0x8008, 1)
    goto(SlateportCity_Harbor_EventScript_AquaEscapeScene)
    end
}

script SlateportCity_Harbor_EventScript_AquaEscapeTrigger2 {
    lockall
    setvar(VAR_0x8008, 2)
    goto(SlateportCity_Harbor_EventScript_AquaEscapeScene)
    end
}

script SlateportCity_Harbor_EventScript_AquaEscapeTrigger3 {
    lockall
    setvar(VAR_0x8008, 3)
    applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
    waitmovement(0)
    goto(SlateportCity_Harbor_EventScript_AquaEscapeScene)
    end
}

script SlateportCity_Harbor_EventScript_AquaEscapeScene {
    applymovement(LOCALID_SLATEPORT_HARBOR_ARCHIE, Common_Movement_StepFasterDown)
    waitmovement(0)
    applymovement(LOCALID_SLATEPORT_HARBOR_GRUNT, Common_Movement_StepFasterDown)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(SlateportCity_Harbor_Text_ArchieYouAgainHideoutInLilycove, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SLATEPORT_HARBOR_GRUNT, moves(delay_16 * 2,  jump_up,  set_invisible))
    applymovement(LOCALID_SLATEPORT_HARBOR_ARCHIE, moves(delay_16 * 2,  jump_up,  set_invisible))
    applymovement(LOCALID_SLATEPORT_HARBOR_SUBMARINE, moves(delay_16 * 4,  walk_right * 3,  run_right * 6))
    waitmovement(0)
    removeobject(LOCALID_SLATEPORT_HARBOR_GRUNT)
    removeobject(LOCALID_SLATEPORT_HARBOR_ARCHIE)
    removeobject(LOCALID_SLATEPORT_HARBOR_SUBMARINE)
    setvar(VAR_SLATEPORT_HARBOR_STATE, 2)
    setflag(FLAG_MET_TEAM_AQUA_HARBOR)
    setflag(FLAG_HIDE_LILYCOVE_MOTEL_SCOTT)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, moves(walk_left * 4,  walk_up))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
		case 1:
			applymovement(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, moves(walk_left * 2,  walk_up,  walk_left))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
		case 2:
		case 3:
			applymovement(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, moves(walk_left * 3))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
	}
	waitmovement(0)
    msgbox(SlateportCity_Harbor_Text_CaptSternWhyStealMySubmarine, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_HIDE_AQUA_HIDEOUT_1F_GRUNT_1_BLOCKING_ENTRANCE)
    setflag(FLAG_HIDE_AQUA_HIDEOUT_1F_GRUNT_2_BLOCKING_ENTRANCE)
    copyobjectxytoperm(LOCALID_SLATEPORT_HARBOR_CAPT_STERN)
    setobjectmovementtype(LOCALID_SLATEPORT_HARBOR_CAPT_STERN, MOVEMENT_TYPE_FACE_RIGHT)
    releaseall
    end
}

script SlateportCity_Harbor_EventScript_FerryAttendant {
    lock_faceplayer
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        goto(SlateportCity_Harbor_EventScript_AskForTicket)
    }
    msgbox(SlateportCity_Harbor_Text_FerryServiceUnavailable, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_Harbor_EventScript_AskForTicket {
    msgbox(SlateportCity_Harbor_Text_MayISeeYourTicket, MSGBOX_DEFAULT)
    message(SlateportCity_Harbor_Text_FlashedTicketWhereTo)
    waitmessage
    goto(SlateportCity_Harbor_EventScript_ChooseDestination)
    end
}

script SlateportCity_Harbor_EventScript_ChooseDestination {
    if (flag(FLAG_MET_SCOTT_ON_SS_TIDAL)) {
        multichoicedefault(17, 6, MULTI_SSTIDAL_SLATEPORT_WITH_BF, 2, FALSE)
		switch (var(VAR_RESULT)) {
			case 0: goto(SlateportCity_Harbor_EventScript_Lilycove)
			case 1: goto(SlateportCity_Harbor_EventScript_BattleFrontier)
			case 2:
			case MULTI_B_PRESSED: 
                goto(SlateportCity_Harbor_EventScript_CancelDestinationSelect)
		}
    } else {
		multichoicedefault(18, 8, MULTI_SSTIDAL_SLATEPORT_NO_BF, 2, FALSE)
		switch (var(VAR_RESULT)) {
			case 0: goto(SlateportCity_Harbor_EventScript_Lilycove)
			case 1:
			case MULTI_B_PRESSED: 
                goto(SlateportCity_Harbor_EventScript_CancelDestinationSelect)
		}
	}
    end
}

// Unused. Should be impossible for player to reach Ferry without having received SS Tidal ticket
script SlateportCity_Harbor_EventScript_NoTicket {
    msgbox(SlateportCity_Harbor_Text_YouMustHaveTicket, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_Harbor_EventScript_Lilycove {
    msgbox(SlateportCity_Harbor_Text_LilycoveItIs, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SlateportCity_Harbor_EventScript_ChooseNewDestination)
    }
    setvar(VAR_SS_TIDAL_STATE, SS_TIDAL_BOARD_SLATEPORT)
    call(SlateportCity_Harbor_EventScript_BoardFerry)
    warp(MAP_SS_TIDAL_CORRIDOR, 1, 10)
    waitstate
    release_end
}

script SlateportCity_Harbor_EventScript_BattleFrontier {
    msgbox(SlateportCity_Harbor_Text_BattleFrontierItIs, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SlateportCity_Harbor_EventScript_ChooseNewDestination)
    }
    call(SlateportCity_Harbor_EventScript_BoardFerry)
    warp(MAP_BATTLE_FRONTIER_OUTSIDE_WEST, 19, 67)
    waitstate
    release_end
}

script SlateportCity_Harbor_EventScript_ChooseNewDestination {
    message(SlateportCity_Harbor_Text_WhereWouldYouLikeToGo)
    waitmessage
    goto(SlateportCity_Harbor_EventScript_ChooseDestination)
    end
}

script SlateportCity_Harbor_EventScript_BoardFerry {
    msgbox(SlateportCity_Harbor_Text_PleaseBoardFerry, MSGBOX_DEFAULT)
    closemessage
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterUp)
    waitmovement(0)
    delay(30)
    hideobjectat(VAR_LAST_TALKED, MAP_SLATEPORT_CITY_HARBOR)
	switch (var(VAR_FACING)) {
		case DIR_NORTH: applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
		case DIR_EAST: applymovement(LOCALID_PLAYER, moves(walk_right,  step_faster_up))
	}
	waitmovement(0)
    delay(30)
    hideplayer
    setvar(VAR_0x8004, LOCALID_SLATEPORT_HARBOR_SS_TIDAL)
    call(Common_EventScript_FerryDepart)
    return
}

script SlateportCity_Harbor_EventScript_CancelDestinationSelect {
    msgbox(SlateportCity_Harbor_Text_SailAnotherTime, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_Harbor_EventScript_Sailor {
    lock_faceplayer
	setvar(VAR_0x8004, 0)
    if (flag(FLAG_DEFEATED_KYOGRE)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_DEFEATED_GROUDON)) {
        addvar(VAR_0x8004, 1)
    }
    if (!flag(FLAG_SYS_GAME_CLEAR) || var(VAR_0x8004) == 2) {
        msgbox(SlateportCity_Harbor_Text_LoveToGoDeepUnderwaterSomeday, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SlateportCity_Harbor_Text_AbnormalWeather, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_Harbor_EventScript_FatMan {
    msgbox(SlateportCity_Harbor_Text_SubTooSmallForMe, MSGBOX_NPC)
    end
}

script SlateportCity_Harbor_EventScript_CaptStern {
    lock_faceplayer
    if (flag(FLAG_BADGE07_GET)) {
        goto(SlateportCity_Harbor_EventScript_CaptSternFerryOrScannerComment)
    }
    elif (flag(FLAG_EVIL_TEAM_ESCAPED_STERN_SPOKE)) {
        msgbox(SlateportCity_Harbor_Text_NeedDiveToCatchSub, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_TEAM_AQUA_ESCAPED_IN_SUBMARINE)) {
        setflag(FLAG_EVIL_TEAM_ESCAPED_STERN_SPOKE)
		msgbox(SlateportCity_Harbor_Text_TeamAquaLeftNeedDive, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SLATEPORT_HARBOR_STATE) == 2) {
        msgbox(SlateportCity_Harbor_Text_CaptSternWhyStealMySubmarine, MSGBOX_DEFAULT)
    }
	else {
		msgbox(SlateportCity_Harbor_Text_SameThugsTriedToRobAtMuseum, MSGBOX_DEFAULT)
    	goto(Common_EventScript_FaceOriginalDirection)
	}
    release_end
}

script SlateportCity_Harbor_EventScript_CaptSternFerryOrScannerComment {
    if (var(VAR_TEMP_1) == 1) {
        goto(SlateportCity_Harbor_EventScript_TradedScanner)
    }
    elif (checkitem(ITEM_SCANNER) == TRUE) {
        message(SlateportCity_Harbor_Text_WouldYouTradeScanner)
		waitmessage
		goto(SlateportCity_Harbor_EventScript_ChooseScannerTrade)
    }
    elif (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(SlateportCity_Harbor_Text_FinishedMakingFerry, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SlateportCity_Harbor_Text_WontBeLongBeforeWeFinishFerry, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_Harbor_EventScript_ChooseScannerTrade {
    multichoice(0, 0, MULTI_STERN_DEEPSEA, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(SlateportCity_Harbor_EventScript_DeepSeaTooth)
        case 1: goto(SlateportCity_Harbor_EventScript_DeepSeaScale)
        case 2:
        case MULTI_B_PRESSED:
			msgbox(SlateportCity_Harbor_Text_IfYouWantToTradeLetMeKnow, MSGBOX_DEFAULT)
    		release_end
    }
    end
}

script SlateportCity_Harbor_EventScript_DeepSeaTooth {
    msgbox(SlateportCity_Harbor_Text_TradeForDeepSeaTooth, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SlateportCity_Harbor_EventScript_ChooseDifferentTrade)
    }
    if (giveitem(ITEM_DEEP_SEA_TOOTH) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    goto(SlateportCity_Harbor_EventScript_ScannerTradeFinish)
    end
}

script SlateportCity_Harbor_EventScript_DeepSeaScale {
    msgbox(SlateportCity_Harbor_Text_TradeForDeepSeaScale, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(SlateportCity_Harbor_EventScript_ChooseDifferentTrade)
    }
    if (giveitem(ITEM_DEEP_SEA_SCALE) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    goto(SlateportCity_Harbor_EventScript_ScannerTradeFinish)
    end
}

script SlateportCity_Harbor_EventScript_ScannerTradeFinish {
    removeitem(ITEM_SCANNER)
    msgbox(SlateportCity_Harbor_Text_HandedScannerToStern, MSGBOX_DEFAULT)
    setflag(FLAG_EXCHANGED_SCANNER)
    goto(SlateportCity_Harbor_EventScript_TradedScanner)
    end
}

script SlateportCity_Harbor_EventScript_ChooseDifferentTrade {
    message(SlateportCity_Harbor_Text_WhichOneDoYouWant)
    waitmessage
    goto(SlateportCity_Harbor_EventScript_ChooseScannerTrade)
    end
}

script SlateportCity_Harbor_EventScript_TradedScanner {
    setvar(VAR_TEMP_1, 1)
    msgbox(SlateportCity_Harbor_Text_ThisWillHelpResearch, MSGBOX_DEFAULT)
    release_end
}

text SlateportCity_Harbor_Text_FerryServiceUnavailable {
	"I beg your pardon?
	You're looking for a ship?

	I'm sorry, the ferry service isn't
	available at present…"
}

text SlateportCity_Harbor_Text_MayISeeYourTicket {
	"Hello, are you here for the ferry?
	May I see your TICKET?"
}

text SlateportCity_Harbor_Text_YouMustHaveTicket {
	"{PLAYER} doesn't have the TICKET…

	I'm terribly sorry.

	You must have a TICKET to board
	the ferry."
}

text SlateportCity_Harbor_Text_FlashedTicketWhereTo {
	"{PLAYER} flashed the TICKET.

	Perfect! That's all you need!

	And where would you like to go?"
}

text SlateportCity_Harbor_Text_SailAnotherTime {
	"Please sail with us another time!"
}

text SlateportCity_Harbor_Text_LilycoveItIs {
	"LILYCOVE CITY it is, then!"
}

text SlateportCity_Harbor_Text_BattleFrontierItIs {
	"BATTLE FRONTIER it is, then!"
}

text SlateportCity_Harbor_Text_PleaseBoardFerry {
	"Please board the ferry and wait for
	departure."
}

text SlateportCity_Harbor_Text_WhereWouldYouLikeToGo {
	"Then, where would you like to go?"
}

text SlateportCity_Harbor_Text_LoveToGoDeepUnderwaterSomeday {
	"A journey to the bottom of the sea…
	I wonder what it'd be like?

	I'd love to go deep underwater like
	that someday."
}

text SlateportCity_Harbor_Text_AbnormalWeather {
	"For a ship to sail safely, we need to
	know about the weather!

	Speaking of weather, I heard something
	from a guy at the WEATHER INSTITUTE.

	He was saying abnormal weather has
	been reported all over the place!

	You should visit the WEATHER INSTITUTE
	and ask around!"
}

text SlateportCity_Harbor_Text_SubTooSmallForMe {
	"I wanted to go with CAPT. STERN on
	the ocean floor exploration.

	But the sub's too small for me.

	If I squeezed in, there wouldn't be
	any room for the CAPTAIN…"
}

text SlateportCity_Harbor_Text_SameThugsTriedToRobAtMuseum {
	"CAPT. STERN: Those thugs…

	They're the same lot who tried to rob
	the DEVON GOODS at the MUSEUM."
}

text SlateportCity_Harbor_Text_ArchieYouAgainHideoutInLilycove {
	"ARCHIE: Oh?
	Not you again…

	You are tenacious to track us here,
	that much I will give you.

	But now…
	No one can stop us! No one!

	Or, will you follow us back to our
	HIDEOUT in LILYCOVE CITY?

	Fwahahahaha…"
}

text SlateportCity_Harbor_Text_CaptSternWhyStealMySubmarine {
	"CAPT. STERN: Why…

	Why would TEAM AQUA steal my
	SUBMARINE EXPLORER 1?

	They can't be after the slumbering
	POKéMON at the bottom of the sea…

	But even if I were to chase them,
	I don't stand a chance against them…"
}

text SlateportCity_Harbor_Text_TeamAquaLeftNeedDive {
	"CAPT. STERN: Oh, {PLAYER}{KUN}…

	Okay… So TEAM AQUA left before you
	could stop them…

	Oh, no, don't blame yourself.
	You're not responsible for this.

	Trying to catch a submarine…
	It's impossible for most people.

	You would need a POKéMON that knows
	how to DIVE…

	Perhaps if you went out to
	MOSSDEEP CITY…

	A lot of divers live out there, so
	someone might teach you…"
}

text SlateportCity_Harbor_Text_NeedDiveToCatchSub {
	"CAPT. STERN: Trying to catch a
	submarine… It's impossible.

	You would need a POKéMON that knows
	how to DIVE…

	Perhaps if you went out to
	MOSSDEEP CITY…

	A lot of divers live out there, so
	someone might teach you…"
}

text SlateportCity_Harbor_Text_WontBeLongBeforeWeFinishFerry {
	"CAPT. STERN: Oh, yes.
	MR. BRINEY came to our SHIPYARD.

	It won't be long now before we finish
	making the ferry!"
}

text SlateportCity_Harbor_Text_FinishedMakingFerry {
	"CAPT. STERN: {PLAYER}{KUN}!

	We finally finished making the ferry
	S.S. TIDAL!

	We couldn't have done it without
	your friend MR. BRINEY.

	Please go for a short cruise on it!"
}

text SlateportCity_Harbor_Text_WouldYouTradeScanner {
	"CAPT. STERN: Oh?
	{PLAYER}{KUN}, that item you have…

	That's a SCANNER! That would sure
	help us on our explorations.

	{PLAYER}{KUN}, would you trade your
	SCANNER for something?

	Like, say, a DEEPSEATOOTH or
	a DEEPSEASCALE that I have?"
}

text SlateportCity_Harbor_Text_IfYouWantToTradeLetMeKnow {
	"CAPT. STERN: Are you certain?
	It's useless to you, {PLAYER}{KUN}…

	Well, okay, then. If you want to trade
	your SCANNER, let me know."
}

text SlateportCity_Harbor_Text_TradeForDeepSeaTooth {
	"CAPT. STERN: So you'll trade it for
	my DEEPSEATOOTH?"
}

text SlateportCity_Harbor_Text_TradeForDeepSeaScale {
	"CAPT. STERN: So you'll trade it for
	my DEEPSEASCALE?"
}

text SlateportCity_Harbor_Text_WhichOneDoYouWant {
	"CAPT. STERN: Which one do you want?"
}

text SlateportCity_Harbor_Text_HandedScannerToStern {
	"{PLAYER} handed the SCANNER to
	CAPT. STERN."
}

text SlateportCity_Harbor_Text_ThisWillHelpResearch {
	"CAPT. STERN: Thanks, {PLAYER}{KUN}!
	This will help our research a lot!"
}
