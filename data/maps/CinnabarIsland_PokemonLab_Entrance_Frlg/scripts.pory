text CinnabarIsland_Gym_Text_PhotoOfBlaineAndFuji {
	"It's a photo of BLAINE and
	MR. FUJI.

	They're standing shoulder to
	shoulder with big grins."
}

text CinnabarIsland_PokemonLab_Entrance_Text_StudyMonsExtensively {
	"We study POKéMON extensively
	every day.

	People often bring us rare POKéMON
	for examination."
}

