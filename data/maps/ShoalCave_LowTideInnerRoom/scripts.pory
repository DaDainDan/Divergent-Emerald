mapscripts ShoalCave_LowTideInnerRoom_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_RECEIVED_SHOAL_SALT_1) && !flag(FLAG_SYS_SHOAL_TIDE)) {
			setmetatile(31, 8, METATILE_Cave_ShoalCave_DirtPile_Large, TRUE)
		}
		if (!flag(FLAG_RECEIVED_SHOAL_SALT_2) && !flag(FLAG_SYS_SHOAL_TIDE)) {
			setmetatile(14, 26, METATILE_Cave_ShoalCave_DirtPile_Large, TRUE)
		}
		if (!flag(FLAG_RECEIVED_SHOAL_SHELL_1)) {
			setmetatile(41, 20, METATILE_Cave_ShoalCave_BlueStone_Large, TRUE)
		}
		if (!flag(FLAG_RECEIVED_SHOAL_SHELL_2)) {
			setmetatile(41, 10, METATILE_Cave_ShoalCave_BlueStone_Large, TRUE)
		}
		if (!flag(FLAG_RECEIVED_SHOAL_SHELL_3)) {
			setmetatile(6, 9, METATILE_Cave_ShoalCave_BlueStone_Large, TRUE)
		}
		if (!flag(FLAG_RECEIVED_SHOAL_SHELL_4)) {
			setmetatile(16, 13, METATILE_Cave_ShoalCave_BlueStone_Large, TRUE)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (flag(FLAG_SYS_SHOAL_TIDE)) {
			setmaplayoutindex(LAYOUT_SHOAL_CAVE_HIGH_TIDE_INNER_ROOM)
		} else {
			setmaplayoutindex(LAYOUT_SHOAL_CAVE_LOW_TIDE_INNER_ROOM)
		}
		end
    }
}

script ShoalCave_LowTideInnerRoom_EventScript_ShoalShell1 {
    lockall
    if (flag(FLAG_RECEIVED_SHOAL_SHELL_1)) {
        goto(ShoalCave_LowTideInnerRoom_EventScript_ReceivedShoalShell)
    }
	setvar(VAR_0x8007, 1)
    goto(ShoalCave_LowTideInnerRoom_EventScript_GiveShoalShell)
	end
}

script ShoalCave_LowTideInnerRoom_EventScript_GiveShoalShell {
	if (giveitem(ITEM_SHOAL_SHELL) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
	switch (var(VAR_0x8007)) {
		case 1: setmetatile(41, 20, METATILE_Cave_ShoalCave_BlueStone_Small, FALSE)
		case 2: setmetatile(41, 10, METATILE_Cave_ShoalCave_BlueStone_Small, FALSE)
		case 3: setmetatile(6, 9, METATILE_Cave_ShoalCave_BlueStone_Small, FALSE)
		case 4: setmetatile(16, 13, METATILE_Cave_ShoalCave_BlueStone_Small, FALSE)
	}
	special(DrawWholeMapView)
	switch (var(VAR_0x8007)) {
		case 1: setflag(FLAG_RECEIVED_SHOAL_SHELL_1)
		case 2: setflag(FLAG_RECEIVED_SHOAL_SHELL_2)
		case 3: setflag(FLAG_RECEIVED_SHOAL_SHELL_3)
		case 4: setflag(FLAG_RECEIVED_SHOAL_SHELL_4)
	}
	releaseall
    end
}

script ShoalCave_LowTideInnerRoom_EventScript_ReceivedShoalShell {
    msgbox(ShoalCave_Text_WasShoallShellNowNothing, MSGBOX_DEFAULT)
    releaseall
    end
}

script ShoalCave_LowTideInnerRoom_EventScript_ShoalShell2 {
    lockall
    if (flag(FLAG_RECEIVED_SHOAL_SHELL_2)) {
        goto(ShoalCave_LowTideInnerRoom_EventScript_ReceivedShoalShell)
    }
	setvar(VAR_0x8007, 2)
    goto(ShoalCave_LowTideInnerRoom_EventScript_GiveShoalShell)
	end
}

