mapscripts DewfordTown_Hall_MapScripts {}

script DewfordTown_Hall_EventScript_Girl {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    special(IsTrendyPhraseBoring)
    if (var(VAR_RESULT) == TRUE) {
        msgbox(DewfordTown_Hall_Text_GettingBoredOfTrend, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(DewfordTown_Hall_Text_CantImagineLifeWithoutTrend, MSGBOX_DEFAULT)
    release_end
}

script DewfordTown_Hall_EventScript_Woman {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    msgbox(DewfordTown_Hall_Text_TeachingMonAboutTrend, MSGBOX_DEFAULT)
    release_end
}

script DewfordTown_Hall_EventScript_Man {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    special(BufferDeepLinkPhrase)
    msgbox(DewfordTown_Hall_Text_DeepLinkBetweenXAndY, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(DewfordTown_Hall_Text_MyHunchWasRight, MSGBOX_DEFAULT)
    } else {
        msgbox(DewfordTown_Hall_Text_NotEasyToKeepUp, MSGBOX_DEFAULT)
    }
    release_end
}

script DewfordTown_Hall_EventScript_ExpertM {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    msgbox(DewfordTown_Hall_Text_TVShowAboutTrend, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_DEWFORD_HALL_EXPERT_M, Common_Movement_StepFasterUp)
    waitmovement(0)
    release_end
}

script DewfordTown_Hall_EventScript_Twin {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    msgbox(DewfordTown_Hall_Text_IsTrendMorePopularAcrossSea, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_DEWFORD_HALL_TWIN, Common_Movement_StepFasterUp)
    waitmovement(0)
    release_end
}

script DewfordTown_Hall_EventScript_LittleBoy {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    msgbox(DewfordTown_Hall_Text_CollectTrendMerchandise, MSGBOX_DEFAULT)
    release_end
}

script DewfordTown_Hall_EventScript_Bookshelf {
    lockall
    call(Common_EventScript_BufferTrendyPhrase)
    msgbox(DewfordTown_Hall_Text_BooksAboutTrend, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_Painting {
    lockall
    call(Common_EventScript_BufferTrendyPhrase)
    special(GetDewfordHallPaintingNameIndex)
    switch (var(VAR_RESULT)) {
        case 0:
        case 4:
		case 5: msgbox(DewfordTown_Hall_Text_TrendsScream, MSGBOX_DEFAULT)
        case 1: msgbox(DewfordTown_Hall_Text_TrendsSmile, MSGBOX_DEFAULT)
		case 3: msgbox(DewfordTown_Hall_Text_BirthOfTrend, MSGBOX_DEFAULT)
        case 2:
        case 6:
        case 7: msgbox(DewfordTown_Hall_Text_LastTrend, MSGBOX_DEFAULT)
    }
    releaseall
    end
}

script DewfordTown_Hall_EventScript_SchoolKidM {
    lockall
    setvar(VAR_0x8008, 0)
    goto(DewfordTown_Hall_EventScript_DoTrendDebate)
    end
}

script DewfordTown_Hall_EventScript_PsychicM {
    lockall
    setvar(VAR_0x8008, 1)
    goto(DewfordTown_Hall_EventScript_DoTrendDebate)
    end
}

script DewfordTown_Hall_EventScript_DoTrendDebate {
    call(Common_EventScript_BufferTrendyPhrase)
    special(GetDewfordHallPaintingNameIndex)
    switch (var(VAR_RESULT)) {
        case 0:
        case 1: goto(DewfordTown_Hall_EventScript_TrendDebate1)
        case 2:
        case 3: goto(DewfordTown_Hall_EventScript_TrendDebate2)
        case 4:
        case 5: goto(DewfordTown_Hall_EventScript_TrendDebate3)
        case 6: goto(DewfordTown_Hall_EventScript_TrendDebate4)
        case 7: goto(DewfordTown_Hall_EventScript_TrendDebate5)
    }
    end
}

script DewfordTown_Hall_EventScript_TrendDebate1 {
    call(DewfordTown_Hall_EventScript_DebateReact1)
    msgbox(DewfordTown_Hall_Text_SawTrendCoolestThing, MSGBOX_DEFAULT)
    call(DewfordTown_Hall_EventScript_DebateReact2)
    msgbox(DewfordTown_Hall_Text_AllegedTrendNotAuthentic, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_TrendDebate2 {
    call(DewfordTown_Hall_EventScript_DebateReact1)
    msgbox(DewfordTown_Hall_Text_ComposedTrendThemeSong, MSGBOX_DEFAULT)
    call(DewfordTown_Hall_EventScript_DebateReact2)
    msgbox(DewfordTown_Hall_Text_WorkOnYourSinging, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_TrendDebate3 {
    call(DewfordTown_Hall_EventScript_DebateReact1)
    msgbox(DewfordTown_Hall_Text_OrganizeTrendParty, MSGBOX_DEFAULT)
    call(DewfordTown_Hall_EventScript_DebateReact2)
    msgbox(DewfordTown_Hall_Text_BrilliantIndeed, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_TrendDebate4 {
    call(DewfordTown_Hall_EventScript_DebateReact1)
    msgbox(DewfordTown_Hall_Text_TrendHasBecomePartOfLife, MSGBOX_DEFAULT)
    call(DewfordTown_Hall_EventScript_DebateReact2)
    msgbox(DewfordTown_Hall_Text_TrendWeighsHeavilyOnMind, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_TrendDebate5 {
    call(DewfordTown_Hall_EventScript_DebateReact1)
    msgbox(DewfordTown_Hall_Text_IfWeTeamUpWellBeInvincible, MSGBOX_DEFAULT)
    call(DewfordTown_Hall_EventScript_DebateReact2)
    msgbox(DewfordTown_Hall_Text_WellBeTrendDuo, MSGBOX_DEFAULT)
    releaseall
    end
}

script DewfordTown_Hall_EventScript_DebateReact1 {
    applymovement(LOCALID_DEWFORD_HALL_PSYCHIC_M, Common_Movement_StepLeft)
    waitmovement(0)
    if (var(VAR_0x8008) == 0 && var(VAR_FACING) != DIR_EAST) {
        applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    	waitmovement(0)
    }
    end
}

script DewfordTown_Hall_EventScript_DebateReact2 {
    applymovement(LOCALID_DEWFORD_HALL_SCHOOL_KID_M, Common_Movement_StepRight)
    waitmovement(0)
    if (var(VAR_0x8008) == 0) {
        switch (var(VAR_FACING)) {
			case DIR_NORTH: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
			case DIR_SOUTH: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
		}
    }
    elif (var(VAR_0x8008) == 1 && var(VAR_FACING) != DIR_WEST) {
        applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    }
	waitmovement(0)
    end
}

script DewfordTown_Hall_EventScript_SludgeBombMan {
    lock_faceplayer
    call(Common_EventScript_BufferTrendyPhrase)
    if (flag(FLAG_RECEIVED_TM_SLUDGE_BOMB)) {
        msgbox(DewfordTown_Hall_Text_LoveSludgeBombButTrendInToo, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(DewfordTown_Hall_Text_GiveYouSludgeBomb, MSGBOX_DEFAULT)
    if (giveitem(ITEM_TM_SLUDGE_BOMB) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_TM_SLUDGE_BOMB)
    release_end
}

text DewfordTown_Hall_Text_CantImagineLifeWithoutTrend {
	"What's in vogue? Why, it has to be
	“{STR_VAR_1}”!

	I can't imagine what life would be like
	without “{STR_VAR_1}”!"
}

text DewfordTown_Hall_Text_GettingBoredOfTrend {
	"What's in vogue? Why, it has to be
	“{STR_VAR_1}”!

	But I'm getting kind of bored with it.

	I should look for the next big thing."
}

text DewfordTown_Hall_Text_TeachingMonAboutTrend {
	"I'm teaching my POKéMON about
	“{STR_VAR_1},”
	but it's not going well.

	It's a bit too much, I think."
}

text DewfordTown_Hall_Text_DeepLinkBetweenXAndY {
	"I'm studying up on the hip and trendy
	“{STR_VAR_1}” now.

	Is it true that there's a deep link
	between “{STR_VAR_1}”
	and “{STR_VAR_2}”?"
}

text DewfordTown_Hall_Text_MyHunchWasRight {
	"Oh!
	So, my hunch was right!

	I'm one step closer to being hip and
	happening, yowza!"
}

text DewfordTown_Hall_Text_NotEasyToKeepUp {
	"What?!
	Is that so?!

	It's not easy for an older fellow like
	me to keep up with trends!"
}

text DewfordTown_Hall_Text_TVShowAboutTrend {
	"This whole business about
	“{STR_VAR_1}”…
	Isn't there a TV show on it?"
}

text DewfordTown_Hall_Text_IsTrendMorePopularAcrossSea {
	"Across the sea…

	Is “{STR_VAR_1}”
	even more popular?"
}

text DewfordTown_Hall_Text_CollectTrendMerchandise {
	"I collect official
	“{STR_VAR_1}”
	licensed merchandise.

	I have official
	“{STR_VAR_1}” DOLLS…

	Official “{STR_VAR_1}”
	brand clothing…

	And officially licensed
	“{STR_VAR_1}”
	picture books.

	Heheh, I own!
	I'm not sharing anything with you!"
}

text DewfordTown_Hall_Text_BooksAboutTrend {
	"IDENTIFYING GOOD
	“{STR_VAR_1}” &
	BAD “{STR_VAR_1}”…

	THE LINK BETWEEN
	“{STR_VAR_1}” AND
	POKéMON…

	USEFUL
	“{STR_VAR_1}”…

	It's neatly jammed with books about
	“{STR_VAR_1}.”"
}

text DewfordTown_Hall_Text_TrendsScream {
	"“{STR_VAR_1}'S
	SCREAM” is the title."
}

text DewfordTown_Hall_Text_TrendsSmile {
	"“{STR_VAR_1}'S
	SMILE” is the title."
}

text DewfordTown_Hall_Text_LastTrend {
	"It's titled “THE LAST
	{STR_VAR_1}”."
}

text DewfordTown_Hall_Text_BirthOfTrend {
	"It's titled “THE BIRTH OF
	{STR_VAR_1}”."
}

text DewfordTown_Hall_Text_SawTrendCoolestThing {
	"I saw “{STR_VAR_1}”!
	Cool, huh?

	It's, like, the coolest thing going!

	It was awesome!
	It was the real thing, oh yeah!"
}

text DewfordTown_Hall_Text_AllegedTrendNotAuthentic {
	"Oh, no, no, no.

	That alleged
	“{STR_VAR_1}”
	you claim to have seen--it's not.

	The authentic article is much…
	How should I say it?
	Sharper, yet more mellow!

	Ah, no matter. It's astonishing!"
}

text DewfordTown_Hall_Text_ComposedTrendThemeSong {
	"Hey, listen, I composed a theme song
	for “{STR_VAR_1}.”

	“{STR_VAR_1}”
	is really popular right now.

	Okay, listen!
	… …

	Oh!
	{STR_VAR_1}!

	Wonderful
	{STR_VAR_1}!"
}

text DewfordTown_Hall_Text_WorkOnYourSinging {
	"… …

	I dare say, chap, it would pay for you
	to work on your singing before you
	trifle yourself with
	“{STR_VAR_1}.”"
}

text DewfordTown_Hall_Text_OrganizeTrendParty {
	"Anyway, as I was saying earlier, we
	should get together and organize a
	“{STR_VAR_1}” party
	on the island."
}

text DewfordTown_Hall_Text_BrilliantIndeed {
	"Oh, a smashing good idea!

	It will settle once and for all
	who is the best at
	“{STR_VAR_1}.”
	Brilliant, indeed!

	Starting today, our lives will revolve
	around “{STR_VAR_1}”!"
}

text DewfordTown_Hall_Text_TrendHasBecomePartOfLife {
	"I was thinking, though…

	Wouldn't you agree that
	“{STR_VAR_1}” has
	grown from being something trendy to
	being a part of our daily lives?"
}

text DewfordTown_Hall_Text_TrendWeighsHeavilyOnMind {
	"Beg pardon?
	That much, what?

	However, it's true that
	“{STR_VAR_1}”
	weighs heavily on your mind, whether
	you're awake or asleep.

	Absolutely, you're the
	“{STR_VAR_1}”
	PROFESSOR, old sport!"
}

text DewfordTown_Hall_Text_IfWeTeamUpWellBeInvincible {
	"If you and me team up as a combo,
	we'll be invincible when it comes to all
	things “{STR_VAR_1}”!"
}

text DewfordTown_Hall_Text_WellBeTrendDuo {
	"Spot on, my friend!

	We shall be the
	“{STR_VAR_1}” DUO!

	Isn't that a ripe image?
	Hahahah!"
}

text DewfordTown_Hall_Text_GiveYouSludgeBomb {
	"For me, SLUDGE BOMB is at the peak
	of popularity. It's the one.

	Hunh? You're telling me that you don't
	know about SLUDGE BOMB?

	That's outright pitiful.
	I'll give you one."
}

text DewfordTown_Hall_Text_LoveSludgeBombButTrendInToo {
	"I love SLUDGE BOMB.

	But POKéMON with the move
	“{STR_VAR_1}”
	are in, too."
}
