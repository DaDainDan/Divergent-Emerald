mapscripts TrainerTower_Lobby_Frlg_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        setvar(VAR_TEMP_2, 0)
		ttower_resumetimer
		ttower_shouldexit
		if (var(VAR_RESULT) == TRUE) {
			// Never reached, above always FALSE
			setvar(VAR_TEMP_0, 0)
			setobjectxy(LOCALID_PLAYER, 9, 7)
			applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
		}
		end
    }
    MAP_SCRIPT_ON_RETURN_TO_FIELD {
        addobject(LOCALID_TOWER_NURSE)
		addobject(LOCALID_TOWER_MART_CLERK)
		addobject(LOCALID_TOWER_RECEPTIONIST)
		addobject(LOCALID_TOWER_COOLTRAINER_F)
		addobject(LOCALID_TOWER_BALDING_MAN)
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_TRAINER_TOWER_LOBBY)
		getplayerxy(VAR_TEMP_D, VAR_RESULT)
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_TEMP_D) == 17) {
			setmetatile(17, 10, METATILE_TrainerTower_Floor_ShadeBottomLeft, 0)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: TrainerTower_Lobby_EventScript_Enter
    	VAR_TEMP_D, 17: TrainerTower_Lobby_EventScript_ExitElevator
    ]
}

script TrainerTower_Lobby_EventScript_ExitElevator {
    lockall
    applymovement(LOCALID_PLAYER, moves(walk_down * 2))
    waitmovement(0)
    setmetatile(17, 10, METATILE_TrainerTower_CounterBarrier, 1)
    special(DrawWholeMapView)
    playse(SE_CLICK)
    waitse
    setvar(VAR_TEMP_D, 0)
    releaseall
    end
}

script TrainerTower_Lobby_EventScript_Enter {
    setvar(VAR_TEMP_0, 1)
    ttower_getchallengestatus
	if (var(VAR_RESULT) == TT_CHALLENGE_STATUS_LOST || var(VAR_RESULT) == TT_CHALLENGE_STATUS_UNK) {
		lock_faceplayer
		applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
		textcolor(NPC_TEXT_COLOR_FEMALE)
	}
    switch (var(VAR_RESULT)) {
        case TT_CHALLENGE_STATUS_LOST: msgbox(TrainerTower_Lobby_Text_TooBadComeBackTryAgain)
        case TT_CHALLENGE_STATUS_UNK: msgbox(TrainerTower_Lobby_Text_MoveCounterHereWhenTrainersSwitch)
		default: end
    }
	goto(TrainerTower_Lobby_EventScript_ExitChallenge)
    end
}

script TrainerTower_Lobby_EventScript_LostChallenge {
    lock_faceplayer
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    textcolor(NPC_TEXT_COLOR_FEMALE)
    msgbox(TrainerTower_Lobby_Text_TooBadComeBackTryAgain)
    goto(TrainerTower_Lobby_EventScript_ExitChallenge)
}

script TrainerTower_Lobby_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script TrainerTower_Lobby_EventScript_Receptionist {
    lock_faceplayer
    ttower_getbeatchallenge
    if (var(VAR_RESULT) == TRUE) {
        msgbox(TrainerTower_Lobby_Text_ThanksForCompeting)
    	release_end
    }
    msgbox(TrainerTower_Lobby_Text_GiveItYourBest)
    release_end
}

script TrainerTower_Lobby_EventScript_MartClerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(TrainerTower_Lobby_Mart_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart TrainerTower_Lobby_Mart_Items {
    ITEM_ULTRA_BALL
    ITEM_GREAT_BALL
    ITEM_FULL_RESTORE
    ITEM_MAX_POTION
    ITEM_HYPER_POTION
    ITEM_REVIVE
    ITEM_FULL_HEAL
    ITEM_ESCAPE_ROPE
    ITEM_MAX_REPEL
}

script TrainerTower_Lobby_EventScript_EntryTrigger {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    textcolor(NPC_TEXT_COLOR_FEMALE)
    msgbox(TrainerTower_Lobby_Text_WelcomeToTrainerTower)
    ttower_getnumfloors
    if (var(VAR_RESULT) == FALSE) {
        msgbox(TrainerTower_Lobby_Text_TrainersUpEighthFloor)
    } else {
		msgbox(TrainerTower_Lobby_Text_TrainersUpToFloorNum)
	}
    goto(TrainerTower_Lobby_EventScript_AskEnterChallenge)
	end
}

script TrainerTower_Lobby_EventScript_AskEnterChallenge {
    message(TrainerTower_Lobby_Text_LikeToChallengeTrainers)
    waitmessage
    multichoice(18, 6, MULTI_YESNOINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(TrainerTower_Lobby_EventScript_ChooseChallenge)
        case 2:
			msgbox(TrainerTower_Lobby_Text_ExplainTrainerTower)
    		goto(TrainerTower_Lobby_EventScript_AskEnterChallenge)
		case 1:
        case MULTI_B_PRESSED: 
			goto(TrainerTower_Lobby_EventScript_DeclineChallenge)
    }
    end
}

script TrainerTower_Lobby_EventScript_ChooseChallenge {
    multichoice(13, 3, MULTI_TRAINER_TOWER_MODE, FALSE)
	if (var(VAR_RESULT) < 4) {
		copyvar(VAR_0x8005, VAR_RESULT)
		setvar(VAR_MAP_SCENE_TRAINER_TOWER, 1)
		special(HealPlayerParty)
		msgbox(TrainerTower_Lobby_Text_StartClockGetSetGo)
		ttower_startchallenge
	} else {
		msgbox(TrainerTower_Lobby_Text_PleaseVisitUsAgain)
		closemessage
		applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
		waitmovement(0)
	}
    releaseall
	end
}

script TrainerTower_Lobby_EventScript_ShowRecords {
    lockall
    fadescreen(FADE_TO_BLACK)
    setvar(VAR_0x8004, 1)
    special(ShowTrainerHillRecords)
    releaseall
    end
}

script TrainerTower_Lobby_EventScript_CooltrainerF {
    msgbox(TrainerTower_Lobby_Text_WonderWhatKindsOfTrainers, MSGBOX_NPC)
    end
}

script TrainerTower_Lobby_EventScript_BaldingMan {
    msgbox(TrainerTower_Lobby_Text_StairsTougherThanAnyBattle, MSGBOX_NPC)
    end
}

// All Trainer Tower text (Lobby and Roof) is interleaved here
text TrainerTower_Lobby_Text_WelcomeToTrainerTower {
	"Hello!

	Welcome to TRAINER TOWER where
	TRAINERS gather from all over!"
}

text TrainerTower_Lobby_Text_TrainersUpToFloorNum {
	"TRAINERS from all over the world
	gather here to battle.

	Let me see…

	Right now, there are TRAINERS only
	up to Floor {STR_VAR_1}."
}

text TrainerTower_Lobby_Text_TrainersUpEighthFloor {
	"TRAINERS are awaiting your
	challenge up to the eighth floor."
}

text TrainerTower_Lobby_Text_LikeToChallengeTrainers {
	"Would you like to challenge the
	waiting TRAINERS?"
}

text TrainerTower_Lobby_Text_StartClockGetSetGo {
	"Okay, I'll get the clock started,
	so give it everything you have.

	On your marks…

	Get set…

	Go!"
}

text TrainerTower_Lobby_Text_PleaseVisitUsAgain {
	"Please do visit us again!"
}

text TrainerTower_Lobby_Text_TooBadComeBackTryAgain {
	"That was too bad.

	I think you put in a tremendous
	effort in your battling.

	Please come back and try again!"
}

text TrainerTower_Lobby_Text_GiveItYourBest {
	"I hope you give it your best."
}

text TrainerTower_Lobby_Text_MoveCounterHereWhenTrainersSwitch {
	"When the TRAINERS switch places,
	the movement can be hectic.

	To avoid the stampede, we moved
	the reception counter here.

	I'm sorry for the inconvenience."
}

text TrainerTower_Roof_Text_ImOwnerBattledPerfectly {
	"Hello…

	I am the owner of this TOWER…

	How the sky soars above this
	rooftop…

	The caress of the winds up here…

	It's all so perfect…

	The way you battled…
	It, too, was perfection…"
}

text TrainerTower_Roof_Text_ThisIsForYou {
	"This is for you…"
}

text TrainerTower_Roof_Text_DoneItInRecordTime {
	"Oh!
	Stupendous!

	It's marvelous how you've come up
	here so quickly.

	The fact is, you've done it in
	record time…

	I'll have your record posted at
	the reception counter."
}

text TrainerTower_Roof_Text_TookSweetTimeGettingHere {
	"You seem to have taken your sweet
	time getting here…"
}

text TrainerTower_Roof_Text_IdLikeToSeeBetterTime {
	"What I would like to see is a
	better time out of you…

	I'm counting on you.

	Until then, farewell…"
}

text TrainerTower_Text_XMinYZSec {
	"{STR_VAR_1} min. {STR_VAR_2}.{STR_VAR_3} sec."
}

text TrainerTower_Lobby_Text_HereAreTheResults {
	"せいせきひょうです"
}

text TrainerTower_Lobby_Text_NeedTwoMonsForDouble {
	"This is a two-on-two battle.

	You may not battle unless you have
	at least two POKéMON."
}

text TrainerTower_Lobby_Text_ExplainTrainerTower {
	"Here at TRAINER TOWER, there is an
	event called TIME ATTACK.

	You will be timed on how quickly
	you can get from the reception
	counter to the OWNER on the roof.

	The best times will be recorded on
	the Time Board.

	Try competing with friends to see
	who can beat it the fastest.

	You will not earn any EXP. Points
	or money by beating TRAINERS here."
}

text TrainerTower_Lobby_Text_ThanksForCompeting {
	"Thank you for competing!"
}

text TrainerTower_Lobby_Text_WonderWhatKindsOfTrainers {
	"I'm here to see how good I am.

	I wonder what kinds of TRAINERS
	are waiting for me?

	It's nerve-racking!"
}

text TrainerTower_Lobby_Text_StairsTougherThanAnyBattle {
	"Gasp, gasp…
	Gasp…

	Never mind battling! These stairs…
	They're tougher than any battle…"
}
