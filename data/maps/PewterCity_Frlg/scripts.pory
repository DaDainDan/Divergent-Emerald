mapscripts PewterCity_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_PEWTER_CITY)
		setvar(VAR_MAP_SCENE_PEWTER_CITY_MUSEUM_1F, 0)
		end
    }
}

// Impossible to speak to this NPC from a facing dir != DIR_EAST normally, so they arent checked
// Additionally, no movement script exists for facing DIR_SOUTH, which would necessitate walking out of bounds
script PewterCity_EventScript_GymGuide {
    lock_faceplayer
    msgbox(PewterCity_Text_BrocksLookingForChallengersFollowMe)
    closemessage
    playbgm(MUS_FOLLOW_ME, 0)
    if (var(VAR_FACING) == DIR_EAST) {
        applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  delay_4,  step_faster_down))
		applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_down,  walk_left,  step_faster_up,  step_up))
		waitmovement(0)
		applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToGymEast)
		applymovement(LOCALID_PEWTER_GYM_GUIDE, PewterCity_Movement_GuideWalkToGymEast)
		waitmovement(0)
    }
    msgbox(PewterCity_Text_GoTakeOnBrock)
    closemessage
    applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_down,  walk_left * 9))
    waitmovement(0)
    fadedefaultbgm
    removeobject(LOCALID_PEWTER_GYM_GUIDE)
    clearflag(FLAG_HIDE_PEWTER_CITY_GYM_GUIDE)
    release_end
}

// Unused
script PewterCity_EventScript_WalkToGymWest {
    applymovement(LOCALID_PLAYER, moves(delay_16))
    applymovement(LOCALID_PEWTER_GYM_GUIDE, Common_Movement_StepRight)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(walk_left * 20,  walk_up * 7,  walk_left * 10,  walk_down * 6,  walk_right))
    applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_left * 19,  walk_up * 7,  walk_left * 10,  walk_down * 6,  walk_right * 2,  step_faster_left))
    waitmovement(0)
    return
}

// Unused
script PewterCity_EventScript_WalkToGymNorth {
    applymovement(LOCALID_PLAYER, moves(delay_16))
    applymovement(LOCALID_PEWTER_GYM_GUIDE, Common_Movement_StepDown)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(walk_up,  walk_left * 19,  walk_up * 7,  walk_left * 10,  walk_down * 6,  walk_right))
    applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_left * 19,  walk_up * 7,  walk_left * 10,  walk_down * 6,  walk_right * 2,  step_faster_left))
    waitmovement(0)
    return
}

movement PewterCity_Movement_PlayerWalkToGymEast {
    // moves(walk_down,  walk_left * 3,  walk_up,  walk_left * 15,  walk_up * 10,  walk_left * 16,  walk_down * 8,  walk_right * 8)
    walk_down
    walk_left * 3
    walk_up
    walk_left * 15
    walk_up * 10
    walk_left * 16
    walk_down * 8
    walk_right * 8
}

movement PewterCity_Movement_GuideWalkToGymEast {
    // moves(walk_left * 3,  walk_up,  walk_left * 15,  walk_up * 10,  walk_left * 16,  walk_down * 8,  walk_right * 9,  step_faster_left)
    walk_left * 3
    walk_up
    walk_left * 15
    walk_up * 10
    walk_left * 16
    walk_down * 8
    walk_right * 9
    step_faster_left
}

script PewterCity_EventScript_GymGuideTriggerTop {
    lockall
    setvar(VAR_TEMP_1, 0)
    goto(PewterCity_EventScript_GymGuideTrigger)
    end
}

script PewterCity_EventScript_GymGuideTriggerMid {
    lockall
    setvar(VAR_TEMP_1, 1)
    goto(PewterCity_EventScript_GymGuideTrigger)
    end
}

script PewterCity_EventScript_GymGuideTriggerBottom {
    lockall
    setvar(VAR_TEMP_1, 2)
    goto(PewterCity_EventScript_GymGuideTrigger)
    end
}

// This trigger is inaccessible and its corresponding movement script isnt linked
script PewterCity_EventScript_GymGuideTriggerRight {
    lockall
    setvar(VAR_TEMP_1, 3)
    goto(PewterCity_EventScript_GymGuideTrigger)
    end
}

script PewterCity_EventScript_GymGuideTrigger {
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(PewterCity_Text_BrocksLookingForChallengersFollowMe)
    closemessage
    playbgm(MUS_FOLLOW_ME, 0)
	switch (var(VAR_TEMP_1)) {
		case 0:
			applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_left,  walk_down,  step_faster_right,  step_right))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToGymTop)
			applymovement(LOCALID_PEWTER_GYM_GUIDE, PewterCity_Movement_GuideWalkToGymTop)
		case 1:
			applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_down,  step_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToGymMid)
			applymovement(LOCALID_PEWTER_GYM_GUIDE, PewterCity_Movement_GuideWalkToGymMid)
		case 2:
			applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_down * 2,  step_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToGymBottom)
			applymovement(LOCALID_PEWTER_GYM_GUIDE, PewterCity_Movement_GuideWalkToGymBottom)
	}
	waitmovement(0)
    msgbox(PewterCity_Text_GoTakeOnBrock)
    closemessage
    applymovement(LOCALID_PEWTER_GYM_GUIDE, moves(walk_down,  walk_left * 9))
    waitmovement(0)
    fadedefaultbgm
    removeobject(LOCALID_PEWTER_GYM_GUIDE)
    clearflag(FLAG_HIDE_PEWTER_CITY_GYM_GUIDE)
    releaseall
    end
}

