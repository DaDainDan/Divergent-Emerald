script PewterCity_EventScript_MuseumGuide {
    lock_faceplayer
    msgbox(PewterCity_Text_DidYouCheckOutMuseum, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(PewterCity_Text_WerentThoseFossilsAmazing)
    	release_end
    }
    msgbox(PewterCity_Text_ReallyYouHaveToGo)
    closemessage
    delay(10)
    playbgm(MUS_FOLLOW_ME, 0)
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement(LOCALID_PEWTER_MUSEUM_GUIDE, moves(walk_up * 4,  walk_left * 10,  walk_up * 4,  walk_left * 7,  step_faster_up))
    		applymovement(LOCALID_PLAYER, moves(walk_up * 5,  walk_left * 10,  walk_up * 4,  walk_left * 6,  delay_8,  step_faster_up))
		case DIR_SOUTH:
			applymovement(LOCALID_PEWTER_MUSEUM_GUIDE, moves(walk_left,  walk_up * 4,  walk_left * 9,  walk_up * 4,  walk_left * 7,  step_faster_up))
    		applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToMuseumSouth)
		case DIR_WEST:
			applymovement(LOCALID_PEWTER_MUSEUM_GUIDE, moves(walk_up * 4,  walk_left * 10,  walk_up * 4,  walk_left * 7,  step_faster_up))
    		applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToMuseumWest)
		case DIR_EAST:
			applymovement(LOCALID_PEWTER_MUSEUM_GUIDE, moves(walk_up * 4,  walk_left * 10,  walk_up * 4,  walk_left * 7,  step_faster_up))
    		applymovement(LOCALID_PLAYER, PewterCity_Movement_PlayerWalkToMuseumEast)
	}
	waitmovement(0)
    msgbox(PewterCity_Text_ThisIsTheMuseum)
    closemessage
    delay(10)
    applymovement(LOCALID_PEWTER_MUSEUM_GUIDE, moves(walk_down,  walk_right * 7,  walk_down * 3,  walk_right * 3))
    waitmovement(0)
    fadedefaultbgm
    removeobject(LOCALID_PEWTER_MUSEUM_GUIDE)
    clearflag(FLAG_HIDE_PEWTER_MUSEUM_GUIDE)
    release_end
}

movement PewterCity_Movement_PlayerWalkToMuseumSouth {
    // moves(delay_16 * 2,  walk_left,  walk_up * 3,  walk_left * 9,  walk_up * 4,  walk_left * 6,  delay_8,  step_faster_up)
    delay_16 * 2
    walk_left
    walk_up * 3
    walk_left * 9
    walk_up * 4
    walk_left * 6
    delay_8
    step_faster_up
}

movement PewterCity_Movement_PlayerWalkToMuseumWest {
    // moves(walk_left,  walk_up * 4,  walk_left * 10,  walk_up * 4,  walk_left * 6,  delay_8,  step_faster_up)
    walk_left
    walk_up * 4
    walk_left * 10
    walk_up * 4
    walk_left * 6
    delay_8
    step_faster_up
}

movement PewterCity_Movement_PlayerWalkToMuseumEast {
    // moves(walk_right,  walk_up * 4,  walk_left * 10,  walk_up * 4,  walk_left * 6,  delay_8,  step_faster_up)
    walk_right
    walk_up * 4
    walk_left * 10
    walk_up * 4
    walk_left * 6
    delay_8
    step_faster_up
}

