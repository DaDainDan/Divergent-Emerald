text CeladonCity_DepartmentStore_3F_Text_OTStandsForOriginalTrainer {
	"Captured POKéMON are registered
	with an ID No. and the OT.

	OT stands for “Original TRAINER” -
	the TRAINER that caught it first."
}

text CeladonCity_DepartmentStore_3F_Text_BuddyTradingKangaskhanForHaunter {
	"All right!

	My buddy's going to trade me his
	KANGASKHAN for my HAUNTER!"
}

text CeladonCity_DepartmentStore_3F_Text_HaunterEvolvedOnTrade {
	"Come on, HAUNTER!

	I love HAUNTER!
	I collect them!

	Huh?

	HAUNTER turned into a different
	POKéMON while being traded!"
}

text CeladonCity_DepartmentStore_3F_Text_CanIdentifyTradeMonsByID {
	"You can identify POKéMON you get
	in trades by their ID Numbers."
}

text CeladonCity_DepartmentStore_3F_Text_ItsSuperNES {
	"It's a Super NES."
}

text CeladonCity_DepartmentStore_3F_Text_AnRPG {
	"An RPG!
	There's no time for that!"
}

text CeladonCity_DepartmentStore_3F_Text_SportsGame {
	"A sports game!
	Dad'll like that!"
}

text CeladonCity_DepartmentStore_3F_Text_PuzzleGame {
	"A puzzle game!
	Looks addictive!"
}

text CeladonCity_DepartmentStore_3F_Text_FightingGame {
	"A fighting game!
	Looks tough!"
}

text CeladonCity_DepartmentStore_3F_Text_TVGameShop {
	"3F: TV GAME SHOP"
}

text CeladonCity_DepartmentStore_3F_Text_RedGreenBothArePokemon {
	"Red and Green!
	Both are POKéMON!"
}

text Text_CounterTeach {
	"Oh, hi!
	I finally finished POKéMON.

	Not done yet? How about I teach
	you a good move?

	The move I have in mind is
	COUNTER.

	Not like the one I'm leaning on,
	mind you!"
}

text Text_CounterDeclined {
	"You're not interested? Come see
	me if you change your mind."
}

text Text_CounterWhichMon {
	"Which POKéMON should I teach
	COUNTER to?"
}

text Text_CounterTaught {
	"Are you using that COUNTER move
	I taught your POKéMON?"
}
