mapscripts RustboroCity_Flat2_2F_MapScripts {}

script RustboroCity_Flat2_2F_EventScript_OldMan {
    msgbox(RustboroCity_Flat2_2F_Text_DevonWasTinyInOldDays, MSGBOX_NPC)
    end
}

script RustboroCity_Flat2_2F_EventScript_NinjaBoy {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_PREMIER_BALL_RUSTBORO)) {
        msgbox(RustboroCity_Flat2_2F_Text_GoingToWorkAtDevonToo, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(RustboroCity_Flat2_2F_Text_MyDaddyMadeThisYouCanHaveIt, MSGBOX_DEFAULT)
    if (giveitem(ITEM_PREMIER_BALL) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_PREMIER_BALL_RUSTBORO)
    release_end
}

text RustboroCity_Flat2_2F_Text_DevonWasTinyInOldDays {
	"Way back in the old days, DEVON was just
	a teeny, tiny company."
}

text RustboroCity_Flat2_2F_Text_MyDaddyMadeThisYouCanHaveIt {
	"My daddy's working at the CORPORATION.

	My daddy made this!
	But I can't use it, so you can have it."
}

text RustboroCity_Flat2_2F_Text_GoingToWorkAtDevonToo {
	"My daddy's working at the CORPORATION.

	When I grow up, I'm going to work for
	DEVON, too."
}
