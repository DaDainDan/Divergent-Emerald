mapscripts BattleFrontier_BattlePyramidTop_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        frontier_getbrainstatus
		if (var(VAR_RESULT) != FRONTIER_BRAIN_NOT_READY) {
			frontier_setbrainobj
		}
		copyvar(VAR_TEMP_C, VAR_RESULT)
		frontier_getstatus
		switch (var(VAR_TEMP_CHALLENGE_STATUS)) {
			case CHALLENGE_STATUS_SAVING: goto(BattleFrontier_BattlePyramid_EventScript_WarpToLobby)
			case 0:
			case CHALLENGE_STATUS_PAUSED:
				pyramid_save(CHALLENGE_STATUS_SAVING)
				special(SavePlayerParty)
				frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
				pyramid_settrainers
				frontier_setpartyorder(FRONTIER_PARTY_SIZE)
				setvar(VAR_TEMP_F, 1)
				end
		}
		frontier_get(FRONTIER_DATA_BATTLE_OUTCOME)
		if (var(VAR_RESULT) == B_OUTCOME_LOST || var(VAR_RESULT) == B_OUTCOME_DREW || var(VAR_RESULT) == B_OUTCOME_FORFEITED) {
			goto(BattleFrontier_BattlePyramid_EventScript_WarpToLobbyLost)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_PLAYING_PYRAMID_MUSIC, 0 {
			playbgm(MUS_B_PYRAMID_TOP, FALSE)
			setvar(VAR_TEMP_PLAYING_PYRAMID_MUSIC, 1)
			end
		}
    	VAR_TEMP_F, 1 {
			special(ShowMapNamePopup)
			setvar(VAR_TEMP_F, 0)
			end
		}
    ]
    MAP_SCRIPT_ON_TRANSITION {
        pyramid_updatelight(200, PYRAMID_LIGHT_SET_RADIUS)
		setvar(VAR_TEMP_F, 1)
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			if (var(VAR_TEMP_C) == 0) {
				setobjectxyperm(LOCALID_BRANDON, 0, 0)
			}
			end
		}
    ]
}

script BattleFrontier_BattlePyramidTop_EventScript_Attendant {
    lock_faceplayer
    if (var(VAR_TEMP_D) != 0) {
        msgbox(BattleFrontier_BattlePyramidTop_Text_StepForwardWhenReady, MSGBOX_DEFAULT)
		closemessage
		end
    }
    if (var(VAR_TEMP_C) != FRONTIER_BRAIN_NOT_READY) {
        msgbox(BattleFrontier_BattlePyramidTop_Text_ChiefBeatYouHere, MSGBOX_DEFAULT)
		applymovement(LOCALID_PYRAMID_TOP_ATTENDANT, moves(walk_right,  step_faster_left))
		setvar(VAR_TEMP_D, 1)
		closemessage
		end
    }
    msgbox(BattleFrontier_BattlePyramidTop_Text_ReachedSummitUpYouGo, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PYRAMID_TOP_ATTENDANT, moves(walk_right,  step_faster_left))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(walk_up * 5,  step_faster_down))
    waitmovement(0)
    applymovement(LOCALID_PYRAMID_TOP_ATTENDANT, moves(walk_left,  step_faster_up))
    waitmovement(0)
    message(BattleFrontier_BattlePyramidTop_Text_PlayerConqueredPyramid)
    waitmessage
    playfanfare(MUS_OBTAIN_B_POINTS)
    waitfanfare
    closemessage
    goto(BattleFrontier_BattlePyramidTop_EventScript_WarpToLobbyWon)
}

script BattleFrontier_BattlePyramidTop_EventScript_WarpToLobbyWon {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_WON)
    warp(MAP_BATTLE_FRONTIER_BATTLE_PYRAMID_LOBBY, 7, 13)
    waitstate
    end
}

script BattleFrontier_BattlePyramidTop_EventScript_BattleBrandon {
    lockall
    switch (var(VAR_TEMP_C)) {
        case FRONTIER_BRAIN_GOLD: goto(BattleFrontier_BattlePyramidTop_EventScript_BrandonIntroGold)
        case FRONTIER_BRAIN_STREAK: goto(BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardSilverSpeech)
        case FRONTIER_BRAIN_STREAK_LONG: goto(BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardGoldSpeech)
    }
    frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    if (var(VAR_RESULT) != FALSE) {
        goto(BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardSilverSpeech)
    }
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(creep_up * 2,  delay_16))
    waitmovement(0)
    msgbox(BattleFrontier_BattlePyramidTop_Text_ExplorationsAreGrandestAdventure, MSGBOX_DEFAULT)
    closemessage
    frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    applymovement(LOCALID_BRANDON, Common_Movement_RunDown)
    waitmovement(0)
    msgbox(BattleFrontier_BattlePyramidTop_Text_ImPyramidKingBrandon, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonSilver)
    end
}

script BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardSilverSpeech {
    applymovement(LOCALID_BRANDON, Common_Movement_RunDown)
    waitmovement(0)
    goto(BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonSilver)
	end
}

script BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonSilver {
    msgbox(BattleFrontier_BattlePyramidTop_Text_BringCourageToOurBattle, MSGBOX_DEFAULT)
    call(BattleFrontier_BattlePyramidTop_EventScript_DoBrandonBattle)
    playbgm(MUS_B_PYRAMID_TOP, FALSE)
    if (var(VAR_RESULT) == 1) {
        frontier_getsymbols
		if (var(VAR_RESULT) == 0) {
			msgbox(BattleFrontier_BattlePyramidTop_Text_BrandonFrontierPassPlease, MSGBOX_DEFAULT)
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattlePyramidTop_Text_ReceivedBraveSymbol)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattlePyramidTop_Text_LookForwardToNextMeeting, MSGBOX_DEFAULT)
		}
		goto(BattleFrontier_BattlePyramidTop_EventScript_WarpToLobbyWon)
    }
    goto(BattleFrontier_BattlePyramid_EventScript_WarpToLobbyLost)
}

script BattleFrontier_BattlePyramidTop_EventScript_BrandonIntroGold {
    frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    if (var(VAR_RESULT) != FALSE) {
        goto(BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardGoldSpeech)
    }
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(creep_up * 2,  delay_16))
    waitmovement(0)
    msgbox(BattleFrontier_BattlePyramidTop_Text_BrandonYouveReturned, MSGBOX_DEFAULT)
    closemessage
    frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    applymovement(LOCALID_BRANDON, Common_Movement_RunDown)
    waitmovement(0)
    msgbox(BattleFrontier_BattlePyramidTop_Text_MyCourageIsOffMeter, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonGold)
    end
}

script BattleFrontier_BattlePyramidTop_EventScript_BrandonHeardGoldSpeech {
    applymovement(LOCALID_BRANDON, Common_Movement_RunDown)
    waitmovement(0)
    goto(BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonGold)
}

script BattleFrontier_BattlePyramidTop_EventScript_BattleBrandonGold {
    msgbox(BattleFrontier_BattlePyramidTop_Text_EverythingYouHave, MSGBOX_DEFAULT)
    call(BattleFrontier_BattlePyramidTop_EventScript_DoBrandonBattle)
    playbgm(MUS_B_PYRAMID_TOP, FALSE)
    if (var(VAR_RESULT) == 1) {
        frontier_getsymbols
		if (var(VAR_RESULT) != 2) {
			msgbox(BattleFrontier_BattlePyramidTop_Text_BrandonRemarkableHaveThis, MSGBOX_DEFAULT)
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattlePyramidTop_Text_BraveSymbolTookGoldenShine)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattlePyramidTop_Text_FarewellForNow, MSGBOX_DEFAULT)
		}
		goto(BattleFrontier_BattlePyramidTop_EventScript_WarpToLobbyWon)
    }
    goto(BattleFrontier_BattlePyramid_EventScript_WarpToLobbyLost)
}

script BattleFrontier_BattlePyramidTop_EventScript_DoBrandonBattle {
    closemessage
    dofacilitytrainerbattle(FACILITY_BATTLE_PYRAMID)
    waitstate
    return
}

text BattleFrontier_BattlePyramidTop_Text_ReachedSummitUpYouGo {
	"It is a delight to see you here!
	You have reached the summit of
	the BATTLE PYRAMID!

	Above here is the PYRAMID's
	lookout point.

	It is a place open only to those
	who have conquered the PYRAMID.

	Now, please!
	Up you go!"
}

text BattleFrontier_BattlePyramidTop_Text_PlayerConqueredPyramid {
	"The PYRAMID's new conqueror!
	Let the name {PLAYER} be known!"
}

text BattleFrontier_BattlePyramidTop_Text_ChiefBeatYouHere {
	"It is a delight to see you here!

	Unfortunately, you were second by
	a mere fraction of time!

	Our chief has already conquered
	the PYRAMID ahead of you.

	However, my young explorer…
	You are a TRAINER!

	Assert your power and take the glory
	of the pinnacle from our chief!

	Now, please! When you are ready,
	take one more step of courage!"
}

text BattleFrontier_BattlePyramidTop_Text_ExplorationsAreGrandestAdventure {
	"Young adventurer…

	Wouldn't you agree that explorations
	are the grandest of adventures?

	Your own wits!

	Your own strength!

	Your own POKéMON!

	And, above all, only your own courage
	to lead you through unknown worlds…"
}

text BattleFrontier_BattlePyramidTop_Text_ImPyramidKingBrandon {
	"Aah, yes, indeed this life is grand!
	Grand, it is! Eh?

	I'm BRANDON!

	I'm the PYRAMID KING, which means
	I'm in charge here.

	Most people call me the chief!

	You coming here means you have
	that much confidence in yourself,
	am I right?

	Hahahah!
	This should be exciting!"
}

text BattleFrontier_BattlePyramidTop_Text_BringCourageToOurBattle {
	"Now, then!
	Bring your courage to our battle!"
}

text BattleFrontier_BattlePyramidTop_Text_BrandonFrontierPassPlease {
	"BRANDON: Hahahah! Grand it was!
	Grand, yes, indeed!

	Well done! You've earned recognition!
	Your FRONTIER PASS, please!"
}

text BattleFrontier_BattlePyramidTop_Text_ReceivedBraveSymbol {
	"The Brave Symbol was embossed on
	the FRONTIER PASS!"
}

text BattleFrontier_BattlePyramidTop_Text_LookForwardToNextMeeting {
	"Young explorer!
	I look forward to our next meeting!"
}

text BattleFrontier_BattlePyramidTop_Text_BrandonYouveReturned {
	"BRANDON: …You've finally returned,
	young explorer…

	Your love of adventure seems to come
	deep from within your heart…

	Yes… You are exactly as I was in
	my own youth…

	… … …Ah…

	The passionate!

	The dangerous!

	The desperate!

	Those days of death-defying,
	life-affirming adventures are back…"
}

text BattleFrontier_BattlePyramidTop_Text_MyCourageIsOffMeter {
	"Now, then!

	I sense my own courage is off
	the meter!"
}

text BattleFrontier_BattlePyramidTop_Text_EverythingYouHave {
	"Everything you have!
	I'm braced for it all!"
}

text BattleFrontier_BattlePyramidTop_Text_BrandonRemarkableHaveThis {
	"BRANDON: Hahahah!
	Remarkable!
	Yes, it's grand, indeed!

	Young explorer!

	You've bested me through and through!
	Here! I want you to have this!"
}

text BattleFrontier_BattlePyramidTop_Text_BraveSymbolTookGoldenShine {
	"The Brave Symbol took on
	a golden shine!"
}

text BattleFrontier_BattlePyramidTop_Text_FarewellForNow {
	"Ah, yes! It just goes to show that
	I have much to learn still!

	May our paths cross again!
	Farewell for now, young explorer!"
}

text BattleFrontier_BattlePyramidTop_Text_StepForwardWhenReady {
	"Now, when you are ready, take courage
	and step forward."
}
