mapscripts TwoIsland_JoyfulGameCorner_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (flag(FLAG_GOT_MOON_STONE_FROM_JOYFUL_GAME_CORNER)) {
			setobjectxyperm(LOCALID_JOYFUL_GAME_CORNER_DADDY, 6, 2)
			setobjectmovementtype(LOCALID_JOYFUL_GAME_CORNER_DADDY, MOVEMENT_TYPE_FACE_DOWN)
			setobjectmovementtype(LOCALID_JOYFUL_GAME_CORNER_LOSTELLE, MOVEMENT_TYPE_LOOK_AROUND)
			setvar(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 4)
		}
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 2 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    	VAR_CABLE_CLUB_STATE, USING_MINIGAME: EventScript_CheckTurnAttendant_Frlg
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 0: TwoIsland_JoyfulGameCorner_EventScript_HelpFindLostelleScene
		VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 2: TwoIsland_JoyfulGameCorner_EventScript_FoundLostelleScene
		VAR_CABLE_CLUB_STATE, USING_MINIGAME: CableClub_EventScript_ExitMinigameRoom
    ]
    MAP_SCRIPT_ON_LOAD: CableClub_OnLoad_Frlg
}

script TwoIsland_JoyfulGameCorner_EventScript_FoundLostelleScene {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(TwoIsland_JoyfulGameCorner_Text_YouRescuedLostelle)
    textcolor(NPC_TEXT_COLOR_FEMALE)
    special(GetPlayerBigGuyGirlString)
    msgbox(TwoIsland_JoyfulGameCorner_Text_LostelleItsOkayDaddy)
    closemessage
    applymovement(LOCALID_JOYFUL_GAME_CORNER_LOSTELLE, Common_Movement_StepFasterDown)
    waitmovement(0)
    setvar(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 3)
    releaseall
    end
}

script TwoIsland_JoyfulGameCorner_EventScript_HelpFindLostelleScene {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_DADDY, moves(walk_left,  walk_right * 2,  delay_8,  step_faster_up,  delay_16))
    waitmovement(0)
    msgbox(TwoIsland_JoyfulGameCorner_Text_WhereHasLostelleGottenTo)
    closemessage
    applymovement(LOCALID_JOYFUL_GAME_CORNER_DADDY, Common_Movement_StepFasterDown)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_DADDY, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_DADDY, Common_Movement_Delay48)
    waitmovement(0)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_DADDY, moves(walk_down * 3,  step_faster_left))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    msgbox(TwoIsland_JoyfulGameCorner_Text_PleaseHelpFindLostelle)
    closemessage
    playse(SE_DOOR)
    waitse
    applymovement(LOCALID_PLAYER, moves(walk_left,  step_faster_right))
    waitmovement(0)
    playbgm(MUS_RG_ENCOUNTER_BOY, 0)
    addobject(LOCALID_JOYFUL_GAME_CORNER_BIKER)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_BIKER, moves(step_faster_left,  delay_8,  step_faster_right,  delay_8,  step_faster_up))
    waitmovement(0)
    msgbox(TwoIsland_JoyfulGameCorner_Text_IsThisOnlyThreeIsland)
    applymovement(LOCALID_JOYFUL_GAME_CORNER_BIKER, Common_Movement_StepFasterRight)
    waitmovement(0)
    msgbox(TwoIsland_JoyfulGameCorner_Text_ThisIsTwoIslandMoveIt)
    msgbox(TwoIsland_JoyfulGameCorner_Text_TheseIslandsAreConfusing)
    closemessage
    applymovement(LOCALID_JOYFUL_GAME_CORNER_BIKER, Common_Movement_StepFasterDown)
    waitmovement(0)
    playse(SE_EXIT)
    removeobject(LOCALID_JOYFUL_GAME_CORNER_BIKER)
    fadedefaultbgm
    delay(60)
    msgbox(TwoIsland_JoyfulGameCorner_Text_PunkScuffedUpMyFloor)
    clearflag(FLAG_HIDE_THREE_ISLAND_LONE_BIKER)
    setvar(VAR_MAP_SCENE_THREE_ISLAND, 2)
    setvar(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER, 1)
    releaseall
    end
}

script TwoIsland_JoyfulGameCorner_EventScript_InfoMan {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER) == 4) {
        goto(JoyfulGameCorner_EventScript_InfoMan2_Frlg)
    }
    elif (flag(FLAG_RESCUED_LOSTELLE)) {
        msgbox(TwoIsland_JoyfulGameCorner_Text_GetGamesGoingSoon)
    	release_end
    }
    msgbox(TwoIsland_JoyfulGameCorner_Text_NotRunningAnyGamesToday)
    release_end
}

// Only referred to as Lostelles Daddy in text
script TwoIsland_JoyfulGameCorner_EventScript_LostellesDaddy {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER) == 4) {
        goto(JoyfulGameCorner_EventScript_MinigameAttendant_Frlg)
    }
    elif (flag(FLAG_GOT_MOON_STONE_FROM_JOYFUL_GAME_CORNER)) {
        msgbox(TwoIsland_JoyfulGameCorner_Text_IllGetGameCornerRunning)
    	release_end
    }
    elif (var(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER) == 3) {
        goto(TwoIsland_JoyfulGameCorner_EventScript_GiveDaddyMeteorite)
    }
    msgbox(TwoIsland_JoyfulGameCorner_Text_PleaseGoToThreeIsland)
    release_end
}

script TwoIsland_JoyfulGameCorner_EventScript_GiveDaddyMeteorite {
    if (!flag(FLAG_NO_ROOM_FOR_JOYFUL_GAME_CORNER_MOON_STONE)) {
        msgbox(TwoIsland_JoyfulGameCorner_Text_ThisIsForMe)
		setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 2)
		textcolor(NPC_TEXT_COLOR_NEUTRAL)
		playfanfare(MUS_OBTAIN_TMHM)
		message(TwoIsland_JoyfulGameCorner_Text_HandedMeteoriteToLostellesDaddy)
		waitmessage
		waitfanfare
		call(EventScript_RestorePrevTextColor)
		removeitem(ITEM_METEORITE)
		msgbox(TwoIsland_JoyfulGameCorner_Text_OhThisIsFromBill)
    }
    if (checkitemspace(ITEM_MOON_STONE) == FALSE) {
        setflag(FLAG_NO_ROOM_FOR_JOYFUL_GAME_CORNER_MOON_STONE)
		msgbox(TwoIsland_JoyfulGameCorner_Text_NotGoingToFitInBag)
		release_end
    }
    additem(ITEM_MOON_STONE)
    setflag(FLAG_GOT_MOON_STONE_FROM_JOYFUL_GAME_CORNER)
    msgreceiveditem(TwoIsland_JoyfulGameCorner_Text_ReceivedMoonStoneFromLostellesDaddy, ITEM_MOON_STONE)
    release_end
}

script TwoIsland_JoyfulGameCorner_EventScript_Lostelle {
    lock_faceplayer
    msgbox(TwoIsland_JoyfulGameCorner_Text_PleaseShowMeYouBeingCool)
    release_end
}

text TwoIsland_JoyfulGameCorner_Text_WhereHasLostelleGottenTo {
	"Now, where's LOSTELLE gotten to
	today?

	She always brings me lunch every
	day right about now…"
}

text TwoIsland_JoyfulGameCorner_Text_PleaseHelpFindLostelle {
	"Hm? You, there!
	Are you a friend of LOSTELLE's?

	Have you seen LOSTELLE around?
	I don't know where she might be.
	She should've been here long ago.

	LOSTELLE's a cutie - she got my
	looks - so what if someone…

	What if something's happened to
	my LOSTELLE?!

	Please, help me find her!
	Please go search THREE ISLAND!"
}

text TwoIsland_JoyfulGameCorner_Text_IsThisOnlyThreeIsland {
	"Hah? What is this GAME CORNER?
	How much sadder can this get?

	Those clowns…

	They said they'd be waiting on the
	island, so where are they?

	Hey, you! Is this the only THREE
	ISLAND around here?"
}

text TwoIsland_JoyfulGameCorner_Text_ThisIsTwoIslandMoveIt {
	"Try waking up before you crawl out
	of bed, you punk.

	This is TWO ISLAND!

	Move it! Get your filthy motorbike
	out of my place!"
}

text TwoIsland_JoyfulGameCorner_Text_TheseIslandsAreConfusing {
	"Huh…
	Oh, oh, gotcha.

	Tch…
	These islands are confusing…"
}

text TwoIsland_JoyfulGameCorner_Text_PunkScuffedUpMyFloor {
	"Would you look at that?
	That punk scuffed up my floor."
}

text TwoIsland_JoyfulGameCorner_Text_PleaseGoToThreeIsland {
	"Hey, but listen! I'm begging you,
	you have to go to THREE ISLAND.

	If anything were to happen to my
	LOSTELLE…

	My place is the house with the red
	roof on THREE ISLAND.

	She may just show up late here,
	so I can't run off anywhere.

	That's why I have to get you to do
	me this big favor."
}

text TwoIsland_JoyfulGameCorner_Text_NotRunningAnyGamesToday {
	"I'm sorry.
	We're not running any games today."
}

text TwoIsland_JoyfulGameCorner_Text_GetGamesGoingSoon {
	"We'll get the games going soon
	for you!"
}

text TwoIsland_JoyfulGameCorner_Text_YouRescuedLostelle {
	"So you rescued LOSTELLE?
	How can I thank you?

	LOSTELLE, darling, forgive me!

	Daddy didn't know you were scared
	and in trouble!"
}

text TwoIsland_JoyfulGameCorner_Text_LostelleItsOkayDaddy {
	"LOSTELLE: It's okay, Daddy.
	I got to be friends with {PLAYER}!"
}

text TwoIsland_JoyfulGameCorner_Text_ThisIsForMe {
	"Oh, what's that?
	You're saying that this is for me?

	How did you know that I love rare
	rocks and gems?

	You sure know how to make a guy
	happy."
}

text TwoIsland_JoyfulGameCorner_Text_HandedMeteoriteToLostellesDaddy {
	"{PLAYER} handed the METEORITE
	to LOSTELLE's daddy."
}

text TwoIsland_JoyfulGameCorner_Text_OhThisIsFromBill {
	"Oh, I see, this is from BILL!
	You have to thank him for me!

	You know, you've been fantastic.
	I want you to have this."
}

text TwoIsland_JoyfulGameCorner_Text_ReceivedMoonStoneFromLostellesDaddy {
	"{PLAYER} received a MOON STONE
	from LOSTELLE's daddy."
}

text TwoIsland_JoyfulGameCorner_Text_NotGoingToFitInBag {
	"Your BAG's not going to fit another
	thing…"
}

text TwoIsland_JoyfulGameCorner_Text_IllGetGameCornerRunning {
	"All right, I'll get the GAME CORNER
	running right away.

	You have to come visit with a
	friend."
}

text TwoIsland_JoyfulGameCorner_Text_PleaseShowMeYouBeingCool {
	"Listen, listen!

	Please show me you being cool
	again!"
}
