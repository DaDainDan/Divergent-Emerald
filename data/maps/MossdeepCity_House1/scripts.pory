mapscripts MossdeepCity_House1_MapScripts {}

script MossdeepCity_House1_EventScript_BlackBelt {
    lock_faceplayer
    bufferleadmonspeciesname(STR_VAR_1)
    msgbox(MossdeepCity_House1_Text_HmmYourPokemon, MSGBOX_DEFAULT)
    if (specialvar(VAR_RESULT, GetPokeblockNameByMonNature) == 0) {
		msgbox(MossdeepCity_House1_Text_DoesntLikeOrDislikePokeblocks, MSGBOX_DEFAULT)
    	release_end
	}
    msgbox(MossdeepCity_House1_Text_ItLikesXPokeblocks, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_House1_EventScript_Woman {
    msgbox(MossdeepCity_House1_Text_HusbandCanTellPokeblockMonLikes, MSGBOX_NPC)
    end
}

text MossdeepCity_House1_Text_HmmYourPokemon {
	"Hmm!
	Your {STR_VAR_1}…"
}

text MossdeepCity_House1_Text_ItLikesXPokeblocks {
	"It likes {STR_VAR_1}S,
	doesn't it?

	No, I'm positive of it! It definitely
	likes {STR_VAR_1}S!"
}

text MossdeepCity_House1_Text_DoesntLikeOrDislikePokeblocks {
	"It doesn't appear to like or dislike
	any {POKEBLOCK}S."
}

text MossdeepCity_House1_Text_HusbandCanTellPokeblockMonLikes {
	"My husband can tell what kind of
	{POKEBLOCK}S a POKéMON likes at a glance."
}
