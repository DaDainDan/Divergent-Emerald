mapscripts BattleFrontier_BattleDomePreBattleRoom_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattleDomePreBattleRoom_EventScript_EnterRoom
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
    		turnobject(LOCALID_PLAYER, DIR_NORTH)
    		end
		}
    ]
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_EnterRoom {
    if (var(VAR_0x8006) == 1) {
        goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ReturnFromBattle)
    }
    delay(1)
    frontier_set(FRONTIER_DATA_RECORD_DISABLED, TRUE)
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_PLAYER, moves(walk_up * 4))
    waitmovement(0)
    lockall
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    switch (var(VAR_RESULT)) {
        case DOME_ROUND1: message(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForRound1)
        case DOME_ROUND2: message(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForRound2)
        case DOME_SEMIFINAL: message(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForSemifinals)
        case DOME_FINAL: call(BattleFrontier_BattleDomePreBattleRoom_EventScript_ReadyForFinals)
    }
    waitmessage
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRoundNoRecord)
    }
    multichoice(16, 0, MULTI_TOURNEY_WITH_RECORD, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowOpponentInfo)
        case 1: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowTourneyTree)
        case 2: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ContinueChallenge)
        case 3: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskRecordBattle)
        case 4: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskPauseChallenge)
        case 5: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    }
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRoundNoRecord {
    multichoice(16, 2, MULTI_TOURNEY_NO_RECORD, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowOpponentInfo)
        case 1: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowTourneyTree)
        case 2: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_ContinueChallenge)
        case 3: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskPauseChallenge)
        case 4: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskRetireChallenge)
        case MULTI_B_PRESSED: goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    }
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_AskRecordBattle {
    message(BattleFrontier_BattleDomePreBattleRoom_Text_RecordLastMatch)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		call(BattleFrontier_EventScript_SaveBattle)
	}
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        message(BattleFrontier_BattleDomePreBattleRoom_Text_SavingDataPleaseWait)
 		waitmessage
    	dome_save(CHALLENGE_STATUS_PAUSED)
    	playse(SE_SAVE)
    	waitse
    	fadescreen(FADE_TO_BLACK)
    	frontier_reset
    } else {
        goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    }
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattleDomePreBattleRoom_Text_RetireYourChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    if (var(VAR_RESULT) == 0) {
        dome_resolvewinners(DOME_PLAYER_RETIRED)
    	goto(BattleFrontier_BattleDomeBattleRoom_EventScript_WarpToLobbyLost)
    }
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowOpponentInfo {
    msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_PlayersNextOpponentIsTrainer, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    dome_showopponentinfo
    waitstate
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_ShowTourneyTree {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    switch (var(VAR_RESULT)) {
        case DOME_ROUND1: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_TourneyInRound1, MSGBOX_DEFAULT)
        case DOME_ROUND2: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_TourneyInRound2, MSGBOX_DEFAULT)
        case DOME_SEMIFINAL: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_TourneyInSemifinals, MSGBOX_DEFAULT)
        case DOME_FINAL: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_TourneyInFinals, MSGBOX_DEFAULT)
    }
    fadescreen(FADE_TO_BLACK)
    dome_showtourneytree
    waitstate
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_ContinueChallenge {
    message(BattleFrontier_BattleDomePreBattleRoom_Text_ChooseTwoMons)
    waitmessage
    waitbuttonpress
    fadescreen(FADE_TO_BLACK)
    frontier_get(FRONTIER_DATA_LVL_MODE)
    copyvar(VAR_0x8004, VAR_RESULT)
    setvar(VAR_0x8005, DOME_BATTLE_PARTY_SIZE)
    special(ChoosePartyForBattleFrontier)
    frontier_resetsketch
    if (var(VAR_RESULT) == 0) {
        goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    }
    dome_set(DOME_DATA_SELECTED_MONS)
    dome_reduceparty
    dome_setopponent
    msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_RightThisWay, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_DOME_PRE_BATTLE_ATTENDANT, moves(walk_right,  face_left))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
    waitmovement(0)
    opendoor(5, 1)
    waitdooranim
    applymovement(LOCALID_PLAYER, moves(walk_up,  set_invisible))
    waitmovement(0)
    closedoor(5, 1)
    waitdooranim
    warp(MAP_BATTLE_FRONTIER_BATTLE_DOME_BATTLE_ROOM, 9, 5)
    setvar(VAR_TEMP_0, 0)
    waitstate
    end
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_ReadyForFinals {
    frontier_getbrainstatus
    switch (var(VAR_RESULT)) {
        case FRONTIER_BRAIN_SILVER:
		case FRONTIER_BRAIN_STREAK:
			if (flag(FLAG_TEMP_1)) {
				msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForTuckerSilverShort, MSGBOX_DEFAULT)
			} else {
                msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForTuckerSilver, MSGBOX_DEFAULT)
			    setflag(FLAG_TEMP_1)
            }
        case FRONTIER_BRAIN_GOLD:
        case FRONTIER_BRAIN_STREAK_LONG:
			if (flag(FLAG_TEMP_1)) {
				msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForTuckerGoldShort, MSGBOX_DEFAULT)
			} else {
                msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForTuckerGold, MSGBOX_DEFAULT)
			    setflag(FLAG_TEMP_1)
            }
        default: message(BattleFrontier_BattleDomePreBattleRoom_Text_ReadyForFinals)
    }
    return
}

script BattleFrontier_BattleDomePreBattleRoom_EventScript_ReturnFromBattle {
    setvar(VAR_TEMP_0, 1)
    msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_RestoreMonsToFullHealth, MSGBOX_DEFAULT)
    special(LoadPlayerParty)
    frontier_setpartyorder(FRONTIER_PARTY_SIZE)
    playfanfare(MUS_HEAL)
    waitfanfare
    special(HealPlayerParty)
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    switch (var(VAR_RESULT)) {
        case DOME_ROUND2: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_Round1Complete, MSGBOX_DEFAULT)
        case DOME_SEMIFINAL: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_Round2Complete, MSGBOX_DEFAULT)
        case DOME_FINAL: msgbox(BattleFrontier_BattleDomePreBattleRoom_Text_SemifinalsComplete, MSGBOX_DEFAULT)
    }
    fadescreen(FADE_TO_BLACK)
    dome_showstatictourneytree
    waitstate
    goto(BattleFrontier_BattleDomePreBattleRoom_EventScript_AskReadyForNextRound)
    end
}

