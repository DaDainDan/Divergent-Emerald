script BattleFrontier_BattleTowerLobby_EventScript_NotEnoughValidMons {
	if (var(VAR_RESULT) == FRONTIER_LVL_50) {
		switch (var(VAR_FRONTIER_BATTLE_MODE)) {
			case FRONTIER_MODE_SINGLES: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLv50Singles, MSGBOX_DEFAULT)
			case FRONTIER_MODE_DOUBLES: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLv50Doubles, MSGBOX_DEFAULT)
			default: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLv50Multis, MSGBOX_DEFAULT)
		}
	}
	elif (var(VAR_RESULT) == FRONTIER_LVL_OPEN) {
		switch (var(VAR_FRONTIER_BATTLE_MODE)) {
			case FRONTIER_MODE_SINGLES: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLvOpenSingles, MSGBOX_DEFAULT)
			case FRONTIER_MODE_DOUBLES: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLvOpenDoubles, MSGBOX_DEFAULT)
			default: msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsLvOpenMultis, MSGBOX_DEFAULT)
		}
	}
	call(BattleFrontier_ShowCaughtBannedSpecies)
    msgbox(BattleFrontier_BattleTowerLobby_Text_NotEnoughValidMonsEnd, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_BattleTowerLobby_EventScript_CancelChallengeSaveFailed {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS) // No status provided, so it relies on VAR_0x8006 being 0 already
    goto(BattleFrontier_BattleTowerLobby_EventScript_CancelChallenge)
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_LoadPartyCancelChallenge {
    special(LoadPlayerParty)
    callnative(UpdateFollowingPokemon)
    goto(BattleFrontier_BattleTowerLobby_EventScript_CancelChallenge)
}

script BattleFrontier_BattleTowerLobby_EventScript_CancelChallenge {
    special(CloseLink)
    msgbox(BattleFrontier_BattleTowerLobby_Text_LookForwardToAnotherChallenge, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_BattleTowerLobby_EventScript_EnterElevator {
    special(SavePlayerParty)
    setvar(VAR_0x8004, FRONTIER_UTIL_FUNC_SET_PARTY_ORDER)
    switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: setvar(VAR_0x8005, FRONTIER_PARTY_SIZE)
		case FRONTIER_MODE_DOUBLES: setvar(VAR_0x8005, FRONTIER_DOUBLES_PARTY_SIZE)
		case FRONTIER_MODE_MULTIS: setvar(VAR_0x8005, FRONTIER_MULTI_PARTY_SIZE)
		case FRONTIER_MODE_LINK_MULTIS: setvar(VAR_0x8005, FRONTIER_MULTI_PARTY_SIZE)
	}
    special(CallFrontierUtilFunc)
    setvar(VAR_RESULT, 0)
    goto(BattleFrontier_BattleTowerLobby_EventScript_WaitForLinkOpponentLoad)
	end
}

script BattleFrontier_BattleTowerLobby_EventScript_WaitForLinkOpponentLoad {
    tower_loadlinkopponents
    delay(1)
    if (var(VAR_RESULT) != 6) {
        goto(BattleFrontier_BattleTowerLobby_EventScript_WaitForLinkOpponentLoad)
    }
    switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: bufferstdstring(STR_VAR_1, STDSTRING_SINGLE)
		case FRONTIER_MODE_DOUBLES: bufferstdstring(STR_VAR_1, STDSTRING_DOUBLE)
		case FRONTIER_MODE_MULTIS: bufferstdstring(STR_VAR_1, STDSTRING_MULTI)
		case FRONTIER_MODE_LINK_MULTIS: bufferstdstring(STR_VAR_1, STDSTRING_MULTI_LINK)
	}
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        messageautoscroll(BattleFrontier_BattleTowerLobby_Text_ShowYouToBattleRoom)
		waitmessage
		delay(48)
    } else {
		msgbox(BattleFrontier_BattleTowerLobby_Text_ShowYouToBattleRoom, MSGBOX_DEFAULT)
	}
    closemessage
    switch (var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_SINGLES: 
			setvar(VAR_LAST_TALKED, LOCALID_TOWER_ATTENDANT_SINGLES)
			setvar(VAR_0x8004, 6)
		case FRONTIER_MODE_DOUBLES: 
			setvar(VAR_LAST_TALKED, LOCALID_TOWER_ATTENDANT_DOUBLES)
			setvar(VAR_0x8004, 10)
		case FRONTIER_MODE_MULTIS: 
			setvar(VAR_LAST_TALKED, LOCALID_TOWER_ATTENDANT_MULTIS)
			setvar(VAR_0x8004, 14)
		case FRONTIER_MODE_LINK_MULTIS: 
			setvar(VAR_LAST_TALKED, LOCALID_TOWER_ATTENDANT_LINK_MULTIS)
			setvar(VAR_0x8004, 18)
	}
    applymovement(VAR_LAST_TALKED, moves(walk_up * 3))
    applymovement(LOCALID_PLAYER, moves(walk_up * 3))
    waitmovement(0)
    opendoor(VAR_0x8004, 1)
    waitdooranim
    applymovement(VAR_LAST_TALKED, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    closedoor(VAR_0x8004, 1)
    waitdooranim
    clearflag(FLAG_CANCEL_BATTLE_ROOM_CHALLENGE)
    warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_ELEVATOR, 1, 6)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    waitstate
    end
}

// Unused
movement BattleFrontier_BattleTowerLobby_Movement_UnusedEnterElevator {
    // moves(run_up * 5,  set_invisible)
    run_up * 5
    set_invisible
}

script BattleFrontier_BattleTowerLobby_EventScript_TryCableLink {
    setvar(VAR_0x8004, USING_BATTLE_TOWER)
    message(gText_PleaseWaitForLink)
    waitmessage
    setvar(VAR_0x8005, 0)
    special(TryBattleLinkup)
	switch (var(VAR_RESULT)) {
		case LINKUP_SUCCESS: goto(BattleFrontier_BattleTowerLobby_EventScript_CableLinkSuccessful)
		case LINKUP_SOMEONE_NOT_READY: goto(CableClub_EventScript_AbortLinkSomeoneNotReady)
		case LINKUP_DIFF_SELECTIONS: goto(BattleFrontier_BattleTowerLobby_EventScript_AbortLinkDifferentSelections)
		case LINKUP_WRONG_NUM_PLAYERS: goto(BattleFrontier_BattleTowerLobby_EventScript_AbortLinkIncorrectNumberOfPlayers)
		case LINKUP_FAILED: goto(BattleFrontier_BattleTowerLobby_EventScript_CancelChallenge)
		case LINKUP_CONNECTION_ERROR: goto(CableClub_EventScript_AbortLinkConnectionError)
		case LINKUP_FAILED_BATTLE_TOWER: goto(BattleFrontier_BattleTowerLobby_EventScript_AbortLink)
	}
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_AbortLinkDifferentSelections {
    special(CloseLink)
	if (var(VAR_0x8005) == 3) {
		msgbox(BattleFrontier_BattleTowerLobby_Text_FriendChoseDifferentLvlMode, MSGBOX_DEFAULT)
		msgbox(BattleFrontier_BattleTowerLobby_Text_ChooseDifferentMonsMatchLvlMode, MSGBOX_DEFAULT)
		release_end
	}
	msgbox(Text_PlayersMadeDifferentSelections, MSGBOX_DEFAULT)
	release_end
}

script BattleFrontier_BattleTowerLobby_EventScript_AbortLinkIncorrectNumberOfPlayers {
    msgbox(BattleFrontier_BattleTowerLobby_Text_LinkMultiOnlyForTwoPlayers, MSGBOX_DEFAULT)
	special(CloseLink)
	msgbox(CableClub_Text_IncorrectNumberOfParticipants, MSGBOX_DEFAULT)
	release_end
}

script BattleFrontier_BattleTowerLobby_EventScript_AbortLink {
    special(CloseLink)
	switch (var(VAR_0x8005)) {
		case 0: msgbox(BattleFrontier_BattleTowerLobby_Text_FriendChoseDifferentLvlMode, MSGBOX_DEFAULT)
		case 1: msgbox(BattleFrontier_BattleTowerLobby_Text_FriendAlsoSelectedMon, MSGBOX_DEFAULT)
		case 2: msgbox(BattleFrontier_BattleTowerLobby_Text_FriendAlsoSelectedMons, MSGBOX_DEFAULT)
		default: msgbox(BattleFrontier_BattleTowerLobby_Text_ChooseDifferentMonsMatchLvlMode, MSGBOX_DEFAULT)
	}
    release_end
}

script BattleFrontier_BattleTowerLobby_EventScript_CableLinkSuccessful {
    incrementgamestat(GAME_STAT_ENTERED_BATTLE_TOWER)
    setvar(VAR_BRAVO_TRAINER_BATTLE_TOWER_ON, FALSE)
    message(BattleFrontier_BattleTowerLobby_Text_SaveGameBeforeShowingIn)
    waitmessage
    tower_save(CHALLENGE_STATUS_SAVING)
    special(SaveForBattleTowerLink)
    playse(SE_SAVE)
    waitse
    special(TrySetBattleTowerLinkType)
    goto(BattleFrontier_BattleTowerLobby_EventScript_EnterElevator)
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_TryWirelessLink {
	setvar(VAR_0x8004, LINK_GROUP_BATTLE_TOWER)
	goto(BattleFrontier_BattleTowerLobby_EventScript_ChooseLeader)
	end
}

script BattleFrontier_BattleTowerLobby_EventScript_ChooseLeader {
    message(CableClub_Text_ChooseGroupLeaderOfTwo)
    waitmessage
    multichoice(16, 6, MULTI_LINK_LEADER, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(BattleFrontier_BattleTowerLobby_EventScript_TryJoinGroup)
        case 1: goto(BattleFrontier_BattleTowerLobby_EventScript_TryBecomeLeader)
        case 2:
        case MULTI_B_PRESSED: 
			goto(BattleFrontier_BattleTowerLobby_EventScript_CancelChallenge)
    }
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_TryBecomeLeader {
    call(CableClub_EventScript_TryBecomeLinkLeader)
	switch (var(VAR_RESULT)) {
		case LINKUP_SUCCESS: goto(BattleFrontier_BattleTowerLobby_EventScript_WirelessLinkSuccessful)
		case LINKUP_FAILED: goto(BattleFrontier_BattleTowerLobby_EventScript_ChooseLeader)
		case LINKUP_RETRY_ROLE_ASSIGN: goto(BattleFrontier_BattleTowerLobby_EventScript_TryBecomeLeader)
		case LINKUP_FAILED_BATTLE_TOWER: goto(BattleFrontier_BattleTowerLobby_EventScript_AbortLink)
	}
    release
    return
}

script BattleFrontier_BattleTowerLobby_EventScript_TryJoinGroup {
    call(CableClub_EventScript_TryJoinLinkGroup)
	switch (var(VAR_RESULT)) {
		case LINKUP_SUCCESS: goto(BattleFrontier_BattleTowerLobby_EventScript_WirelessLinkSuccessful)
		case LINKUP_FAILED: goto(BattleFrontier_BattleTowerLobby_EventScript_ChooseLeader)
		case LINKUP_RETRY_ROLE_ASSIGN: goto(BattleFrontier_BattleTowerLobby_EventScript_TryJoinGroup)
		case LINKUP_FAILED_BATTLE_TOWER: goto(BattleFrontier_BattleTowerLobby_EventScript_AbortLink)
	}
    release
    return
}

script BattleFrontier_BattleTowerLobby_EventScript_WirelessLinkSuccessful {
    incrementgamestat(GAME_STAT_ENTERED_BATTLE_TOWER)
    setvar(VAR_BRAVO_TRAINER_BATTLE_TOWER_ON, FALSE)
    message(BattleFrontier_BattleTowerLobby_Text_SaveGameBeforeShowingIn)
    waitmessage
    tower_save(CHALLENGE_STATUS_SAVING)
    special(SaveForBattleTowerLink)
    playse(SE_SAVE)
    waitse
    goto(BattleFrontier_BattleTowerLobby_EventScript_EnterElevator)
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_RulesBoard {
    lockall
    msgbox(BattleFrontier_BattleTowerLobby_Text_RulesAreListed, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard)
    end
}

script BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard {
    message(BattleFrontier_BattleTowerLobby_Text_ReadWhichHeading)
    waitmessage
    multichoice(17, 2, MULTI_BATTLE_TOWER_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_BattleTowerLobby_Text_ExplainTowerRules, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_BattleTowerLobby_Text_ExplainMonRules, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_BattleTowerLobby_Text_ExplainSalonRules, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_BattleTowerLobby_Text_ExplainMultiLinkRules, MSGBOX_DEFAULT)
        case 4:
        case MULTI_B_PRESSED:
			releaseall
			end
    }
	goto(BattleFrontier_BattleTowerLobby_EventScript_ReadRulesBoard)
    end
}

