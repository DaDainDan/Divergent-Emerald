mapscripts FallarborTown_MoveRelearnersHouse_MapScripts {}

script FallarborTown_MoveRelearnersHouse_EventScript_MoveRelearner {
    lockall
    applymovement(LOCALID_MOVE_RELEARNER, Common_Movement_FacePlayer)
    waitmovement(0)
    if (flag(FLAG_MOVE_RELEARNER)) {
        msgbox(FallarborTown_MoveRelearnersHouse_Text_GoOnYourWay, MSGBOX_DEFAULT)
        releaseall
        end
    }
    if (!flag(FLAG_TEMP_1)) {
        msgbox(FallarborTown_MoveRelearnersHouse_Text_ImTheMoveTutor, MSGBOX_DEFAULT)
    	setflag(FLAG_TEMP_1)
    }
    if (checkitem(ITEM_HEART_SCALE) == FALSE) {
        goto(FallarborTown_MoveRelearnersHouse_EventScript_ComeBackWithHeartScale)
    } else {
        if (checkitem(ITEM_HEART_SCALE, 10) == FALSE) {
            msgbox(FallarborTown_MoveRelearnersHouse_Text_ThatsAStart, MSGBOX_DEFAULT)
        } else {
            msgbox(FallarborTown_MoveRelearnersHouse_Text_OkayIllTeachYou, MSGBOX_DEFAULT)
            removeitem(ITEM_HEART_SCALE, 10)
            message(FallarborTown_MoveRelearnersHouse_Text_HandedOverHeartScale)
            waitmessage
            setflag(FLAG_MOVE_RELEARNER)
            playfanfare(MUS_LEVEL_UP)
            waitfanfare
            msgbox(FallarborTown_MoveRelearnersHouse_Text_AreYouEnlightened, MSGBOX_DEFAULT)
        }
    }
    releaseall
    end
}

script FallarborTown_MoveRelearnersHouse_EventScript_ChooseMon {
    msgbox(FallarborTown_MoveRelearnersHouse_Text_TutorWhichMon, MSGBOX_DEFAULT)
    setmoverelearnerstate(MOVE_RELEARNER_LEVEL_UP_MOVES) // Specifically supposed to teach level up moves
    chooseboxmon(SELECT_PC_MON_MOVE_RELEARNER)
    waitstate
    if (var(VAR_0x8004) == PARTY_NOTHING_CHOSEN) {
        goto(FallarborTown_MoveRelearnersHouse_EventScript_ComeBackWithHeartScale)
    }
    special(IsSelectedMonEgg)
    if (var(VAR_RESULT) == TRUE) {
        msgbox(FallarborTown_MoveRelearnersHouse_Text_CantTeachEgg, MSGBOX_DEFAULT)
    	goto(FallarborTown_MoveRelearnersHouse_EventScript_ChooseMon)
    }
    special(Special_HasMoveToRelearn)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(FallarborTown_MoveRelearnersHouse_Text_DontHaveMoveToTeachPokemon, MSGBOX_DEFAULT)
    	goto(FallarborTown_MoveRelearnersHouse_EventScript_ChooseMon)
    }
    goto(FallarborTown_MoveRelearnersHouse_EventScript_ChooseMove)
    end
}

script FallarborTown_MoveRelearnersHouse_EventScript_ChooseMove {
    msgbox(FallarborTown_MoveRelearnersHouse_Text_TeachWhichMove, MSGBOX_DEFAULT)
    special(TeachMoveRelearnerMove)
    if (var(VAR_RESULT) == FALSE) {
        goto(FallarborTown_MoveRelearnersHouse_EventScript_ChooseMon)
    }
    msgbox(FallarborTown_MoveRelearnersHouse_Text_HandedOverHeartScale, MSGBOX_DEFAULT)
    removeitem(ITEM_HEART_SCALE)
    goto(FallarborTown_MoveRelearnersHouse_EventScript_ComeBackWithHeartScale)
    end
}

script FallarborTown_MoveRelearnersHouse_EventScript_ComeBackWithHeartScale {
    msgbox(FallarborTown_MoveRelearnersHouse_Text_ComeBackWithHeartScale, MSGBOX_DEFAULT)
    releaseall
    end
}

text FallarborTown_MoveRelearnersHouse_Text_ImTheMoveTutor {
	"I'm the MOVE RELEARNER.

	I know how to unlock the memory of
    any POKéMON and allow them to remember
    any move they've forgotten.

	I sometimes teach my techniques to
    other trainers, but one must prove
    themselves to become my pupil.

	Bring me 10 HEART SCALES, and I might
    consider teaching you my method."
}

text FallarborTown_MoveRelearnersHouse_Text_ThatsAHeartScaleWantMeToTeachMove {
	"Oh! That's it! That's an honest to
	goodness HEART SCALE!

	Let me guess, you want me to teach
	a move?"
}

text FallarborTown_MoveRelearnersHouse_Text_TutorWhichMon {
	"Which POKéMON needs tutoring?"
}

text FallarborTown_MoveRelearnersHouse_Text_TeachWhichMove {
	"Which move should I teach?"
}

text FallarborTown_MoveRelearnersHouse_Text_DontHaveMoveToTeachPokemon {
	"Sorry…

	It doesn't appear as if I have any move
	I can teach that POKéMON."
}

text FallarborTown_MoveRelearnersHouse_Text_HandedOverHeartScale {
	"{PLAYER} offered 10 HEART SCALES."
}

text FallarborTown_MoveRelearnersHouse_Text_ComeBackWithHeartScale {
	"Why are you even talking to me when you
    haven't found a single HEART SCALE?
    
    Get out there and find one, or get lost."
}

text FallarborTown_MoveRelearnersHouse_Text_CantTeachEgg {
	"Hunh? There isn't a single move that
	I can teach an EGG."
}

text FallarborTown_MoveRelearnersHouse_Text_ThatsAStart {
	"Ah, yes.
    That's a HEART SCALE.
    
    However, you don't have enough yet.

    Keep looking for more if you ever want
    to learn my masterful techniques."
}

text FallarborTown_MoveRelearnersHouse_Text_OkayIllTeachYou {
	"Oh, baby! That's a lot of HEART SCALES!
    
    You've done well, pupil.
    
    I will now teach you the secrets of
    move relearning."
}

text FallarborTown_MoveRelearnersHouse_Text_AreYouEnlightened {
	"Do you feel enlightened now, pupil?
    
    I'm sure you do.

    You can now reteach any move that a
    POKéMON has forgotten."
}

text FallarborTown_MoveRelearnersHouse_Text_GoOnYourWay {
	"I don't have anything more to teach,
    so be a good pupil and go on your way."
}
