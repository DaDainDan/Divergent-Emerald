mapscripts Route124_DivingTreasureHuntersHouse_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_LANDMARK_HUNTERS_HOUSE)
    	end
    }
}

script Route124_DivingTreasureHuntersHouse_EventScript_TreasureHunter {
    lock_faceplayer
    if (flag(FLAG_MET_DIVING_TREASURE_HUNTER)) {
        msgbox(Route124_DivingTreasureHuntersHouse_Text_HaveYouSeenAnyShards, MSGBOX_DEFAULT)
    } else {
		msgbox(Route124_DivingTreasureHuntersHouse_Text_Greeting, MSGBOX_DEFAULT)
    	setflag(FLAG_MET_DIVING_TREASURE_HUNTER)
	}
    goto(Route124_DivingTreasureHuntersHouse_EventScript_CheckPlayerHasShard)
    end
}

script Route124_DivingTreasureHuntersHouse_EventScript_CheckPlayerHasShard {
    if (checkitem(ITEM_RED_SHARD) == TRUE || checkitem(ITEM_YELLOW_SHARD) == TRUE || checkitem(ITEM_BLUE_SHARD) == TRUE || checkitem(ITEM_GREEN_SHARD) == TRUE) {
		msgbox(Route124_DivingTreasureHuntersHouse_Text_ThatsAShardIllTradeYou, MSGBOX_DEFAULT)
    	goto(Route124_DivingTreasureHuntersHouse_EventScript_ShowTradeOptions)
	} else {
        msgbox(Route124_DivingTreasureHuntersHouse_Text_YouHaventGotAnyShards, MSGBOX_DEFAULT)
    }
    release_end
}

script Route124_DivingTreasureHuntersHouse_EventScript_GetPlayersShards {
    
    return
}

script Route124_DivingTreasureHuntersHouse_EventScript_ShowTradeOptions {
    message(Route124_DivingTreasureHuntersHouse_Text_WhatDoYouWantToTrade)
    waitmessage
	if (checkitem(ITEM_RED_SHARD) == TRUE) {
		dynmultipush("RED SHARD", ITEM_RED_SHARD)
    }
    if (checkitem(ITEM_YELLOW_SHARD) == TRUE) {
		dynmultipush("YELLOW SHARD", ITEM_YELLOW_SHARD)
    }
    if (checkitem(ITEM_BLUE_SHARD) == TRUE) {
		dynmultipush("BLUE SHARD", ITEM_BLUE_SHARD)
    }
    if (checkitem(ITEM_GREEN_SHARD) == TRUE) {
		dynmultipush("GREEN SHARD", ITEM_GREEN_SHARD)
    }
	dynmultipush("EXIT", 0)
    dynmultistack(0, 0, FALSE, 5, FALSE, 0, DYN_MULTICHOICE_CB_SHOW_ITEM)
	switch (var(VAR_RESULT)) {
		case ITEM_RED_SHARD: settradeitems(ITEM_RED_SHARD, ITEM_FIRE_STONE)
		case ITEM_YELLOW_SHARD: settradeitems(ITEM_YELLOW_SHARD, ITEM_THUNDER_STONE)
		case ITEM_BLUE_SHARD: settradeitems(ITEM_BLUE_SHARD, ITEM_WATER_STONE)
		case ITEM_GREEN_SHARD: settradeitems(ITEM_GREEN_SHARD, ITEM_LEAF_STONE)
		case 0:
		case MULTI_B_PRESSED: 
			goto(Route124_DivingTreasureHuntersHouse_EventScript_DeclineTrade)
	}
	goto(Route124_DivingTreasureHuntersHouse_EventScript_TryTradeShard)
    end
}

script Route124_DivingTreasureHuntersHouse_EventScript_TryTradeShard {
    bufferitemname(STR_VAR_1, VAR_EXCHANGE_ITEM)
    bufferitemname(STR_VAR_2, VAR_GIFT_ITEM)
    msgbox(Route124_DivingTreasureHuntersHouse_Text_YoullTradeShardForStone, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(Route124_DivingTreasureHuntersHouse_EventScript_DeclineTrade)
    }
    if (checkitemspace(VAR_GIFT_ITEM) == TRUE || checkitem(VAR_EXCHANGE_ITEM, 2) == FALSE) {
        removeitem(VAR_EXCHANGE_ITEM)
		giveitem(VAR_GIFT_ITEM)
		msgbox(Route124_DivingTreasureHuntersHouse_Text_ItsADeal, MSGBOX_DEFAULT)
		if (checkitem(ITEM_RED_SHARD) == TRUE || checkitem(ITEM_YELLOW_SHARD) == TRUE || checkitem(ITEM_BLUE_SHARD) == TRUE || checkitem(ITEM_GREEN_SHARD) == TRUE) {
			msgbox(Route124_DivingTreasureHuntersHouse_Text_TradeSomethingElse, MSGBOX_YESNO)
			if (var(VAR_RESULT) == YES) {
				goto(Route124_DivingTreasureHuntersHouse_EventScript_ShowTradeOptions)
			}
			goto(Route124_DivingTreasureHuntersHouse_EventScript_DeclineTrade)
		}
    }
    msgbox(Route124_DivingTreasureHuntersHouse_Text_BagFull, MSGBOX_DEFAULT)
    release_end
}

script Route124_DivingTreasureHuntersHouse_EventScript_DeclineTrade {
    msgbox(Route124_DivingTreasureHuntersHouse_Text_ComeBackIfYouChangeMind, MSGBOX_DEFAULT)
    release_end
}

script Route124_DivingTreasureHuntersHouse_EventScript_ShardTradeBoard {
    msgbox(Route124_DivingTreasureHuntersHouse_Text_ShardTradeBoard, MSGBOX_SIGN)
    end
}

text Route124_DivingTreasureHuntersHouse_Text_Greeting {
	"I'm the DIVING TREASURE HUNTER!

	I'm the awesome dude who makes
	deep-sea dives to gather treasures
	resting at the bottom."
}

text Route124_DivingTreasureHuntersHouse_Text_HaveYouSeenAnyShards {
	"Tell me, have you seen any SHARDS of
	tools made in ancient times?"
}

text Route124_DivingTreasureHuntersHouse_Text_YouHaventGotAnyShards {
	"You haven't got any treasures
	for me…

	If you see any SHARDS, like the RED
	SHARD, you've got to trade it with me!"
}

text Route124_DivingTreasureHuntersHouse_Text_ThatsAShardIllTradeYou {
	"Oh, hey! That…
	That's a SHARD! I'm looking for those!

	Oh, man, you've got to trade that
	with me! I'll give you something good!"
}

text Route124_DivingTreasureHuntersHouse_Text_WhatDoYouWantToTrade {
	"What do you want to trade?"
}

text Route124_DivingTreasureHuntersHouse_Text_YoullTradeShardForStone {
	"You'll trade your {STR_VAR_1} for
	my {STR_VAR_2}, then?"
}

text Route124_DivingTreasureHuntersHouse_Text_ItsADeal {
	"It's a done deal!
	Use that wisely!"
}

text Route124_DivingTreasureHuntersHouse_Text_TradeSomethingElse {
	"Do you want to trade something else?"
}

text Route124_DivingTreasureHuntersHouse_Text_BagFull {
	"Whoops, your BAG's full.
	Get rid of some items, friend!"
}

text Route124_DivingTreasureHuntersHouse_Text_ComeBackIfYouChangeMind {
	"No? That's a downer.
	Well, if you change your mind, come back."
}

