	"{CLEAR_TO 10}Wanted item{CLEAR_TO 124}Trade item
	{CLEAR_TO 15}RED SHARD{CLEAR_TO 89}{LEFT_ARROW}{RIGHT_ARROW}{CLEAR_TO 123}FIRE STONE{CLEAR_TO 200}

	{CLEAR_TO 10}Wanted item{CLEAR_TO 124}Trade item
	{CLEAR_TO 6}YELLOW SHARD{CLEAR_TO 89}{LEFT_ARROW}{RIGHT_ARROW}{CLEAR_TO 115}THUNDERSTONE{CLEAR_TO 200}

	{CLEAR_TO 10}Wanted item{CLEAR_TO 124}Trade item
	{CLEAR_TO 12}BLUE SHARD{CLEAR_TO 89}{LEFT_ARROW}{RIGHT_ARROW}{CLEAR_TO 121}WATER STONE{CLEAR_TO 200}

	{CLEAR_TO 10}Wanted item{CLEAR_TO 124}Trade item
	{CLEAR_TO 8}GREEN SHARD{CLEAR_TO 89}{LEFT_ARROW}{RIGHT_ARROW}{CLEAR_TO 123}LEAF STONE"
}
