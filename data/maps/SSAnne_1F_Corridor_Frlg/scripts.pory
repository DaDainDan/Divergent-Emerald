mapscripts SSAnne_1F_Corridor_Frlg_MapScripts {}

script SSAnne_1F_Corridor_EventScript_WorkerM {
    msgbox(SSAnne_1F_Corridor_Text_LeStrongSilentType, MSGBOX_NPC)
    end
}

script SSAnne_1F_Corridor_EventScript_Sailor {
    msgbox(SSAnne_1F_Corridor_Text_PassengersAreRestless, MSGBOX_NPC)
    end
}

text SSAnne_1F_Corridor_Text_LeStrongSilentType {
	"Bonjour!
	I am le waiter on this ship!

	I will be happy to serve you
	anything you please!

	… … …
	Ah! Le strong silent type!"
}

text SSAnne_1F_Corridor_Text_PassengersAreRestless {
	"The passengers are restless from
	this long voyage.

	You might be challenged by the
	more bored ones!"
}
