mapscripts TrainerTower_Elevator_Frlg_MapScripts {
    MAP_SCRIPT_ON_RESUME: TrainerTower_OnResume
    MAP_SCRIPT_ON_FRAME_TABLE: TrainerTower_OnFrame
}

script TrainerTower_Elevator_EventScript_FloorSelect {
    lockall
    setvar(VAR_0x8004, 6)
    if (!flag(FLAG_TEMP_2)) {
        call(EventScript_GetElevatorFloor)
    }
    copyvar(VAR_0x8005, VAR_ELEVATOR_FLOOR)
    special(DrawElevatorCurrentFloorWindow)
    message(gText_WantWhichFloor)
    waitmessage
    setvar(VAR_0x8004, 6)
    specialvar(VAR_RESULT, InitElevatorFloorSelectMenuPos)
    switch (var(VAR_RESULT)) {
        case 0: multichoicedefault(0, 0, MULTI_ROOFTOP_B1F, 0, FALSE)
        case 1: multichoicedefault(0, 0, MULTI_ROOFTOP_B1F, 1, FALSE)
    }
	if (var(VAR_RESULT) == 1) {
		setvar(VAR_0x8006, 3)
		setdynamicwarp(MAP_TRAINER_TOWER_LOBBY, 17, 8)
		if (var(VAR_ELEVATOR_FLOOR) == 3) {
			goto(TrainerTower_Elevator_EventScript_CloseFloorSelect)
		}
		special(CloseElevatorCurrentFloorWindow)
		closemessage
		waitse
		special(AnimateElevator)
		waitstate
		setflag(FLAG_TEMP_2)
		setvar(VAR_ELEVATOR_FLOOR, 3)
		special(CloseElevatorCurrentFloorWindow)
		delay(25)
		applymovement(LOCALID_PLAYER, moves(step_faster_down,  delay_16,  walk_down,  walk_right * 2,  walk_down))
		waitmovement(0)
		warp(MAP_TRAINER_TOWER_LOBBY, 17, 8)
		waitstate
		releaseall
		end
	}
	goto(TrainerTower_Elevator_EventScript_CloseFloorSelect)
    end
}

script TrainerTower_Elevator_EventScript_CloseFloorSelect {
    special(CloseElevatorCurrentFloorWindow)
    releaseall
    end
}
