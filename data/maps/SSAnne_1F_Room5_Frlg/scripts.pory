mapscripts SSAnne_1F_Room5_Frlg_MapScripts {}

script SSAnne_1F_Room5_EventScript_Arthur {
    trainerbattle_single(TRAINER_GENTLEMAN_ARTHUR, SSAnne_1F_Room5_Text_ArthurIntro, SSAnne_1F_Room5_Text_ArthurDefeat)
    msgbox(SSAnne_1F_Room5_Text_ArthurPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SSAnne_1F_Room5_Text_ArthurIntro {
	"You insolent pup!
	How dare you barge in!"
}

text SSAnne_1F_Room5_Text_ArthurDefeat {
	"Humph! You rude child!
	You have no sense of courtesy!"
}

text SSAnne_1F_Room5_Text_ArthurPostBattle {
	"I wish to be left alone!
	Get out!"
}
