mapscripts SevenIsland_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_SEVEN_ISLAND)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script SevenIsland_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script SevenIsland_PokemonCenter_1F_EventScript_OldMan {
    msgbox(SevenIsland_PokemonCenter_1F_Text_EventsDependingOnConnections, MSGBOX_NPC)
    end
}

script SevenIsland_PokemonCenter_1F_EventScript_Sailor {
    msgbox(SevenIsland_PokemonCenter_1F_Text_DidYouRideSeagallopHere, MSGBOX_NPC)
    end
}

script SevenIsland_PokemonCenter_1F_EventScript_Beauty {
    msgbox(SevenIsland_PokemonCenter_1F_Text_CheckOutTrainerTower, MSGBOX_NPC)
    end
}

text SevenIsland_PokemonCenter_1F_Text_EventsDependingOnConnections {
	"On this island, different events
	occur depending on connections.

	What are those connections?

	They are for you to discover on
	your own."
}

text SevenIsland_PokemonCenter_1F_Text_DidYouRideSeagallopHere {
	"Did you ride a SEAGALLOP ferry
	to get here?

	There are at least ten of those
	high-speed ships.

	I don't know where they all go,
	though."
}

text SevenIsland_PokemonCenter_1F_Text_CheckOutTrainerTower {
	"If you're confident, you should
	check out TRAINER TOWER."
}
