text Route110_TrickHousePuzzle7_Text_WroteSecretCodeLockOpened {
	"{PLAYER} wrote down the secret code
	on the door.

	“TRICK MASTER is huggable.”
	… … … … … … … …

	The lock clicked open!"
}

text Route110_TrickHousePuzzle7_Text_JoshuaIntro {
	"The TRICK MASTER always vanishes
	like smoke. How does he do it?"
}

text Route110_TrickHousePuzzle7_Text_JoshuaDefeat {
	"Aiyeeeh! You're much too strong!
	How do you do it?"
}

text Route110_TrickHousePuzzle7_Text_JoshuaPostBattle {
	"I wish I could appear and disappear as
	if I were smoke, too."
}

text Route110_TrickHousePuzzle7_Text_PatriciaIntro {
	"Going around the same spot…
	It begets ill fortune…"
}

text Route110_TrickHousePuzzle7_Text_PatriciaDefeat {
	"Defeated!
	It's a bad sign…"
}

text Route110_TrickHousePuzzle7_Text_PatriciaPostBattle {
	"I've circled the same spot over ten
	times now… It's ill fortune…"
}

text Route110_TrickHousePuzzle7_Text_AlexisIntro {
	"Whoever wins will get through here
	first. That's the feeling I get."
}

text Route110_TrickHousePuzzle7_Text_AlexisDefeat {
	"Oh!
	Well, go ahead, then!"
}

text Route110_TrickHousePuzzle7_Text_AlexisPostBattle {
	"You're solving all the puzzles in the
	TRICK HOUSE. That's the feeling I get."
}

text Route110_TrickHousePuzzle7_Text_MarielaIntro {
	"Nufufufu, here at last!
	Let's get right with it!"
}

text Route110_TrickHousePuzzle7_Text_MarielaDefeat {
	"You're so casual about winning!"
}

text Route110_TrickHousePuzzle7_Text_MarielaPostBattle {
	"Humph! I'm not upset!
	Not me!"
}

text Route110_TrickHousePuzzle7_Text_AlvaroIntro {
	"I ever so closely watched you coming!"
}

text Route110_TrickHousePuzzle7_Text_AlvaroDefeat {
	"This outcome I didn't see coming…"
}

text Route110_TrickHousePuzzle7_Text_AlvaroPostBattle {
	"Well, anyway, we both picked a weird
	place to get acquainted.

	As one weirdo to another,
	let's do our best!"
}

text Route110_TrickHousePuzzle7_Text_EverettIntro {
	"It's awfully cramped in here…"
}

text Route110_TrickHousePuzzle7_Text_EverettDefeat {
	"Oh, yes, strong you are."
}

text Route110_TrickHousePuzzle7_Text_EverettPostBattle {
	"I was hoping to switch places with you
	when I beat you, but…"
}
