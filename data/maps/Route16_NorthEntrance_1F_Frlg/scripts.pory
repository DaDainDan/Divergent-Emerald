mapscripts Route16_NorthEntrance_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        clearflag(FLAG_SYS_ON_CYCLING_ROAD)
		if (flag(FLAG_GOT_BICYCLE)) {
			setvar(VAR_TEMP_1, 1)
		}
		end
    }
}

script Route16_NorthEntrance_1F_EventScript_Guard {
    msgbox(Route16_NorthEntrance_1F_Text_CyclingRoadIsDownhillCourse, MSGBOX_NPC)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTriggerTop {
    lockall
    setvar(VAR_0x8008, 0)
    goto(Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTriggerMidTop {
    lockall
    setvar(VAR_0x8008, 1)
    goto(Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTriggerMid {
    lockall
    setvar(VAR_0x8008, 2)
    goto(Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTriggerMidBottom {
    lockall
    setvar(VAR_0x8008, 3)
    goto(Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTriggerBottom {
    lockall
    setvar(VAR_0x8008, 4)
    goto(Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route16_NorthEntrance_1F_EventScript_NeedBikeTrigger {
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(Route16_NorthEntrance_1F_Text_ExcuseMeWaitUp)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    delay(20)
	switch (var(VAR_0x8008)) {
		case 1: applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
		case 2: applymovement(LOCALID_PLAYER, moves(walk_up * 2))
		case 3: applymovement(LOCALID_PLAYER, moves(walk_up * 3))
		case 4: applymovement(LOCALID_PLAYER, moves(walk_up * 4))
	}
    msgbox(Route16_NorthEntrance_1F_Text_NoPedestriansOnCyclingRoad)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkRight)
    waitmovement(0)
    releaseall
    end
}

script Route16_NorthEntrance_1F_EventScript_OldMan {
    msgbox(Route16_NorthEntrance_1F_Text_HowdYouGetInGoodEffort, MSGBOX_NPC)
    end
}

text Route16_NorthEntrance_1F_Text_NoPedestriansOnCyclingRoad {
	"No pedestrians are allowed on
	CYCLING ROAD!"
}

text Route16_NorthEntrance_1F_Text_CyclingRoadIsDownhillCourse {
	"CYCLING ROAD is a downhill course
	by the sea. It's a great ride."
}

text Route16_NorthEntrance_1F_Text_ExcuseMeWaitUp {
	"Excuse me!
	Wait up, please!"
}

text Route16_NorthEntrance_1F_Text_HowdYouGetInGoodEffort {
	"How'd you get in?
	Good effort!"
}
