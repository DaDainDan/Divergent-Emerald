Route18_Frlg_MapScripts::
# 2 "data/maps/Route18_Frlg/scripts.pory"
	map_script MAP_SCRIPT_ON_TRANSITION, Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION
# 8 "data/maps/Route18_Frlg/scripts.pory"
	map_script MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE, Route18_Frlg_MapScripts_MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE
	.byte 0

Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION:
# 3 "data/maps/Route18_Frlg/scripts.pory"
	compare VAR_MAP_SCENE_ROUTE16, 1
	goto_if_eq Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION_2
Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION_1:
	end

Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION_2:
# 4 "data/maps/Route18_Frlg/scripts.pory"
	setflag FLAG_SYS_ON_CYCLING_ROAD
	goto Route18_Frlg_MapScripts_MAP_SCRIPT_ON_TRANSITION_1

Route18_Frlg_MapScripts_MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE:
# 9 "data/maps/Route18_Frlg/scripts.pory"
	map_script_2 VAR_MAP_SCENE_ROUTE16, 1, Route18_Frlg_MapScripts_MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE_0
	.2byte 0

Route18_Frlg_MapScripts_MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE_0:
# 10 "data/maps/Route18_Frlg/scripts.pory"
	special ForcePlayerOntoBike
	end


