mapscripts FiveIsland_House2_Frlg_MapScripts {}

script FiveIsland_House2_EventScript_OldMan {
    msgbox(FiveIsland_House2_Text_MeadowBelongedToFamily, MSGBOX_NPC)
    end
}

text FiveIsland_House2_Text_MeadowBelongedToFamily {
	"That MEADOW has belonged to our
	family for generations.

	I should have had a giant mansion
	built on it.

	It would be preferable to having
	those thugs run wild on it!"
}
