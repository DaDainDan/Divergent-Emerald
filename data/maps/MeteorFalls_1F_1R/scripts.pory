mapscripts MeteorFalls_1F_1R_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (flag(FLAG_BADGE08_GET)) {
			setmetatile(4, 1, METATILE_MeteorFalls_CaveEntrance_Top, TRUE)
			setmetatile(3, 2, METATILE_MeteorFalls_CaveEntrance_Left, TRUE)
			setmetatile(4, 2, METATILE_MeteorFalls_CaveEntrance_Bottom, FALSE)
			setmetatile(5, 2, METATILE_MeteorFalls_CaveEntrance_Right, TRUE)
		}
		end
    }
}

script MeteorFalls_1F_1R_EventScript_MagmaStealsMeteoriteScene {
    lockall
    playbgm(MUS_ENCOUNTER_MAGMA, FALSE)
    applymovement(LOCALID_PLAYER, Common_Movement_FaceDown)
    waitmovement(0)
    delay(30)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_StepDown)
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_WithThisMeteorite, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_StepFasterUp)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_2, Common_Movement_StepFasterUp)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_DontExpectMercyFromMagma, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, moves(walk_right * 2,  step_faster_up))
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_HoldItRightThereMagma, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_2, Common_Movement_StepFasterLeft)
    waitmovement(0)
    addobject(LOCALID_METEOR_FALLS_ARCHIE)
    addobject(LOCALID_METEOR_FALLS_AQUA_GRUNT_1)
    addobject(LOCALID_METEOR_FALLS_AQUA_GRUNT_2)
    playbgm(MUS_ENCOUNTER_AQUA, FALSE)
    applymovement(LOCALID_METEOR_FALLS_ARCHIE, moves(walk_right * 6))
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_1, moves(delay_16 * 2,  walk_right * 5))
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_2, moves(delay_16 * 2,  walk_right * 5))
    waitmovement(0)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_2, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_BeSeeingYouTeamAqua, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PLAYER, MeteorFalls_1F_1R_Movement_PushPlayerOutOfWay)
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1, moves(run_up * 2,  run_right * 7))
    applymovement(LOCALID_METEOR_FALLS_MAGMA_GRUNT_2, moves(run_up * 3,  run_right * 7))
    waitmovement(0)
    removeobject(LOCALID_METEOR_FALLS_MAGMA_GRUNT_1)
    removeobject(LOCALID_METEOR_FALLS_MAGMA_GRUNT_2)
    applymovement(LOCALID_METEOR_FALLS_ARCHIE, moves(walk_right * 2,  walk_up * 2,  step_faster_left))
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_ArchieSeenYouBefore, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_1, moves(walk_right * 3,  step_faster_up))
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_2, moves(walk_right * 3,  step_faster_up))
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_BossWeShouldChaseMagma, MSGBOX_DEFAULT)
    applymovement(LOCALID_METEOR_FALLS_ARCHIE, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_ArchieYesNoTellingWhatMagmaWillDo, MSGBOX_DEFAULT)
    applymovement(LOCALID_METEOR_FALLS_ARCHIE, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(MeteorFalls_1F_1R_Text_ArchieFarewell, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_METEOR_FALLS_ARCHIE, moves(walk_right * 7))
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_1, moves(walk_up * 2,  walk_right * 7))
    applymovement(LOCALID_METEOR_FALLS_AQUA_GRUNT_2, moves(walk_up * 3,  walk_right * 7))
    waitmovement(0)
    fadedefaultbgm
    removeobject(LOCALID_METEOR_FALLS_ARCHIE)
    removeobject(LOCALID_METEOR_FALLS_AQUA_GRUNT_1)
    removeobject(LOCALID_METEOR_FALLS_AQUA_GRUNT_2)
    setflag(FLAG_HIDE_ROUTE_112_TEAM_MAGMA)
    setflag(FLAG_MET_ARCHIE_METEOR_FALLS)
    setflag(FLAG_HIDE_FALLARBOR_TOWN_BATTLE_TENT_SCOTT)
    setvar(VAR_METEOR_FALLS_STATE, 1)
    releaseall
    end
}

movement MeteorFalls_1F_1R_Movement_PushPlayerOutOfWay {
    // moves(step_faster_down,  delay_4,  step_faster_right,  lock_look,  walk_left,  unlock_look,  face_right)
    step_faster_down
    delay_4
    step_faster_right
    lock_look
    walk_left
    unlock_look
    face_right
}

script MeteorFalls_1F_1R_EventScript_ProfCozmo {
    lock_faceplayer
    if (flag(FLAG_MET_PROF_COZMO)) {
        msgbox(MeteorFalls_1F_1R_Text_WhatsTeamMagmaDoingAtMtChimney, MSGBOX_DEFAULT)
    	release_end
    }
    setflag(FLAG_MET_PROF_COZMO)
    msgbox(MeteorFalls_1F_1R_Text_MeetProfCozmo, MSGBOX_DEFAULT)
    release_end
}

text MeteorFalls_1F_1R_Text_WithThisMeteorite {
	"Hehehe!

	With this METEORITE, that thing in
	MT. CHIMNEY will…"
}

text MeteorFalls_1F_1R_Text_DontExpectMercyFromMagma {
	"Heh?

	I don't know who you are, but if you get
	in the way of TEAM MAGMA, don't
	expect any mercy!"
}

text MeteorFalls_1F_1R_Text_HoldItRightThereMagma {
	"Hold it right there, TEAM MAGMA!

	You're badly mistaken if you think you
	can have your way with the world!"
}

text MeteorFalls_1F_1R_Text_BeSeeingYouTeamAqua {
	"Hehehe!
	Even TEAM AQUA joins us!

	But it's too much trouble to deal with
	you all…

	Heh, it doesn't matter!

	We've got the METEORITE, so off to
	MT. CHIMNEY we go!

	Hehehe! Be seeing you, you TEAM
	AQUA dingbats!"
}

text MeteorFalls_1F_1R_Text_ArchieSeenYouBefore {
	"{SPEAKER NAME_ARCHIE}Didn't I see you before?
	At SLATEPORT's MUSEUM?

	Ah, so your name is {PLAYER}.

	At the time, I thought you were one
	of TEAM MAGMA's goons.

	Humph…
	You're one odd kid.

	TEAM MAGMA is a dangerous group of
	total fanatics.

	They engage in destruction, claiming
	to expand the land mass.

	They are the rivals to us,
	the sea-loving TEAM AQUA!"
}

text MeteorFalls_1F_1R_Text_BossWeShouldChaseMagma {
	"BOSS, we should give chase to
	TEAM MAGMA…"
}

text MeteorFalls_1F_1R_Text_ArchieYesNoTellingWhatMagmaWillDo {
	"{SPEAKER NAME_ARCHIE}Yes, yes, we must!
	We've got to hurry.

	There's no telling what TEAM MAGMA
	will do at MT. CHIMNEY!"
}

text MeteorFalls_1F_1R_Text_ArchieFarewell {
	"{SPEAKER NAME_ARCHIE}{PLAYER}, you should keep
	an eye out for TEAM MAGMA, too.

	Farewell!"
}

text MeteorFalls_1F_1R_Text_MeetProfCozmo {
	"I… I'm COZMO…
	I'm a PROFESSOR…

	TEAM MAGMA asked me to guide them
	to METEOR FALLS…

	But they tricked me.
	They even took my METEORITE away…

	And then another similar bunch,
	TEAM AQUA showed up.

	After that…
	I don't understand any of it.

	But that TEAM MAGMA…

	What are they going to do with that
	METEORITE at MT. CHIMNEY?"
}

text MeteorFalls_1F_1R_Text_WhatsTeamMagmaDoingAtMtChimney {
	"{SPEAKER NAME_COZMO}But that TEAM MAGMA…

	What are they going to do with that
	METEORITE at MT. CHIMNEY?"
}
