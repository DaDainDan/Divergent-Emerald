mapscripts BattleFrontier_BattleArenaCorridor_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattleArenaCorridor_EventScript_WalkToBattleRoom
    ]
}

script BattleFrontier_BattleArenaCorridor_EventScript_WalkToBattleRoom {
    delay(16)
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_ARENA_CORRIDOR_ATTENDANT, moves(walk_left * 8,  walk_up * 8,  walk_right * 4))
    applymovement(LOCALID_PLAYER, moves(walk_up,  walk_left * 8,  walk_up * 8,  walk_right * 3))
    waitmovement(0)
    applymovement(LOCALID_ARENA_CORRIDOR_ATTENDANT, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(BattleFrontier_BattleArenaCorridor_Text_PleaseStepIn, MSGBOX_SIGN)
    applymovement(LOCALID_ARENA_CORRIDOR_ATTENDANT, moves(walk_up,  step_faster_down))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(walk_right,  set_invisible))
    waitmovement(0)
    setvar(VAR_0x8006, 0)
    warp(MAP_BATTLE_FRONTIER_BATTLE_ARENA_BATTLE_ROOM, 7, 5)
    waitstate
    end
}

text BattleFrontier_BattleArenaCorridor_Text_PleaseStepIn {
	"Your battles shall be waged in
	the next room. Please step in!"
}
