mapscripts AbandonedShip_Rooms_1F_MapScripts {}

script AbandonedShip_Rooms_1F_EventScript_Gentleman {
    msgbox(AbandonedShip_Rooms_1F_Text_TakingALookAround, MSGBOX_NPC)
    end
}

script AbandonedShip_Rooms_1F_EventScript_Demetrius {
    trainerbattle_single(TRAINER_DEMETRIUS, AbandonedShip_Rooms_1F_Text_DemetriusIntro, AbandonedShip_Rooms_1F_Text_DemetriusDefeat)
    msgbox(AbandonedShip_Rooms_1F_Text_DemetriusPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script AbandonedShip_Rooms_1F_EventScript_Thalia {
    trainerbattle_single(TRAINER_THALIA_1, AbandonedShip_Rooms_1F_Text_ThaliaIntro, AbandonedShip_Rooms_1F_Text_ThaliaDefeat, AbandonedShip_Rooms_1F_EventScript_RegisterThalia)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
		trainerbattle_rematch(TRAINER_THALIA_1, AbandonedShip_Rooms_1F_Text_ThaliaRematchIntro, AbandonedShip_Rooms_1F_Text_ThaliaRematchDefeat)
    	msgbox(AbandonedShip_Rooms_1F_Text_ThaliaPostRematch, MSGBOX_AUTOCLOSE)
    	end
	}
    msgbox(AbandonedShip_Rooms_1F_Text_ThaliaPostBattle, MSGBOX_DEFAULT)
    release_end
}

script AbandonedShip_Rooms_1F_EventScript_RegisterThalia {
    special(PlayerFaceTrainerAfterBattle)
    waitmovement(0)
    msgbox(AbandonedShip_Rooms_1F_Text_ThaliaRegister, MSGBOX_DEFAULT)
    register_matchcall(TRAINER_THALIA_1)
    release_end
}

text AbandonedShip_Rooms_1F_Text_TakingALookAround {
	"Ships of this sort are rare, so I'm
	taking a look around.

	Hmhm…
	There appear to be other cabins…"
}

text AbandonedShip_Rooms_1F_Text_ThaliaIntro {
	"What on earth would compel you to
	come here? You must be curious!"
}

text AbandonedShip_Rooms_1F_Text_ThaliaDefeat {
	"Not just curious, but also strong…"
}

text AbandonedShip_Rooms_1F_Text_ThaliaPostBattle {
	"The man next door…

	He says he's just sightseeing,
	but I don't know about that."
}

text AbandonedShip_Rooms_1F_Text_ThaliaRegister {
	"You're such a tough TRAINER!
	Let me register you as a memento!"
}

text AbandonedShip_Rooms_1F_Text_ThaliaRematchIntro {
	"What on earth would compel you to
	come back? You must really be curious!"
}

text AbandonedShip_Rooms_1F_Text_ThaliaRematchDefeat {
	"Aren't you too strong?"
}

text AbandonedShip_Rooms_1F_Text_ThaliaPostRematch {
	"I'm sure that man's up to something!
	He just acts so suspiciously!"
}

text AbandonedShip_Rooms_1F_Text_DemetriusIntro {
	"Waaah!
	I've been found! …Huh?"
}

text AbandonedShip_Rooms_1F_Text_DemetriusDefeat {
	"Oh, you're not my mom."
}

text AbandonedShip_Rooms_1F_Text_DemetriusPostBattle {
	"I'm in trouble with my mom, so I ran.
	Keep it a secret where I am!"
}
