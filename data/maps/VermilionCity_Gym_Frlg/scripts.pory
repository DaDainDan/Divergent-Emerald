script VermilionCity_Gym_EventScript_TrashCan {
    copyvar(SWITCH1_ID, VAR_TEMP_0)
    copyvar(SWITCH2_ID, VAR_TEMP_1)
    if (flag(FLAG_FOUND_BOTH_VERMILION_GYM_SWITCHES)) {
        msgbox(VermilionCity_Gym_Text_NopeOnlyTrashHere)
    }
    elif (flag(FOUND_FIRST_SWITCH)) {
        if (var(SWITCH2_ID) == TRASH_CAN_ID) {
			msgbox(VermilionCity_Gym_Text_SecondLockOpened)
			closemessage
			call(VermilionCity_Gym_EventScript_SetBeamsOff)
			special(DrawWholeMapView)
			playse(SE_UNLOCK)
			waitse
			setflag(FLAG_FOUND_BOTH_VERMILION_GYM_SWITCHES)
		}
		msgbox(VermilionCity_Gym_Text_OnlyTrashLocksWereReset)
		clearflag(FOUND_FIRST_SWITCH)
		special(SetVermilionTrashCans)
		copyvar(VAR_TEMP_0, SWITCH1_ID)
		copyvar(VAR_TEMP_1, SWITCH2_ID)
		call(VermilionCity_Gym_EventScript_SetBeamsOn)
		special(DrawWholeMapView)
    }
    elif (var(SWITCH1_ID) == TRASH_CAN_ID) {
        msgbox(VermilionCity_Gym_Text_SwitchUnderTrashFirstLockOpened)
		playse(SE_PIN)
		waitse
		call(VermilionCity_Gym_EventScript_SetOneBeamOff)
		special(DrawWholeMapView)
		setflag(FOUND_FIRST_SWITCH)
    }
	else {
		msgbox(VermilionCity_Gym_Text_NopeOnlyTrashHere)
	}
    releaseall
    end
}

script VermilionCity_Gym_EventScript_LtSurge {
    famechecker(FAMECHECKER_LTSURGE, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    trainerbattle_single(TRAINER_LEADER_LT_SURGE, VermilionCity_Gym_Text_LtSurgeIntro, VermilionCity_Gym_Text_LtSurgeDefeat, VermilionCity_Gym_EventScript_DefeatedLtSurge, NO_MUSIC)
    if (!flag(FLAG_GOT_TM34_FROM_SURGE)) {
        goto(VermilionCity_Gym_EventScript_GiveTM34)
    }
    msgbox(VermilionCity_Gym_Text_LtSurgePostBattle)
    release_end
}

script VermilionCity_Gym_EventScript_DefeatedLtSurge {
    famechecker(FAMECHECKER_LTSURGE, 1)
    if (!flag(FLAG_GOT_HM05)) {
        clearflag(FLAG_HIDE_VERMILION_CITY_OAKS_AIDE)
    }
    clearflag(FLAG_HIDE_FAME_CHECKER_LT_SURGE_JOURNAL)
    setflag(FLAG_DEFEATED_LT_SURGE)
    setflag(FLAG_BADGE03_GET)
    set_gym_trainers_frlg(3)
    goto(VermilionCity_Gym_EventScript_GiveTM34)
    end
}

script VermilionCity_Gym_EventScript_GiveTM34 {
    msgbox(VermilionCity_Gym_Text_ExplainThunderBadgeTakeThis)
    if (checkitemspace(ITEM_TM34) == FALSE) {
        msgbox(VermilionCity_Gym_Text_MakeRoomInYourBag)
    	release_end
    }
    giveitem_msg(VermilionCity_Gym_Text_ReceivedTM34FromLtSurge, ITEM_TM34)
    setflag(FLAG_GOT_TM34_FROM_SURGE)
    msgbox(VermilionCity_Gym_Text_ExplainTM34)
    release_end
}

script VermilionCity_Gym_EventScript_Dwayne {
    trainerbattle_single(TRAINER_SAILOR_DWAYNE, VermilionCity_Gym_Text_DwayneIntro, VermilionCity_Gym_Text_DwayneDefeat)
    famechecker(FAMECHECKER_LTSURGE, 4)
    msgbox(VermilionCity_Gym_Text_DwaynePostBattle, MSGBOX_AUTOCLOSE)
    end
}

script VermilionCity_Gym_EventScript_Baily {
    trainerbattle_single(TRAINER_ENGINEER_BAILY, VermilionCity_Gym_Text_BailyIntro, VermilionCity_Gym_Text_BailyDefeat)
    msgbox(VermilionCity_Gym_Text_BailyPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script VermilionCity_Gym_EventScript_Tucker {
    trainerbattle_single(TRAINER_GENTLEMAN_TUCKER, VermilionCity_Gym_Text_TuckerIntro, VermilionCity_Gym_Text_TuckerDefeat, VermilionCity_Gym_EventScript_DefeatedTucker)
    famechecker(FAMECHECKER_LTSURGE, 3)
    msgbox(VermilionCity_Gym_Text_TuckerPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script VermilionCity_Gym_EventScript_DefeatedTucker {
    famechecker(FAMECHECKER_LTSURGE, 2)
    release_end
}

script VermilionCity_Gym_EventScript_GymGuy {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_LT_SURGE)) {
        msgbox(VermilionCity_Gym_Text_GymGuyPostVictory)
    	release_end
    }
    msgbox(VermilionCity_Gym_Text_GymGuyAdvice)
    release_end
}

script VermilionCity_Gym_EventScript_GymStatue {
    lockall
    if (flag(FLAG_BADGE03_GET)) {
        msgbox(VermilionCity_Gym_Text_GymStatuePlayerWon)
    } else {
		msgbox(VermilionCity_Gym_Text_GymStatue)
	}
    releaseall
    end
}

text VermilionCity_Gym_Text_LtSurgeIntro {
	"Hey, kid! What do you think you're
	doing here?

	You won't live long in combat!
	Not with your puny power!

	I tell you, kid, electric POKéMON
	saved me during the war!

	They zapped my enemies into
	paralysis!

	The same as I'll do to you!{PLAY_BGM}{MUS_RG_ENCOUNTER_GYM_LEADER}"
}

text VermilionCity_Gym_Text_LtSurgePostBattle {
	"A little word of advice, kid!

	Electricity is sure powerful!

	But, it's useless against GROUND-
	type POKéMON!"
}

text VermilionCity_Gym_Text_ExplainThunderBadgeTakeThis {
	"The THUNDERBADGE cranks up your
	POKéMON's SPEED!

	It also lets your POKéMON FLY
	lightning-quick anytime, kid!

	You're special, kid!
	Take this!"
}

text VermilionCity_Gym_Text_ReceivedTM34FromLtSurge {
	"{PLAYER} received TM34
	from LT. SURGE."
}

text VermilionCity_Gym_Text_ExplainTM34 {
	"TM34 contains SHOCK WAVE!

	Teach it to an ELECTRIC POKéMON!"
}

text VermilionCity_Gym_Text_MakeRoomInYourBag {
	"Yo, kid, make room in your BAG!"
}

text VermilionCity_Gym_Text_LtSurgeDefeat {
	"Now that's a shocker!

	You're the real deal, kid!

	Fine, then, take the THUNDERBADGE!"
}

text VermilionCity_Gym_Text_TuckerIntro {
	"When I was in the Army, LT. SURGE
	was my strict CO.

	He was a hard taskmaster."
}

text VermilionCity_Gym_Text_TuckerDefeat {
	"Stop!
	You're very good!"
}

text VermilionCity_Gym_Text_TuckerPostBattle {
	"It's not easy opening that door.

	LT. SURGE was always famous for
	his cautious nature in the Army."
}

text VermilionCity_Gym_Text_BailyIntro {
	"I'm a lightweight, but I'm good
	with electricity!

	That's why I joined this GYM."
}

text VermilionCity_Gym_Text_BailyDefeat {
	"Fried!"
}

text VermilionCity_Gym_Text_BailyPostBattle {
	"Okay, I'll talk!

	LT. SURGE said he hid door
	switches inside something."
}

text VermilionCity_Gym_Text_DwayneIntro {
	"This is no place for kids!
	Not even if you're good!"
}

text VermilionCity_Gym_Text_DwayneDefeat {
	"Wow!
	Surprised me!"
}

text VermilionCity_Gym_Text_DwaynePostBattle {
	"LT. SURGE installed the traps in
	the GYM himself.

	He set up double locks everywhere.
	Let me give you a hint.

	When you open the first lock, the
	second lock is right next to it."
}

text VermilionCity_Gym_Text_GymGuyAdvice {
	"Yo!
	Champ in the making!

	LT. SURGE has a nickname.

	People refer to him as the
	Lightning American!

	He's an expert on electric
	POKéMON.

	BIRD/WATER-type POKéMON match
	poorly against the ELECTRIC type.

	Beware of paralysis, too.

	LT. SURGE is very cautious.

	He's locked himself in, so it won't
	be easy getting to him."
}

text VermilionCity_Gym_Text_GymGuyPostVictory {
	"Whew!
	That match was electric!"
}

text VermilionCity_Gym_Text_GymStatue {
	"VERMILION POKéMON GYM
	LEADER: LT. SURGE

	WINNING TRAINERS:
	{RIVAL}"
}

text VermilionCity_Gym_Text_GymStatuePlayerWon {
	"VERMILION POKéMON GYM
	LEADER: LT. SURGE

	WINNING TRAINERS:
	{RIVAL}, {PLAYER}"
}

text VermilionCity_Gym_Text_NopeOnlyTrashHere {
	"Nope!
	There's only trash here."
}

text VermilionCity_Gym_Text_SwitchUnderTrashFirstLockOpened {
	"Hey! There's a switch under the
	trash! Turn it on!

	The first electric lock opened!"
}

text VermilionCity_Gym_Text_SecondLockOpened {
	"The second electric lock opened!
	The motorized door opened!"
}

text VermilionCity_Gym_Text_OnlyTrashLocksWereReset {
	"Nope!
	There's only trash here.

	Hey!
	The electric locks were reset!"
}
