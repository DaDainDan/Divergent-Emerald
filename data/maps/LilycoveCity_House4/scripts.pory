mapscripts LilycoveCity_House4_MapScripts {}

script LilycoveCity_House4_EventScript_Man1 {
    msgbox(LilycoveCity_House4_Text_MysteriesAtBottomOfSea, MSGBOX_NPC)
    end
}

script LilycoveCity_House4_EventScript_Man2 {
    msgbox(LilycoveCity_House4_Text_UnderwaterTrenchMossdeepSootopolis, MSGBOX_NPC)
    end
}

text LilycoveCity_House4_Text_MysteriesAtBottomOfSea {
	"This planet's biggest mysteries are
	at the bottom of the sea.

	Somebody said that, but I don't know…"
}

text LilycoveCity_House4_Text_UnderwaterTrenchMossdeepSootopolis {
	"There's a deep underwater trench
	between MOSSDEEP and SOOTOPOLIS.

	That's what someone told me, anyway."
}
