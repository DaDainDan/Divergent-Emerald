mapscripts BattleFrontier_ReceptionGate_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_HAS_ENTERED_BATTLE_FRONTIER, 0 {
			lockall
    		setvar(VAR_HAS_ENTERED_BATTLE_FRONTIER, 1)
    		playse(SE_PIN)
    		applymovement(LOCALID_FRONTIER_RECEPTION_GREETER, Common_Movement_ExclamationMark)
    		waitmovement(0)
    		applymovement(LOCALID_FRONTIER_RECEPTION_GREETER, Common_Movement_Delay48)
    		waitmovement(0)
    		msgbox(BattleFrontier_ReceptionGate_Text_FirstTimeHereThisWay, MSGBOX_DEFAULT)
    		closemessage
    		applymovement(LOCALID_PLAYER, moves(walk_up * 2,  walk_left * 2))
    		waitmovement(0)
    		goto(BattleFrontier_ReceptionGate_EventScript_ScottScene)
    		end
		}
    ]
    MAP_SCRIPT_ON_TRANSITION {
		setflag(FLAG_LANDMARK_BATTLE_FRONTIER)
    	end
    }
}

script BattleFrontier_ReceptionGate_EventScript_ScottScene {
    msgbox(BattleFrontier_ReceptionGate_Text_WelcomeToBattleFrontier, MSGBOX_DEFAULT)
    msgbox(BattleFrontier_ReceptionGate_Text_IssueFrontierPass, MSGBOX_DEFAULT)
    playfanfare(MUS_OBTAIN_ITEM)
    message(BattleFrontier_ReceptionGate_Text_ObtainedFrontierPass)
    waitfanfare
    waitmessage
    msgbox(BattleFrontier_ReceptionGate_Text_PlacedTrainerCardInFrontierPass, MSGBOX_DEFAULT)
    setflag(FLAG_SYS_FRONTIER_PASS)
    msgbox(BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier, MSGBOX_DEFAULT)
    msgbox(BattleFrontier_ReceptionGate_Text_IfItIsntPlayerYouCame, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FRONTIER_RECEPTION_GREETER, Common_Movement_StepFasterUp)
    applymovement(LOCALID_FRONTIER_RECEPTION_GUIDE, Common_Movement_StepFasterUp)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_FRONTIER_RECEPTION_GREETER, Common_Movement_ExclamationMark)
    applymovement(LOCALID_FRONTIER_RECEPTION_GUIDE, Common_Movement_ExclamationMark)
    applymovement(LOCALID_PLAYER, Common_Movement_ExclamationMark)
    waitmovement(0)
    msgbox(BattleFrontier_ReceptionGate_Text_OhMrScottGoodDay, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FRONTIER_RECEPTION_GREETER, moves(delay_16 * 3,  delay_8,  step_faster_right))
    applymovement(LOCALID_FRONTIER_RECEPTION_GUIDE, moves(delay_16 * 3,  delay_8,  step_faster_left))
    applymovement(LOCALID_PLAYER, moves(delay_16 * 3,  delay_8,  step_faster_right))
    applymovement(LOCALID_FRONTIER_RECEPTION_SCOTT, moves(walk_down * 6,  walk_left))
    waitmovement(0)
    msgbox(BattleFrontier_ReceptionGate_Text_ScottGreatToSeeYouHere, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_FRONTIER_RECEPTION_SCOTT, moves(walk_right,  walk_up * 6))
    waitmovement(0)
    removeobject(LOCALID_FRONTIER_RECEPTION_SCOTT)
    releaseall
    end
}

// Unused
movement BattleFrontier_ReceptionGate_Movement_WalkDown {
    walk_down * 2
}

script BattleFrontier_ReceptionGate_EventScript_Greeter {
    lock_faceplayer
    msgbox(BattleFrontier_ReceptionGate_Text_WelcomeToBattleFrontier, MSGBOX_DEFAULT)
    msgbox(BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_ReceptionGate_EventScript_FacilityGuide {
    lock_faceplayer
    msgbox(BattleFrontier_ReceptionGate_Text_YourGuideToFacilities, MSGBOX_DEFAULT)
    goto(BattleFrontier_ReceptionGate_EventScript_ChooseFacilityToLearnAbout)
    end
}

script BattleFrontier_ReceptionGate_EventScript_ChooseFacilityToLearnAbout {
    message(BattleFrontier_ReceptionGate_Text_LearnAboutWhich2)
    waitmessage
    setvar(VAR_0x8004, SCROLL_MULTI_BF_RECEPTIONIST)
    special(ShowScrollableMultichoice)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_ReceptionGate_Text_BattleTowerInfo, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_ReceptionGate_Text_BattleDomeInfo, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_ReceptionGate_Text_BattlePalaceInfo, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_ReceptionGate_Text_BattleArenaInfo, MSGBOX_DEFAULT)
        case 4: msgbox(BattleFrontier_ReceptionGate_Text_BattleFactoryInfo, MSGBOX_DEFAULT)
        case 5: msgbox(BattleFrontier_ReceptionGate_Text_BattlePikeInfo, MSGBOX_DEFAULT)
        case 6: msgbox(BattleFrontier_ReceptionGate_Text_BattlePyramidInfo, MSGBOX_DEFAULT)
        case 7: msgbox(BattleFrontier_ReceptionGate_Text_RankingHallInfo, MSGBOX_DEFAULT)
        case 8: msgbox(BattleFrontier_ReceptionGate_Text_ExchangeCornerInfo, MSGBOX_DEFAULT)
        case 9:
        case MULTI_B_PRESSED:
			msgbox(BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier, MSGBOX_DEFAULT)
    		release_end
    }
	goto(BattleFrontier_ReceptionGate_EventScript_ChooseFacilityToLearnAbout)
    end
}

script BattleFrontier_ReceptionGate_EventScript_RulesGuide {
    lock_faceplayer
    msgbox(BattleFrontier_ReceptionGate_Text_YourGuideToRules, MSGBOX_DEFAULT)
    goto(BattleFrontier_ReceptionGate_EventScript_ChooseRuleToLearnAbout)
    end
}

script BattleFrontier_ReceptionGate_EventScript_ChooseRuleToLearnAbout {
    message(BattleFrontier_ReceptionGate_Text_LearnAboutWhat)
    waitmessage
    multichoice(15, 0, MULTI_FRONTIER_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_ReceptionGate_Text_LevelModeInfo, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_ReceptionGate_Text_Level50Info, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_ReceptionGate_Text_OpenLevelInfo, MSGBOX_DEFAULT)
        case 3: msgbox(BattleFrontier_ReceptionGate_Text_MonEntryInfo, MSGBOX_DEFAULT)
        case 4: msgbox(BattleFrontier_ReceptionGate_Text_HoldItemsInfo, MSGBOX_DEFAULT)
        case 5:
        case MULTI_B_PRESSED:
			msgbox(BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier, MSGBOX_DEFAULT)
            release_end
    }
	goto(BattleFrontier_ReceptionGate_EventScript_ChooseRuleToLearnAbout)
    end
}

script BattleFrontier_ReceptionGate_EventScript_FrontierPassGuide {
    lock_faceplayer
    msgbox(BattleFrontier_ReceptionGate_Text_YourGuideToFrontierPass, MSGBOX_DEFAULT)
    goto(BattleFrontier_ReceptionGate_EventScript_ChooseFrontierPassInfoToLearnAbout)
    end
}

script BattleFrontier_ReceptionGate_EventScript_ChooseFrontierPassInfoToLearnAbout {
    message(BattleFrontier_ReceptionGate_Text_LearnAboutWhich1)
    waitmessage
    multichoice(16, 4, MULTI_FRONTIER_PASS_INFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_ReceptionGate_Text_SymbolsInfo, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_ReceptionGate_Text_RecordedBattleInfo, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_ReceptionGate_Text_BattlePointsInfo, MSGBOX_DEFAULT)
        case 3:
        case MULTI_B_PRESSED:
			msgbox(BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier, MSGBOX_DEFAULT)
    		release_end
    }
	goto(BattleFrontier_ReceptionGate_EventScript_ChooseFrontierPassInfoToLearnAbout)
    end
}

text BattleFrontier_ReceptionGate_Text_FirstTimeHereThisWay {
	"Is it your first time here?
	Please step this way!"
}

text BattleFrontier_ReceptionGate_Text_WelcomeToBattleFrontier {
	"The front lines of POKéMON battling!
	Welcome to the BATTLE FRONTIER!"
}

text BattleFrontier_ReceptionGate_Text_IssueFrontierPass {
	"For a first-time visitor, we issue
	the FRONTIER PASS.

	It's for use at all the facilities
	in the BATTLE FRONTIER.

	Here you are!"
}

text BattleFrontier_ReceptionGate_Text_ObtainedFrontierPass {
	"{PLAYER} obtained
	the FRONTIER PASS."
}

text BattleFrontier_ReceptionGate_Text_PlacedTrainerCardInFrontierPass {
	"{PLAYER} placed the TRAINER CARD
	in the FRONTIER PASS."
}

text BattleFrontier_ReceptionGate_Text_EnjoyBattleFrontier {
	"We hope you enjoy all that the BATTLE
	FRONTIER has to offer!"
}

text BattleFrontier_ReceptionGate_Text_IfItIsntPlayerYouCame {
	"???: Well, if it isn't {PLAYER}{KUN}!
	You came out here!"
}

text BattleFrontier_ReceptionGate_Text_OhMrScottGoodDay {
	"{SPEAKER NAME_GUIDE}Oh! MR. SCOTT, sir!
	Good day to you, sir!"
}

text BattleFrontier_ReceptionGate_Text_ScottGreatToSeeYouHere {
	"{SPEAKER NAME_SCOTT}It's great to see you here,
	it really is!

	I hope you'll take your time and
	explore everywhere.

	Naturally, I hope you'll also experience
	the pure essence of battling.

	I also have my quarters here, so feel
	free to visit if you have time."
}

text BattleFrontier_ReceptionGate_Text_YourGuideToFacilities {
	"I'm your guide to the various facilities
	here in the BATTLE FRONTIER."
}

text BattleFrontier_ReceptionGate_Text_LearnAboutWhich2 {
	"Which would you like to learn about?"
}

text BattleFrontier_ReceptionGate_Text_BattleTowerInfo {
	"It is the gigantic tower considered
	to be the BATTLE FRONTIER's symbol.

	There are four kinds of BATTLE ROOMS
	in the tower for SINGLE, DOUBLE, MULTI,
	and LINK MULTI BATTLES."
}

text BattleFrontier_ReceptionGate_Text_BattleDomeInfo {
	"The BATTLE DOME is the large building
	shaped like a huge egg.

	Events named Battle Tourneys are held
	in this facility.

	The Battle Tourneys are offered in
	two courses--for SINGLE and DOUBLE
	BATTLES."
}

text BattleFrontier_ReceptionGate_Text_BattlePalaceInfo {
	"The BATTLE PALACE is the red building
	on the right of the BATTLE FRONTIER.

	There are two kinds of BATTLE HALLS
	for SINGLE and DOUBLE BATTLES."
}

text BattleFrontier_ReceptionGate_Text_BattleArenaInfo {
	"The BATTLE ARENA is the dojo-like
	building at the center-right of
	the BATTLE FRONTIER.

	An event called the Set KO Tourney
	takes place at the BATTLE ARENA."
}

text BattleFrontier_ReceptionGate_Text_BattleFactoryInfo {
	"The BATTLE FACTORY is the large
	building that is the closest to us.

	An event called the Battle Swap
	is conducted there.

	The Battle Swap event is offered in
	two courses for SINGLE and DOUBLE
	BATTLES."
}

text BattleFrontier_ReceptionGate_Text_BattlePikeInfo {
	"The BATTLE PIKE is the building shaped
	like a POKéMON at the center-left of
	the BATTLE FRONTIER.

	An event called the Battle Choice
	is conducted there."
}

text BattleFrontier_ReceptionGate_Text_BattlePyramidInfo {
	"The BATTLE PYRAMID is the enormous
	pyramid.

	An event called the Battle Quest
	is conducted there."
}

text BattleFrontier_ReceptionGate_Text_RankingHallInfo {
	"The RANKING HALL is located near
	the BATTLE TOWER.

	There, you may see the most fantastic
	records left by the TRAINERS that
	took on the many challenges of
	the BATTLE FRONTIER."
}

text BattleFrontier_ReceptionGate_Text_ExchangeCornerInfo {
	"The EXCHANGE SERVICE CORNER is near
	the BATTLE TOWER.

	The Battle Points you have earned in
	the BATTLE FRONTIER may be exchanged
	for fabulous prizes there."
}

text BattleFrontier_ReceptionGate_Text_YourGuideToRules {
	"I'm your guide to the basic rules that
	are common to all the challenges
	offered by the facilities in the BATTLE
	FRONTIER."
}

text BattleFrontier_ReceptionGate_Text_LearnAboutWhat {
	"What would you like to learn about?"
}

text BattleFrontier_ReceptionGate_Text_LevelModeInfo {
	"All the challenges at the BATTLE
	FRONTIER's facilities come in
	two courses--Level 50 and Open Level."
}

text BattleFrontier_ReceptionGate_Text_Level50Info {
	"The Level 50 course is open to POKéMON
	up to and including Level 50.

	Please keep in mind, however, that
	no TRAINER you face will have any
	POKéMON below Level 50.

	This course is the entry level for
	battles at the BATTLE FRONTIER.

	To begin, we hope you will challenge
	this course."
}

text BattleFrontier_ReceptionGate_Text_OpenLevelInfo {
	"The Open Level course places no limit
	on the levels of POKéMON entering
	challenges.

	The levels of your opponents will
	be adjusted to match the levels of
	your POKéMON.

	However, no TRAINER you face will
	have any POKéMON below Level 60."
}

text BattleFrontier_ReceptionGate_Text_MonEntryInfo {
	"Virtually any kind of POKéMON may take
	on the challenges at all facilities.

	EGGS and certain kinds of POKéMON,
	however, are not permitted.

	The numbers of POKéMON required for
	challenges will depend on the facility.

	At all facilities, however, two or more
	of the same kind of POKéMON are not
	permitted."
}

text BattleFrontier_ReceptionGate_Text_HoldItemsInfo {
	"When entering a challenge at a BATTLE
	FRONTIER facility, POKéMON may not
	be holding the same kind of item.

	Please make sure that all POKéMON
	entering a challenge are holding
	different items."
}

text BattleFrontier_ReceptionGate_Text_YourGuideToFrontierPass {
	"I'm your guide to the FRONTIER PASS."
}

text BattleFrontier_ReceptionGate_Text_LearnAboutWhich1 {
	"Which would you like to learn about?"
}

text BattleFrontier_ReceptionGate_Text_SymbolsInfo {
	"There are seven facilities at
	the BATTLE FRONTIER.

	TRAINERS who gain recognition for
	their abilities may be rewarded with
	symbols from each of the facilities.

	To earn a symbol, TRAINERS may need
	to defeat other TRAINERS in a row,
	and may need to win events repeatedly.

	It's certainly not easy to win symbols.
	I wish you the best of luck!"
}

text BattleFrontier_ReceptionGate_Text_RecordedBattleInfo {
	"It is possible to record one battle
	on your FRONTIER PASS.

	You may record a battle you had with
	a friend or friends.

	Or you may record a battle conducted
	at the BATTLE FRONTIER excluding
	matches at the BATTLE PIKE or
	the BATTLE PYRAMID.

	You may choose to record your match
	at the end of a battle."
}

text BattleFrontier_ReceptionGate_Text_BattlePointsInfo {
	"Battle Points are rewards given to
	TRAINERS who battled outstandingly
	at the BATTLE FRONTIER.

	You may trade in your Battle Points
	for prizes at the EXCHANGE SERVICE
	CORNER."
}
