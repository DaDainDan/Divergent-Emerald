mapscripts BattleFrontier_BattleTowerElevator_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattleTowerElevator_EventScript_EnterElevator
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script BattleFrontier_BattleTowerElevator_EventScript_EnterElevator {
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_TOWER_ELEVATOR_ATTENDANT, moves(walk_up,  walk_right,  face_down))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  face_down))
    waitmovement(0)
    special(BufferBattleTowerElevatorFloors)
    waitse
    special(MoveElevator)
    delay(48)
    applymovement(LOCALID_TOWER_ELEVATOR_ATTENDANT, moves(walk_down * 2,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_right,  walk_down * 2))
    waitmovement(0)
    switch(var(VAR_FRONTIER_BATTLE_MODE)) {
		case FRONTIER_MODE_MULTIS:
			if (!flag(FLAG_CHOSEN_MULTI_BATTLE_NPC_PARTNER)) {
				warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_MULTI_PARTNER_ROOM, 10, 1)
			} else {
				warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_MULTI_CORRIDOR, 7, 2)
			}
		case FRONTIER_MODE_SINGLES:
		case FRONTIER_MODE_DOUBLES: warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_CORRIDOR, 8, 1)
		case FRONTIER_MODE_LINK_MULTIS: warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_MULTI_CORRIDOR, 7, 2)
	}
	waitstate
    end
}
