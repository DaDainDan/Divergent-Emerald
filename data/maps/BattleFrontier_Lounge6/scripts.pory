mapscripts BattleFrontier_Lounge6_MapScripts {}

script BattleFrontier_Lounge6_EventScript_Trader {
    lock_faceplayer
    if (flag(FLAG_BATTLE_FRONTIER_TRADE_DONE)) {
        msgbox(BattleFrontier_Lounge6_Text_SkittySoMuchCuterThanImagined, MSGBOX_DEFAULT)
    	release_end
    }
    ingame_trade(INGAME_TRADE_MEOWTH, BattleFrontier_Lounge6_Text_WouldYouLikeToTrade, BattleFrontier_Lounge6_EventScript_DeclineTrade, BattleFrontier_Lounge6_EventScript_NotRequestedMon, BattleFrontier_Lounge6_Text_PromiseIllBeGoodToIt)
    setflag(FLAG_BATTLE_FRONTIER_TRADE_DONE)
    release_end
}

script BattleFrontier_Lounge6_EventScript_DeclineTrade {
    msgbox(BattleFrontier_Lounge6_Text_WellThatsFineToo, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge6_EventScript_NotRequestedMon {
    bufferspeciesname(STR_VAR_1, VAR_0x8009)
    msgbox(BattleFrontier_Lounge6_Text_DontTradeForAnythingButMon, MSGBOX_DEFAULT)
    release_end
}

text BattleFrontier_Lounge6_Text_WouldYouLikeToTrade {
	"My POKéMON is a {STR_VAR_2}.
	Do you know it?
	It's quite cute and rather nice.

	This little one, I could trade with
	pride!

	Would you like to trade me a {STR_VAR_1}
	for my {STR_VAR_2}?"
}

text BattleFrontier_Lounge6_Text_PromiseIllBeGoodToIt {
	"Oh, it's adorable!
	Thank you!
	I promise I'll be good to it!

	Oh! I hope you'll be good to
	my {STR_VAR_2}, too!"
}

text BattleFrontier_Lounge6_Text_DontTradeForAnythingButMon {
	"Oh, I'm sorry!
	I don't intend to trade for anything
	but a {STR_VAR_1}."
}

text BattleFrontier_Lounge6_Text_WellThatsFineToo {
	"Oh, you won't?
	Well, that's fine, too.
	Please come visit us again."
}

text BattleFrontier_Lounge6_Text_SkittySoMuchCuterThanImagined {
	"Giggle!
	A SKITTY is so much cuter than I had
	imagined. I'm delighted!"
}
