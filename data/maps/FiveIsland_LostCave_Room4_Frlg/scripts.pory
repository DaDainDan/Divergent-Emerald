mapscripts FiveIsland_LostCave_Room4_Frlg_MapScripts {}

script FiveIsland_LostCave_Room4_EventScript_Laura {
    trainerbattle_single(TRAINER_PSYCHIC_LAURA, FiveIsland_LostCave_Room4_Text_LauraIntro, FiveIsland_LostCave_Room4_Text_LauraDefeat)
    msgbox(FiveIsland_LostCave_Room4_Text_LauraPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text FiveIsland_LostCave_Room4_Text_LauraIntro {
	"I think there is a mysterious power
	at work in this cave."
}

text FiveIsland_LostCave_Room4_Text_LauraDefeat {
	"If you don't go into the right
	tunnel, you won't get ahead."
}

text FiveIsland_LostCave_Room4_Text_LauraPostBattle {
	"Earlier, a lady went into the caves
	ahead."
}
