mapscripts SaffronCity_CopycatsHouse_2F_Frlg_MapScripts {}

script SaffronCity_CopycatsHouse_2F_EventScript_Doduo {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_DODUO, CRY_MODE_NORMAL)
    msgbox(SaffronCity_CopycatsHouse_2F_Text_Doduo)
    waitmoncry
    release_end
}

script SaffronCity_CopycatsHouse_2F_EventScript_Doll {
    lock
    msgbox(SaffronCity_CopycatsHouse_2F_Text_RareMonOnlyDoll)
    release_end
}

script SaffronCity_CopycatsHouse_2F_EventScript_Copycat {
    lock_faceplayer
    if (checkitem(ITEM_POKE_DOLL) == TRUE) {
        goto(EventScript_MimicTutor)
    }
    if (checkplayergender == MALE) {
		msgbox(SaffronCity_CopycatsHouse_2F_Text_MimickingFavoriteHobbyMale)
	} else {
        msgbox(SaffronCity_CopycatsHouse_2F_Text_MimickingFavoriteHobbyFemale)
    }
    release_end
}

script SaffronCity_CopycatsHouse_2F_EventScript_Computer {
    msgbox(SaffronCity_CopycatsHouse_2F_Text_MySecrets, MSGBOX_SIGN)
    end
}

script SaffronCity_CopycatsHouse_2F_EventScript_Game {
    msgbox(SaffronCity_CopycatsHouse_2F_Text_MarioWearingABucket, MSGBOX_SIGN)
    end
}

text SaffronCity_CopycatsHouse_2F_Text_MimickingFavoriteHobbyMale {
	"{PLAYER}: Hi!
	Do you like POKéMON?

	{PLAYER}: Uh, no, I just asked you.

	{PLAYER}: Huh?
	You're strange!

	COPYCAT: Hmm? Quit mimicking?
	But, that's my favorite hobby!"
}

text SaffronCity_CopycatsHouse_2F_Text_MimickingFavoriteHobbyFemale {
	"{PLAYER}: Hi.
	You must like POKéMON.

	{PLAYER}: No, not me.
	I asked you.

	{PLAYER}: Pardon?
	You're weird!
	 
	COPYCAT: Hmm? Quit mimicking?
	But that's my favorite hobby!"
}

text Text_MimicTeach {
	"Oh wow!
	A POKé DOLL!

	For me?
	Thank you!

	You know what?
	I can teach the move MIMIC."
}

text Text_MimicDeclined {
	"Don't you like MIMIC?"
}

text Text_MimicWhichMon {
	"I really love MIMIC!
	Who's going to learn it?"
}

text Text_MimicTaughtMale {
	"{PLAYER}: Hi!
	Thanks for earlier!

	{PLAYER}: Pardon?

	{PLAYER}: Is it that fun to mimic my
	every move?

	COPYCAT: You bet!
	It's a scream!"
}

text Text_MimicTaughtFemale {
	"{PLAYER}: Hi!
	Thanks for what you did for us.

	{PLAYER}: Pardon?

	{PLAYER}: Is it really that fun to
	copy what I say and do?

	COPYCAT: You bet!
	It's a scream!"
}

text SaffronCity_CopycatsHouse_2F_Text_Doduo {
	"DODUO: Giiih!

	PRETTY MIRROR LOOK AT ME,
	SEE HOW PRETTY I CAN BE?"
}

text SaffronCity_CopycatsHouse_2F_Text_RareMonOnlyDoll {
	"This is a rare POKéMON!
	Huh? It's only a doll!"
}

text SaffronCity_CopycatsHouse_2F_Text_MarioWearingABucket {
	"A game with MARIO wearing a bucket
	on his head!"
}

text SaffronCity_CopycatsHouse_2F_Text_MySecrets {
	"…

	My Secrets!

	Skill: Mimicry!
	Hobby: Collecting dolls!
	Favorite POKéMON: CLEFAIRY!"
}
