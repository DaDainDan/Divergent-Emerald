mapscripts FiveIsland_House1_Frlg_MapScripts {}

script FiveIsland_House1_EventScript_Woman {
    msgbox(FiveIsland_House1_Text_HusbandWentOffFishing, MSGBOX_NPC)
    end
}

text FiveIsland_House1_Text_HusbandWentOffFishing {
	"Don't worry about buying anything
	for dinner tonight!

	…That's what my husband said when
	he went off fishing today.

	I'm not sure if I can count on him
	to live up to that promise."
}
