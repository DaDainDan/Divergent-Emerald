    end
}

script Route110_TrickHousePuzzle_EventScript_DoorLocked {
    msgbox(Route110_TrickHouseEntrance_Text_DoorLockedWriteSecretCodeHere, MSGBOX_DEFAULT)
    releaseall
    end
}

script Route110_TrickHousePuzzle_EventScript_ReadScrollAgain {
    msgbox(Route110_TrickHousePuzzle_Text_SecretCodeWrittenOnIt, MSGBOX_DEFAULT)
    releaseall
    end
}

script Route110_TrickHousePuzzle_EventScript_FoundScroll {
    playfanfare(MUS_OBTAIN_ITEM)
    message(Route110_TrickHousePuzzle_Text_FoundAScroll)
    waitfanfare
    msgbox(Route110_TrickHousePuzzle_Text_MemorizedSecretCode, MSGBOX_DEFAULT)
    releaseall
    end
}

script Route110_TrickHouseEntrance_EventScript_TrickMasterHiding {
    lockall
    msgbox(Route110_TrickHouseEntrance_Text_YoureBeingWatched, MSGBOX_DEFAULT)
    releaseall
	switch (var(VAR_TRICK_HOUSE_LEVEL)) {
		case 0:
			setvar(VAR_0x8004, 6) // x
    		setvar(VAR_0x8005, 3) // y
		case 1:
			setvar(VAR_0x8004, 11) // x
    		setvar(VAR_0x8005, 5) // y
		case 2:
			setvar(VAR_0x8004, 9) // x
    		setvar(VAR_0x8005, 2) // y
	}
	setvar(VAR_0x8006, 0)
    dofieldeffectsparkle(VAR_0x8004, VAR_0x8005, VAR_0x8006)
    waitfieldeffect(FLDEFF_SPARKLE)
    delay(10)
    setvar(VAR_TRICK_HOUSE_BEING_WATCHED_STATE, 1)
    end
}

text Route110_TrickHouseEntrance_Text_YoureBeingWatched {
	"You're being watched…"
}

text Route110_TrickHouseEntrance_Text_ConcealedBeneathDesk {
	"Hah? Grrr…

	How did you know I concealed myself
	beneath this desk? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedBehindTree {
	"Hah? Grrr…

	How did you know I concealed myself
	behind this tree? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedInDresser {
	"Hah? Grrr…

	How did you know I concealed myself
	in this dresser? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConealedBeyondWindow {
	"Hah? Grrr…

	How did you know I concealed myself
	beyond this window? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedInPlanter {
	"Hah? Grrr…

	How did you know I concealed myself
	in this planter? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedInCupboard {
	"Hah? Grrr…

	How did you know I concealed myself
	in this cupboard? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedBehindWindow {
	"Hah? Grrr…

	How did you know I concealed myself
	behind this window? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_ConcealedBeneathCushion {
	"Hah? Grrr…

	How did you know I concealed myself
	beneath this cushion? You're sharp!"
}

text Route110_TrickHouseEntrance_Text_TheyCallMeTrickMaster {
	"Behold!

	For I am the greatest living mystery
	of a man in all of HOENN!
	They call me…

	The TRICK MASTER!
	Wahahaha! Glad to meet you!"
}

text Route110_TrickHouseEntrance_Text_ComeToChallengeTrickHouse {
	"You, you've come to challenge
	my TRICK HOUSE, haven't you?

	That's why you're here, isn't it?
	Yes, it is!

	Consider your challenge accepted!

	Enter through the scroll there,
	and let your challenge commence!

	I shall be waiting in the back!"
}

text Route110_TrickHouseEntrance_Text_ItsAScroll {
	"It's a scroll."
}

text Route110_TrickHouseEntrance_Text_GoInHoleBehindScroll {
	"There is a big hole behind the scroll!

	Want to go in?"
}

text Route110_TrickHouseEntrance_Text_LeavingOnJourneyNote {
	"There is a note affixed to the scroll…

	“I am leaving on a journey.
	Don't look for me. TRICK MASTER”"
}

text Route110_TrickHouseEntrance_Text_NextTimeUseThisTrick {
	"For the next time, I'll use this trick,
	and that scheme, and those ruses…

	Mufufufu… If I may say so, it's
	brilliantly difficult, even for me!"
}

text Route110_TrickHouseEntrance_Text_InMidstOfDevisingNewChallenges {
	"Hah? What?!
	Oh, it's you!

	I'm in the midst of devising new tricky
	challenges!

	It's not too much to ask for a bit more
	time for me to think, is it now?
	You wouldn't begrudge me that?
	Come back in a little while!"
}

text Route110_TrickHouseEntrance_Text_YoureHereToAcceptReward {
	"Ah, it's you! You're here to accept the
	reward from before, isn't that right?
	Yes, right I am!

	Here!
	I'll give it to you now!"
}

text Route110_TrickHouseEntrance_Text_DidYouNotComeToClaimReward {
	"Hah?
	Did you not come to claim your reward?"
}

text Route110_TrickHouseEntrance_Text_MechadollWhichTent {
	"MECHADOLL 5 I AM!
	IF REWARD IS NOT TAKEN BY YOU,
	THEN TRICK MASTER YOU CANNOT FOLLOW.

	RED TENT OR BLUE TENT,
	WHICH DO YOU PREFER?"
}

text Route110_TrickHouseEntrance_Text_ThenFarewell {
	"THEN FAREWELL."
}

text Route110_TrickHouseEntrance_Text_PCFullAgain {
	"YOUR PC STATUS: FULL AGAIN.
	MEAN, YOU ARE."
}

