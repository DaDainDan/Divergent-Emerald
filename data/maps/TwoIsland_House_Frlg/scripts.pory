const CHECKED_MUSHROOMS = FLAG_TEMP_1

mapscripts TwoIsland_House_Frlg_MapScripts {}

script TwoIsland_House_EventScript_MoveManiac {
    lock_faceplayer
    if (!flag(CHECKED_MUSHROOMS)) {
        msgbox(TwoIsland_House_Text_TeachMonMoveForMushroom)
    	setflag(CHECKED_MUSHROOMS)
    }
	if (checkitem(ITEM_BIG_MUSHROOM) == FALSE && checkitem(ITEM_TINY_MUSHROOM, 2) == FALSE) {
		goto(TwoIsland_House_EventScript_EndTutorMove)
	}
    msgbox(TwoIsland_House_Text_WantMeToTeachMove, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(TwoIsland_House_EventScript_EndTutorMove)
    }
    goto(TwoIsland_House_EventScript_ChooseMonToTutor)
    end
}

script TwoIsland_House_EventScript_ChooseMonToTutor {
    msgbox(TwoIsland_House_Text_TutorWhichMon)
    special(ChooseMonForMoveRelearner)
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(TwoIsland_House_EventScript_EndTutorMove)
    }
    special(IsSelectedMonEgg)
    if (var(VAR_RESULT) == TRUE) {
        msgbox(TwoIsland_House_Text_CantTeachAnEgg)
    	goto(TwoIsland_House_EventScript_ChooseMonToTutor)
    }
    elif (var(VAR_0x8005) == 0) {
        msgbox(TwoIsland_House_Text_NoMoveICanTeachThatMon)
    	goto(TwoIsland_House_EventScript_ChooseMonToTutor)
    }
    msgbox(TwoIsland_House_Text_TeachWhichMove)
    special(TeachMoveRelearnerMove)
    if (var(VAR_0x8004) == 0) {
        goto(TwoIsland_House_EventScript_ChooseMonToTutor)
    }
    elif (checkitem(ITEM_BIG_MUSHROOM) == TRUE && checkitem(ITEM_TINY_MUSHROOM, 2) == TRUE) {
        message(TwoIsland_House_Text_IllNeedMushroomOrTwo)
		waitmessage
		multichoice(0, 0, MULTI_MUSHROOMS, TRUE)
		copyvar(VAR_0x8007, VAR_RESULT)
    }
    elif (checkitem(ITEM_BIG_MUSHROOM) == TRUE) {
		setvar(VAR_0x8007, 1)
    }
    elif (checkitem(ITEM_TINY_MUSHROOM, 2) == TRUE) {
		setvar(VAR_0x8007, 0)
    }
	goto(TwoIsland_House_EventScript_GiveMushroom)
    end
}

script TwoIsland_House_EventScript_GiveMushroom {
	switch (var(VAR_0x8007)) {
		case 0: removeitem(ITEM_TINY_MUSHROOM, 2)
		case 1: removeitem(ITEM_BIG_MUSHROOM)
	}
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
	switch (var(VAR_0x8007)) {
		case 0: msgbox(TwoIsland_House_Text_HandedOverTwoTinyMushrooms)
		case 1: msgbox(TwoIsland_House_Text_HandedOverOneBigMushroom)
	}
    call(EventScript_RestorePrevTextColor)
    goto(TwoIsland_House_EventScript_EndTutorMove)
    end
}

script TwoIsland_House_EventScript_EndTutorMove {
    msgbox(TwoIsland_House_Text_NeedMushroomOrTwoToLearnMove)
    release_end
}

text TwoIsland_House_Text_TeachMonMoveForMushroom {
	"I'm the POKéMON MOVE MANIAC.

	I know every single move that
	POKéMON learn growing up.

	I'm also a mushroom maniac.

	Bring me two TINYMUSHROOMS,
	or one BIG MUSHROOM.

	If you do that for me, I'll teach
	a move to one POKéMON."
}

text TwoIsland_House_Text_WantMeToTeachMove {
	"Sniff, sniff…
	Hm! You smell of MUSHROOMS!

	Do you want me to teach a move
	to a POKéMON of yours?"
}

text TwoIsland_House_Text_TutorWhichMon {
	"Which POKéMON needs tutoring?"
}

text TwoIsland_House_Text_TeachWhichMove {
	"Which move should I teach?"
}

text TwoIsland_House_Text_NoMoveICanTeachThatMon {
	"Sorry…

	It doesn't appear as if I have a
	move I can teach that POKéMON."
}

text TwoIsland_House_Text_IllNeedMushroomOrTwo {
	"Then, I'll need a MUSHROOM or two.
	What are you going to give me?"
}

text TwoIsland_House_Text_HandedOverTwoTinyMushrooms {
	"{PLAYER} handed over two
	TINYMUSHROOMS in exchange."
}

text TwoIsland_House_Text_HandedOverOneBigMushroom {
	"{PLAYER} handed over one
	BIG MUSHROOM in exchange."
}

text TwoIsland_House_Text_NeedMushroomOrTwoToLearnMove {
	"If your POKéMON need to learn a
	move, I need a MUSHROOM or two."
}

text TwoIsland_House_Text_CantTeachAnEgg {
	"Hunh? There isn't a single move
	that I can teach an EGG."
}
