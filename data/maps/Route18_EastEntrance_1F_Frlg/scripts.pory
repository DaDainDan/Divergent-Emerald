mapscripts Route18_EastEntrance_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        clearflag(FLAG_SYS_ON_CYCLING_ROAD)
		if (flag(FLAG_GOT_BICYCLE)) {
			setvar(VAR_TEMP_1, 1)
		}
		end
    }
}

script Route18_EastEntrance_1F_EventScript_Guard {
    msgbox(Route18_EastEntrance_1F_Text_CyclingRoadAllUphillFromHere, MSGBOX_NPC)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTriggerTop {
    lockall
    setvar(VAR_0x8008, 0)
    goto(Route18_EastEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTriggerMidTop {
    lockall
    setvar(VAR_0x8008, 1)
    goto(Route18_EastEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTriggerMid {
    lockall
    setvar(VAR_0x8008, 2)
    goto(Route18_EastEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTriggerMidBottom {
    lockall
    setvar(VAR_0x8008, 3)
    goto(Route18_EastEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTriggerBottom {
    lockall
    setvar(VAR_0x8008, 4)
    goto(Route18_EastEntrance_1F_EventScript_NeedBikeTrigger)
    end
}

script Route18_EastEntrance_1F_EventScript_NeedBikeTrigger {
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(Route18_EastEntrance_1F_Text_ExcuseMe)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    delay(20)
	switch (var(VAR_0x8008)) {
		case 1: applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
		case 2: applymovement(LOCALID_PLAYER, moves(walk_up * 2))
		case 3: applymovement(LOCALID_PLAYER, moves(walk_up * 3))
		case 4: applymovement(LOCALID_PLAYER, moves(walk_up * 4))
	}
	waitmovement(0)
    msgbox(Route18_EastEntrance_1F_Text_NeedBicycleForCyclingRoad)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkRight)
    waitmovement(0)
    releaseall
    end
}

text Route18_EastEntrance_1F_Text_NeedBicycleForCyclingRoad {
	"You need a BICYCLE to go out on
	CYCLING ROAD!"
}

text Route18_EastEntrance_1F_Text_CyclingRoadAllUphillFromHere {
	"CYCLING ROAD is all uphill from
	here."
}

text Route18_EastEntrance_1F_Text_ExcuseMe {
	"Excuse me!"
}
