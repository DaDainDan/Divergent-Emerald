script SealedChamber_OuterRoom_EventScript_InnerRoomEntranceWall {
    lockall
    if (flag(FLAG_SYS_BRAILLE_DIG)) {
        msgbox(gText_BigHoleInTheWall, MSGBOX_DEFAULT)
    } else {
		braillemsgbox(SealedChamber_OuterRoom_Braille_DigHere)
	}
    releaseall
    end
}

script SealedChamber_OuterRoom_EventScript_BrailleDigHere {
    lockall
    braillemsgbox(SealedChamber_OuterRoom_Braille_DigHere)
    releaseall
    end
}
