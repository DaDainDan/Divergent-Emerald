mapscripts SootopolisCity_LotadAndSeedotHouse_MapScripts {}

script SootopolisCity_LotadAndSeedotHouse_EventScript_SeedotBrother {
    special(GetSeedotSizeRecordInfo)
    lock_faceplayer
    msgbox(SootopolisCity_LotadAndSeedotHouse_Text_PleaseShowMeBigSeedot, MSGBOX_DEFAULT)
    setvar(VAR_0x8009, SPECIES_SEEDOT)
    chooseboxmon(SELECT_PC_MON_TRADE)
    waitstate
    if (var(VAR_0x8004) == PARTY_NOTHING_CHOSEN) {
        msgbox(SootopolisCity_LotadAndSeedotHouse_Text_DontHaveBigSeedot, MSGBOX_DEFAULT)
    	release_end
    }
    special(CompareSeedotSize)
	switch (var(VAR_RESULT)) {
		case COMPARE_SIZE_INCORRECT_SPECIES: msgbox(SootopolisCity_LotadAndSeedotHouse_Text_ThatsNotSeedot, MSGBOX_DEFAULT)
		case COMPARE_SIZE_SMALLER: msgbox(SootopolisCity_LotadAndSeedotHouse_Text_SeenBiggerSeedot, MSGBOX_DEFAULT)
		case COMPARE_SIZE_LARGER: goto(SootopolisCity_LotadAndSeedotHouse_EventScript_GiveElixir)
	}
    release_end
}

script SootopolisCity_LotadAndSeedotHouse_EventScript_GiveElixir {
	msgbox(SootopolisCity_LotadAndSeedotHouse_Text_GoshMightBeBiggerThanLotad, MSGBOX_DEFAULT)
	if (giveitem(ITEM_ELIXIR) == FALSE) {
		msgbox(SootopolisCity_LotadAndSeedotHouse_Text_BagCrammedFull1, MSGBOX_DEFAULT)
		release_end
	}
	closemessage
	release_end
}

script SootopolisCity_LotadAndSeedotHouse_EventScript_LotadBrother {
    special(GetLotadSizeRecordInfo)
    lock_faceplayer
    msgbox(SootopolisCity_LotadAndSeedotHouse_Text_PleaseShowMeBigLotad, MSGBOX_DEFAULT)
    setvar(VAR_0x8009, SPECIES_LOTAD)
    chooseboxmon(SELECT_PC_MON_TRADE)
    waitstate
    if (var(VAR_0x8004) == PARTY_NOTHING_CHOSEN) {
        msgbox(SootopolisCity_LotadAndSeedotHouse_Text_DontHaveBigLotad, MSGBOX_DEFAULT)
    	release_end
    }
    special(CompareLotadSize)
	switch (var(VAR_RESULT)) {
		case COMPARE_SIZE_INCORRECT_SPECIES: msgbox(SootopolisCity_LotadAndSeedotHouse_Text_ThatsNotLotad, MSGBOX_DEFAULT)
		case COMPARE_SIZE_SMALLER: msgbox(SootopolisCity_LotadAndSeedotHouse_Text_SeenBiggerLotad, MSGBOX_DEFAULT)
		case COMPARE_SIZE_LARGER: goto(SootopolisCity_LotadAndSeedotHouse_EventScript_GiveElixir)
	}
    release_end
}

script SootopolisCity_LotadAndSeedotHouse_EventScript_SeedotSizeRecord {
    special(GetSeedotSizeRecordInfo)
    lockall
    msgbox(SootopolisCity_LotadAndSeedotHouse_Text_BiggestSeedotInHistory, MSGBOX_DEFAULT)
    releaseall
    end
}

script SootopolisCity_LotadAndSeedotHouse_EventScript_LotadSizeRecord {
    special(GetLotadSizeRecordInfo)
    lockall
    msgbox(SootopolisCity_LotadAndSeedotHouse_Text_BiggestLotadInHistory, MSGBOX_DEFAULT)
    releaseall
    end
}

text SootopolisCity_LotadAndSeedotHouse_Text_PleaseShowMeBigSeedot {
	"Do you know the POKéMON SEEDOT?
	It's hardly ever seen in SOOTOPOLIS.

	Anyway, I love big SEEDOT.
	The bigger the better.

	But my younger brother, he says that
	LOTAD is bigger.

	That's silly.
	SEEDOT has to be bigger than that!

	Huh? Do you have a SEEDOT with you?
	P-p-please, show me!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_GoshMightBeBiggerThanLotad {
	"{STR_VAR_2}!
	Oh, my gosh, this is a big one!

	It might even beat the big LOTAD
	my younger brother saw!

	Thanks for showing me.
	This is my thanks!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_ReceivedPotion1 {
	"{PLAYER} received a POTION."
}

text SootopolisCity_LotadAndSeedotHouse_Text_BagCrammedFull1 {
	"Hunh?
	Your BAG is crammed full."
}

text SootopolisCity_LotadAndSeedotHouse_Text_SeenBiggerSeedot {
	"{STR_VAR_2}, is it?

	Hmm… I've seen a bigger SEEDOT
	than this one."
}

text SootopolisCity_LotadAndSeedotHouse_Text_ThatsNotSeedot {
	"Oh, now this is quite something…
	But it's not a SEEDOT!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_DontHaveBigSeedot {
	"You don't have a big SEEDOT?
	That's too bad…

	If you get a big SEEDOT, please
	come show me."
}

text SootopolisCity_LotadAndSeedotHouse_Text_BiggestSeedotInHistory {
	"The biggest SEEDOT in history!
	{STR_VAR_2}'s {STR_VAR_3} giant!

	A SEEDOT bigger than a LOTAD
	always wanted!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_PleaseShowMeBigLotad {
	"Do you know the POKéMON LOTAD?
	It's rarely seen in SOOTOPOLIS.

	I love, I mean love, big LOTAD!

	My big brother says that SEEDOT is
	bigger.

	But that's wrong! Everyone knows that
	LOTAD is a lot bigger.

	Hunh? Do you have a LOTAD?
	P-p-please show me!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_WowMightBeBiggerThanSeedot {
	"{STR_VAR_2}!
	Wow, that is big!

	It might be even bigger than the huge
	SEEDOT my big brother saw.

	Thanks for showing me!
	This is my thanks!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_ReceivedPotion2 {
	"{PLAYER} received a POTION."
}

text SootopolisCity_LotadAndSeedotHouse_Text_BagCrammedFull2 {
	"Hunh?
	Your BAG is crammed full."
}

text SootopolisCity_LotadAndSeedotHouse_Text_SeenBiggerLotad {
	"{STR_VAR_2}?

	Hmm… I've seen a bigger LOTAD
	than this one here."
}

text SootopolisCity_LotadAndSeedotHouse_Text_ThatsNotLotad {
	"Well, isn't this something!
	But it's no LOTAD!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_DontHaveBigLotad {
	"Don't you have a big LOTAD?
	How disappointing…

	If you get a big LOTAD, please
	come show me!"
}

text SootopolisCity_LotadAndSeedotHouse_Text_BiggestLotadInHistory {
	"The biggest LOTAD in history!
	{STR_VAR_2}'s {STR_VAR_3} colossus!

	A LOTAD bigger than a SEEDOT
	always wanted!"
}
