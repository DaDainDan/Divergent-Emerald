mapscripts RocketHideout_B3F_Frlg_MapScripts {}

script RocketHideout_B3F_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_14, RocketHideout_B3F_Text_Grunt1Intro, RocketHideout_B3F_Text_Grunt1Defeat)
    msgbox(RocketHideout_B3F_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RocketHideout_B3F_EventScript_Grunt2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_15, RocketHideout_B3F_Text_Grunt2Intro, RocketHideout_B3F_Text_Grunt2Defeat)
    msgbox(RocketHideout_B3F_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

text RocketHideout_B3F_Text_Grunt1Intro {
	"Stop meddling in TEAM ROCKET's
	affairs or else!"
}

text RocketHideout_B3F_Text_Grunt1Defeat {
	"Oof!
	Taken down!"
}

text RocketHideout_B3F_Text_Grunt1PostBattle {
	"SILPH SCOPE?
	Oh, that machine the BOSS stole.

	It's here somewhere."
}

text RocketHideout_B3F_Text_Grunt2Intro {
	"We got word from upstairs that you
	were coming!"
}

text RocketHideout_B3F_Text_Grunt2Defeat {
	"What?
	I lost? No!"
}

text RocketHideout_B3F_Text_Grunt2PostBattle {
	"Go ahead and go!

	But you can't run the elevator
	without the LIFT KEY."
}
