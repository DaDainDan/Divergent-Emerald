script RustboroCity_PokemonSchool_EventScript_StudentNotebook {
    msgbox(RustboroCity_PokemonSchool_Text_StudentsNotes, MSGBOX_SIGN)
    end
}

script RustboroCity_PokemonSchool_EventScript_Teacher {
    lock_faceplayer
    if (!flag(FLAG_RECEIVED_QUICK_CLAW)) {
		switch (var(VAR_FACING)) {
			case DIR_EAST: applymovement(VAR_LAST_TALKED, RustboroCity_PokemonSchool_Movement_TeacherCheckOnStudentsEast)
			case DIR_WEST: applymovement(VAR_LAST_TALKED, RustboroCity_PokemonSchool_Movement_TeacherCheckOnStudentsWest)
		}
		waitmovement(0)
		msgbox(RustboroCity_PokemonSchool_Text_StudentsWhoDontStudyGetQuickClaw, MSGBOX_DEFAULT)
		if (giveitem(ITEM_QUICK_CLAW) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		setflag(FLAG_RECEIVED_QUICK_CLAW)
    } else {
		msgbox(RustboroCity_PokemonSchool_Text_ExplainQuickClaw, MSGBOX_DEFAULT)
	}
    closemessage
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterDown)
    waitmovement(0)
    release_end
}

movement RustboroCity_PokemonSchool_Movement_TeacherCheckOnStudentsWest {
    // moves(walk_left,  walk_down * 2,  walk_right,  step_faster_down,  delay_16 * 3,  walk_down,  step_faster_left,  delay_16 * 2,  walk_right,  delay_16 * 2,  delay_8,  walk_up,  walk_left * 2,  walk_up * 2,  walk_right)
    walk_left
    walk_down * 2
    walk_right
    step_faster_down
    delay_16 * 3
    walk_down
    step_faster_left
    delay_16 * 2
    walk_right
    delay_16 * 2
    delay_8
    walk_up
    walk_left * 2
    walk_up * 2
    walk_right
}

movement RustboroCity_PokemonSchool_Movement_TeacherCheckOnStudentsEast {
    // moves(walk_right * 2,  walk_down * 2,  walk_left * 2,  step_faster_down,  delay_16 * 3,  walk_down,  step_faster_left,  delay_16 * 2,  walk_right,  delay_16 * 2,  delay_8,  walk_up,  walk_right,  walk_up * 2,  walk_left * 2)
    walk_right * 2
    walk_down * 2
    walk_left * 2
    step_faster_down
    delay_16 * 3
    walk_down
    step_faster_left
    delay_16 * 2
    walk_right
    delay_16 * 2
    delay_8
    walk_up
    walk_right
    walk_up * 2
    walk_left * 2
}

script RustboroCity_PokemonSchool_EventScript_Scott {
    lock_faceplayer
    if (flag(FLAG_MET_SCOTT_AFTER_OBTAINING_STONE_BADGE)
    || (flag(FLAG_MET_SCOTT_RUSTBORO) && !flag(FLAG_BADGE01_GET))) {
        msgbox(RustboroCity_PokemonSchool_Text_StudentTalentLevelUnknown, MSGBOX_DEFAULT)
        release_end
    }
    if (flag(FLAG_BADGE01_GET)) {
        if (flag(FLAG_MET_SCOTT_RUSTBORO)) {
            msgbox(RustboroCity_PokemonSchool_Text_ScottStoneBadge, MSGBOX_DEFAULT)
        }
        else {
            msgbox(RustboroCity_PokemonSchool_Text_ScottMetAlreadyStoneBadge, MSGBOX_DEFAULT)
        }
        addvar(VAR_SCOTT_STATE, 1)
        setflag(FLAG_MET_SCOTT_AFTER_OBTAINING_STONE_BADGE)
        release_end
    }
    msgbox(RustboroCity_PokemonSchool_Text_ScottMetAlreadyCut, MSGBOX_DEFAULT)
    addvar(VAR_SCOTT_STATE, 1)
    setflag(FLAG_MET_SCOTT_RUSTBORO)
    release_end
}

text RustboroCity_PokemonSchool_Text_BlackboardListsStatusChanges {
	"The blackboard lists status changes
	that may affect POKéMON in battle."
}

text RustboroCity_PokemonSchool_Text_ReadWhichTopic {
	"Which topic do you want to read?"
}

text RustboroCity_PokemonSchool_Text_ExplainPoison {
	"If a POKéMON is poisoned, it will
	steadily lose HP.

	The effects of poison remain after
	a battle.

	A poisoned POKéMON's HP will drop
	while it is traveling.

	Heal a poisoning using an ANTIDOTE."
}

text RustboroCity_PokemonSchool_Text_ExplainParalysis {
	"If a POKéMON becomes paralyzed,
	its SPEED drops.

	It may also not be able to move while
	it is in battle.

	Paralysis remains after battle.
	Cure it using a PARLYZ HEAL."
}

text RustboroCity_PokemonSchool_Text_ExplainSleep {
	"If a POKéMON falls asleep, it will be
	unable to attack.

	A POKéMON may wake up on its own,
	but if a battle ends while it is
	sleeping, it will stay asleep.

	Wake it up using an AWAKENING."
}

text RustboroCity_PokemonSchool_Text_ExplainBurn {
	"A burn reduces ATTACK power, and it
	steadily reduces the victim's HP.

	A burn lingers after battle.
	Cure a burn using a BURN HEAL."
}

text RustboroCity_PokemonSchool_Text_ExplainFreeze {
	"If a POKéMON is frozen, it becomes
	completely helpless.

	It will remain frozen after battle.
	Thaw it out using an ICE HEAL."
}

text RustboroCity_PokemonSchool_Text_StudentsWhoDontStudyGetQuickClaw {
	"Students who don't study get a little
	taste of my QUICK CLAW.

	Whether or not you are a good student 
	will be evident from the way you use
	this item."
}

text RustboroCity_PokemonSchool_Text_ExplainQuickClaw {
	"A POKéMON holding the QUICK CLAW will
	occasionally speed up and get to move
	before its opponent.

	There are many other items that are
	meant to be held by POKéMON.

	Just those alone will give you many
	topics to study!"
}

text RustboroCity_PokemonSchool_Text_TradingRightNow {
	"I'm trading POKéMON with my friend
	right now."
}

text RustboroCity_PokemonSchool_Text_AlwaysWantedSeedot {
	"I always wanted a SEEDOT, and
	I'm finally getting one!"
}

text RustboroCity_PokemonSchool_Text_PokemontCantUseManMadeItems {
	"POKéMON can hold items, but they
	don't know what to do with man-made
	items like POTION and ANTIDOTE."
}

text RustboroCity_PokemonSchool_Text_ConfusedPokemonAttacksItself {
	"You know how some POKéMON moves can
	confuse a POKéMON?

	A confused POKéMON will sometimes
	attack itself without meaning to.

	But once it leaves battle, it will
	return to normal."
}

text RustboroCity_PokemonSchool_Text_PokemonHealItselfWithBerry {
	"A POKéMON holding a BERRY will heal
	itself…

	There are many kinds of items that
	POKéMON can hold…

	Boy, it sure is hard taking notes
	down…"
}

text RustboroCity_PokemonSchool_Text_StudentsNotes {
	"It's this student's notebook…

	POKéMON are to be caught using
	POKé BALLS.

	Up to six POKéMON can accompany
	a TRAINER.

	A TRAINER is someone who catches
	POKéMON, raises them, and battles
	with them.

	A TRAINER's mission is to defeat
	the strong TRAINERS who await
	challengers in POKéMON GYMS."
}

text RustboroCity_PokemonSchool_Text_ScottMetAlreadyCut {
	"Hello? Didn't we meet before?
	I think back in PETALBURG CITY.

	Let me introduce myself.
	My name's SCOTT.

	I've been traveling everywhere in
	search of outstanding TRAINERS.

	More specifically, I'm looking for
	POKéMON battle experts.

	So, what brings you to this SCHOOL?
	Are you a TRAINER, too?

	The first thing you should do is to
	have a POKéMON learn the move CUT.

	If I remember correctly, someone in
	this town has CUT."
}

text RustboroCity_PokemonSchool_Text_StudentTalentLevelUnknown {
	"SCOTT: Hmm…

	The talent levels of the students here
	are unknown. The potential's there."
}

text RustboroCity_PokemonSchool_Text_ScottStoneBadge {
	"SCOTT: Oh, what's that?

	It's a STONE BADGE, isn't it?
	That's pretty impressive, I'd say.

	But, you know, I would've loved to see
	you in battle.

	It's hard to tell what you're like as
	a TRAINER from a LEAGUE BADGE."
}

text RustboroCity_PokemonSchool_Text_ScottMetAlreadyStoneBadge {
	"Hello? Didn't we meet before?
	I think back in PETALBURG CITY.

	Let me introduce myself.
	My name's SCOTT.

	I've been traveling everywhere in
	search of outstanding TRAINERS.

	More specifically, I'm looking for
	POKéMON battle experts.

	Oh, what's that?
	It's a STONE BADGE, isn't it?

	That's pretty impressive, I'd say, for
	a starting TRAINER like yourself.

	But, you know, I would've loved to see
	you in battle.

	It's hard to tell what you're like as
	a TRAINER from a LEAGUE BADGE."
}
