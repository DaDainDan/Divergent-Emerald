mapscripts SaffronCity_House_Frlg_MapScripts {}

script SaffronCity_House_EventScript_Lass {
    msgbox(SaffronCity_House_Text_DontLookAtMyLetter, MSGBOX_NPC)
    end
}

script SaffronCity_House_EventScript_Youngster {
    msgbox(SaffronCity_House_Text_GettingCopycatPokeDoll, MSGBOX_NPC)
    end
}

script SaffronCity_House_EventScript_Pidgey {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PIDGEY, CRY_MODE_NORMAL)
    msgbox(SaffronCity_House_Text_Pidgey)
    waitmoncry
    release_end
}

script SaffronCity_House_EventScript_Letter {
    msgbox(SaffronCity_House_Text_ExplainPPUp, MSGBOX_SIGN)
    end
}

text SaffronCity_House_Text_DontLookAtMyLetter {
	"…Thank you for writing.
	I hope to see you soon!

	…Hey!
	Don't look at my letter!"
}

text SaffronCity_House_Text_Pidgey {
	"PIDGEY: Kurukkoo!"
}

text SaffronCity_House_Text_GettingCopycatPokeDoll {
	"The COPYCAT is cute!
	I'm getting her a POKé DOLL."
}

text SaffronCity_House_Text_ExplainPPUp {
	"I was given a PP UP as a gift.

	It's used to increase the PP of
	a POKéMON's move.

	I should use it on a powerful move
	with only a few PP."
}
