script LavaridgeTown_Gym_1F_EventScript_GymGuide {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_LAVARIDGE_GYM)) {
        msgbox(LavaridgeTown_Gym_1F_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LavaridgeTown_Gym_1F_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

script LavaridgeTown_Gym_1F_EventScript_LeftGymStatue {
    lockall
	goto(LavaridgeTown_Gym_1F_EventScript_GymStatue)
    end
}

script LavaridgeTown_Gym_1F_EventScript_RightGymStatue {
    lockall
    goto(LavaridgeTown_Gym_1F_EventScript_GymStatue)
    end
}

script LavaridgeTown_Gym_1F_EventScript_GymStatue {
    if (flag(FLAG_BADGE04_GET)) {
        msgbox(LavaridgeTown_Gym_1F_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(LavaridgeTown_Gym_1F_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

text LavaridgeTown_Gym_1F_Text_GymGuideAdvice {
	"Hey, how's it going, CHAMPION-
	bound {PLAYER}?

	LAVARIDGE's GYM LEADER FLANNERY
	uses FIRE-type POKéMON.

	Her passion for POKéMON burns stronger
	and hotter than a volcano.

	Don't get too close to her--you'll burn!
	Hose her down with water and then
	go for it!"
}

text LavaridgeTown_Gym_1F_Text_GymGuidePostVictory {
	"Yow! That was a scorching-hot battle!"
}

text LavaridgeTown_Gym_1F_Text_ColeIntro {
	"Owowowowow!
	Yikes, it's hot!"
}

text LavaridgeTown_Gym_1F_Text_ColeDefeat {
	"I'm blinded by sweat in my eyes…"
}

text LavaridgeTown_Gym_1F_Text_ColePostBattle {
	"Being buried in hot sand promotes
	circulation.

	It's effective for healing pain in
	your joints."
}

text LavaridgeTown_Gym_1F_Text_AxleIntro {
	"I'm trying to relieve my stress.
	Don't come along and stress me out!"
}

text LavaridgeTown_Gym_1F_Text_AxleDefeat {
	"I hope FLANNERY flames you good!"
}

text LavaridgeTown_Gym_1F_Text_AxlePostBattle {
	"Haaah… Whew…

	If you spend too much time buried in
	hot sand, it tuckers you out…"
}

text LavaridgeTown_Gym_B1F_Text_KeeganIntro {
	"You must be getting tired by now.
	You'd like to rest in the hot sand,
	wouldn't you?

	But you should know that maintaining
	your willpower is an important ability
	for all TRAINERS."
}

text LavaridgeTown_Gym_B1F_Text_KeeganDefeat {
	"Play with fire, and be burned…"
}

text LavaridgeTown_Gym_B1F_Text_KeeganPostBattle {
	"Your skill is real…
	But our LEADER FLANNERY is strong.

	If you don't watch yourself, you'll be
	burned seriously."
}

text LavaridgeTown_Gym_1F_Text_GeraldIntro {
	"Can your POKéMON withstand
	392-degree heat?"
}

text LavaridgeTown_Gym_1F_Text_GeraldDefeat {
	"It didn't burn hotly enough…"
}

text LavaridgeTown_Gym_1F_Text_GeraldPostBattle {
	"The temperature of magma is
	392 degrees.

	Your POKéMON beat me, so they should
	easily survive in magma."
}

text LavaridgeTown_Gym_1F_Text_DanielleIntro {
	"Um…
	Okay, I'll battle with you."
}

text LavaridgeTown_Gym_1F_Text_DanielleDefeat {
	"Oh, but you're too strong."
}

text LavaridgeTown_Gym_1F_Text_DaniellePostBattle {
	"I'm going to be a pretty and strong
	TRAINER just like FLANNERY."
}

text LavaridgeTown_Gym_B1F_Text_JaceIntro {
	"Come on, get with it!
	Let's go before my feelings cool!"
}

text LavaridgeTown_Gym_B1F_Text_JaceDefeat {
	"It's so hot, and yet my heart is
	clutched by ice…"
}

text LavaridgeTown_Gym_B1F_Text_JacePostBattle {
	"The way the battling spirit burns
	within you, you may stand a chance
	against our LEADER."
}

text LavaridgeTown_Gym_B1F_Text_JeffIntro {
	"See how the flames blaze wildly?
	They flare in anticipation of my win!"
}

text LavaridgeTown_Gym_B1F_Text_JeffDefeat {
	"Something didn't go right."
}

text LavaridgeTown_Gym_B1F_Text_JeffPostBattle {
	"Well, so what? I say so what?
	I can walk on hot coals barefoot!

	…Don't even think about trying it!"
}

text LavaridgeTown_Gym_B1F_Text_EliIntro {
	"As much as I love mountains,
	I especially love volcanoes."
}

text LavaridgeTown_Gym_B1F_Text_EliDefeat {
	"Well, it seems to me I lost without
	ever being in control."
}

text LavaridgeTown_Gym_B1F_Text_EliPostBattle {
	"I stay here because I became a fan
	of FLANNERY's power.

	Hehehehe."
}

text LavaridgeTown_Gym_1F_Text_FlanneryIntro {
	"Welcome… No, wait.

	Puny TRAINER, how good to see you've
	made it here!

	I have been entrusted with the…
	No, wait.

	I am FLANNERY, and I'm the GYM
	LEADER here!

	Uh…
	Dare not underestimate me, though
	I have been LEADER only a short time!

	With skills inherited from my grand-
	father, I shall, uh…demonstrate the
	hot moves we have honed on this land!"
}

text LavaridgeTown_Gym_1F_Text_FlanneryDefeat {
	"Oh…
	I guess I was trying too hard…

	I… I've only recently become
	a GYM LEADER.

	I tried too hard to be someone
	I'm not.

	I have to do things my natural way. If
	I don't, my POKéMON will be confused.

	Thanks for teaching me that.
	For that, you deserve this."
}

text LavaridgeTown_Gym_1F_Text_ReceivedHeatBadge {
	"{PLAYER} received the HEAT BADGE
	from FLANNERY."
}

text LavaridgeTown_Gym_1F_Text_ExplainHeatBadgeTakeThis {
	"If you have a HEAT BADGE, all POKéMON
	up to Level 50, even those you get in
	trades from other people, will obey
	you completely.

	And, it lets POKéMON use the HM move
	STRENGTH outside of battle.

	This is a token of my appreciation.
	Don't be shy about taking it!"
}

text LavaridgeTown_Gym_1F_Text_ExplainOverheat {
	"That TM50 contains OVERHEAT.

	That move inflicts serious damage on
	the opponent.

	But it also sharply cuts the SP. ATK
	of the POKéMON using it. It might not
	be suitable for longer battles."
}

text LavaridgeTown_Gym_1F_Text_RegisteredFlannery {
	"Registered GYM LEADER FLANNERY
	in the POKéNAV."
}

text LavaridgeTown_Gym_1F_Text_FlanneryPostBattle {
	"Your power reminds me of someone…

	Oh! I know! You battle like NORMAN,
	the GYM LEADER of PETALBURG."
}

text LavaridgeTown_Gym_1F_Text_GymStatue {
	"LAVARIDGE TOWN POKéMON GYM"
}

text LavaridgeTown_Gym_1F_Text_GymStatueCertified {
	"LAVARIDGE TOWN POKéMON GYM

	FLANNERY'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text LavaridgeTown_Gym_1F_Text_FlanneryPreRematch {
	"{SPEAKER NAME_FLANNERY}Losing a battle isn't going
	to deflate me.

	I love POKéMON.
	I love to battle.
	And… I love this GYM!

	Let's exchange superhot moves
	in another battle!"
}

text LavaridgeTown_Gym_1F_Text_FlanneryRematchDefeat {
	"Whew!
	On the verge of eruption!"
}

text LavaridgeTown_Gym_1F_Text_FlanneryPostRematch {
	"{SPEAKER NAME_FLANNERY}I lost the match,
	but I'm completely satisfied.

	It's not often I get to enjoy a battle
	this heated.

	Let's have another one like this
	again sometime!"
}

text LavaridgeTown_Gym_1F_Text_FlanneryRematchNeedTwoMons {
	"{SPEAKER NAME_FLANNERY}Losing a battle isn't going
	to deflate me.

	I love POKéMON.
	I love to battle.
	And… I love this GYM!

	Let's exchange superhot moves
	in another battle!

	Oh, wait. Do you only have one POKéMON
	that can battle?

	I hate to say this, but when you come
	see me, bring at least two POKéMON."
}
