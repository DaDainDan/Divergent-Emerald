mapscripts FallarborTown_BattleTentCorridor_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: FallarborTown_BattleTentCorridor_EventScript_EnterCorridor
    ]
}

script FallarborTown_BattleTentCorridor_EventScript_EnterCorridor {
    lockall
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_FALLARBOR_TENT_CORRIDOR_ATTENDANT, moves(walk_up * 4))
    applymovement(LOCALID_PLAYER, moves(walk_up * 4))
    waitmovement(0)
    opendoor(2, 1)
    waitdooranim
    applymovement(LOCALID_FALLARBOR_TENT_CORRIDOR_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
    waitmovement(0)
    closedoor(2, 1)
    waitdooranim
    setvar(VAR_0x8006, 0)
    warp(MAP_FALLARBOR_TOWN_BATTLE_TENT_BATTLE_ROOM, 4, 4)
    waitstate
    releaseall
    end
}

// Leftover text from when this was a Contest Hall in R/S
// Unused
text FallarborTown_ContestHall_Text_DoAllRightInPreliminary {
	"We do all right in the preliminary round,
	but we can never win the appeals…

	Maybe it means I have to watch what
	other contestants are doing…"
}

text FallarborTown_ContestHall_Text_MonAllTheseRibbons {
	"See!
	My POKéMON won all these RIBBONS!

	Have your POKéMON earned any RIBBONS?
	You can check them on your POKéNAV."
}

text FallarborTown_ContestHall_Text_CantWinEverywhere {
	"I can't beat GYM LEADERS…

	I can't win any CONTESTS…

	I've been here, there, and everywhere,
	and it's all for naught…"
}

text FallarborTown_ContestHall_Text_SuperRankStage {
	"POKéMON CONTESTS
	SUPER RANK STAGE!"
}
