mapscripts SilphCo_6F_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_SILPH_6F_DOOR)) {
			call(EventScript_Close6FDoor)
		}
		end
    }
}

script SilphCo_6F_EventScript_WorkerM2 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_6F_Text_ComeWorkForSilphWhenYoureOlder)
    	release_end
    }
    msgbox(SilphCo_6F_Text_TargetedSilphForOurMonProducts)
    release_end
}

script SilphCo_6F_EventScript_WorkerM3 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_6F_Text_BetterGetBackToWork)
    	release_end
    }
    msgbox(SilphCo_6F_Text_RocketsTookOverBuilding)
    release_end
}

script SilphCo_6F_EventScript_WorkerM1 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_6F_Text_WeGotEngaged)
    	release_end
    }
    msgbox(SilphCo_6F_Text_HelpMePlease)
    release_end
}

script SilphCo_6F_EventScript_WorkerF1 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_6F_Text_NeedsMeToLookAfterHim)
    	release_end
    }
    msgbox(SilphCo_6F_Text_ThatManIsSuchACoward)
    release_end
}

script SilphCo_6F_EventScript_WorkerF2 {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) >= 1) {
        msgbox(SilphCo_6F_Text_RocketsRanAwayBecauseOfYou)
    	release_end
    }
    msgbox(SilphCo_6F_Text_RocketsTryingToConquerWorld)
    release_end
}

script SilphCo_6F_EventScript_FloorSign {
    msgbox(SilphCo_6F_Text_FloorSign, MSGBOX_SIGN)
    end
}

script SilphCo_6F_EventScript_Taylor {
    trainerbattle_single(TRAINER_SCIENTIST_TAYLOR, SilphCo_6F_Text_TaylorIntro, SilphCo_6F_Text_TaylorDefeat)
    msgbox(SilphCo_6F_Text_TaylorPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SilphCo_6F_EventScript_Grunt1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_30, SilphCo_6F_Text_Grunt1Intro, SilphCo_6F_Text_Grunt1Defeat)
    msgbox(SilphCo_6F_Text_Grunt1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SilphCo_6F_EventScript_Grunt2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_31, SilphCo_6F_Text_Grunt2Intro, SilphCo_6F_Text_Grunt2Defeat)
    msgbox(SilphCo_6F_Text_Grunt2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SilphCo_6F_Text_RocketsTookOverBuilding {
	"The ROCKETS came and took over
	the building!"
}

text SilphCo_6F_Text_BetterGetBackToWork {
	"Well, better get back to work."
}

text SilphCo_6F_Text_HelpMePlease {
	"Oh dear, oh dear.
	Help me, please!"
}

text SilphCo_6F_Text_WeGotEngaged {
	"We got engaged.
	Heheh!"
}

text SilphCo_6F_Text_ThatManIsSuchACoward {
	"That man next to me…
	He's such a coward!"
}

text SilphCo_6F_Text_NeedsMeToLookAfterHim {
	"He's so helpless, he needed
	someone like me to look after him."
}

text SilphCo_6F_Text_RocketsTryingToConquerWorld {
	"TEAM ROCKET is trying to conquer
	the world with POKéMON."
}

text SilphCo_6F_Text_RocketsRanAwayBecauseOfYou {
	"TEAM ROCKET ran away, and it's all
	because of you!"
}

text SilphCo_6F_Text_TargetedSilphForOurMonProducts {
	"They must have targeted SILPH for
	our POKéMON products."
}

text SilphCo_6F_Text_ComeWorkForSilphWhenYoureOlder {
	"Come work for SILPH when you
	get older."
}

text SilphCo_6F_Text_Grunt1Intro {
	"I am one of the four ROCKET
	BROTHERS!"
}

text SilphCo_6F_Text_Grunt1Defeat {
	"Flame out!"
}

text SilphCo_6F_Text_Grunt1PostBattle {
	"No matter!
	My brothers will avenge me!"
}

text SilphCo_6F_Text_TaylorIntro {
	"That rotten PRESIDENT!

	Serves him right for shipping me
	off to the TIKSI BRANCH!

	That's why TEAM ROCKET came after
	us, I'm sure of it!"
}

text SilphCo_6F_Text_TaylorDefeat {
	"Shoot!"
}

text SilphCo_6F_Text_TaylorPostBattle {
	"TIKSI BRANCH?
	It's in Russian no-man's-land!"
}

text SilphCo_6F_Text_Grunt2Intro {
	"You dare betray TEAM ROCKET?"
}

text SilphCo_6F_Text_Grunt2Defeat {
	"You traitor!"
}

text SilphCo_6F_Text_Grunt2PostBattle {
	"If you stand for justice, you
	betray us bad guys!"
}

text SilphCo_6F_Text_FloorSign {
	"SILPH CO. HEAD OFFICE
	6F"
}
