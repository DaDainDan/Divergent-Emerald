mapscripts ThreeIsland_House4_Frlg_MapScripts {}

script ThreeIsland_House4_EventScript_BaldingMan {
    msgbox(ThreeIsland_House4_Text_GhostsInBerryForest, MSGBOX_NPC)
    end
}

script ThreeIsland_House4_EventScript_LittleBoy {
    msgbox(ThreeIsland_House4_Text_PapaKeepsLyingToMe, MSGBOX_NPC)
    end
}

text ThreeIsland_House4_Text_GhostsInBerryForest {
	"You must never, ever go out to
	the BERRY FOREST alone.

	Why?
	There are ghosts there."
}

text ThreeIsland_House4_Text_PapaKeepsLyingToMe {
	"Papa keeps lying to me, and won't
	let me go out and play!"
}
