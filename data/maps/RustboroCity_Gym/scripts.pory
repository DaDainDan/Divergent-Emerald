mapscripts RustboroCity_Gym_MapScripts {}

script RustboroCity_Gym_EventScript_Roxanne {
    trainerbattle_single(TRAINER_ROXANNE_1, RustboroCity_Gym_Text_RoxanneIntro, RustboroCity_Gym_Text_RoxanneDefeat, RustboroCity_Gym_EventScript_RoxanneDefeated, NO_MUSIC)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
        trainerbattle_rematch_double(TRAINER_ROXANNE_1, RustboroCity_Gym_Text_RoxannePreRematch, RustboroCity_Gym_Text_RoxanneRematchDefeat, RustboroCity_Gym_Text_RoxanneRematchNeedTwoMons)
		msgbox(RustboroCity_Gym_Text_RoxannePostRematch, MSGBOX_AUTOCLOSE)
		end
    }
    if (!flag(FLAG_RECEIVED_HM_CUT)) {
        call(RustboroCity_Gym_EventScript_GiveCut)
		release_end
    }
    msgbox(RustboroCity_Gym_Text_RoxannePostBattle, MSGBOX_DEFAULT)
    release_end
}

script RustboroCity_Gym_EventScript_RoxanneDefeated {
    message(RustboroCity_Gym_Text_ReceivedStoneBadge)
    waitmessage
    call(Common_EventScript_PlayGymBadgeFanfare)
    msgbox(RustboroCity_Gym_Text_StoneBadgeInfoTakeThis, MSGBOX_DEFAULT)
	call(RustboroCity_Gym_EventScript_GiveCut)
    setflag(FLAG_DEFEATED_RUSTBORO_GYM)
    setflag(FLAG_BADGE01_GET)
    setvar(VAR_RUSTBORO_CITY_STATE, 1)
    addvar(VAR_PETALBURG_GYM_STATE, 1)
    setvar(VAR_0x8008, 1)
    call(Common_EventScript_SetGymTrainers)
    if (var(VAR_PETALBURG_GYM_STATE) == 6) {
        call(Common_EventScript_ReadyPetalburgGymForBattle)
    }
    end
}

script RustboroCity_Gym_EventScript_GiveCut {
    if (giveitem(ITEM_HM_CUT) == FALSE) {
        goto(Common_EventScript_BagIsFull)
    }
    setflag(FLAG_RECEIVED_HM_CUT)
    msgbox(RustboroCity_Gym_Text_ExplainCut, MSGBOX_DEFAULT)
    return
}

script RustboroCity_Gym_EventScript_Trinity {
    trainerbattle_single(TRAINER_TRINITY, RustboroCity_Gym_Text_TrinityIntro, RustboroCity_Gym_Text_TrinityDefeat)
    msgbox(RustboroCity_Gym_Text_TrinityPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RustboroCity_Gym_EventScript_Tommy {
    trainerbattle_single(TRAINER_TOMMY, RustboroCity_Gym_Text_TommyIntro, RustboroCity_Gym_Text_TommyDefeat)
    msgbox(RustboroCity_Gym_Text_TommyPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RustboroCity_Gym_EventScript_Marc {
    trainerbattle_single(TRAINER_MARC, RustboroCity_Gym_Text_MarcIntro, RustboroCity_Gym_Text_MarcDefeat)
    msgbox(RustboroCity_Gym_Text_MarcPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script RustboroCity_Gym_EventScript_GymGuide {
    lock_faceplayer
	if (flag(FLAG_RECEIVED_TM_ROCK_TOMB)) {
		msgbox(RustboroCity_Gym_Text_GymGuideNextGym, MSGBOX_DEFAULT)
	}
    elif (flag(FLAG_DEFEATED_RUSTBORO_GYM)) {
        msgbox(RustboroCity_Gym_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	if (giveitem(ITEM_TM_ROCK_TOMB) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		setflag(FLAG_RECEIVED_TM_ROCK_TOMB)
		msgbox(RustboroCity_Gym_Text_ExplainRockTomb, MSGBOX_DEFAULT)
    }
	else {
		msgbox(RustboroCity_Gym_Text_GymGuideAdvice, MSGBOX_DEFAULT)
	}
    release_end
}

script RustboroCity_Gym_EventScript_LeftGymStatue {
    lockall
    goto(RustboroCity_Gym_EventScript_GymStatue)
}

script RustboroCity_Gym_EventScript_RightGymStatue {
    lockall
    goto(RustboroCity_Gym_EventScript_GymStatue)
}

script RustboroCity_Gym_EventScript_GymStatue {
	if (flag(FLAG_BADGE01_GET)) {
        msgbox(RustboroCity_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(RustboroCity_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

script RustboroCity_Gym_EventScript_RegisterRoxanne {
    lockall
    pokenavcall(RustboroCity_Gym_Text_RoxanneRegisterCall)
    waitmessage
    delay(30)
    playfanfare(MUS_REGISTER_MATCH_CALL)
    msgbox(RustboroCity_Gym_Text_RegisteredRoxanne, MSGBOX_DEFAULT)
    waitfanfare
    closemessage
    delay(30)
    setflag(FLAG_ENABLE_ROXANNE_MATCH_CALL)
    clearflag(FLAG_ENABLE_ROXANNE_FIRST_CALL)
    releaseall
    end
}

text RustboroCity_Gym_Text_GymGuideAdvice {
	"Welcome to Rustboro Gym, young trainer!

	This gym is helmed by the formidable 
	Roxanne, known for her POKéMON's
	strength and resilience!

	She was a child prodigy born right here
	in Rustboro City.

	After graduating at the top of her
	class at Rustboro Trainer's School,
	she was quickly elevated to the rank of
	Gym Leader.

	Her advancement was not only
	unprecedented but also made her the
	youngest Gym Leader in the history of
	the Pokemon League!

	Proceed forward and defeat Roxanne's
	handpicked Gym Trainers!

	These Trainers will give you useful
	information about their Gym Leader,
	so you should listen carefully to what
	they have to say.

	Once they are all defeated, you will be
	able to challenge Roxanne herself!"
}

text RustboroCity_Gym_Text_GymGuidePostVictory {
	"Outstanding!
	You've defeated Roxanne!

	Now that you've earned a badge,
	you're one step closer to completing
	the Gym Challenge!

	As a badge holder, you are also entitled
	to our GYM's unique TECHNICAL MACHINE!"
}

text RustboroCity_Gym_Text_GymGuideNextGym {
	"Your next challenge lies to the east in
	Mauville City.

	There, you will be able to challenge
	Watson, the Gregarious Engineer."
}

text RustboroCity_Gym_Text_TrinityIntro {
	"You don't look like much!
	You won't even make it to Roxanne!"
}

text RustboroCity_Gym_Text_TrinityDefeat {
	"Hmph... not bad for a newbie."
}

text RustboroCity_Gym_Text_TrinityPostBattle {
	"I have a lot in common with Roxanne.
	I'm top of my class in Trainer's School,
	and my Phanpy fights just like one of
	her POKéMON.

	I know I'll be a Gym Leader too
	one day!"
}

text RustboroCity_Gym_Text_TommyIntro {
	"Roxanne believed in me enough to make
	me one of her Gym Trainers!

	I have to win, so I won't let her down!"
}

text RustboroCity_Gym_Text_TommyDefeat {
	"I'm sorry Roxanne...
	I lost."
}

text RustboroCity_Gym_Text_TommyPostBattle {
	"I chose Nacli as my POKéMON because
	it's the same type as Roxanne's ace.

	Maybe I can't follow in her footsteps
	like I thought I could."
}

text RustboroCity_Gym_Text_MarcIntro {
	"Not just anyone can battle my niece!
	Prove your metal to me or get lost!"
}

text RustboroCity_Gym_Text_MarcDefeat {
	"The way you battle\.
    It almost reminds me of\."
}

text RustboroCity_Gym_Text_MarcPostBattle {
	"I used to take Roxanne hiking around
	Meteor Falls when she was young.

	I think that's where she developed her
	passion for POKéMON.

	She even met one of her favorite
	POKéMON on Route 115!"
}

text RustboroCity_Gym_Text_RoxanneIntro {
	"Hello, challenger.

	I am ROXANNE, the GYM LEADER for
	RUSTBORO CITY.

	I'm always glad to be challenged by
	young trainers such as yourself.

	It takes courage and willpower for
	ANYONE to attempt the Gym Challenge,
	let alone one as young as you.

	Now, show me what you've learned.

	Let this battle mark the next stage in
	your development."
}

text RustboroCity_Gym_Text_RoxanneDefeat {
	"Congratulations!
	You've beaten me.

	I see that you've learned a lot despite
	only being a trainer for a short time.

	Please accept this badge as a
	commemoration of your victory."
}

text RustboroCity_Gym_Text_ReceivedStoneBadge {
	"{PLAYER} received the STONE BADGE
	from ROXANNE."
}

text RustboroCity_Gym_Text_StoneBadgeInfoTakeThis {
	"It is also my duty as Gym Leader to
	reward you with this HM."
}

text RustboroCity_Gym_Text_ExplainCut {
	"HIDDEN MACHINES, or HMs, contain the
	instructions to teach any eligible
	POKéMON moves that can be helpful for
	traversing terrain, but they do not
	have to be taught in order for a
	POKéMON to use them.

	In this case, HM01:CUT allows you to
	chop down small trees that are blocking
	your path.

	I hope this machine proves useful
	throughout your journey."
}

text RustboroCity_Gym_Text_ExplainRockTomb {
	"That TM contains the instructions in
	order to teach the move ROCK TOMB to
	any eligible POKéMON.

	As the name clearly indicates, it's a
	ROCK-TYPE move, but in addition to
	dealing damage, it also lowers the
	opponent's SPEED.

	This can allow you to turn the tables on
	your opponent if used effectively."
}

text RustboroCity_Gym_Text_RoxannePostBattle {
	"Talent like yours is rare to come by.

	I hope you continue to hone your skills,
	and perhaps, we'll meet again one day.

	Until then, you have my best wishes!"
}

text RustboroCity_Gym_Text_GymStatue {
	"RUSTBORO CITY POKéMON GYM"
}

text RustboroCity_Gym_Text_GymStatueCertified {
	"RUSTBORO CITY POKéMON GYM

	NEWEST VICTOR:
	{PLAYER}"
}

text RustboroCity_Gym_Text_RoxanneRegisterCall {
	"… … … … … …
	… … … … … Beep!

	{SPEAKER NAME_ROXANNE}Oh, hello, {PLAYER}?
	This is ROXANNE of RUSTBORO CITY.

	I heard from BRAWLY that you're
	moving up through the ranks of
	TRAINERS at an incredible clip.

	Well, I'd rather not think that
	I can't beat you.

	I promise, I will shape up my GYM
	so that you may challenge us again.

	I hope you'll be looking forward to
	that occasion as much as me!

	… … … … … …
	… … … … … Click!"
}

text RustboroCity_Gym_Text_RegisteredRoxanne {
	"Registered GYM LEADER ROXANNE
	in the POKéNAV."
}

text RustboroCity_Gym_Text_RoxannePreRematch {
	"{SPEAKER NAME_ROXANNE}I'm so glad to see you again.
	I'm ROXANNE, the GYM LEADER here.

	I'm sure we've both experienced many
	battles since we last met.

	I would like to see how much better
	we've become. Let us battle!"
}

text RustboroCity_Gym_Text_RoxanneRematchDefeat {
	"Grr…
	Again, I have lost…"
}

text RustboroCity_Gym_Text_RoxannePostRematch {
	"{SPEAKER NAME_ROXANNE}I still have much to learn
	when it comes to battling POKéMON.

	That awareness makes me love battling
	all that much more!"
}

text RustboroCity_Gym_Text_RoxanneRematchNeedTwoMons {
	"{SPEAKER NAME_ROXANNE}I'm so glad to see you again.
	I'm ROXANNE, the GYM LEADER here.

	I'm sure we've both experienced many
	battles since we last met.

	I would like to see how much better
	we've become…

	Oh, no…
	You only have one POKéMON with you?

	Please return with at least one more
	POKéMON."
}
