mapscripts Route8_WestEntrance_Frlg_MapScripts {}

script Route8_WestEntrance_EventScript_Guard {
    msgbox(Route8_WestEntrance_Text_HiHowsItGoing, MSGBOX_NPC)
    end
}

script Route8_WestEntrance_EventScript_GuardTriggerTop {
    lockall
    setvar(VAR_TEMP_1, 0)
    goto(Route8_WestEntrance_EventScript_GuardTrigger)
    end
}

script Route8_WestEntrance_EventScript_GuardTriggerMid {
    lockall
    setvar(VAR_TEMP_1, 1)
    goto(Route8_WestEntrance_EventScript_GuardTrigger)
    end
}

script Route8_WestEntrance_EventScript_GuardTriggerBottom {
    lockall
    setvar(VAR_TEMP_1, 2)
    goto(Route8_WestEntrance_EventScript_GuardTrigger)
    end
}

script Route8_WestEntrance_EventScript_GuardTrigger {
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    if (flag(FLAG_GOT_TEA)) {
        removeitem(ITEM_TEA)
    	goto(Route8_WestEntrance_EventScript_GuardDrinkTea)
    }
    msgbox(Route8_WestEntrance_Text_ThirstyOnGuardDuty)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkRight)
    waitmovement(0)
    releaseall
    end
}

script Route8_WestEntrance_EventScript_GuardDrinkTea {
    msgbox(Route8_WestEntrance_Text_ThatTeaLooksTasty)
    closemessage
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_PLAYER, Common_Movement_StepUp)
		case 1: applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
		case 2: applymovement(LOCALID_PLAYER, moves(walk_up * 2))
	}
	waitmovement(0)
    msgbox(Route8_WestEntrance_Text_ThanksIllShareTeaWithGuards)
    setvar(VAR_MAP_SCENE_ROUTE5_ROUTE6_ROUTE7_ROUTE8_GATES, 1)
    releaseall
    end
}

// Unused
script Route8_WestEntrance_EventScript_GiveSodaPop {
    removeitem(ITEM_SODA_POP)
    goto(Route8_WestEntrance_EventScript_GuardDrinkTea)
    end
}

// Unused
script Route8_WestEntrance_EventScript_GiveLemonade {
    removeitem(ITEM_LEMONADE)
    goto(Route8_WestEntrance_EventScript_GuardDrinkTea)
    end
}

text Route8_WestEntrance_Text_ThirstyOnGuardDuty {
	"I'm on guard duty.
	Gee, I'm thirsty, though!

	Oh, wait there, the road's closed."
}

text Route8_WestEntrance_Text_ThatTeaLooksTasty {
	"Oh, that TEA…
	It looks awfully tasty…"
}

text Route8_WestEntrance_Text_ThanksIllShareTeaWithGuards {
	"Huh? I can have this drink?
	Gee, thanks!
	… …
	Glug, glug…
	… …
	Gulp…
	If you want to go to SAFFRON
	CITY…
	… …
	You can go on through.

	I'll share this TEA with the other
	guards!"
}

text Route8_WestEntrance_Text_HiHowsItGoing {
	"Hi, how's it going?"
}
