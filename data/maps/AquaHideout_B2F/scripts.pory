mapscripts AquaHideout_B2F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
		if (flag(FLAG_TEAM_AQUA_ESCAPED_IN_SUBMARINE)) {
			setvar(VAR_TEMP_1, 1)
		}
		end
    }
}

script AquaHideout_B2F_EventScript_MattNoticePlayer {
    lockall
    setvar(VAR_0x8008, LOCALID_AQUA_HIDEOUT_MATT)
    playse(SE_PIN)
    applymovement(VAR_0x8008, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(VAR_0x8008, Common_Movement_FacePlayer)
    waitmovement(0)
    setvar(VAR_TEMP_1, 1)
    releaseall
    end
}

script AquaHideout_B2F_EventScript_Matt {
    trainerbattle_single(TRAINER_MATT, AquaHideout_B2F_Text_MattIntro, AquaHideout_B2F_Text_MattDefeat, AquaHideout_B2F_EventScript_SubmarineEscape)
    msgbox(AquaHideout_B2F_Text_MattPostBattle, MSGBOX_DEFAULT)
    release_end
}

script AquaHideout_B2F_EventScript_SubmarineEscape {
    setvar(VAR_0x8008, LOCALID_AQUA_HIDEOUT_MATT)
    setvar(VAR_0x8009, LOCALID_AQUA_HIDEOUT_SUBMARINE)
    applymovement(VAR_0x8008, Common_Movement_StepFasterLeft)
    waitmovement(0)
    delay(20)
    applymovement(VAR_0x8008, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(AquaHideout_B2F_Text_OurBossGotThroughHisPreparations, MSGBOX_DEFAULT)
    closemessage
    applymovement(VAR_0x8008, Common_Movement_StepFasterLeft)
    applymovement(VAR_0x8009, moves(walk_left * 4))
    waitmovement(0)
    removeobject(VAR_0x8009)
    delay(20)
    applymovement(VAR_0x8008, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(AquaHideout_B2F_Text_MattPostBattle, MSGBOX_DEFAULT)
    setflag(FLAG_TEAM_AQUA_ESCAPED_IN_SUBMARINE)
    setflag(FLAG_HIDE_LILYCOVE_CITY_AQUA_GRUNTS)
    release_end
}

// Unused
movement AquaHideout_B2F_Movement_SumbarineDepartRight {
    walk_right * 4
}

script AquaHideout_B2F_EventScript_Grunt4 {
    trainerbattle_single(TRAINER_GRUNT_AQUA_HIDEOUT_4, AquaHideout_B2F_Text_Grunt4Intro, AquaHideout_B2F_Text_Grunt4Defeat, AquaHideout_B2F_EventScript_Grunt4Defeated)
    msgbox(AquaHideout_B2F_Text_Grunt4PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script AquaHideout_B2F_EventScript_Grunt4Defeated {
    msgbox(AquaHideout_B2F_Text_Grunt4PostBattle, MSGBOX_DEFAULT)
    release_end
}

script AquaHideout_B2F_EventScript_Grunt6 {
    trainerbattle_single(TRAINER_GRUNT_AQUA_HIDEOUT_6, AquaHideout_B2F_Text_Grunt6Intro, AquaHideout_B2F_Text_Grunt6Defeat)
    msgbox(AquaHideout_B2F_Text_Grunt6PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script AquaHideout_B2F_EventScript_Grunt8 {
    trainerbattle_single(TRAINER_GRUNT_AQUA_HIDEOUT_8, AquaHideout_B2F_Text_Grunt8Intro, AquaHideout_B2F_Text_Grunt8Defeat)
    msgbox(AquaHideout_B2F_Text_Grunt8PostBattle, MSGBOX_AUTOCLOSE)
    end
}

text AquaHideout_B2F_Text_MattIntro {
	"Hehehe…

	Got here already, did you?
	We underestimated you!

	But this is it!

	I'm a cut above the GRUNTS you've seen
	so far.

	I'm not stalling for time.
	I'm going to pulverize you!"
}

text AquaHideout_B2F_Text_MattDefeat {
	"Hehehe…
	So, I lost, too…"
}

text AquaHideout_B2F_Text_OurBossGotThroughHisPreparations {
	"Hehehe!

	While I was toying with you, our BOSS
	got through his preparations!"
}

text AquaHideout_B2F_Text_MattPostBattle {
	"Hehehe!

	Our BOSS has already gone on his way to
	some cave under the sea!

	If you're going to give chase, you'd
	better search the big, wide sea beyond
	LILYCOVE.

	But will you find it then?
	Hehehe!"
}

text AquaHideout_B2F_Text_Grunt4Intro {
	"Wahahah, I grew weary of waiting!
	You owe me a battle, too!"
}

text AquaHideout_B2F_Text_Grunt4Defeat {
	"Tired of waiting…
	Lost and dazed…"
}

text AquaHideout_B2F_Text_Grunt4PostBattle {
	"BOSS…
	Is this good enough?"
}

text AquaHideout_B2F_Text_Grunt6Intro {
	"Warp panels, the HIDEOUT's pride
	and joy!

	You're clueless about where you are,
	aren't you?

	Fluster and tire out the enemy, then
	lower the boom! That's our plan!"
}

text AquaHideout_B2F_Text_Grunt6Defeat {
	"What's wrong with you?
	You're not tired at all!"
}

text AquaHideout_B2F_Text_Grunt6PostBattle {
	"That reminds me… I can't remember
	where I put the MASTER BALL.

	If I fail to guard it, our BOSS will
	chew me out…"
}

text AquaHideout_B2F_Text_Grunt8Intro {
	"When I joined TEAM AQUA, the first
	thing I had to learn was how these
	warp panels connected."
}

text AquaHideout_B2F_Text_Grunt8Defeat {
	"I was too occupied thinking about
	the warp panels…"
}

text AquaHideout_B2F_Text_Grunt8PostBattle {
	"I'll have to learn about how I can
	battle more effectively…"
}
