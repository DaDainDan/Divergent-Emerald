mapscripts SootopolisCity_House6_MapScripts {}

script SootopolisCity_House6_EventScript_Woman {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_WAILMER_DOLL)) {
        msgbox(SootopolisCity_House6_Text_LovePlushDolls, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_House6_Text_FirstGuestInWhileTakeDoll, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(SootopolisCity_House6_Text_DontWantThisDoll, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_House6_Text_TakeGoodCareOfIt, MSGBOX_DEFAULT)
    if (givedecoration(DECOR_WAILMER_DOLL) == FALSE) {
        bufferdecorationname(STR_VAR_2, DECOR_WAILMER_DOLL)
		msgbox(gText_NoRoomLeftForAnother, MSGBOX_DEFAULT)
		msgbox(SootopolisCity_House6_Text_IllHoldItForYou, MSGBOX_DEFAULT)
		release_end
    }
    setflag(FLAG_RECEIVED_WAILMER_DOLL)
    release_end
}

text SootopolisCity_House6_Text_FirstGuestInWhileTakeDoll {
	"Hello! You're our first guest in
	a good while.

	You've brightened up my day, so I'll
	give you a big WAILMER DOLL."
}

text SootopolisCity_House6_Text_TakeGoodCareOfIt {
	"Take good care of it!"
}

text SootopolisCity_House6_Text_IllHoldItForYou {
	"Oh, you want it, but not right now?
	Okay, then I'll hold it for you."
}

text SootopolisCity_House6_Text_DontWantThisDoll {
	"Are you sure?
	You don't want this DOLL?"
}

text SootopolisCity_House6_Text_LovePlushDolls {
	"I love plush DOLLS!"
}
