    trainerbattle_single(TRAINER_BUG_CATCHER_RICK, ViridianForest_Text_RickIntro, ViridianForest_Text_RickDefeat)
    msgbox(ViridianForest_Text_RickPostBattle, MSGBOX_AUTOCLOSE)
    end
}

