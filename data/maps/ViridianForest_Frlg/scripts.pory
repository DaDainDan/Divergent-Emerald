script ViridianForest_EventScript_Charlie {
    trainerbattle_single(TRAINER_BUG_CATCHER_CHARLIE, ViridianForest_Text_CharlieIntro, ViridianForest_Text_CharlieDefeat)
    msgbox(ViridianForest_Text_CharliePostBattle, MSGBOX_AUTOCLOSE)
    end
}

text ViridianForest_Text_FriendsItchingToBattle {
	"I came here with some friends to
	catch us some BUG POKéMON!

	They're all itching to get into
	some POKéMON battles!"
}

text ViridianForest_Text_RickIntro {
	"Hey! You have POKéMON!
	Come on!
	Let's battle 'em!"
}

text ViridianForest_Text_RickDefeat {
	"No!
	CATERPIE can't hack it!"
}

text ViridianForest_Text_RickPostBattle {
	"Ssh! You'll scare the bugs away.
	Another time, okay?"
}

text ViridianForest_Text_DougIntro {
	"Yo!
	You can't jam out if you're a
	POKéMON TRAINER!"
}

text ViridianForest_Text_DougDefeat {
	"Huh?
	I ran out of POKéMON!"
}

text ViridianForest_Text_DougPostBattle {
	"That totally stinks! I'm going to
	catch some stronger ones!"
}

text ViridianForest_Text_SammyIntro {
	"Hey, wait up!
	What's the hurry? Why the rush?"
}

text ViridianForest_Text_SammyDefeat {
	"I give!
	You're good at this!"
}

text ViridianForest_Text_SammyPostBattle {
	"Sometimes, you can find stuff on
	the ground.

	I'm looking for the stuff I
	dropped. Can you help me?"
}

text ViridianForest_Text_AnthonyIntro {
	"I might be little, but I won't like
	it if you go easy on me!"
}

text ViridianForest_Text_AnthonyDefeat {
	"Oh, boo.
	Nothing went right."
}

text ViridianForest_Text_AnthonyPostBattle {
	"I lost some of my allowance…"
}

text ViridianForest_Text_CharlieIntro {
	"Did you know that POKéMON evolve?"
}

text ViridianForest_Text_CharlieDefeat {
	"Oh!
	I lost!"
}

text ViridianForest_Text_CharliePostBattle {
	"BUG POKéMON evolve quickly.
	They're a lot of fun!"
}

text ViridianForest_Text_RanOutOfPokeBalls {
	"I was throwing POKé BALLS to
	catch POKéMON, and I ran out.

	That's why you can never have too
	many POKé BALLS."
}

text ViridianForest_Text_AvoidGrassyAreasWhenWeak {
	"TRAINER TIPS

	If your POKéMON are weak and you
	want to avoid battles, stay away
	from grassy areas!"
}

text ViridianForest_Text_UseAntidoteForPoison {
	"For poison, use ANTIDOTE!
	Get it at POKéMON MARTS!"
}

text ViridianForest_Text_ContactOakViaPCToRatePokedex {
	"TRAINER TIPS

	Contact PROF. OAK via a PC to
	get your POKéDEX evaluated!"
}

text ViridianForest_Text_CantCatchOwnedMons {
	"TRAINER TIPS

	You can't catch a POKéMON that
	belongs to someone else.

	Throw POKé BALLS only at wild
	POKéMON to catch them!"
}

text ViridianForest_Text_WeakenMonsBeforeCapture {
	"TRAINER TIPS

	Weaken POKéMON before attempting
	capture!

	When healthy, they may escape!"
}

text ViridianForest_Text_LeavingViridianForest {
	"LEAVING VIRIDIAN FOREST
	PEWTER CITY AHEAD"
}
