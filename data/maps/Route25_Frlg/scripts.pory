mapscripts Route25_Frlg_MapScripts {}

script Route25_EventScript_SeaCottageSign {
    msgbox(Route25_Text_SeaCottageSign, MSGBOX_SIGN)
    end
}

script Route25_EventScript_Man {
    msgbox(Route25_Text_AreYouHereAlone, MSGBOX_NPC)
    end
}

text Route25_Text_JoeyIntro {
	"Local TRAINERS come here to
	practice."
}

text Route25_Text_JoeyDefeat {
	"You're decent."
}

text Route25_Text_JoeyPostBattle {
	"All POKéMON have weaknesses.
	Even the strongest ones.

	That's why it's best to raise
	POKéMON of different types."
}

text Route25_Text_DanIntro {
	"Dad took me to a great party on
	the S.S. ANNE at VERMILION CITY."
}

text Route25_Text_DanDefeat {
	"I'm not mad!"
}

text Route25_Text_DanPostBattle {
	"On the S.S. ANNE, I saw TRAINERS
	from around the world."
}

text Route25_Text_FlintIntro {
	"I'm a cool guy.
	I've got a girlfriend!"
}

text Route25_Text_FlintDefeat {
	"Aww, darn…"
}

text Route25_Text_FlintPostBattle {
	"Oh, well.
	My girlfriend will cheer me up."
}

text Route25_Text_KelseyIntro {
	"Hi!
	My boyfriend is cool!"
}

text Route25_Text_KelseyDefeat {
	"My conditioning isn't the best…"
}

text Route25_Text_KelseyPostBattle {
	"I wish my boyfriend was as good
	as you."
}

text Route25_Text_ChadIntro {
	"I had this feeling…
	I knew I had to battle you!"
}

text Route25_Text_ChadDefeat {
	"I knew I'd lose, too!"
}

text Route25_Text_ChadPostBattle {
	"If your POKéMON gets confused,
	switch it out.

	That's a good tactic."
}

text Route25_Text_HaleyIntro {
	"My friend has many cute POKéMON.
	I'm so jealous!"
}

text Route25_Text_HaleyDefeat {
	"I'm not so jealous!"
}

text Route25_Text_HaleyPostBattle {
	"You came from MT. MOON?
	May I have a CLEFAIRY?"
}

text Route25_Text_FranklinIntro {
	"I just got down from MT. MOON,
	but I've still got gas in the tank!"
}

text Route25_Text_FranklinDefeat {
	"You worked hard!"
}

text Route25_Text_FranklinPostBattle {
	"Drat!
	A ZUBAT bit me back in that cave."
}

text Route25_Text_NobIntro {
	"I'm off to see a POKéMANIAC's
	collection at the cape."
}

text Route25_Text_NobDefeat {
	"You done got me, and real good,
	too!"
}

text Route25_Text_NobPostBattle {
	"The POKéMANIAC sure lives up to
	his name.

	His collection includes many rare
	species of POKéMON."
}

text Route25_Text_WayneIntro {
	"You're going to see BILL?
	First, we battle!"
}

text Route25_Text_WayneDefeat {
	"You're something."
}

text Route25_Text_WaynePostBattle {
	"The trail below is a shortcut to
	CERULEAN CITY."
}

text Route25_Text_SeaCottageSign {
	"SEA COTTAGE
	BILL lives here!"
}

text Route25_Text_MistyHighHopesAboutThisPlace {
	"This cape is a famous date spot.

	MISTY, the GYM LEADER, has high
	hopes about this place."
}

text Route25_Text_AreYouHereAlone {
	"Hello, are you here alone?

	If you're out at CERULEAN's cape…
	Well, it should be as a couple."
}
