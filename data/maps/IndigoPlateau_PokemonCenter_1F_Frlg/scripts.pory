mapscripts IndigoPlateau_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_INDIGO_PLATEAU)
		if (specialvar(VAR_RESULT, IsNationalPokedexEnabled) == TRUE && !flag(FLAG_IS_CHAMPION)) {
			setobjectxyperm(LOCALID_LEAGUE_DOOR_GUARD, 4, 2)
		}
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script IndigoPlateau_PokemonCenter_1F_EventScript_DoorGuard {
    lock_faceplayer
    if (specialvar(VAR_RESULT, IsNationalPokedexEnabled) == TRUE) {
		if (flag(FLAG_IS_CHAMPION)) {
			msgbox(IndigoPlateau_PokemonCenter_1F_Text_FaceEliteFourGoodLuck)
    		release_end
		}
		msgbox(IndigoPlateau_PokemonCenter_1F_Text_LoreleiIsAbsentClosedForTimeBeing)
		release_end
	}
    msgbox(IndigoPlateau_PokemonCenter_1F_Text_FaceEliteFourGoodLuck)
    release_end
}

script IndigoPlateau_PokemonCenter_1F_EventScript_GymGuy {
    msgbox(IndigoPlateau_PokemonCenter_1F_Text_GymGuyAdvice, MSGBOX_NPC)
    end
}

script IndigoPlateau_PokemonCenter_1F_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(IndigoPlateau_PokemonCenter_1F_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart IndigoPlateau_PokemonCenter_1F_Items {
    ITEM_ULTRA_BALL
    ITEM_GREAT_BALL
    ITEM_FULL_RESTORE
    ITEM_MAX_POTION
    ITEM_REVIVE
    ITEM_FULL_HEAL
    ITEM_MAX_REPEL
}

script IndigoPlateau_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

text IndigoPlateau_PokemonCenter_1F_Text_GymGuyAdvice {
	"Yo!
	Champ in the making!

	At the POKéMON LEAGUE, you will
	face the ELITE FOUR all in a row.

	If you lose, you have to start all
	over again!

	This is it!
	Go for it!"
}

text IndigoPlateau_PokemonCenter_1F_Text_FaceEliteFourGoodLuck {
	"From here on, you face the
	ELITE FOUR one by one.

	If you win, a door opens to the
	next TRAINER. Good luck!"
}

text IndigoPlateau_PokemonCenter_1F_Text_LoreleiIsAbsentClosedForTimeBeing {
	"I am so sorry, but you've wasted
	your time coming here.

	LORELEI of the ELITE FOUR is
	absent, you see.

	As a result, the POKéMON LEAGUE is
	closed for the time being."
}

text IndigoPlateau_PokemonCenter_1F_Text_AgathaWhuppedUs {
	"AGATHA's GHOST-type POKéMON are
	horrifically terrifying in toughness.

	I took my FIGHTING-type POKéMON
	and raised them to the max.

	I went at AGATHA feeling pretty
	confident, but she whupped us.

	That old lady's also got a really
	short fuse, too.

	It doesn't take anything to get
	that scary lady hollering."
}

text IndigoPlateau_PokemonCenter_1F_Text_LancesCousinGymLeaderFarAway {
	"Maybe becoming an ELITE FOUR
	member is in the blood.

	From what I've heard, LANCE has
	a cousin who's a GYM LEADER
	somewhere far away."
}
