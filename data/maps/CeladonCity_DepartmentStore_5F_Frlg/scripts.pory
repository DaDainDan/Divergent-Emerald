mapscripts CeladonCity_DepartmentStore_5F_Frlg_MapScripts {}

script CeladonCity_DepartmentStore_5F_EventScript_Gentleman {
    msgbox(CeladonCity_DepartmentStore_5F_Text_ExplainStatEnhancers, MSGBOX_NPC)
    end
}

script CeladonCity_DepartmentStore_5F_EventScript_Sailor {
    msgbox(CeladonCity_DepartmentStore_5F_Text_HereForStatEnhancers, MSGBOX_NPC)
    end
}

script CeladonCity_DepartmentStore_5F_EventScript_FloorSign {
    msgbox(CeladonCity_DepartmentStore_5F_Text_Drugstore, MSGBOX_SIGN)
    end
}

script CeladonCity_DepartmentStore_5F_EventScript_ClerkXItems {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(CeladonCity_DepartmentStore_5F_XItems)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart CeladonCity_DepartmentStore_5F_XItems {
    ITEM_X_ATTACK
    ITEM_X_DEFEND
    ITEM_X_SPEED
    ITEM_X_SPECIAL
    ITEM_X_ACCURACY
    ITEM_GUARD_SPEC
    ITEM_DIRE_HIT
}

script CeladonCity_DepartmentStore_5F_EventScript_ClerkVitamins {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(CeladonCity_DepartmentStore_5F_Vitamins)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart CeladonCity_DepartmentStore_5F_Vitamins {
    ITEM_HP_UP
    ITEM_PROTEIN
    ITEM_IRON
    ITEM_CALCIUM
    ITEM_ZINC
    ITEM_CARBOS
}

text CeladonCity_DepartmentStore_5F_Text_ExplainStatEnhancers {
	"POKéMON stat enhancers can be
	bought only here.

	HP UP increases the base HP of a
	POKéMON.

	CALCIUM raises the base SP. ATK
	stat of one POKéMON.

	ZINC boosts the base SP. DEF stat
	of one POKéMON.

	CARBOS enhances the base SPEED
	stat."
}

text CeladonCity_DepartmentStore_5F_Text_HereForStatEnhancers {
	"I'm here for POKéMON stat
	enhancers.

	PROTEIN increases the base ATTACK
	power.

	IRON increases the base DEFENSE
	stat."
}

text CeladonCity_DepartmentStore_5F_Text_Drugstore {
	"5F: DRUGSTORE"
}
