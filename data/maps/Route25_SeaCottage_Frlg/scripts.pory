const BILL_IN_TELEPORTER = FLAG_TEMP_2
const RETURN_AFTER_SS_TICKET = FLAG_TEMP_3

mapscripts Route25_SeaCottage_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (!flag(FLAG_HELPED_BILL_IN_SEA_COTTAGE)) {
			clearflag(FLAG_HIDE_BILL_CLEFAIRY)
			setobjectxyperm(LOCALID_BILL_HUMAN, 3, 3)
		}
		if (flag(FLAG_GOT_SS_TICKET)) {
			setflag(RETURN_AFTER_SS_TICKET)
		}
		end
    }
}

script Route25_SeaCottage_EventScript_Bill {
    lock_faceplayer
    if (flag(RETURN_AFTER_SS_TICKET)) {
        msgbox(Route25_SeaCottage_Text_CheckOutRareMonsOnPC)
    	release_end
    }
    elif (flag(FLAG_GOT_SS_TICKET)) {
        msgbox(Route25_SeaCottage_Text_SSAnnePartyYouGoInstead)
    	release_end
    }
    elif (flag(FLAG_HELPED_BILL_IN_SEA_COTTAGE)) {
        goto(Route25_SeaCottage_EventScript_BillGiveSSTicket)
    }
    if (checkplayergender == MALE) {
        msgbox(Route25_SeaCottage_Text_ImBillHelpMeOutPal, MSGBOX_YESNO)
    } else {
        msgbox(Route25_SeaCottage_Text_ImBillHelpMeOutLady, MSGBOX_YESNO)
    }
	if (var(VAR_RESULT) == NO) {
        if (checkplayergender == MALE) {
			msgbox(Route25_SeaCottage_Text_NoPleaseChief)
		} else {
			msgbox(Route25_SeaCottage_Text_NoPleaseBeautiful)
		}
    }
    msgbox(Route25_SeaCottage_Text_RunCellSeparationOnPC)
    closemessage
    delay(10)
	switch (var(VAR_FACING)) {
		case DIR_SOUTH: applymovement(LOCALID_BILL_CLEFAIRY, moves(walk_right,  walk_up * 2,  walk_left,  step_faster_up))
		default: applymovement(LOCALID_BILL_CLEFAIRY, moves(walk_up * 2))
	}
	waitmovement(0)
    opendoor(10, 3)
    waitdooranim
    applymovement(LOCALID_BILL_CLEFAIRY, Common_Movement_WalkUp)
    waitmovement(0)
    removeobject(LOCALID_BILL_CLEFAIRY)
    playse(SE_CONTEST_CURTAIN_FALL)
    closedoor(10, 3)
    waitdooranim
    setflag(BILL_IN_TELEPORTER)
    release_end
}

script Route25_SeaCottage_EventScript_BillGiveSSTicket {
    famechecker(FAMECHECKER_BILL, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    if (checkplayergender == MALE) {
        msgbox(Route25_SeaCottage_Text_ThanksBudTakeThis)
    } else {
        msgbox(Route25_SeaCottage_Text_ThanksLadyTakeThis)
    }
    if (checkitemspace(ITEM_SS_TICKET) == FALSE) {
        msgbox(Route25_SeaCottage_Text_YouveGotTooMuchStuff)
    	release_end
    }
    giveitem_msg(Route25_SeaCottage_Text_ReceivedSSTicketFromBill, ITEM_SS_TICKET, 1, MUS_RG_OBTAIN_KEY_ITEM)
    setflag(FLAG_GOT_SS_TICKET_DUP)
    setflag(FLAG_HIDE_NUGGET_BRIDGE_ROCKET)
    setflag(FLAG_GOT_SS_TICKET)
    setflag(FLAG_SYS_PC_LANETTE)
    msgbox(Route25_SeaCottage_Text_SSAnnePartyYouGoInstead)
    release_end
}

script Route25_SeaCottage_EventScript_Computer {
    lockall
    if (flag(RETURN_AFTER_SS_TICKET)) {
        msgbox(Route25_SeaCottage_Text_BillsFavoriteMonList)
    	goto(Route25_SeaCottage_EventScript_BillsMonList)
    }
    elif (flag(BILL_IN_TELEPORTER)) {
        goto(Route25_SeaCottage_EventScript_RunCellSeparator)
    }
    msgbox(Route25_SeaCottage_Text_TeleporterIsDisplayed)
    releaseall
    end
}

script Route25_SeaCottage_EventScript_RunCellSeparator {
    fadeoutbgm(0)
    msgbox(Route25_SeaCottage_Text_InitiatedTeleportersCellSeparator)
    closemessage
    clearflag(BILL_IN_TELEPORTER)
    setflag(FLAG_HELPED_BILL_IN_SEA_COTTAGE)
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(walk_up * 2,  walk_right * 2))
    waitmovement(0)
    delay(35)
    playse(SE_PIN)
    waitse
    setvar(VAR_0x8004, 0)
    special(AnimateTeleporterHousing)
    delay(10)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    setvar(VAR_0x8004, 1)
    special(AnimateTeleporterHousing)
    playse(SE_WARP_IN)
    special(AnimateTeleporterCable)
    waitse
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    call(Route25_SeaCottage_EventScript_PlayTeleporterBeepSE)
    opendoor(3, 3)
    waitdooranim
    fadeinbgm(0)
    addobject(LOCALID_BILL_HUMAN)
    clearflag(FLAG_HIDE_BILL_HUMAN_SEA_COTTAGE)
    delay(50)
    playfanfare(MUS_LEVEL_UP)
    applymovement(LOCALID_BILL_HUMAN, Common_Movement_WalkDown)
    waitmovement(0)
    waitfanfare
    applymovement(LOCALID_CAMERA, moves(delay_16 * 2,  walk_down * 2,  walk_left * 2))
    waitmovement(0)
    playse(SE_CONTEST_CURTAIN_FALL)
    closedoor(3, 3)
    waitdooranim
    applymovement(LOCALID_BILL_HUMAN, moves(walk_right * 4,  walk_down * 2))
    waitmovement(0)
    special(RemoveCameraObject)
    releaseall
    end
}

script Route25_SeaCottage_EventScript_PlayTeleporterBeepSE {
    playse(SE_BALL)
    waitse
    delay(20)
    return
}

script Route25_SeaCottage_EventScript_BillsMonList {
    message(Route25_SeaCottage_Text_SeeWhichMon)
    waitmessage
    multichoice(0, 0, MULTI_EEVEELUTIONS, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: setvar(VAR_0x800A, SPECIES_EEVEE)
		case 1: setvar(VAR_0x800A, SPECIES_FLAREON)
		case 2: setvar(VAR_0x800A, SPECIES_JOLTEON)
		case 3: setvar(VAR_0x800A, SPECIES_VAPOREON)
        case 4:
        case MULTI_B_PRESSED:
			releaseall
    		end
    }
	showmonpic(VAR_0x800A, 10, 3)
    waitbuttonpress
    hidemonpic
    copyvar(VAR_0x8004, VAR_0x800A)
    special(SetSeenMon)
    goto(Route25_SeaCottage_EventScript_BillsMonList)
    end
}

text Route25_SeaCottage_Text_ImBillHelpMeOutPal {
	"Hiya! I'm a POKéMON…
	…No I'm not!

	Call me BILL!
	I'm a true-blue POKéMANIAC!

	Hey!
	What's with that skeptical look?

	I'm not joshing you, pal.

	I screwed up an experiment and got
	combined with a POKéMON!

	So, how about it?
	Help me out here!"
}

text Route25_SeaCottage_Text_ImBillHelpMeOutLady {
	"Hiya! I'm a POKéMON…
	…No I'm not!

	Call me BILL!
	I'm a true-blue POKéMANIAC!

	Hey!
	What's with that skeptical look?

	I'm not joshing you, lady.

	I screwed up an experiment and got
	combined with a POKéMON!

	So, how about it?
	Help me out here!"
}

text Route25_SeaCottage_Text_RunCellSeparationOnPC {
	"Wait till I get inside the
	TELEPORTER.

	When I do, go to my PC and run
	the Cell Separation System."
}

text Route25_SeaCottage_Text_NoPleaseChief {
	"No!?
	Now don't be so cold!

	Come on, you gotta help a guy in
	deep, deep trouble!

	What do you say, chief?
	Please?
	Okay?
	All right!"
}

text Route25_SeaCottage_Text_NoPleaseBeautiful {
	"No!?
	Now don't be so cold!

	Come on, you gotta help a guy in
	deep, deep trouble!

	What do you say, beautiful?
	Please?
	Okay?
	All right!"
}

text Route25_SeaCottage_Text_ThanksBudTakeThis {
	"BILL: Yeehah!
	Thanks, bud! I owe you one!

	So, did you come to see my
	POKéMON collection?

	You didn't?
	That's a bummer.

	I've got to thank you…
	Oh, here, maybe this'll do."
}

text Route25_SeaCottage_Text_ThanksLadyTakeThis {
	"BILL: Yeehah!
	Thanks, lady! I owe you one!

	So, did you come to see my
	POKéMON collection?

	You didn't?
	That's a bummer.

	I've got to thank you…
	Oh, here, maybe this'll do."
}

