mapscripts LavenderTown_House2_Frlg_MapScripts {}

script LavenderTown_House2_EventScript_NameRater {
    lock_faceplayer
    msgbox(LavenderTown_House2_Text_WantMeToRateNicknames, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(LavenderTown_House2_Text_CritiqueWhichMonsNickname)
		special(ChoosePartyMon)
		if (var(VAR_0x8004) < PARTY_SIZE) {
			goto(LavenderTown_House2_EventScript_CheckCanRateMon)
		}
    } 
    goto(LavenderTown_House2_EventScript_DontRateNickname)
    end
}

script LavenderTown_House2_EventScript_DontRateNickname {
    msgbox(LavenderTown_House2_Text_ISeeComeVisitAgain)
    release_end
}

script LavenderTown_House2_EventScript_CheckCanRateMon {
    specialvar(VAR_RESULT, ScriptGetPartyMonSpecies)
    if (var(VAR_RESULT) == SPECIES_EGG) {
        msgbox(LavenderTown_House2_Text_ThatIsMerelyAnEgg)
    	release_end
    }
    special(BufferMonNickname)
    special(IsMonOTIDNotPlayers)
    if (var(VAR_RESULT) == TRUE) {
        goto(LavenderTown_House2_EventScript_CantNicknameTradeMon)
    }
    specialvar(VAR_RESULT, MonOTNameNotPlayer)
    special(BufferMonNickname)
    if (var(VAR_RESULT) == TRUE) {
        goto(LavenderTown_House2_EventScript_CantNicknameTradeMon)
    }
    msgbox(LavenderTown_House2_Text_GiveItANicerName, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(LavenderTown_House2_Text_WhatShallNewNicknameBe)
		call(Common_EventScript_NameReceivedPartyMon)
		specialvar(VAR_RESULT, TryPutNameRaterShowOnTheAir)
		special(BufferMonNickname)
		if (var(VAR_RESULT) == TRUE) {
			msgbox(LavenderTown_House2_Text_FromNowOnShallBeKnownAsName)
			release_end
		}
		msgbox(LavenderTown_House2_Text_FromNowOnShallBeKnownAsSameName)
		release_end
    }
    goto(LavenderTown_House2_EventScript_DontRateNickname)
    end
}

script LavenderTown_House2_EventScript_CantNicknameTradeMon {
    msgbox(LavenderTown_House2_Text_TrulyImpeccableName)
    release_end
}

text LavenderTown_House2_Text_WantMeToRateNicknames {
	"Hello, hello!
	I am the official NAME RATER!

	Want me to rate the nicknames of
	your POKéMON?"
}

text LavenderTown_House2_Text_CritiqueWhichMonsNickname {
	"Which POKéMON's nickname should
	I critique?"
}

text LavenderTown_House2_Text_GiveItANicerName {
	"{STR_VAR_1}, is it?
	That is a decent nickname!

	But, would you like me to give it
	a nicer name?

	How about it?"
}

text LavenderTown_House2_Text_WhatShallNewNicknameBe {
	"Ah, good. Then, what shall the new
	nickname be?"
}

text LavenderTown_House2_Text_FromNowOnShallBeKnownAsName {
	"Done! From now on, this POKéMON
	shall be known as {STR_VAR_1}!

	It is a better name than before!
	How fortunate for you!"
}

text LavenderTown_House2_Text_ISeeComeVisitAgain {
	"I see.
	Do come visit again."
}

text LavenderTown_House2_Text_FromNowOnShallBeKnownAsSameName {
	"Done! From now on, this POKéMON
	shall be known as {STR_VAR_1}!

	It looks no different from before,
	and yet, this is vastly superior!

	How fortunate for you!"
}

text LavenderTown_House2_Text_TrulyImpeccableName {
	"{STR_VAR_1}, is it?
	That is a truly impeccable name!

	Take good care of {STR_VAR_1}!"
}

text LavenderTown_House2_Text_ThatIsMerelyAnEgg {
	"Now, now.
	That is merely an EGG!"
}
