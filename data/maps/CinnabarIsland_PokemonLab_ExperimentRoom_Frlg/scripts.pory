const HELIX_FOSSIL = 1
const DOME_FOSSIL = 2
const OLD_AMBER = 3

mapscripts CinnabarIsland_PokemonLab_ExperimentRoom_Frlg_MapScripts {}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_Garett {
    lock_faceplayer
    setvar(VAR_0x8008, INGAME_TRADE_SEEL)
    call(EventScript_GetInGameTradeSpeciesInfo)
    if (flag(FLAG_DID_SEELOR_TRADE)) {
        msgbox(Trade_Text_IsntMyOldMonGreat)
    	release_end
    }
    msgbox(Trade_Text_LookingForMonWannaTradeForMon, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineTrade)
    }
    call(EventScript_ChooseMonForInGameTrade)
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineTrade)
    }
    call(EventScript_GetInGameTradeSpecies)
    if (var(VAR_RESULT) != VAR_0x8009) {
        bufferspeciesname(STR_VAR_1, VAR_0x8009)
		msgbox(Trade_Text_WhatThatsNoMon)
		release_end
    }
    call(EventScript_DoInGameTrade)
    msgbox(Trade_Text_HeyThanks)
    setflag(FLAG_DID_SEELOR_TRADE)
    release_end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineTrade {
    msgbox(Trade_Text_AwwOhWell)
    release_end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_FossilScientist {
    lock_faceplayer
    if (flag(FLAG_REVIVED_AMBER) && 
	  ((flag(FLAG_GOT_HELIX_FOSSIL) && flag(FLAG_REVIVED_HELIX)) || (flag(FLAG_GOT_DOME_FOSSIL) && flag(FLAG_REVIVED_DOME)))) {
        goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineReviveFossil)
    }
    if (var(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_REVIVE_STATE) == 2) {
        goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_GiveRevivedMon)
    }
    if (var(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_REVIVE_STATE) == 1) {
        msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_TakesTimeGoForWalk)
    	release_end
    }
	if (!flag(FLAG_GOT_HELIX_FOSSIL) && !flag(FLAG_GOT_DOME_FOSSIL) && !flag(FLAG_GOT_OLD_AMBER)) {
		msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_HaveYouAFossilForMe)
    	goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DontShowFossil)
	}
	message(CinnabarIsland_PokemonLab_ExperimentRoom_Text_HaveYouAFossilForMe)
    waitmessage
	if (flag(FLAG_GOT_HELIX_FOSSIL) && !flag(FLAG_REVIVED_HELIX)) {
		dynmultipush("HELIX FOSSIL", HELIX_FOSSIL)
	}
	if (flag(FLAG_GOT_DOME_FOSSIL) && !flag(FLAG_REVIVED_DOME)) {
		dynmultipush("DOME FOSSIL", DOME_FOSSIL)
	}
	if (flag(FLAG_GOT_OLD_AMBER) && !flag(FLAG_REVIVED_AMBER)) {
		dynmultipush("OLD AMBER", OLD_AMBER)
	}
	dynmultipush("EXIT", 0)
	dynmultistack(0, 0, FALSE, 5, FALSE, 0, DYN_MULTICHOICE_CB_NONE)
	switch (var(VAR_RESULT)) {
		case HELIX_FOSSIL: setvar(VAR_EXCHANGE_ITEM, ITEM_HELIX_FOSSIL)
		case DOME_FOSSIL: setvar(VAR_EXCHANGE_ITEM, ITEM_DOME_FOSSIL)
		case OLD_AMBER: setvar(VAR_EXCHANGE_ITEM, ITEM_OLD_AMBER)
		case 0:
		case MULTI_B_PRESSED: 
			goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DontShowFossil)
	}
	goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_ShowFossil)
    end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineReviveFossil {
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_YouComeAgain)
    release_end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DontShowFossil {
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_NoIsTooBad)
    release_end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_ShowFossil {
	switch (var(VAR_EXCHANGE_ITEM)) {
		case ITEM_HELIX_FOSSIL: bufferspeciesname(STR_VAR_1, SPECIES_OMANYTE)
		case ITEM_DOME_FOSSIL: bufferspeciesname(STR_VAR_1, SPECIES_KABUTO)
		case ITEM_OLD_AMBER: bufferspeciesname(STR_VAR_1, SPECIES_AERODACTYL)
	}
    bufferitemname(STR_VAR_2, VAR_EXCHANGE_ITEM)
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_ThatFossilIsOfMonMakeItLiveAgain, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_DeclineReviveFossil)
    }
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_HandedFossilToWeirdDoctor)
    textcolor(NPC_TEXT_COLOR_MALE)
    removeitem(VAR_EXCHANGE_ITEM)
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_TakesTimeGoForWalk)
    setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_REVIVE_STATE, 1)
	switch (var(VAR_EXCHANGE_ITEM)) {
		case ITEM_HELIX_FOSSIL: setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_WHICH_FOSSIL, HELIX_FOSSIL)
		case ITEM_DOME_FOSSIL: setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_WHICH_FOSSIL, DOME_FOSSIL)
		case ITEM_OLD_AMBER: setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_WHICH_FOSSIL, OLD_AMBER)
	}
    release_end
}

script CinnabarIsland_PokemonLab_ExperimentRoom_EventScript_GiveRevivedMon {
	switch (var(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_WHICH_FOSSIL)) {
		case HELIX_FOSSIL: setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_OMANYTE)
		case DOME_FOSSIL: setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_KABUTO)
		case OLD_AMBER: setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_AERODACTYL)
	}
	bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    msgbox(CinnabarIsland_PokemonLab_ExperimentRoom_Text_FossilMonBackToLife)
    if (givemon(VAR_TEMP_TRANSFERRED_SPECIES, 5) == MON_CANT_GIVE) {
		goto(Common_EventScript_NoMoreRoomForPokemon)
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	switch (var(VAR_TEMP_TRANSFERRED_SPECIES)) {
		case SPECIES_OMANYTE: setflag(FLAG_REVIVED_HELIX)
		case SPECIES_KABUTO: setflag(FLAG_REVIVED_DOME)
		case SPECIES_AERODACTYL: setflag(FLAG_REVIVED_AMBER)
	}
	textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_LEVEL_UP)
    message(CinnabarIsland_PokemonLab_ExperimentRoom_Text_ReceivedMonFromDoctor)
    waitmessage
    waitfanfare
    setvar(VAR_MAP_SCENE_CINNABAR_ISLAND_POKEMON_LAB_EXPERIMENT_ROOM_REVIVE_STATE, 0)
    msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_GetGiftMonPartySlot)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
    release_end
}

text Text_MetronomeTeach {
	"Tch-tch-tch!
	I'll teach you a nifty move.

	Teach it to a POKéMON, and watch
	the fun unfold!

	It's a move called METRONOME.
	Does it strike your fancy?"
}

text Text_MetronomeDeclined {
	"I tell you, it's a lot of fun!"
}

text Text_MetronomeWhichMon {
	"Okay!
	Which POKéMON should I teach?"
}

text Text_MetronomeTaught {
	"Tch-tch-tch!
	That's the sound of a METRONOME.

	It tweaks your POKéMON's brain into
	using moves it doesn't even know."
}

text CinnabarIsland_PokemonLab_ExperimentRoom_Text_HaveYouAFossilForMe {
	"Hiya!

	I am important doctor.
	Yes, very much so, indeed.

	Here, I study rare POKéMON fossils.
	All the time, I study.

	You!
	Have you a fossil for me?"
}

text CinnabarIsland_PokemonLab_ExperimentRoom_Text_NoIsTooBad {
	"No!
	Is too bad!"
}

