script AquaHideout_B1F_EventScript_Grunt7 {
    trainerbattle_single(TRAINER_GRUNT_AQUA_HIDEOUT_7, AquaHideout_B1F_Text_Grunt7Intro, AquaHideout_B1F_Text_Grunt7Defeat)
