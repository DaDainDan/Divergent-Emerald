mapscripts MossdeepCity_House4_MapScripts {}

script MossdeepCity_House4_EventScript_Woman {
    lock_faceplayer
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(MossdeepCity_House4_Text_BrotherLikesToVisitBasesAndBattle, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MossdeepCity_House4_Text_BrotherLikesToFindBases, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_House4_EventScript_NinjaBoy {
    lock_faceplayer
    special(CheckPlayerHasSecretBase)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(MossdeepCity_House4_Text_MakeSecretBase, MSGBOX_DEFAULT)
    	release_end
    }
    special(GetSecretBaseNearbyMapName)
    msgbox(MossdeepCity_House4_Text_YouMadeSecretBaseNearX, MSGBOX_DEFAULT)
    release_end
}

script MossdeepCity_House4_EventScript_Skitty {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_SKITTY, CRY_MODE_NORMAL)
    msgbox(MossdeepCity_House4_Text_Skitty, MSGBOX_DEFAULT)
    waitmoncry
    release_end
}

text MossdeepCity_House4_Text_BrotherLikesToFindBases {
	"My little brother says he likes to go
	find people's SECRET BASES."
}

text MossdeepCity_House4_Text_BrotherLikesToVisitBasesAndBattle {
	"My little brother says he likes to
	visit people's SECRET BASES and have
	POKéMON battles."
}

text MossdeepCity_House4_Text_YouMadeSecretBaseNearX {
	"Was it you who made a SECRET BASE
	near {STR_VAR_1}?"
}

text MossdeepCity_House4_Text_MakeSecretBase {
	"You should make a SECRET BASE
	somewhere. I'll go find it!"
}

text MossdeepCity_House4_Text_Skitty {
	"SKITTY: Miyaan?"
}
