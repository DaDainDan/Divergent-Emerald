mapscripts SevenIsland_Mart_Frlg_MapScripts {}

script SevenIsland_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(SevenIsland_Mart_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart SevenIsland_Mart_Items {
    ITEM_ULTRA_BALL
    ITEM_GREAT_BALL
    ITEM_FULL_RESTORE
    ITEM_MAX_POTION
    ITEM_HYPER_POTION
    ITEM_REVIVE
    ITEM_FULL_HEAL
    ITEM_ESCAPE_ROPE
    ITEM_MAX_REPEL
}

script SevenIsland_Mart_EventScript_Lass {
    msgbox(SevenIsland_Mart_Text_MonHavePersonalitiesOfTheirOwn, MSGBOX_NPC)
    end
}

script SevenIsland_Mart_EventScript_Hiker {
    msgbox(SevenIsland_Mart_Text_PreparationsCompleteForRuins, MSGBOX_NPC)
    end
}

script SevenIsland_Mart_EventScript_Fisher {
    msgbox(SevenIsland_Mart_Text_NeedToFishOnSevenIsland, MSGBOX_NPC)
    end
}

text SevenIsland_Mart_Text_MonHavePersonalitiesOfTheirOwn {
	"POKéMON have personalities of their
	own, just like people.

	My PIKACHU has a HASTY nature,
	so it grew to be a speedy POKéMON."
}

text SevenIsland_Mart_Text_PreparationsCompleteForRuins {
	"Okay, preparations are complete
	for me to explore the RUINS."
}

text SevenIsland_Mart_Text_NeedToFishOnSevenIsland {
	"I need to fish on SEVEN ISLAND.

	That will complete my fishing tour
	of the SEVII ISLANDS.

	I'd better stock up on some
	POKé BALLS first, though."
}
