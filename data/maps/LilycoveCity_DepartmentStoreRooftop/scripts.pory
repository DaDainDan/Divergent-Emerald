mapscripts LilycoveCity_DepartmentStoreRooftop_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        getpokenewsactive(POKENEWS_LILYCOVE)
		if (var(VAR_RESULT) == TRUE) {
			clearflag(FLAG_HIDE_LILYCOVE_DEPARTMENT_STORE_ROOFTOP_SALE_WOMAN)
		} else {
			setflag(FLAG_HIDE_LILYCOVE_DEPARTMENT_STORE_ROOFTOP_SALE_WOMAN)
		}
		end
    }
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_SaleWoman {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemartdecoration(LilycoveCity_DepartmentStoreRooftop_PokemartDecor_ClearOutSale)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart LilycoveCity_DepartmentStoreRooftop_PokemartDecor_ClearOutSale {
    DECOR_MUD_BALL
    DECOR_FENCE_LENGTH
    DECOR_FENCE_WIDTH
    DECOR_TIRE
    DECOR_BREAKABLE_DOOR
    DECOR_SOLID_BOARD
    DECOR_SAND_ORNAMENT
    DECOR_STAND
    DECOR_SLIDE
    DECOR_TV
    DECOR_ROUND_TV
    DECOR_CUTE_TV
    DECOR_WAILMER_DOLL
    DECOR_RHYDON_DOLL
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_Man {
    lock_faceplayer
    getpokenewsactive(POKENEWS_LILYCOVE)
    if (var(VAR_RESULT) == TRUE) {
        msgbox(LilycoveCity_DepartmentStoreRooftop_Text_BeenWaitingForClearOutSale, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_DepartmentStoreRooftop_Text_SetDatesForClearOutSales, MSGBOX_DEFAULT)
    release_end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_ThirstyMan {
    msgbox(LilycoveCity_DepartmentStoreRooftop_Text_BoneDryThirsty, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_VendingMachine {
    lockall
    message(LilycoveCity_DepartmentStoreRooftop_Text_WhichDrinkWouldYouLike)
    waitmessage
    showmoneybox(0, 0)
    goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseDrink)
    end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseDrink {
    multichoice(16, 0, MULTI_VENDING_MACHINE, FALSE)
    copyvar(VAR_TEMP_1, VAR_RESULT)
    switch (var(VAR_TEMP_1)) {
        case 0: setvar(VAR_TEMP_0, ITEM_FRESH_WATER)
        case 1: setvar(VAR_TEMP_0, ITEM_SODA_POP)
        case 2: setvar(VAR_TEMP_0, ITEM_LEMONADE)
		default:
			msgbox(LilycoveCity_DepartmentStoreRooftop_Text_DecidedAgainstBuyingDrink, MSGBOX_DEFAULT)
    		goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ExitVendingMachine)
    }
    switch (var(VAR_TEMP_0)) {
		case ITEM_FRESH_WATER: checkmoney(200)
		case ITEM_SODA_POP: checkmoney(300)
		case ITEM_LEMONADE: checkmoney(350)
	}
    if (var(VAR_RESULT) == FALSE) {
        msgbox(LilycoveCity_DepartmentStoreRooftop_Text_NotEnoughMoney, MSGBOX_DEFAULT)
		goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ExitVendingMachine)
    }
    if (checkitemspace(VAR_TEMP_0) == FALSE) {
        goto(LilycoveCity_DepartmentStoreRooftop_EventScript_NoRoomForDrink)
    }
	switch (var(VAR_TEMP_0)) {
		case ITEM_FRESH_WATER: removemoney(200)
		case ITEM_SODA_POP: removemoney(300)
		case ITEM_LEMONADE: removemoney(350)
	}
    updatemoneybox
    bufferitemname(STR_VAR_1, VAR_TEMP_0)
    playse(SE_VEND)
    msgbox(LilycoveCity_DepartmentStoreRooftop_Text_CanOfDrinkDroppedDown, MSGBOX_DEFAULT)
    call(LilycoveCity_DepartmentStoreRooftop_EventScript_GiveDrink)
    call(LilycoveCity_DepartmentStoreRooftop_EventScript_RandomExtraDrink) // 1/64 chance of an additional drink dropping
    call(LilycoveCity_DepartmentStoreRooftop_EventScript_RandomExtraDrink) // 1/64 * the prev 1/64 chance of a third additional drink dropping, ~ 0.02% chance
    goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseNewDrink)
    end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_GiveDrink {
	additem(VAR_TEMP_0)
    bufferitemname(STR_VAR_2, VAR_TEMP_0)
    bufferstdstring(STR_VAR_3, STDSTRING_ITEMS)
    msgbox(gText_PutItemInPocket, MSGBOX_DEFAULT)
	return
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_RandomExtraDrink {
	if (random(64) != 0) {
        goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseNewDrink)
    }
    elif (checkitemspace(VAR_TEMP_0) == FALSE) {
        goto(LilycoveCity_DepartmentStoreRooftop_EventScript_NoRoomForDrink)
    }
    playse(SE_VEND)
    msgbox(LilycoveCity_DepartmentStoreRooftop_Text_ExtraCanOfDrinkDroppedDown, MSGBOX_DEFAULT)
    call(LilycoveCity_DepartmentStoreRooftop_EventScript_GiveDrink)
	return
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseNewDrink {
    message(LilycoveCity_DepartmentStoreRooftop_Text_WhichDrinkWouldYouLike)
    waitmessage
    goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ChooseDrink)
    end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_NoRoomForDrink {
    msgbox(gText_TheBagIsFull, MSGBOX_DEFAULT)
    goto(LilycoveCity_DepartmentStoreRooftop_EventScript_ExitVendingMachine)
    end
}

script LilycoveCity_DepartmentStoreRooftop_EventScript_ExitVendingMachine {
    hidemoneybox
    releaseall
    end
}

text LilycoveCity_DepartmentStoreRooftop_Text_SetDatesForClearOutSales {
	"Don't they have set dates for their
	clear-out sales?

	I watch TV, but they never show any
	commercials."
}

text LilycoveCity_DepartmentStoreRooftop_Text_BeenWaitingForClearOutSale {
	"Yes! I've been waiting a long time for
	this clear-out sale.

	They have items that you can only get
	here. I'm going to load up, that I am!"
}

text LilycoveCity_DepartmentStoreRooftop_Text_BoneDryThirsty {
	"Ohh… I'm bone-dry thirsty!"
}

text LilycoveCity_DepartmentStoreRooftop_Text_WhichDrinkWouldYouLike {
	"It's a VENDING MACHINE.
	Which drink would you like?"
}

text LilycoveCity_DepartmentStoreRooftop_Text_CanOfDrinkDroppedDown {
	"Clang!

	A can of {STR_VAR_1} dropped down."
}

text LilycoveCity_DepartmentStoreRooftop_Text_ExtraCanOfDrinkDroppedDown {
	"Clang!

	Score! An extra can of {STR_VAR_1}
	dropped down!"
}

text LilycoveCity_DepartmentStoreRooftop_Text_NotEnoughMoney {
	"Not enough money…"
}

text LilycoveCity_DepartmentStoreRooftop_Text_DecidedAgainstBuyingDrink {
	"Decided against buying a drink."
}
