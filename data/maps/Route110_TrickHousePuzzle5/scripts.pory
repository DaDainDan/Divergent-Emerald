script Route110_TrickHousePuzzle5_EventScript_Mechadoll1Activate {
    setvar(VAR_TEMP_1, 1)
    setvar(VAR_TEMP_8, LOCALID_MECHADOLL_1)
    call(Route110_TrickHousePuzzle5_EventScript_MechadollAlert)
	switch (var(VAR_TEMP_9)) {
		case 1: call(Route110_TrickHousePuzzle5_EventScript_MechadollWalkLeft1)
		case 2: call(Route110_TrickHousePuzzle5_EventScript_MechadollWalkLeft2)
		case 3: call(Route110_TrickHousePuzzle5_EventScript_MechadollWalkLeft3)
		case 4: call(Route110_TrickHousePuzzle5_EventScript_MechadollWalkLeft4)
	}
    msgbox(Route110_TrickHousePuzzle5_Text_Mechadoll1Intro, MSGBOX_DEFAULT)
    random(3)
    switch (var(VAR_RESULT)) {
        case 0: goto(Route110_TrickHousePuzzle5_EventScript_Mechadoll1Quiz1)
        case 1: goto(Route110_TrickHousePuzzle5_EventScript_Mechadoll1Quiz2)
        case 2: goto(Route110_TrickHousePuzzle5_EventScript_Mechadoll1Quiz3)
    }
    end
}

