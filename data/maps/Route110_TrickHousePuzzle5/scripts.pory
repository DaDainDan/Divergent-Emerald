	applymovement(VAR_TEMP_8, Common_Movement_WalkRight)
	waitmovement(0)
    return
}

script Route110_TrickHousePuzzle5_EventScript_MechadollWalkRight2 {
	applymovement(VAR_TEMP_8, moves(walk_right * 2))
	waitmovement(0)
    return
}

script Route110_TrickHousePuzzle5_EventScript_MechadollWalkRight3 {
	applymovement(VAR_TEMP_8, moves(walk_right * 3))
	waitmovement(0)
    return
}

script Route110_TrickHousePuzzle5_EventScript_MechadollWalkRight4 {
	applymovement(VAR_TEMP_8, moves(walk_right * 4))
	waitmovement(0)
    return
}

script Route110_TrickHousePuzzle5_EventScript_MechadollWalkRight5 {
	applymovement(VAR_TEMP_8, moves(walk_right * 5))
    waitmovement(0)
    return
}

