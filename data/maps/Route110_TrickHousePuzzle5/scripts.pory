text Route110_TrickHousePuzzle5_Text_WroteSecretCodeLockOpened {
	"{PLAYER} wrote down the secret code
	on the door.

	“TRICK MASTER is a genius.”
	… … … … … … … …

	The lock clicked open!"
}

text Route110_TrickHousePuzzle5_Text_Mechadoll1Intro {
	"CLICKETY-CLACK…
	MECHADOLL 1 AM I!

	IF YOU ANSWER QUIZZES CORRECTLY,
	THEN YOU WILL GO TO MECHADOLL 5.
	THEN YOU CAN OBTAIN THE SECRET CODE."
}

