mapscripts FiveIsland_LostCave_Room1_Frlg_MapScripts {}

script FiveIsland_LostCave_Room1_EventScript_Lawson {
    trainerbattle_single(TRAINER_RUIN_MANIAC_LAWSON, FiveIsland_LostCave_Room1_Text_LawsonIntro, FiveIsland_LostCave_Room1_Text_LawsonDefeat)
    msgbox(FiveIsland_LostCave_Room1_Text_LawsonPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text FiveIsland_LostCave_Room1_Text_LawsonIntro {
	"Aiyeeeeeh!

	I thought this was an ancient ruin.
	But it's teeming with ghosts!"
}

text FiveIsland_LostCave_Room1_Text_LawsonDefeat {
	"Aiyeeeeeh!
	Mercy!"
}

text FiveIsland_LostCave_Room1_Text_LawsonPostBattle {
	"I'm trying to get out of here, but
	I always end up at the same spot.

	Maybe the number of boulders is
	a hint…"
}
