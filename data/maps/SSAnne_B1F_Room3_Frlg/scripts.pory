mapscripts SSAnne_B1F_Room3_Frlg_MapScripts {}

script SSAnne_B1F_Room3_EventScript_Dylan {
    trainerbattle_single(TRAINER_SAILOR_DYLAN, SSAnne_B1F_Room3_Text_DylanIntro, SSAnne_B1F_Room3_Text_DylanDefeat)
    msgbox(SSAnne_B1F_Room3_Text_DylanPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SSAnne_B1F_Room3_Text_DylanIntro {
	"I like feisty kids like you!"
}

text SSAnne_B1F_Room3_Text_DylanDefeat {
	"Argh!
	Lost it!"
}

text SSAnne_B1F_Room3_Text_DylanPostBattle {
	"Sea POKéMON live in deep water.
	You'll need a ROD to fish them up!"
}
