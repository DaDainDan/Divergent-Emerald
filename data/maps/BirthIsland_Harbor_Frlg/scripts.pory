mapscripts BirthIsland_Harbor_Frlg_MapScripts {}

script BirthIsland_Harbor_EventScript_Sailor_Frlg {
    lock_faceplayer
    message(Text_WhereDoYouWantToSail)
    waitmessage
    setvar(VAR_0x8004, SEAGALLOP_BIRTH_ISLAND)
    multichoice(20, 8, MULTI_SEAGALLOP_VERMILION, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(EventScript_SailToVermilionCity)
        case 1:
        case MULTI_B_PRESSED: 
            goto(EventScript_CancelSail)
    }
    end
}
