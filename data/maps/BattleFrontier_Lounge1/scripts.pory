mapscripts BattleFrontier_Lounge1_MapScripts {}

script BattleFrontier_Lounge1_EventScript_Breeder {
    lock_faceplayer
    if (!flag(FLAG_MET_BATTLE_FRONTIER_BREEDER)) {
        msgbox(BattleFrontier_Lounge1_Text_PokemonBreederIntro, MSGBOX_DEFAULT)
		setflag(FLAG_MET_BATTLE_FRONTIER_BREEDER)
    } else {
        msgbox(BattleFrontier_Lounge1_Text_LetsLookAtYourPokemon, MSGBOX_DEFAULT)
    }
    goto(BattleFrontier_Lounge1_EventScript_ChooseMonToShowBreeder)
    end
}

script BattleFrontier_Lounge1_EventScript_ChooseMonToShowBreeder {
    chooseboxmon
    waitstate
    if (var(VAR_0x8004) == PARTY_NOTHING_CHOSEN) {
        msgbox(BattleFrontier_Lounge1_Text_NoTimeForMyAdvice, MSGBOX_DEFAULT)
    	release_end
    } else {
		goto(BattleFrontier_Lounge1_EventScript_ShowMonToBreeder)
	}
    end
}

// BufferVarsForIVRater buffers the following values
// VAR_0x8005: Sum of the mons IVs
// VAR_0x8006: Stat id of highest IV stat
// VAR_0x8007: IV of the highest IV stat
script BattleFrontier_Lounge1_EventScript_ShowMonToBreeder {
    specialvar(VAR_RESULT, ScriptGetPartyMonSpecies)
    if (var(VAR_RESULT) == SPECIES_EGG) {
        msgbox(BattleFrontier_Lounge1_Text_EvenICantTell, MSGBOX_DEFAULT)
		goto(BattleFrontier_Lounge1_EventScript_ChooseMonToShowBreeder)
    	end
    }
    special(BufferVarsForIVRater)
    if (var(VAR_0x8005) <= 90) { // Average of 15
        msgbox(BattleFrontier_Lounge1_Text_AverageAbility, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8005) <= 120) { // Average of 20
        msgbox(BattleFrontier_Lounge1_Text_BetterThanAverageAbility, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8005) <= 150) { // Average of 25
        msgbox(BattleFrontier_Lounge1_Text_ImpressiveAbility, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8005) >= 151) { // Average of > 25
        msgbox(BattleFrontier_Lounge1_Text_OutstandingAbility, MSGBOX_DEFAULT)
    }
	goto(BattleFrontier_Lounge1_EventScript_HighestIVStat)
    end
}

// Comment on the highest IV stat
script BattleFrontier_Lounge1_EventScript_HighestIVStat {
	switch (var(VAR_0x8006)) {
		case STAT_HP: msgbox(BattleFrontier_Lounge1_Text_BestAspectHP, MSGBOX_DEFAULT)
		case STAT_ATK: msgbox(BattleFrontier_Lounge1_Text_BestAspectAtk, MSGBOX_DEFAULT)
		case STAT_DEF: msgbox(BattleFrontier_Lounge1_Text_BestAspectDef, MSGBOX_DEFAULT)
		case STAT_SPEED: msgbox(BattleFrontier_Lounge1_Text_BestAspectSpeed, MSGBOX_DEFAULT)
		case STAT_SPATK: msgbox(BattleFrontier_Lounge1_Text_BestAspectSpAtk, MSGBOX_DEFAULT)
		case STAT_SPDEF: msgbox(BattleFrontier_Lounge1_Text_BestAspectSpDef, MSGBOX_DEFAULT)
	}
    goto(BattleFrontier_Lounge1_EventScript_HighestIVValue)
    end
}

// Comment on the highest IV value
script BattleFrontier_Lounge1_EventScript_HighestIVValue {
    if (var(VAR_0x8007) <= 15) {
        msgbox(BattleFrontier_Lounge1_Text_StatRelativelyGood, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8007) <= 25) {
        msgbox(BattleFrontier_Lounge1_Text_StatImpressive, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8007) <= 30) {
        msgbox(BattleFrontier_Lounge1_Text_StatOutstanding, MSGBOX_DEFAULT)
    }
    elif (var(VAR_0x8007) >= 31) {
        msgbox(BattleFrontier_Lounge1_Text_StatFlawless, MSGBOX_DEFAULT)
    }
    release_end
}

script BattleFrontier_Lounge1_EventScript_Boy1 {
    msgbox(BattleFrontier_Lounge1_Text_SaidMyMonIsOutstanding, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge1_EventScript_Boy2 {
    msgbox(BattleFrontier_Lounge1_Text_DidntDoAnythingSpecialRaisingIt, MSGBOX_NPC)
    end
}

text BattleFrontier_Lounge1_Text_PokemonBreederIntro {
	"For 70 years I have raised POKéMON!
	I am the man they revere as
	the legendary top POKéMON BREEDER!

	If you ever become as seasoned as me,
	you'll see the abilities of POKéMON
	at a glance.

	You're a TRAINER. Doesn't it interest
	you to know your own POKéMON's
	abilities?

	Here!
	Let's have a look at your POKéMON!"
}

text BattleFrontier_Lounge1_Text_AverageAbility {
	"…Hmm…

	This one, overall, I would describe
	as being of average ability."
}

text BattleFrontier_Lounge1_Text_BetterThanAverageAbility {
	"…Hmm…

	This one, overall, I would describe as
	having better-than-average ability."
}

text BattleFrontier_Lounge1_Text_ImpressiveAbility {
	"…Hmm…

	This one, overall, I would say is
	quite impressive in ability!"
}

text BattleFrontier_Lounge1_Text_OutstandingAbility {
	"…Hmm…

	This one, overall, I would say is
	wonderfully outstanding in ability!"
}

text BattleFrontier_Lounge1_Text_BestAspectHP {
	"Incidentally, the best aspect of it,
	I would say, is its HP…"
}

text BattleFrontier_Lounge1_Text_BestAspectAtk {
	"Incidentally, the best aspect of it,
	I would say, is its ATTACK…"
}

text BattleFrontier_Lounge1_Text_BestAspectDef {
	"Incidentally, the best aspect of it,
	I would say, is its DEFENSE…"
}

text BattleFrontier_Lounge1_Text_BestAspectSpAtk {
	"Incidentally, the best aspect of it,
	I would say, is its SPECIAL ATTACK…"
}

text BattleFrontier_Lounge1_Text_BestAspectSpDef {
	"Incidentally, the best aspect of it,
	I would say, is its SPECIAL DEFENSE…"
}

text BattleFrontier_Lounge1_Text_BestAspectSpeed {
	"Incidentally, the best aspect of it,
	I would say, is its SPEED…"
}

text BattleFrontier_Lounge1_Text_StatRelativelyGood {
	"That stat is relatively good.
	…Hm… That's how I call it."
}

text BattleFrontier_Lounge1_Text_StatImpressive {
	"That stat is quite impressive.
	…Hm… That's how I call it."
}

text BattleFrontier_Lounge1_Text_StatOutstanding {
	"That stat is outstanding!
	…Hm… That's how I call it."
}

text BattleFrontier_Lounge1_Text_StatFlawless {
	"It's flawless! A thing of perfection!
	…Hm… That's how I call it."
}

text BattleFrontier_Lounge1_Text_NoTimeForMyAdvice {
	"What?
	You have no time for my advice?

	You should always be eager to learn
	from the experiences of your elders!"
}

text BattleFrontier_Lounge1_Text_HaveBusinessNeedsTending {
	"Yes, what is it now?

	I have business that needs tending!
	Save it for next time!"
}

text BattleFrontier_Lounge1_Text_LetsLookAtYourPokemon {
	"Ah, youngster! Do your POKéMON's
	abilities intrigue you?

	Here, here!
	Let's have a look at your POKéMON!"
}

text BattleFrontier_Lounge1_Text_EvenICantTell {
	"An expert I am, but even I can't tell
	anything about an unhatched POKéMON!

	Show me a POKéMON!
	A POKéMON is what I need to see!"
}

text BattleFrontier_Lounge1_Text_SaidMyMonIsOutstanding {
	"He said my POKéMON is outstanding!
	I'm glad I raised it carefully!"
}

text BattleFrontier_Lounge1_Text_DidntDoAnythingSpecialRaisingIt {
	"He said my POKéMON is outstanding!
	But I didn't do anything special
	raising it…"
}
