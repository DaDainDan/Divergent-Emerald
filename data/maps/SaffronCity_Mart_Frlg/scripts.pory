mapscripts SaffronCity_Mart_Frlg_MapScripts {}

script SaffronCity_Mart_EventScript_Lass {
    msgbox(SaffronCity_Mart_Text_ReviveIsCostly, MSGBOX_NPC)
    end
}

script SaffronCity_Mart_EventScript_Youngster {
    msgbox(SaffronCity_Mart_Text_MaxRepelMoreEffectiveThanSuper, MSGBOX_NPC)
    end
}

script SaffronCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(SaffronCity_Mart_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart SaffronCity_Mart_Items {
    ITEM_GREAT_BALL
    ITEM_HYPER_POTION
    ITEM_REVIVE
    ITEM_FULL_HEAL
    ITEM_ESCAPE_ROPE
    ITEM_MAX_REPEL
}

text SaffronCity_Mart_Text_MaxRepelMoreEffectiveThanSuper {
	"MAX REPEL keeps weaker POKéMON
	from appearing.

	MAX REPEL stays effective longer
	than SUPER REPEL."
}

text SaffronCity_Mart_Text_ReviveIsCostly {
	"REVIVE is costly, but it revives
	fainted POKéMON!"
}
