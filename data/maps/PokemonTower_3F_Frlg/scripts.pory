script PokemonTower_3F_EventScript_Hope {
    trainerbattle_single(TRAINER_CHANNELER_HOPE, PokemonTower_3F_Text_HopeIntro, PokemonTower_3F_Text_HopeDefeat)
    msgbox(PokemonTower_3F_Text_HopePostBattle, MSGBOX_AUTOCLOSE)
    end
}

text PokemonTower_3F_Text_HopeIntro {
	"Urrg… Awaa…
	Huhu… Graa…"
}

text PokemonTower_3F_Text_HopeDefeat {
	"Hwa!
	I'm saved!"
}

text PokemonTower_3F_Text_HopePostBattle {
	"The ghosts can be identified by
	the SILPH SCOPE."
}

text PokemonTower_3F_Text_CarlyIntro {
	"Kekeke…
	Kwaaah!"
}

text PokemonTower_3F_Text_CarlyDefeat {
	"Hmm?
	What am I doing?"
}

text PokemonTower_3F_Text_CarlyPostBattle {
	"Sorry!
	I was possessed!"
}

text PokemonTower_3F_Text_PatriciaIntro {
	"Be gone!
	Malevolent spirit!"
}

text PokemonTower_3F_Text_PatriciaDefeat {
	"Whew!
	The spirit left!"
}

text PokemonTower_3F_Text_PatriciaPostBattle {
	"The others above…
	They must have been possessed."
}
