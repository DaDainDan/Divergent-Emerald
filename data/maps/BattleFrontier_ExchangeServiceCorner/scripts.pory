mapscripts BattleFrontier_ExchangeServiceCorner_MapScripts {}

script BattleFrontier_ExchangeServiceCorner_EventScript_ClerkWelcome {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_WelcomePleaseChoosePrize, MSGBOX_DEFAULT)
    special(ShowBattlePointsWindow)
    return
}

script BattleFrontier_ExchangeServiceCorner_EventScript_ClerkGoodbye {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_ThankYouVisitWithPoints, MSGBOX_DEFAULT)
    special(CloseBattlePointsWindow)
    release_end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_DecorClerk1 {
    lock_faceplayer
    setvar(VAR_TEMP_2, EXCHANGE_CORNER_DECOR1_CLERK)
    call(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkWelcome)
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor1)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor1 {
    setvar(VAR_0x8004, SCROLL_MULTI_BF_EXCHANGE_CORNER_DECOR_VENDOR_1)
    special(ShowFrontierExchangeCornerItemIconWindow)
    special(ShowScrollableMultichoice)
    special(CloseFrontierExchangeCornerItemIconWindow)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(DECOR_KISS_POSTER, 16)
        case 1: setitemandprice(DECOR_KISS_CUSHION, 32)
        case 2: setitemandprice(DECOR_SMOOCHUM_DOLL, 32)
        case 3: setitemandprice(DECOR_TOGEPI_DOLL, 48)
        case 4: setitemandprice(DECOR_MEOWTH_DOLL, 48)
        case 5: setitemandprice(DECOR_CLEFAIRY_DOLL, 48)
        case 6: setitemandprice(DECOR_DITTO_DOLL, 48)
		case 7: setitemandprice(DECOR_CYNDAQUIL_DOLL, 80)
		case 8: setitemandprice(DECOR_CHIKORITA_DOLL, 80)
		case 9: setitemandprice(DECOR_TOTODILE_DOLL, 80)
        case 10:
        case MULTI_B_PRESSED:
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkGoodbye)
			end
    }
	goto(BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseDecor)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseDecor {
    bufferdecorationname(STR_VAR_1, VAR_GIFT_ITEM)
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_ConfirmPurchase, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
		if (var(VAR_TEMP_2) == EXCHANGE_CORNER_DECOR1_CLERK) {
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor1)
		}
        goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor2)
    }
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_TryPurchasePrize)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_DecorClerk2 {
    lock_faceplayer
    setvar(VAR_TEMP_2, EXCHANGE_CORNER_DECOR2_CLERK)
    call(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkWelcome)
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor2)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor2 {
    setvar(VAR_0x8004, SCROLL_MULTI_BF_EXCHANGE_CORNER_DECOR_VENDOR_2)
    special(ShowFrontierExchangeCornerItemIconWindow)
    special(ShowScrollableMultichoice)
    special(CloseFrontierExchangeCornerItemIconWindow)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(DECOR_LAPRAS_DOLL, 128)
        case 1: setitemandprice(DECOR_SNORLAX_DOLL, 128)
        case 2: setitemandprice(DECOR_VENUSAUR_DOLL, 256)
        case 3: setitemandprice(DECOR_CHARIZARD_DOLL, 256)
        case 4: setitemandprice(DECOR_BLASTOISE_DOLL, 256)
        case 5:
        case MULTI_B_PRESSED: 
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkGoodbye)
			end
    }
	goto(BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseDecor)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_TryGiveDecor {
    if (checkdecorspace(VAR_GIFT_ITEM) == FALSE) {
		msgbox(BattleFrontier_ExchangeServiceCorner_Text_PCIsFull, MSGBOX_DEFAULT)
    	special(CloseBattlePointsWindow)
 		release_end
	}
    copyvar(VAR_0x8004, VAR_EXCHANGE_PRICE)
    special(TakeFrontierBattlePoints)
    adddecoration(VAR_GIFT_ITEM)
    special(UpdateBattlePointsWindow)
    playse(SE_SHOP)
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_WellSendItToPC, MSGBOX_DEFAULT)
    if (var(VAR_TEMP_2) == EXCHANGE_CORNER_DECOR1_CLERK) {
        goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor1)
    }
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor2)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_TryPurchasePrize {
    specialvar(VAR_TEMP_1, GetFrontierBattlePoints)
    if (var(VAR_TEMP_1) >= VAR_EXCHANGE_PRICE) {
        switch (var(VAR_TEMP_2)) {
			case EXCHANGE_CORNER_DECOR1_CLERK:
			case EXCHANGE_CORNER_DECOR2_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_TryGiveDecor)
			case EXCHANGE_CORNER_VITAMIN_CLERK: 
			case EXCHANGE_CORNER_HOLD_ITEM_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_TryGiveItem)
		}
		end
    }
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_DontHaveEnoughPoints, MSGBOX_DEFAULT)
	switch (var(VAR_TEMP_2)) {
		case EXCHANGE_CORNER_DECOR1_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor1)
		case EXCHANGE_CORNER_DECOR2_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseDecor2)
		case EXCHANGE_CORNER_VITAMIN_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseVitamin)
		case EXCHANGE_CORNER_HOLD_ITEM_CLERK: goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseHoldItem)
	}
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_VitaminClerk {
    lock_faceplayer
    setvar(VAR_TEMP_2, EXCHANGE_CORNER_VITAMIN_CLERK)
    call(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkWelcome)
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseVitamin)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_ChooseVitamin {
    setvar(VAR_0x8004, SCROLL_MULTI_BF_EXCHANGE_CORNER_VITAMIN_VENDOR)
    special(ShowFrontierExchangeCornerItemIconWindow)
    special(ShowScrollableMultichoice)
    special(CloseFrontierExchangeCornerItemIconWindow)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(ITEM_PROTEIN, 1)
        case 1: setitemandprice(ITEM_CALCIUM, 1)
        case 2: setitemandprice(ITEM_IRON, 1)
        case 3: setitemandprice(ITEM_ZINC, 1)
        case 4: setitemandprice(ITEM_CARBOS, 1)
        case 5: setitemandprice(ITEM_HP_UP, 1)
        case 6:
        case MULTI_B_PRESSED:
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkGoodbye)
			end
    }
	goto(BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseItem)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_HoldItemClerk {
    lock_faceplayer
    setvar(VAR_TEMP_2, EXCHANGE_CORNER_HOLD_ITEM_CLERK)
    call(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkWelcome)
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseHoldItem)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_ChooseHoldItem {
    setvar(VAR_0x8004, SCROLL_MULTI_BF_EXCHANGE_CORNER_HOLD_ITEM_VENDOR)
    special(ShowFrontierExchangeCornerItemIconWindow)
    special(ShowScrollableMultichoice)
    special(CloseFrontierExchangeCornerItemIconWindow)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(ITEM_LEFTOVERS, 48)
        case 1: setitemandprice(ITEM_WHITE_HERB, 48)
        case 2: setitemandprice(ITEM_QUICK_CLAW, 48)
        case 3: setitemandprice(ITEM_MENTAL_HERB, 48)
        case 4: setitemandprice(ITEM_BRIGHT_POWDER, 64)
        case 5: setitemandprice(ITEM_CHOICE_BAND, 64)
        case 6: setitemandprice(ITEM_KINGS_ROCK, 64)
        case 7: setitemandprice(ITEM_FOCUS_BAND, 64)
        case 8: setitemandprice(ITEM_SCOPE_LENS, 64)
        case 9:
        case MULTI_B_PRESSED:
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ClerkGoodbye)
			end
    }
	goto(BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseItem)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_PurchaseItem {
    bufferitemname(STR_VAR_1, VAR_GIFT_ITEM)
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_ConfirmPurchase, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        if (var(VAR_TEMP_2) == EXCHANGE_CORNER_VITAMIN_CLERK) {
			goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseVitamin)
		}
		goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseHoldItem)
    }
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_TryPurchasePrize)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_TryGiveItem {
    if (checkitemspace(VAR_GIFT_ITEM) == FALSE) {
		msgbox(BattleFrontier_ExchangeServiceCorner_Text_DontHaveSpaceToHoldIt, MSGBOX_DEFAULT)
    	special(CloseBattlePointsWindow)
    	release_end
	}
    copyvar(VAR_0x8004, VAR_EXCHANGE_PRICE)
    special(TakeFrontierBattlePoints)
    additem(VAR_GIFT_ITEM)
    special(UpdateBattlePointsWindow)
    playse(SE_SHOP)
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_HereIsYourPrize, MSGBOX_DEFAULT)
    if (var(VAR_TEMP_2) == EXCHANGE_CORNER_VITAMIN_CLERK) {
        goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseVitamin)
    }
    goto(BattleFrontier_ExchangeServiceCorner_EventScript_ChooseHoldItem)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_Man {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_GoGetYourOwnDoll, MSGBOX_NPC)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_Sailor {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_ItemsWillGetMonTougher, MSGBOX_NPC)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_PokefanF {
    lock
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_GetYouAnythingYouWant, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_RichBoy {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_WishIHadAllDolls, MSGBOX_NPC)
    end
}

script BattleFrontier_ExchangeServiceCorner_EventScript_Girl {
    msgbox(BattleFrontier_ExchangeServiceCorner_Text_MoreBattlePointsForRecord, MSGBOX_NPC)
    end
}

text BattleFrontier_ExchangeServiceCorner_Text_WelcomePleaseChoosePrize {
	"Hello, this is the EXCHANGE SERVICE
	CORNER.

	We exchange the Battle Points you
	have collected for lovely prizes.

	Please choose a prize from this list."
}

text BattleFrontier_ExchangeServiceCorner_Text_PleaseChoosePrize {
	"Please choose a prize from this list."
}

text BattleFrontier_ExchangeServiceCorner_Text_ConfirmPurchase {
	"You've chosen the {STR_VAR_1}.
	Is that correct?"
}

text BattleFrontier_ExchangeServiceCorner_Text_WellSendItToPC {
	"Thank you!
	We'll send it to your PC at home."
}

text BattleFrontier_ExchangeServiceCorner_Text_HereIsYourPrize {
	"Here is your prize!"
}

text BattleFrontier_ExchangeServiceCorner_Text_DontHaveEnoughPoints {
	"I'm so sorry…
	You don't have enough Battle Points…"
}

text BattleFrontier_ExchangeServiceCorner_Text_PCIsFull {
	"I'm so sorry…
	Your PC appears to be full…"
}

text BattleFrontier_ExchangeServiceCorner_Text_DontHaveSpaceToHoldIt {
	"I'm so sorry…
	You don't have space to hold it…"
}

text BattleFrontier_ExchangeServiceCorner_Text_ThankYouVisitWithPoints {
	"Thank you very much.

	Please visit us when you have
	saved up Battle Points."
}

text BattleFrontier_ExchangeServiceCorner_Text_WishIHadAllDolls {
	"Oh, they're so nice!
	I wish I had them!
	Cute cushions!
	Big plush DOLLS!
	Little plush DOLLS!
	I wish I had them all!"
}

text BattleFrontier_ExchangeServiceCorner_Text_GetYouAnythingYouWant {
	"Leave it to your mommy!

	If it's anything you want, I'll go
	through anything to get it, honey!"
}

text BattleFrontier_ExchangeServiceCorner_Text_ItemsWillGetMonTougher {
	"If I can get hold of the items here,
	my POKéMON will get tougher.

	You bet they will!
	No question about it!"
}

text BattleFrontier_ExchangeServiceCorner_Text_GoGetYourOwnDoll {
	"Hah?
	What are you gawking at?

	I don't like you staring at my plush
	doll like that.

	If you want it, go get one yourself!
	Isn't that right, SMOOCHUM?"
}

text BattleFrontier_ExchangeServiceCorner_Text_MoreBattlePointsForRecord {
	"Did you know?

	If you stretch your record at any of
	the BATTLE facilities, they start
	giving you more and more Battle Points."
}

