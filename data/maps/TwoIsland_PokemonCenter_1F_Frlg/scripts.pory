mapscripts TwoIsland_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_TWO_ISLAND)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script TwoIsland_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script TwoIsland_PokemonCenter_1F_EventScript_GBAKid {
    msgbox(TwoIsland_PokemonCenter_1F_Text_HaveYouVisitedGameCorner, MSGBOX_NPC)
    end
}

script TwoIsland_PokemonCenter_1F_EventScript_BugCatcher {
    msgbox(TwoIsland_PokemonCenter_1F_Text_OldLadyLivesOutOnCape, MSGBOX_NPC)
    end
}

text TwoIsland_PokemonCenter_1F_Text_HaveYouVisitedGameCorner {
	"Have you visited the GAME CORNER
	already?

	It's no good to go alone.
	You have to take a friend along."
}

text TwoIsland_PokemonCenter_1F_Text_OldLadyLivesOutOnCape {
	"Not many people live on
	TWO ISLAND.

	There is this old lady who lives
	out on the cape.

	She's been there since I don't know
	when."
}
