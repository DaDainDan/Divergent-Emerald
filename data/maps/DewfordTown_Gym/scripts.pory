script DewfordTown_Gym_EventScript_GymGuide {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_DEWFORD_GYM)) {
        msgbox(DewfordTown_Gym_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(DewfordTown_Gym_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

script DewfordTown_Gym_EventScript_LeftGymStatue {
    lockall
	goto(DewfordTown_Gym_EventScript_GymStatue)
	end
}

script DewfordTown_Gym_EventScript_RightGymStatue {
    lockall
    goto(DewfordTown_Gym_EventScript_GymStatue)
	end
}

script DewfordTown_Gym_EventScript_GymStatue {
    if (flag(FLAG_BADGE02_GET)) {
        msgbox(DewfordTown_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(DewfordTown_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
	releaseall
    end
}

text DewfordTown_Gym_Text_GymGuideAdvice {
	"Hey, how's it going, CHAMPION-
	bound {PLAYER}?

	DEWFORD's GYM LEADER BRAWLY commands
	FIGHTING-type POKéMON.

	Going against him with NORMAL-type
	POKéMON is asking for trouble.

	FIGHTING POKéMON will lay a serious
	smack down on NORMAL POKéMON,
	so be careful!

	What's worse, the GYM is as dark as
	the ocean floor.

	But it will get brighter after defeating
	the TRAINERS in your way.

	Hey, okay, go for it!"
}

text DewfordTown_Gym_Text_GymGuidePostVictory {
	"Whoah! It's turned too bright in here!

	Your future is bright, too!"
}

text DewfordTown_Gym_Text_TakaoIntro {
	"Might is right!
	Come on!"
}

text DewfordTown_Gym_Text_TakaoDefeat {
	"Not enough power…"
}

text DewfordTown_Gym_Text_TakaoPostBattle {
	"Your skill overcame my strength!
	Your technique is commendable!"
}

text DewfordTown_Gym_Text_JocelynIntro {
	"There's no need for BRAWLY to be
	involved!

	I'll crush you!"
}

text DewfordTown_Gym_Text_JocelynDefeat {
	"But… How?
	How could I lose so easily?"
}

text DewfordTown_Gym_Text_JocelynPostBattle {
	"I'm not going to waste this loss.
	I'll use it to motivate me to train!

	One day I'll become a GYM LEADER…

	No, I'll become the POKéMON LEAGUE
	CHAMPION!"
}

text DewfordTown_Gym_Text_LauraIntro {
	"Don't you dare brush me off!
	It's not my fault if you cry!"
}

text DewfordTown_Gym_Text_LauraDefeat {
	"Waaaaaaah!
	I lost!"
}

text DewfordTown_Gym_Text_LauraPostBattle {
	"I battle in the dark to make my heart
	stronger.

	But because it's so dark, I can never
	see BRAWLY's face…"
}

text DewfordTown_Gym_Text_LilithIntro {
	"Ufufu…
	Are you stumbling around in the dark?"
}

text DewfordTown_Gym_Text_LilithDefeat {
	"Oh, you…
	I don't want to know you!"
}

text DewfordTown_Gym_Text_LilithPostBattle {
	"You deserve to stay lost and end up
	back at the entrance again!"
}

text DewfordTown_Gym_Text_BrendenIntro {
	"I'll show you the gumption of
	a sailing man!"
}

text DewfordTown_Gym_Text_BrendenDefeat {
	"How'd this happen?
	It's not like me to lose this way!"
}

text DewfordTown_Gym_Text_BrendenPostBattle {
	"Oh, aye! You're worthy of seeing
	our GYM LEADER."
}

text DewfordTown_Gym_Text_CristianIntro {
	"If you mean to pass, it has to be
	through me!"
}

text DewfordTown_Gym_Text_CristianDefeat {
	"Grrrrr!
	Vastly overpowered!"
}

text DewfordTown_Gym_Text_CristianPostBattle {
	"You win!
	Go after that BADGE!"
}

text DewfordTown_Gym_Text_BrawlyIntro {
	"I'm BRAWLY!
	DEWFORD's GYM LEADER!

	I've been churned in the rough waves
	of these parts, and I've grown tough
	in the pitch-black cave!

	So you wanted to challenge me?
	Let me see what you're made of!"
}

text DewfordTown_Gym_Text_BrawlyDefeat {
	"Whoah, wow! You made a much bigger
	splash than I expected!

	You swamped me!

	Okay, you've got me.
	Take this GYM BADGE!"
}

text DewfordTown_Gym_Text_ReceivedKnuckleBadge {
	"{PLAYER} received the KNUCKLE BADGE
	from BRAWLY."
}

text DewfordTown_Gym_Text_KnuckleBadgeInfoTakeThis {
	"The KNUCKLE BADGE makes all POKéMON
	up to Level 30, even those you get in
	trades, obey without question.

	And, you'll be able to use the HM move
	FLASH outside of battle.

	If you'd like, use this TECHNICAL
	MACHINE, too."
}

text DewfordTown_Gym_Text_ExplainBulkUp {
	"That TM08 contains BULK UP.

	It's a move that raises both ATTACK
	and DEFENSE stats.

	… … … … … …"
}

text DewfordTown_Gym_Text_RegisteredBrawly {
	"Registered GYM LEADER BRAWLY
	in the POKéNAV."
}

text DewfordTown_Gym_Text_BrawlyPostBattle {
	"I can see your talent becoming a giant
	wave to cause a storm of astonishment
	among TRAINERS one day!"
}

text DewfordTown_Gym_Text_GymStatue {
	"DEWFORD TOWN POKéMON GYM"
}

text DewfordTown_Gym_Text_GymStatueCertified {
	"DEWFORD TOWN POKéMON GYM

	BRAWLY'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text DewfordTown_Gym_Text_BrawlyPreRematch {
	"{SPEAKER NAME_BRAWLY}A wave may draw back, but it
	always returns to the shore.

	A giant wave of a talent like you…
	I knew you would return!

	Show me how much higher
	you've gone!"
}

text DewfordTown_Gym_Text_BrawlyRematchDefeat {
	"Wow!
	Swamped again!"
}

text DewfordTown_Gym_Text_BrawlyPostRematch {
	"{SPEAKER NAME_BRAWLY}Battling is vast and it's deep.
	You can't see the bottom.
	It's just like the sea of HOENN!"
}

text DewfordTown_Gym_Text_BrawlyRematchNeedTwoMons {
	"{SPEAKER NAME_BRAWLY}A wave may draw back, but it
	always returns to the shore.

	A giant wave of a talent like you…
	I knew you would return!

	Oh? You only have one POKéMON
	that can battle.

	I'm sorry, but I'd like you to come back
	with at least two POKéMON."
}
