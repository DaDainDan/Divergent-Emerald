mapscripts BattleFrontier_BattleTowerMultiPartnerRoom_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        pyramid_resetparty
    	end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (flag(FLAG_CHOSEN_MULTI_BATTLE_NPC_PARTNER)) {
			setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_2, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_3, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_4, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_5, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_6, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_OBJ_GFX_ID_7, OBJ_EVENT_GFX_BOY_1)
			setvar(VAR_TEMP_1, 1)
			setvar(VAR_TEMP_3, 1)
			setobjectxyperm(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, 10, 2)
			end
		}
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_1)
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_2)
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_3)
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_4)
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_5)
		clearflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_6)
		setflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_ALT_1)
		setflag(FLAG_HIDE_BATTLE_TOWER_MULTI_BATTLE_PARTNER_ALT_2)
		tower_loadpartners
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_3, 1 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_1, 0 {
			lockall
			applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
			waitmovement(0)
			applymovement(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, moves(walk_left,  step_faster_down))
			waitmovement(0)
			copyobjectxytoperm(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
			waitmovement(0)
			msgbox(BattleFrontier_BattleTowerMultiPartnerRoom_Text_PleaseFindPartner, MSGBOX_DEFAULT)
			special(HealPlayerParty)
			setvar(VAR_TEMP_1, 1)
			releaseall
			end
		}
    	VAR_TEMP_3, 1 {
			lockall
			setvar(VAR_TEMP_3, 0)
			goto(BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_EnterElevator)
			end
		}
    ]
}

script BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_Attendant {
    lock_faceplayer
    message(BattleFrontier_BattleTowerMultiPartnerRoom_Text_QuitLookingForPartner)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    if (var(VAR_RESULT) == 0) {
        frontier_set(FRONTIER_DATA_RECORD_DISABLED, TRUE)
		goto(BattleFrontier_BattleTower_EventScript_WarpToLobbyLost)
    }
    msgbox(BattleFrontier_BattleTowerMultiPartnerRoom_Text_PleaseFindPartner2, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_EnterElevator {
    msgbox(BattleFrontier_BattleTowerMultiPartnerRoom_Text_ThankYouForChoosingPartner, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, Common_Movement_StepFasterUp)
    waitmovement(0)
    opendoor(10, 1)
    waitdooranim
    applymovement(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    closedoor(10, 1)
    waitdooranim
    warp(MAP_BATTLE_FRONTIER_BATTLE_TOWER_ELEVATOR, 1, 6)
    waitstate
    releaseall
    end
}

// Unused
script(local) BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_MoveToElevatorEast {
    applymovement(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_right,  walk_up,  set_invisible))
    waitmovement(0)
    return
}

// Unused
script(local) BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_MoveToElevatorWest {
    applymovement(LOCALID_TOWER_PARTNER_ROOM_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_left,  walk_up,  set_invisible))
    waitmovement(0)
    return
}

script BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_Partner1 {
    lock_faceplayer
    setvar(VAR_TEMP_2, 0)
    goto(BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_TalkToPotentialPartner)
    end
}

script BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_TalkToPotentialPartner {
    if (flag(FLAG_CHOSEN_MULTI_BATTLE_NPC_PARTNER)) {
        goto(BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_RejectPartner)
    }
    tower_dopartnermsg(PARTNER_MSGID_INTRO)
    waitmessage
    waitbuttonpress
    tower_dopartnermsg(PARTNER_MSGID_MON1)
    waitmessage
    waitbuttonpress
    tower_dopartnermsg(PARTNER_MSGID_MON2_ASK)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) != 0) {
		goto(BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_RejectPartner)
	}
    tower_dopartnermsg(PARTNER_MSGID_ACCEPT)
    waitmessage
    waitbuttonpress
    closemessage
	if (var(VAR_FACING) == DIR_SOUTH) {
		applymovement(VAR_LAST_TALKED, moves(run_left,  run_up * 7))
	} else {
		applymovement(VAR_LAST_TALKED, moves(run_up * 7))
	}
	waitmovement(0)
    removeobject(VAR_LAST_TALKED)
    setflag(FLAG_CHOSEN_MULTI_BATTLE_NPC_PARTNER)
    warpsilent(MAP_BATTLE_FRONTIER_BATTLE_TOWER_MULTI_PARTNER_ROOM, 10, 3)
    waitstate
    release_end
}

script BattleFrontier_BattleTowerMultiPartnerRoom_EventScript_RejectPartner {
    tower_dopartnermsg(PARTNER_MSGID_REJECT)
    waitmessage
    waitbuttonpress
    release_end
}

