text BattleFrontier_BattleTowerMultiPartnerRoom_Text_PleaseFindPartner {
	"Please find a partner from out of
	the TRAINERS gathered here."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_QuitLookingForPartner {
	"{PLAYER}, you have not found a partner
	for your tag team.

	Would you like to quit looking and
	return to the reception counter?"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_PleaseFindPartner2 {
	"Then, please find a partner from
	the TRAINERS gathered here."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_ThankYouForChoosingPartner {
	"Thank you for choosing a partner.

	I will now show you to your
	MULTI BATTLE ROOM."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice1Intro {
	"I'm {STR_VAR_1}'s no. {STR_VAR_2} apprentice.
	You can call me {STR_VAR_3}!"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice1Mon1 {
	"On {STR_VAR_1}'s advice, I brought
	one {STR_VAR_3} with {STR_VAR_2} and"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice1Mon2Ask {
	"one {STR_VAR_2} with {STR_VAR_1}.

	Please, let me join you as a tag team."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice1Accept {
	"Thank you!
	I'll go register right now."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice1Reject {
	"I really wanted to form a tag team
	with you, {PLAYER}…"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice2Intro {
	"I am {STR_VAR_1}'s no. {STR_VAR_2} apprentice.
	My name is {STR_VAR_3}."
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice2Mon1 {
	"I got advice from {STR_VAR_1} and chose
	one {STR_VAR_3} with {STR_VAR_2} and"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice2Mon2Ask {
	"one {STR_VAR_2} with {STR_VAR_1}.

	Please, let's form a tag team!"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice2Accept {
	"Thank you very much!
	I'll be done with registration quickly!"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_UnusedApprentice2Reject {
