	partner up with you…"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_Apprentice1Intro {
	"Um, my name's {STR_VAR_3}, and I'm
	{STR_VAR_1}'s no. {STR_VAR_2} apprentice.

	Snivel…

	I'm sorry!
	This tension is making me cry…"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_Apprentice1Mon1 {
	"{STR_VAR_3} advised me, so I have
	one {STR_VAR_2} with {STR_VAR_1} and"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_Apprentice1Mon2Ask {
	"one {STR_VAR_2} with {STR_VAR_1}.

	Snivel…
	Please, please team up with me!"
}

text BattleFrontier_BattleTowerMultiPartnerRoom_Text_Apprentice1Accept {
