// This is Slateport Tent's version of the Battle Factory Pre-Battle Room
mapscripts SlateportCity_BattleTentCorridor_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: SlateportCity_BattleTentCorridor_EventScript_EnterCorridor
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			if (var(VAR_0x8006) == 1) {
				setobjectxy(LOCALID_SLATEPORT_TENT_CORRIDOR_ATTENDANT, 2, 2)
				turnobject(LOCALID_SLATEPORT_TENT_CORRIDOR_ATTENDANT, DIR_SOUTH)
			}
			turnobject(LOCALID_PLAYER, DIR_NORTH)
    		end
		}
    ]
}

script SlateportCity_BattleTentCorridor_EventScript_EnterCorridor {
    if (var(VAR_0x8006) == 1) {
        factory_setopponentmons
		factory_resethelditems
		msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_LetUsRestoreMons, MSGBOX_DEFAULT)
		playfanfare(MUS_HEAL)
		waitfanfare
		special(HealPlayerParty)
		goto(SlateportCity_BattleTentCorridor_EventScript_AskReadyForOpponent)
    }
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_SLATEPORT_TENT_CORRIDOR_ATTENDANT, moves(walk_up * 4,  step_faster_down))
    applymovement(LOCALID_PLAYER, moves(walk_up * 4))
    waitmovement(0)
    if (var(VAR_0x8006) == 2) {
        special(SavePlayerParty)
		factory_setparties(0)
		goto(SlateportCity_BattleTentCorridor_EventScript_AskReadyForOpponent)
    }
    slateporttent_generaterentalmons
    slateporttent_generateopponentmons
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_HoldMonsChooseFromSelection, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    slateporttent_rentmons
    waitstate
	goto(SlateportCity_BattleTentCorridor_EventScript_EnterBattleRoom)
}

script SlateportCity_BattleTentCorridor_EventScript_EnterBattleRoom {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_RightThisWay, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SLATEPORT_TENT_CORRIDOR_ATTENDANT, Common_Movement_StepFasterUp)
    waitmovement(0)
    opendoor(2, 1)
    waitdooranim
    applymovement(LOCALID_SLATEPORT_TENT_CORRIDOR_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    closedoor(2, 1)
    waitdooranim
    warp(MAP_SLATEPORT_CITY_BATTLE_TENT_BATTLE_ROOM, 4, 4)
    waitstate
    end
}

script SlateportCity_BattleTentCorridor_EventScript_AskReadyForOpponent {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
	switch (var(VAR_RESULT)) {
		case 1: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor2ndOpponent)
		case 2: message(BattleFrontier_BattleFactoryPreBattleRoom_Text_ReadyFor3rdOpponent)
	}
	waitmessage
    multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(SlateportCity_BattleTentCorridor_EventScript_AskSwapMon)
        case 1: goto(SlateportCity_BattleTentCorridor_EventScript_AskPauseChallenge)
        case 2: goto(SlateportCity_BattleTentCorridor_EventScript_AskRetireChallenge)
    }
    end
}

script SlateportCity_BattleTentCorridor_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		message(BattleFrontier_BattleFactoryPreBattleRoom_Text_SavingDataPleaseWait)
		waitmessage
		slateporttent_save(CHALLENGE_STATUS_PAUSED)
		playse(SE_SAVE)
		waitse
		fadescreen(FADE_TO_BLACK)
		frontier_reset
	} else {
		goto(SlateportCity_BattleTentCorridor_EventScript_AskReadyForOpponent)
	}
    end
}

script SlateportCity_BattleTentCorridor_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattleFactoryPreBattleRoom_Text_RetireFromChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    switch (var(VAR_RESULT)) {
		case 0: goto(SlateportCity_BattleTent_EventScript_WarpToLobbyLost)
        case 1:
        case MULTI_B_PRESSED: 
			goto(SlateportCity_BattleTentCorridor_EventScript_AskReadyForOpponent)
    }
    end
}

script SlateportCity_BattleTentCorridor_EventScript_AskSwapMon {
    slateporttent_generateopponentmons
    msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_LikeToSwapMon, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		fadescreen(FADE_TO_BLACK)
		slateporttent_swapmons
		waitstate
		if (var(VAR_RESULT) != 1) {
			msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_YourSwapIsComplete, MSGBOX_DEFAULT)
		}
	}
	goto(SlateportCity_BattleTentCorridor_EventScript_EnterBattleRoom)
    end
}

// Leftover text from when this was a Contest Hall in R/S
// Unused
text SlateportCity_ContestHall_Text_AdviceForContests {
	"Want a tasty little bit of advice
	for CONTESTS?

	Using a certain move after another
	certain kind of move sometimes gets
	you extra attention.

	If you know what you're doing,
	you can score big in appeal.

	Of course, your opponents might try
	disrupting your POKéMON's showing."
}

text SlateportCity_ContestHall_Text_MyPapaIsContestJudge {
	"My papa, he's a CONTEST JUDGE.

	I wonder what I should be when I
	grow up, a JUDGE or a GYM LEADER?"
}

text SlateportCity_ContestHall_Text_ImLikeMajorlyCheesed {
	"Hey, man, I'm like majorly cheesed,
	you know. Like, you know, I just
	wanted to know why my POKéMON
	never won, you know, like, hey?

	So, like, I gave the JUDGE my two
	cents, you know, they're free.

	And he wouldn't hear me out, like, hey!
	So, like, total bummer, man!

	Hey, like, you! Zip it, you know?
	Just, you know, take this!"
}

text SlateportCity_ContestHall_Text_ExplainTorment {
	"That's, like, TM41, you know?
	Hey, it's TORMENT, you hearing me?

	Like, it won't let the other guy
	use the same move twice in a row, see?

	Hey, now, you listen here, like,
	I'm not laying a torment on you!"
}

text SlateportCity_ContestHall_Text_MCStepUpTakePartInContest {
	"MC: Oh, my, my!
	Now isn't that a dandy of a POKéMON?

	Please! Do step right up and take
	part in our splendid CONTESTS!

	You'll do well! I'm sure of it!
	My eyes have never failed me!"
}

text SlateportCity_ContestHall_Text_JudgeWouldntDoToMissContest {
	"JUDGE: Well, hello there!
	I see that you're a TRAINER!

	Then, it just wouldn't do for you
	to miss a POKéMON CONTEST!

	Get a CONTEST PASS in VERDANTURF
	CITY and enter anytime!"
}

text SlateportCity_ContestHall_Text_ItsAppealTime {
	"It's appeal time!
	What should I lead with?"
}

text SlateportCity_ContestHall_Text_DidntPayAttentionToAppeal {
	"They didn't pay much attention to
	my POKéMON's appeal…

	Humph, that JUDGE, he doesn't know
	a good thing when he sees it."
}

text SlateportCity_ContestHall_Text_RewardWithSageAdvice {
	"Oh, hi! You must be a serious fan to get
	this close to the action.

	I'll reward your enthusiasm with
	this sage advice.

	If a move goes over really well,
	the audience will get excited.

	The POKéMON that makes its appeal
	right when everyone's excited…

	Well, you'd think something good has
	to happen!"
}

text SlateportCity_ContestHall_Text_MoreFreakedOutThanMon {
	"I can't do this! I'm more freaked out
	than my POKéMON.

	I'm shivering and my heart is racing!"
}

text SlateportCity_ContestHall_Text_BattleAndContestAlike {
	"A battle and a CONTEST aren't the
	same, but they are alike, too.

	You need to work hard and believe
	in the POKéMON you've raised."
}

text SlateportCity_ContestHall_Text_MonLooksOnTopOfGame {
	"That POKéMON looks like it's on top
	of its game, huh?

	A POKéMON that does good in the
	secondary judging seems to be more
	relaxed when it's doing appeals."
}

text SlateportCity_ContestHall_Text_MyMonBetterThanThatLot {
	"Will you look at that sorry sight?

	Heh, my POKéMON's absolutely better
	than that lot!"
}

text SlateportCity_ContestHall_Text_GetUrgeToMoveWithMon {
	"Don't you get the urge to move with
	POKéMON if they're putting on an
	energetic appeal?"
}

text SlateportCity_ContestHall_Text_HyperRankStage {
	"POKéMON CONTESTS
	HYPER RANK STAGE!"
}
