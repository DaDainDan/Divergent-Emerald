mapscripts SixIsland_OutcastIsland_Frlg_MapScripts {}

script SixIsland_OutcastIsland_EventScript_Rocket {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_46, SixIsland_OutcastIsland_Text_RocketIntro, SixIsland_OutcastIsland_Text_RocketDefeat)
    msgbox(SixIsland_OutcastIsland_Text_RocketPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SixIsland_OutcastIsland_Text_RocketIntro {
	"There're no rare POKéMON around
	these parts! Not a one!

	That burns me up, man.
	I'll take it out on you!"
}

text SixIsland_OutcastIsland_Text_RocketDefeat {
	"…Huh?"
}

text SixIsland_OutcastIsland_Text_RocketPostBattle {
	"So listen, you haven't seen any
	rare POKéMON, have you?"
}

text SixIsland_OutcastIsland_Text_TylorIntro {
	"I'm having no luck at all.
	A battle'd be a change of pace!"
}

text SixIsland_OutcastIsland_Text_TylorDefeat {
	"Nope, no luck at all…"
}

text SixIsland_OutcastIsland_Text_TylorPostBattle {
	"I can't very well go home without
	catching something, though."
}

text SixIsland_OutcastIsland_Text_MymoIntro {
	"Gasp… Gasp…

	I swam here from SIX ISLE PORT
	in one go."
}

text SixIsland_OutcastIsland_Text_MymoDefeat {
	"Gasp…
	Gasp…"
}

text SixIsland_OutcastIsland_Text_MymoPostBattle {
	"I'm only at the halfway point…
	I'm beat…"
}

text SixIsland_OutcastIsland_Text_NicoleIntro {
	"It's not so easy sending POKéMON
	out while swimming, you know?"
}

text SixIsland_OutcastIsland_Text_NicoleDefeat {
	"I didn't lose to you at swimming.
	This doesn't bother me."
}

text SixIsland_OutcastIsland_Text_NicolePostBattle {
	"Are you headed for the island up
	past here?

	I didn't see anything interesting
	there."
}

text SixIsland_OutcastIsland_Text_AvaIntro {
	"AVA: Let's have a two-on-two
	marine battle!"
}

text SixIsland_OutcastIsland_Text_AvaDefeat {
	"AVA: Oh, you're amazing!
	Even better, you're on your own!"
}

text SixIsland_OutcastIsland_Text_AvaPostBattle {
	"AVA: You know, I do prefer the
	sea over any pool."
}

text SixIsland_OutcastIsland_Text_AvaNotEnoughMons {
	"AVA: You're challenging us to
	a battle?

	You'll need at least two POKéMON
	if you want to do that."
}

text SixIsland_OutcastIsland_Text_GebIntro {
	"GEB: Big Sister, help!
	Please battle with me!"
}

text SixIsland_OutcastIsland_Text_GebDefeat {
	"GEB: Wow, Big Sister, this person's
	really good!"
}

text SixIsland_OutcastIsland_Text_GebPostBattle {
	"GEB: I'm hanging onto my sister
	because I can't touch the bottom."
}

text SixIsland_OutcastIsland_Text_GebNotEnoughMons {
	"GEB: Please battle against me and
	my sister!

	…Oh, you don't have two POKéMON?"
}
