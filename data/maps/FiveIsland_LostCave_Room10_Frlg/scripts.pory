mapscripts FiveIsland_LostCave_Room10_Frlg_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        if (defeated(TRAINER_LADY_SELPHY)) {
			setvar(VAR_MAP_SCENE_FIVE_ISLAND_LOST_CAVE_ROOM10, 1)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_FIVE_ISLAND_LOST_CAVE_ROOM10, 0: FiveIsland_LostCave_Room10_EventScript_FindSelphyScene
    ]
}

script FiveIsland_LostCave_Room10_EventScript_FindSelphyScene {
    lockall
    textcolor(NPC_TEXT_COLOR_FEMALE)
    applymovement(LOCALID_LOST_CAVE_SELPHY, FiveIsland_LostCave_Room10_Movement_SelphyWander)
    waitmovement(0)
    delay(100)
    applymovement(LOCALID_LOST_CAVE_SELPHY, moves(walk_down * 2))
    waitmovement(0)
    msgbox(FiveIsland_LostCave_Room10_Text_SelphyIntro)
    trainerbattle_no_intro(TRAINER_LADY_SELPHY, FiveIsland_LostCave_Room10_Text_SelphyDefeat)
    msgbox(FiveIsland_LostCave_Room10_Text_MayIAskYouToTakeMeHome)
    closemessage
    call(FiveIsland_LostCave_Room10_EventScript_SetSelphyFound)
    warp(MAP_FIVE_ISLAND_RESORT_GORGEOUS, 39, 10)
    waitstate
    releaseall
    end
}

script FiveIsland_LostCave_Room10_EventScript_SetSelphyFound {
    setflag(FLAG_HIDE_LOST_CAVE_SELPHY)
    clearflag(FLAG_HIDE_RESORT_GORGEOUS_SELPHY)
    setvar(VAR_MAP_SCENE_FIVE_ISLAND_LOST_CAVE_ROOM10, 1)
    setvar(VAR_MAP_SCENE_FIVE_ISLAND_RESORT_GORGEOUS, 1)
    return
}

script FiveIsland_LostCave_Room10_EventScript_SelphyQuestLog {
    settrainerflag(TRAINER_LADY_SELPHY)
    call(FiveIsland_LostCave_Room10_EventScript_SetSelphyFound)
    releaseall
    end
}

movement FiveIsland_LostCave_Room10_Movement_SelphyWander {
    // moves(walk_left,  delay_16,  walk_right,  delay_16,  step_faster_up,  delay_16,  step_faster_down)
    walk_left
    delay_16
    walk_right
    delay_16
    step_faster_up
    delay_16
    step_faster_down
}

text FiveIsland_LostCave_Room10_Text_SelphyIntro {
	"W-what do you intend to do with
	me?"
}

text FiveIsland_LostCave_Room10_Text_SelphyDefeat {
	"Oh… I was afraid that you meant to
	harm me."
}

text FiveIsland_LostCave_Room10_Text_MayIAskYouToTakeMeHome {
	"I am so glad that you happened
	here.

	I grew rather bored of walking,
	and I am feeling fatigued.

	May I ask you to take me home
	from here?"
}
