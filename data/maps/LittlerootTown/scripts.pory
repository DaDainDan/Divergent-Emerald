script LittlerootTown_EventScript_GiveRunningShoesTrigger0 {
    lockall
    setvar(VAR_0x8008, 0)
    setobjectxy(LOCALID_LITTLEROOT_MOM, 10, 9)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger1 {
    lockall
    setvar(VAR_0x8008, 1)
    setobjectxy(LOCALID_LITTLEROOT_MOM, 11, 9)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger2 {
    lockall
    setvar(VAR_0x8008, 2)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger3 {
    lockall
    setvar(VAR_0x8008, 3)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger4 {
    lockall
    setvar(VAR_0x8008, 4)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger5 {
    lockall
    setvar(VAR_0x8008, 5)
    goto(LittlerootTown_EventScript_GiveRunningShoesTrigger)
    end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger {
    if (checkplayergender == MALE) {
		call(LittlerootTown_EventScript_SetHomeDoorCoordsMale)
		applymovement(LOCALID_LITTLEROOT_MOM, Common_Movement_StepFasterRight)
	} else {
		call(LittlerootTown_EventScript_SetHomeDoorCoordsFemale)
		applymovement(LOCALID_LITTLEROOT_MOM, Common_Movement_StepFasterLeft)
	}
	waitmovement(0)
    msgbox(LittlerootTown_Text_WaitPlayer, MSGBOX_DEFAULT)
    closemessage
    if (checkplayergender == MALE) {
		call(LittlerootTown_EventScript_MomApproachPlayerMale)
		call(LittlerootTown_EventScript_GiveRunningShoes)
		call(LittlerootTown_EventScript_MomReturnHomeMale)
	} else {
		call(LittlerootTown_EventScript_MomApproachPlayerFemale)
		call(LittlerootTown_EventScript_GiveRunningShoes)
		call(LittlerootTown_EventScript_MomReturnHomeFemale)
	}
    goto(LittlerootTown_EventScript_SetReceivedRunningShoes)
    end
}

script LittlerootTown_EventScript_SetHomeDoorCoordsMale {
    setvar(VAR_0x8009, 5)
    setvar(VAR_0x800A, 8)
    return
}

script LittlerootTown_EventScript_SetHomeDoorCoordsFemale {
    setvar(VAR_0x8009, 14)
    setvar(VAR_0x800A, 8)
    return
}

script LittlerootTown_EventScript_MomApproachPlayerMale {
	if (var(VAR_0x8008) <= 1) {
		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
	} else {
		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
	}
	waitmovement(0)
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_up * 6))
		case 1: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_up * 6))
		case 2: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 4))
		case 3: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 5))
		case 4: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 2))
		case 5: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 3))
	}
	waitmovement(0)
    return
}

script LittlerootTown_EventScript_MomApproachPlayerFemale {
	if (var(VAR_0x8008) <= 1) {
		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
	} else {
		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
	}
	waitmovement(0)
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_up * 6))
		case 1: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_up * 6))
		case 2: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 3))
		case 3: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 2))
		case 4: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 5))
		case 5: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 4))
	}
	waitmovement(0)
    return
}

script LittlerootTown_EventScript_GiveRunningShoes {
    msgbox(LittlerootTown_Text_WearTheseRunningShoes, MSGBOX_DEFAULT)
    playfanfare(MUS_OBTAIN_ITEM)
    message(LittlerootTown_Text_SwitchShoesWithRunningShoes)
    waitfanfare
    setflag(FLAG_RECEIVED_RUNNING_SHOES)
    msgbox(LittlerootTown_Text_ExplainRunningShoes, MSGBOX_DEFAULT)
    msgbox(LittlerootTown_Text_ComeHomeIfAnythingHappens, MSGBOX_DEFAULT)
    closemessage
    delay(30)
    return
}

script LittlerootTown_EventScript_MomReturnHomeMale {
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_down * 5))
		case 1: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_down * 5))
		case 2: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 4,  step_faster_up))
		case 3: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 5,  step_faster_up))
		case 4: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 2,  step_faster_up))
		case 5: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_left * 3,  step_faster_up))
	}
	waitmovement(0)
	if (var(VAR_0x8008) >= 2) {
		call(LittlerootTown_EventScript_MomEntersHouse)
	}
    return
}

script LittlerootTown_EventScript_MomReturnHomeFemale {
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_down * 5))
		case 1: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_down * 5))
		case 2: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 3,  step_faster_up))
		case 3: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 2,  step_faster_up))
		case 4: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 5,  step_faster_up))
		case 5: applymovement(LOCALID_LITTLEROOT_MOM, moves(walk_right * 4,  step_faster_up))
	}
	waitmovement(0)
	if (var(VAR_0x8008) >= 2) {
		call(LittlerootTown_EventScript_MomEntersHouse)
	}
    return
}

script LittlerootTown_EventScript_MomEntersHouse {
    opendoor(VAR_0x8009, VAR_0x800A)
    waitdooranim
    applymovement(LOCALID_LITTLEROOT_MOM, Common_Movement_WalkUp)
    waitmovement(0)
    hideobjectat(LOCALID_LITTLEROOT_MOM, MAP_LITTLEROOT_TOWN)
    closedoor(VAR_0x8009, VAR_0x800A)
    waitdooranim
	return
}

script LittlerootTown_EventScript_SetReceivedRunningShoes {
    removeobject(LOCALID_LITTLEROOT_MOM)
    setflag(FLAG_SYS_B_DASH)
    setvar(VAR_LITTLEROOT_TOWN_STATE, 4)
    release_end
}

script LittlerootTown_EventScript_Mom {
    lock_faceplayer
    if (checkplayergender == MALE) {
		call(LittlerootTown_EventScript_SetHomeDoorCoordsMale)
	} else {
		call(LittlerootTown_EventScript_SetHomeDoorCoordsFemale)
	}
    call(LittlerootTown_EventScript_GiveRunningShoes)
    applymovement(LOCALID_LITTLEROOT_MOM, Common_Movement_StepFasterUp)
    waitmovement(0)
    call(LittlerootTown_EventScript_MomEntersHouse)
    goto(LittlerootTown_EventScript_SetReceivedRunningShoes)
    end
}

text LittlerootTown_Text_OurNewHomeLetsGoInside {
	"MOM: {PLAYER}, we're here, honey!

	It must be tiring riding with our things
	in the moving truck.

	Well, this is LITTLEROOT TOWN.

	How do you like it?
	This is our new home!

	It has a quaint feel, but it seems to be
	an easy place to live, don't you think?

	And, you get your own room, {PLAYER}!
	Let's go inside."
}

text LittlerootTown_Text_WaitPlayer {
	"MOM: Wait, {PLAYER}!"
}

text LittlerootTown_Text_WearTheseRunningShoes {
	"MOM: {PLAYER}! {PLAYER}! Did you
	introduce yourself to PROF. BIRCH?

	Oh! What an adorable POKéMON!
	You got it from PROF. BIRCH. How nice!

	You're your father's child, all right.
	You look good together with POKéMON!

	Here, honey! If you're going out on an
	adventure, wear these RUNNING SHOES.

	They'll put a zip in your step!"
}

text LittlerootTown_Text_SwitchShoesWithRunningShoes {
	"{PLAYER} switched shoes with the
	RUNNING SHOES."
}

text LittlerootTown_Text_ExplainRunningShoes {
	"MOM: {PLAYER}, those shoes came with
	instructions.

	“Press the B Button while wearing these
	RUNNING SHOES to run extra-fast!

	“Slip on these RUNNING SHOES and race
	in the great outdoors!”"
}

text LittlerootTown_Text_ComeHomeIfAnythingHappens {
	"… … … … … … … …
	… … … … … … … …

	To think that you have your very own
	POKéMON now…
	Your father will be overjoyed.

	…But please be careful.
	If anything happens, you can come home.

	Go on, go get them, honey!"
}

text LittlerootTown_Text_CanUsePCToStoreItems {
	"If you use a PC, you can store items
	and POKéMON.

	The power of science is staggering!"
}

text LittlerootTown_Text_BirchSpendsDaysInLab {
	"PROF. BIRCH spends days in his LAB
	studying, then he'll suddenly go out in
	the wild to do more research…

	When does PROF. BIRCH spend time
	at home?"
}

text LittlerootTown_Text_IfYouGoInGrassPokemonWillJumpOut {
	"Um, um, um!

	If you go outside and go in the grass,
	wild POKéMON will jump out!"
}

text LittlerootTown_Text_DangerousIfYouDontHavePokemon {
	"It's dangerous if you don't have
	your own POKéMON."
}

text LittlerootTown_Text_CanYouGoSeeWhatsHappening {
	"Um, hi!

	There are scary POKéMON outside!
	I can hear their cries!

	I want to go see what's going on,
	but I don't have any POKéMON…

	Can you go see what's happening
	for me?"
}

text LittlerootTown_Text_YouSavedBirch {
	"You saved PROF. BIRCH!
	I'm so glad!"
}

text LittlerootTown_Text_GoodLuckCatchingPokemon {
	"Are you going to catch POKéMON?
	Good luck!"
}

text LittlerootTown_Text_TownSign {
	"LITTLEROOT TOWN
	“A town that can't be shaded any hue.”"
}

text LittlerootTown_Text_ProfBirchsLab {
	"PROF. BIRCH'S POKéMON LAB"
}

text LittlerootTown_Text_PlayersHouse {
	"{PLAYER}'s HOUSE"
}

text LittlerootTown_Text_ProfBirchsHouse {
	"PROF. BIRCH'S HOUSE"
}

text LittlerootTown_Text_BirchSomethingToShowYouAtLab {
	"PROF. BIRCH: Well, well, {PLAYER}{KUN}!
	That was good work out there!

	I knew there was something special
	about you when I first saw you,
	but I never expected this.

	Oh, yes. Do you still have the POKéDEX
	I gave you?

