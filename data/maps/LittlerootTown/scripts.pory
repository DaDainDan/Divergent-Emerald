    msgbox(LittlerootTown_Text_TownSign, MSGBOX_SIGN)
    end
}

script LittlerootTown_EventScript_BirchsLabSign {
    msgbox(LittlerootTown_Text_ProfBirchsLab, MSGBOX_SIGN)
