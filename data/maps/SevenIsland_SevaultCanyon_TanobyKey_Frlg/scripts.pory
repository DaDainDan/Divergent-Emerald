script SevenIsland_SevaultCanyon_TanobyKey_EventScript_SwitchPressed {
    addvar(NUM_SWITCHES_PRESSED, 1)
    playse(SE_TRUCK_MOVE)
    setvar(VAR_0x8004, 1)
    setvar(VAR_0x8005, 1)
    setvar(VAR_0x8006, 8)
    setvar(VAR_0x8007, 3)
    special(ShakeScreen)
    delay(60)
    return
}

script SevenIsland_SevaultCanyon_TanobyKey_EventScript_PuzzleSolved {
    setvar(VAR_0x8004, 2)
    setvar(VAR_0x8005, 2)
    setvar(VAR_0x8006, 10)
    setvar(VAR_0x8007, 3)
    special(ShakeScreen)
    delay(60)
    setvar(VAR_0x8004, 3)
    setvar(VAR_0x8005, 3)
    setvar(VAR_0x8006, 12)
    setvar(VAR_0x8007, 2)
    special(ShakeScreen)
    delay(60)
    playse(SE_LAVARIDGE_FALL_WARP)
    waitse
    msgbox(SevenIsland_SevaultCanyon_TanobyKey_Text_MysteriousRumbleFarAway)
    setflag(FLAG_SYS_UNLOCKED_TANOBY_RUINS)
    releaseall
    end
}

text SevenIsland_SevaultCanyon_TanobyKey_Text_MysteriousRumbleFarAway {
	"A mysterious rumble echoed
	somewhere far away."
}
