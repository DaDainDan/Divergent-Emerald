mapscripts Route103_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        call(Common_EventScript_SetupRivalGfxId)
    	call(ProfBirch_EventScript_UpdateLocation)
    	end
    }
    MAP_SCRIPT_ON_LOAD {
		setmetatile(45, 5, METATILE_General_CaveEntrance_Top, TRUE)
    	setmetatile(45, 6, METATILE_General_CaveEntrance_Bottom, FALSE)
		end
    }
}

script Route103_EventScript_Rival {
    lockall
    if (checkplayergender == MALE) {
        goto(Route103_EventScript_RivalMay)
    } else {
		goto(Route103_EventScript_RivalBrendan)
	}
    end
}

script Route103_EventScript_RivalMay {
    msgbox(Route103_Text_MayRoute103Pokemon, MSGBOX_DEFAULT)
    closemessage
    playbgm(MUS_ENCOUNTER_MAY, TRUE)
    call(Route103_EventScript_RivalNoticePlayer)
    msgbox(Route103_Text_MayLetsBattle, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case PC_CHOSE_TREECKO: trainerbattle_no_intro(TRAINER_MAY_ROUTE_103_TORCHIC, Route103_Text_MayDefeated)
        case PC_CHOSE_TORCHIC: trainerbattle_no_intro(TRAINER_MAY_ROUTE_103_MUDKIP, Route103_Text_MayDefeated)
        case PC_CHOSE_MUDKIP: trainerbattle_no_intro(TRAINER_MAY_ROUTE_103_TREECKO, Route103_Text_MayDefeated)
    }
	msgbox(Route103_Text_MayTimeToHeadBack, MSGBOX_DEFAULT)
	goto(Route103_EventScript_RivalExit)
    end
}

script Route103_EventScript_RivalBrendan {
    msgbox(Route103_Text_BrendanRoute103Pokemon, MSGBOX_DEFAULT)
    closemessage
    playbgm(MUS_ENCOUNTER_BRENDAN, TRUE)
    call(Route103_EventScript_RivalNoticePlayer)
    msgbox(Route103_Text_BrendanLetsBattle, MSGBOX_DEFAULT)
    switch (var(VAR_STARTER_MON)) {
        case PC_CHOSE_TREECKO: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_103_TORCHIC, Route103_Text_BrendanDefeated)
        case PC_CHOSE_TORCHIC: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_103_MUDKIP, Route103_Text_BrendanDefeated)
        case PC_CHOSE_MUDKIP: trainerbattle_no_intro(TRAINER_BRENDAN_ROUTE_103_TREECKO, Route103_Text_BrendanDefeated)
    }
	msgbox(Route103_Text_BrendanTimeToHeadBack, MSGBOX_DEFAULT)
	goto(Route103_EventScript_RivalExit)
    end
}

script Route103_EventScript_RivalNoticePlayer {
	applymovement(LOCALID_ROUTE103_RIVAL, Common_Movement_FacePlayer)
    waitmovement(0)
    applymovement(LOCALID_ROUTE103_RIVAL, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_ROUTE103_RIVAL, Common_Movement_Delay48)
    waitmovement(0)
	return
}

script Route103_EventScript_RivalExit {
    closemessage
	if (var(VAR_FACING) == DIR_NORTH) {
		applymovement(LOCALID_PLAYER, moves(delay_16,  delay_4,  step_faster_left,  delay_16,  step_faster_down))
		applymovement(LOCALID_ROUTE103_RIVAL, moves(walk_left,  walk_down))
		waitmovement(0)
		playse(SE_LEDGE)
		applymovement(LOCALID_ROUTE103_RIVAL, moves(jump_2_down,  delay_16,  walk_down * 4))
	} else {
		if (var(VAR_FACING) != DIR_SOUTH) {
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down))
		}
		applymovement(LOCALID_ROUTE103_RIVAL, Common_Movement_WalkDown)
		waitmovement(0)
		playse(SE_LEDGE)
		applymovement(LOCALID_ROUTE103_RIVAL, moves(jump_2_down,  delay_16,  walk_down * 3))
	}
	waitmovement(0)
    removeobject(LOCALID_ROUTE103_RIVAL)
    setvar(VAR_BIRCH_LAB_STATE, 4)
    clearflag(FLAG_HIDE_LITTLEROOT_TOWN_BIRCHS_LAB_RIVAL)
    setflag(FLAG_DEFEATED_RIVAL_ROUTE103)
    setvar(VAR_OLDALE_RIVAL_STATE, 1)
    clearflag(FLAG_HIDE_OLDALE_TOWN_RIVAL)
    savebgm(MUS_DUMMY)
    fadedefaultbgm
    releaseall
    end
}

