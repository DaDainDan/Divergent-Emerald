script MtChimney_EventScript_Archie {
    lock_faceplayer
    if (!flag(FLAG_EVIL_LEADER_PLEASE_STOP)) {
        msgbox(MtChimney_Text_ArchieGoStopTeamMagma, MSGBOX_DEFAULT)
    } else {
		msgbox(MtChimney_Text_ArchieIHaveMyHandsFull, MSGBOX_DEFAULT)
	}
    closemessage
    applymovement(LOCALID_MT_CHIMNEY_ARCHIE, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    setflag(FLAG_EVIL_LEADER_PLEASE_STOP)
    release_end
}

script MtChimney_EventScript_Maxie {
    lockall
    playbgm(MUS_ENCOUNTER_MAGMA, FALSE)
    msgbox(MtChimney_Text_MeteoriteWillActivateVolcano, MSGBOX_DEFAULT)
    applymovement(LOCALID_MT_CHIMNEY_MAXIE, Common_Movement_FacePlayer)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_MT_CHIMNEY_MAXIE, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_MT_CHIMNEY_MAXIE, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(MtChimney_Text_MaxieIntro, MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_MAXIE_MT_CHIMNEY, MtChimney_Text_MaxieDefeat)
    msgbox(MtChimney_Text_MaxieYouHaventSeenLastOfMagma, MSGBOX_DEFAULT)
    closemessage
    delay(30)
    fadescreenswapbuffers(FADE_TO_BLACK)
    removeobject(LOCALID_MT_CHIMNEY_MAXIE)
    removeobject(LOCALID_MT_CHIMNEY_MAGMA_GRUNT_1)
    removeobject(LOCALID_MT_CHIMNEY_TABITHA)
    removeobject(LOCALID_MT_CHIMNEY_MAGMA_GRUNT_2)
    setflag(FLAG_HIDE_MT_CHIMNEY_TEAM_MAGMA)
    fadescreenswapbuffers(FADE_FROM_BLACK)
    setobjectxyperm(LOCALID_MT_CHIMNEY_ARCHIE, 10, 12)
    addobject(LOCALID_MT_CHIMNEY_ARCHIE)
	switch (var(VAR_FACING)) {
		case DIR_EAST: applymovement(LOCALID_MT_CHIMNEY_ARCHIE, moves(walk_up * 6,  walk_right))
		case DIR_NORTH: applymovement(LOCALID_MT_CHIMNEY_ARCHIE, moves(walk_up * 5,  walk_right * 2))
	}
	waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(MtChimney_Text_ArchieThankYou, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_FACING)) {
		case DIR_EAST: applymovement(LOCALID_MT_CHIMNEY_ARCHIE, moves(walk_left,  walk_down * 7))
		case DIR_NORTH: applymovement(LOCALID_MT_CHIMNEY_ARCHIE, moves(walk_left * 2,  walk_down * 7))
	}
	waitmovement(0)
    removeobject(LOCALID_MT_CHIMNEY_ARCHIE)
    setflag(FLAG_HIDE_MT_CHIMNEY_TEAM_AQUA)
    setflag(FLAG_DEFEATED_EVIL_TEAM_MT_CHIMNEY)
    clearflag(FLAG_HIDE_FALLARBOR_HOUSE_PROF_COZMO)
    setflag(FLAG_HIDE_METEOR_FALLS_1F_1R_COZMO)
    clearflag(FLAG_HIDE_MT_CHIMNEY_LAVA_COOKIE_LADY)
    releaseall
    end
}

raw `
MtChimney_EventScript_LavaCookieLady::
	lock
	faceplayer
	showmoneybox 0, 0
	msgbox MtChimney_Text_LavaCookiesJust200, MSGBOX_YESNO
	goto_if_eq VAR_RESULT, NO, MtChimney_EventScript_DeclineLavaCookie
	checkmoney 200
	goto_if_eq VAR_RESULT, FALSE, MtChimney_EventScript_NotEnoughMoney
	msgbox MtChimney_Text_ThankYouDear, MSGBOX_DEFAULT
	checkitemspace ITEM_LAVA_COOKIE
	call_if_eq VAR_RESULT, TRUE, MtChimney_EventScript_RemoveMoney
.if OW_SHOW_ITEM_DESCRIPTIONS == OW_ITEM_DESCRIPTIONS_OFF
	giveitem ITEM_LAVA_COOKIE
	goto_if_eq VAR_RESULT, FALSE, MtChimney_EventScript_BagIsFull
	hidemoneybox
	release
	end

MtChimney_EventScript_BagIsFull::
	msgbox gText_TooBadBagIsFull, MSGBOX_DEFAULT
	hidemoneybox
	release
	end
.else
	hidemoneybox
	giveitem ITEM_LAVA_COOKIE
	goto_if_eq VAR_RESULT, FALSE, MtChimney_EventScript_BagIsFull
	release
	end

MtChimney_EventScript_BagIsFull::
	msgbox gText_TooBadBagIsFull, MSGBOX_DEFAULT
	release
	end
.endif @ OW_SHOW_ITEM_DESCRIPTIONS	
`

script MtChimney_EventScript_RemoveMoney {
    removemoney(200)
    updatemoneybox
    return
}

script MtChimney_EventScript_DeclineLavaCookie {
    msgbox(MtChimney_Text_OhFineThen, MSGBOX_DEFAULT)
    hidemoneybox
    release_end
}

script MtChimney_EventScript_NotEnoughMoney {
    msgbox(MtChimney_Text_YouveNotGotTheMoney, MSGBOX_DEFAULT)
    hidemoneybox
    release_end
}

movement MtChimney_Movement_Unused1 {
    // moves(walk_down * 5,  walk_left * 2,  walk_down * 4,  walk_left * 5,  walk_down)
    walk_down * 5
    walk_left * 2
    walk_down * 4
    walk_left * 5
    walk_down
}

movement MtChimney_Movement_Unused2 {
    // moves(walk_down * 4,  walk_left * 3,  walk_down)
    walk_down * 4
    walk_left * 3
    walk_down
}

movement MtChimney_Movement_Unused3 {
    // moves(walk_right,  walk_down * 4,  walk_left * 5,  walk_down * 4)
    walk_right
    walk_down * 4
    walk_left * 5
    walk_down * 4
}

movement MtChimney_Movement_Unused4 {
    // moves(run_down * 9,  walk_left * 2,  walk_down * 3,  walk_left * 2,  walk_down * 2,  walk_left * 5,  walk_down)
    run_down * 9
    walk_left * 2
    walk_down * 3
    walk_left * 2
    walk_down * 2
    walk_left * 5
    walk_down
}

movement MtChimney_Movement_Unused5 {
    // moves(delay_16 * 3,  walk_down * 3,  walk_left * 3,  walk_down)
    delay_16 * 3
    walk_down * 3
    walk_left * 3
    walk_down
}

movement MtChimney_Movement_Unused6 {
    // moves(delay_16,  walk_left,  walk_down * 4,  walk_left * 5,  walk_down * 4)
    delay_16
    walk_left
    walk_down * 4
    walk_left * 5
    walk_down * 4
}

movement MtChimney_Movement_Unused7 {
    // moves(delay_16,  walk_left * 2,  walk_down * 3,  walk_left * 2,  walk_down * 2,  walk_left * 5,  walk_down)
    delay_16
    walk_left * 2
    walk_down * 3
    walk_left * 2
    walk_down * 2
    walk_left * 5
    walk_down
}

movement MtChimney_Movement_Unused8 {
    // moves(delay_16,  walk_down,  walk_left * 4,  step_faster_down)
    delay_16
    walk_down
    walk_left * 4
    step_faster_down
}

movement MtChimney_Movement_Unused9 {
    // moves(walk_down * 4,  walk_left * 5,  walk_down * 4)
    walk_down * 4
    walk_left * 5
    walk_down * 4
}

movement MtChimney_Movement_Unused10 {
    // moves(walk_down)
    walk_down
}

movement MtChimney_Movement_Unused11 {
    // moves(walk_down * 7)
    walk_down * 7
}

movement MtChimney_Movement_Unused12 {
    // moves(delay_16 * 2,  step_faster_left,  delay_16,  walk_down * 5)
    delay_16 * 2
    step_faster_left
    delay_16
    walk_down * 5
}

movement MtChimney_Movement_Unused13 {
    // moves(delay_16 * 6,  step_faster_left,  delay_16,  walk_down * 2)
    delay_16 * 6
    step_faster_left
    delay_16
    walk_down * 2
}

movement MtChimney_Movement_Unused14 {
    // moves(lock_look,  run_left,  unlock_look,  face_right)
    lock_look
    run_left
    unlock_look
    face_right
}

movement MtChimney_Movement_Unused15 {
    // moves(walk_left,  step_faster_right,  delay_16)
    walk_left
    step_faster_right
    delay_16
}

