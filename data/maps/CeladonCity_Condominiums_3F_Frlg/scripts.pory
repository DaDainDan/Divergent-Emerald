mapscripts CeladonCity_Condominiums_3F_Frlg_MapScripts {}

script CeladonCity_Condominiums_3F_EventScript_Programmer {
    msgbox(CeladonCity_Condominiums_3F_Text_ImTheProgrammer, MSGBOX_NPC)
    end
}

script CeladonCity_Condominiums_3F_EventScript_GraphicArtist {
    msgbox(CeladonCity_Condominiums_3F_Text_ImTheGraphicArtist, MSGBOX_NPC)
    end
}

script CeladonCity_Condominiums_3F_EventScript_Writer {
    msgbox(CeladonCity_Condominiums_3F_Text_IWroteTheStory, MSGBOX_NPC)
    end
}

script CeladonCity_Condominiums_3F_EventScript_Designer {
    lock_faceplayer
    if (specialvar(VAR_RESULT, HasAllKantoMons) == TRUE) {
		message(CeladonCity_Condominiums_3F_Text_CompletedPokedexCongratulations)
		waitmessage
		delay(60)
		special(Special_ShowDiploma)
		release_end
	}
    msgbox(CeladonCity_Condominiums_3F_Text_ImGameDesignerShowMeFinishedPokedex)
    release_end
}

script CeladonCity_Condominiums_3F_EventScript_DevelopmentRoomSign {
    msgbox(CeladonCity_Condominiums_3F_Text_GameFreakDevelopmentRoom, MSGBOX_SIGN)
    end
}

script CeladonCity_Condominiums_3F_EventScript_Computer1 {
    msgbox(CeladonCity_Condominiums_3F_Text_ItsTheGameProgram, MSGBOX_SIGN)
    end
}

script CeladonCity_Condominiums_3F_EventScript_Computer2 {
    msgbox(CeladonCity_Condominiums_3F_Text_SomeonesPlayingGame, MSGBOX_SIGN)
    end
}

script CeladonCity_Condominiums_3F_EventScript_Computer3 {
    msgbox(CeladonCity_Condominiums_3F_Text_ItsScriptBetterNotLookAtEnding, MSGBOX_SIGN)
    end
}

text CeladonCity_Condominiums_3F_Text_ImTheProgrammer {
	"Me?
	I'm the programmer!"
}

text CeladonCity_Condominiums_3F_Text_ImTheGraphicArtist {
	"I'm the graphic artist!
	I drew you!"
}

text CeladonCity_Condominiums_3F_Text_IWroteTheStory {
	"I wrote the story!
	Isn't ERIKA cute?

	I like MISTY a lot, too!
	Oh, and SABRINA, I like her!"
}

text CeladonCity_Condominiums_3F_Text_ImGameDesignerShowMeFinishedPokedex {
	"Is that right?

	I'm the game designer!

	Filling up your POKéDEX is tough,
	but don't quit!

	When you finish, come tell me!"
}

text CeladonCity_Condominiums_3F_Text_CompletedPokedexCongratulations {
	"Wow! Excellent!
	You completed your POKéDEX!
	Congratulations!
	…"
}

text CeladonCity_Condominiums_3F_Text_ItsTheGameProgram {
	"It's the game program! Messing with
	it could bug out the game!"
}

text CeladonCity_Condominiums_3F_Text_SomeonesPlayingGame {
	"Someone's playing a game instead of
	working!"
}

text CeladonCity_Condominiums_3F_Text_ItsScriptBetterNotLookAtEnding {
	"It's the script!
	Better not look at the ending!"
}

text CeladonCity_Condominiums_3F_Text_GameFreakDevelopmentRoom {
	"GAME FREAK Development Room"
}
