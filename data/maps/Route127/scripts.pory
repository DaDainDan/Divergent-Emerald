mapscripts Route127_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (flag(FLAG_SYS_WEATHER_CTRL)) {
			call(Common_EventScript_SetAbnormalWeather)
		}
		if (var(VAR_SHOULD_END_ABNORMAL_WEATHER) == 1) {
			call(AbnormalWeather_EventScript_HideMapNamePopup)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_127_NORTH || var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_127_SOUTH) {
			call(AbnormalWeather_StartKyogreWeather)
		}
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_127_NORTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute127North)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_127_SOUTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute127South)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SHOULD_END_ABNORMAL_WEATHER, 1: AbnormalWeather_EventScript_EndEventAndCleanup_1
    ]
}

script Route127_EventScript_Camden {
    trainerbattle_single(TRAINER_CAMDEN, Route127_Text_CamdenIntro, Route127_Text_CamdenDefeat)
    msgbox(Route127_Text_CamdenPostBattle, MSGBOX_AUTOCLOSE)
    end
}

