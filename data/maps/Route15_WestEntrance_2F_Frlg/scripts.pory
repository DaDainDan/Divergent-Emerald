const REQUIRED_CAUGHT_MONS = 50

mapscripts Route15_WestEntrance_2F_Frlg_MapScripts {}

script Route15_WestEntrance_2F_EventScript_LeftBinoculars {
    lockall
    msgbox(Route15_WestEntrance_2F_Text_LargeShiningBird)
    showmonpic(SPECIES_ARTICUNO, 10, 3)
    delay(20)
    waitbuttonpress
    hidemonpic
    setvar(VAR_0x8004, SPECIES_ARTICUNO)
    special(SetSeenMon)
    releaseall
    end
}

script Route15_WestEntrance_2F_EventScript_RightBinoculars {
    msgbox(Route15_WestEntrance_2F_Text_SmallIslandOnHorizon, MSGBOX_SIGN)
    end
}

script Route15_WestEntrance_2F_EventScript_Aide {
    lock_faceplayer
    call(Route15_WestEntrance_2F_EventScript_GetAideRequestInfo)
    if (!flag(FLAG_GOT_EXP_SHARE_FROM_OAKS_AIDE)) {
        msgbox(Route15_WestEntrance_2F_Text_GiveItemIfCaughtEnough, MSGBOX_YESNO)
		if (var(VAR_RESULT) == NO) {
			goto(Aide_EventScript_DeclineCheckMons)
		}
		setvar(VAR_0x8004, 0)
		specialvar(VAR_RESULT, GetFrlgPokedexCount)
		buffernumberstring(STR_VAR_3, VAR_0x8006)
		call(Route15_WestEntrance_2F_EventScript_GetAideRequestInfo)
		if (var(VAR_0x8006) < REQUIRED_CAUGHT_MONS) {
			goto(Aide_EventScript_HaventCaughtEnough)
		}
		msgbox(Route15_WestEntrance_2F_Text_GreatHereYouGo)
		if (checkitemspace(ITEM_EXP_SHARE) == FALSE) {
			goto(Aide_EventScript_NoRoomForItem)
		}
		giveitem_msg(Route15_WestEntrance_2F_Text_ReceivedItemFromAide, ITEM_EXP_SHARE)
		setflag(FLAG_GOT_EXP_SHARE_FROM_OAKS_AIDE)
    }
    msgbox(Route15_WestEntrance_2F_Text_ExplainExpShare)
    release_end
}

script Route15_WestEntrance_2F_EventScript_GetAideRequestInfo {
    buffernumberstring(STR_VAR_1, REQUIRED_CAUGHT_MONS)
    bufferitemname(STR_VAR_2, ITEM_EXP_SHARE)
    return
}

text Route15_WestEntrance_2F_Text_GiveItemIfCaughtEnough {
	"Hi! Remember me?
	I'm one of PROF. OAK's AIDES.

	If your POKéDEX has complete data
	on {STR_VAR_1} species, I'm supposed to
	give you a reward.

	PROF. OAK entrusted me with the
	{STR_VAR_2} for you.

	So, {PLAYER}, let me ask you.

	Have you gathered data on at least
	{STR_VAR_1} kinds of POKéMON?"
}

text Route15_WestEntrance_2F_Text_GreatHereYouGo {
	"Great! You have caught or owned
	{STR_VAR_3} kinds of POKéMON!

	Congratulations!
	Here you go!"
}

text Route15_WestEntrance_2F_Text_ReceivedItemFromAide {
	"{PLAYER} received the {STR_VAR_2}
	from the AIDE."
}

text Route15_WestEntrance_2F_Text_ExplainExpShare {
	"EXP. SHARE is an item to be held
	by a POKéMON.

	The POKéMON will receive a share
	of the EXP. Points without having
	to battle."
}

text Route15_WestEntrance_2F_Text_LargeShiningBird {
	"Let's see what the binoculars have
	to show…

	A large, shining bird is flying
	toward the sea."
}

text Route15_WestEntrance_2F_Text_SmallIslandOnHorizon {
	"Let's see what the binoculars have
	to show…

	It looks like a small island on
	the horizon!"
}
