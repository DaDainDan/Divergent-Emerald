mapscripts UndergroundPath_NorthEntrance_Frlg_MapScripts {}

script UndergroundPath_NorthEntrance_EventScript_Saige {
    lock_faceplayer
    setvar(VAR_0x8008, INGAME_TRADE_NIDORAN)
    call(EventScript_GetInGameTradeSpeciesInfo)
    if (flag(FLAG_DID_MS_NIDO_TRADE)) {
        msgbox(Trade_Text_HowIsMyOldMon)
    	release_end
    }
    msgbox(Trade_Text_DoYouHaveMonWantToTradeForMon, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(UndergroundPath_NorthEntrance_EventScript_DeclineTrade)
    }
    call(EventScript_ChooseMonForInGameTrade)
    if (var(VAR_0x8004) >= PARTY_SIZE) {
        goto(UndergroundPath_NorthEntrance_EventScript_DeclineTrade)
    }
    call(EventScript_GetInGameTradeSpecies)
    if (var(VAR_RESULT) != VAR_0x8009) {
        bufferspeciesname(STR_VAR_1, VAR_0x8009)
		msgbox(Trade_Text_ThisIsNoMon)
		release_end
    }
    call(EventScript_DoInGameTrade)
    msgbox(Trade_Text_ThanksYoureAPal)
    setflag(FLAG_DID_MS_NIDO_TRADE)
    release_end
}

script UndergroundPath_NorthEntrance_EventScript_DeclineTrade {
    msgbox(Trade_Text_ThatsTooBad)
    release_end
}
