mapscripts Route116_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (flag(FLAG_RECOVERED_DEVON_GOODS)) {
			setobjectxyperm(LOCALID_ROUTE116_WANDAS_BF, 38, 10)
		}
		if (var(VAR_SHOULD_END_ABNORMAL_WEATHER) == 1) {
			call(AbnormalWeather_EventScript_HideMapNamePopup)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_116_NORTH
		 || var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_116_SOUTH) {
			call(AbnormalWeather_StartGroudonWeather)
		}
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_116_NORTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute116North)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_116_SOUTH) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute116South)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SHOULD_END_ABNORMAL_WEATHER, 1: AbnormalWeather_EventScript_EndEventAndCleanup_1
    ]
}

script Route116_EventScript_WandasBoyfriend {
    lock_faceplayer
    if (flag(FLAG_RECOVERED_DEVON_GOODS)) {
        msgbox(Route116_Text_GoonHightailedItOutOfTunnel, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_DEVON_GOODS_STOLEN)) {
        msgbox(Route116_Text_DiggingTunnelWhenGoonOrderedMeOut, MSGBOX_DEFAULT)
    }
	else {
		msgbox(Route116_Text_WantToDigTunnel, MSGBOX_DEFAULT)
	}
    release_end
}

script Route116_EventScript_DevonEmployee {
    lock_faceplayer
    if (flag(FLAG_MET_DEVON_EMPLOYEE)) {
        msgbox(Route116_Text_TokenOfAppreciation, MSGBOX_DEFAULT)
    } else {
		msgbox(Route116_Text_ThankYouTokenOfAppreciation, MSGBOX_DEFAULT)
	}
    goto(Route116_EventScript_GiveRepeatBall)
    end
}

script Route116_EventScript_GiveRepeatBall {
    setflag(FLAG_MET_DEVON_EMPLOYEE)
    giveitem(ITEM_REPEAT_BALL)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(Route116_Text_BagIsJamPacked, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(Route116_Text_NewBallAvailableAtMart, MSGBOX_DEFAULT)
    closemessage
	if (var(VAR_FACING) == DIR_EAST) {
		applymovement(VAR_LAST_TALKED, moves(walk_down,  walk_left * 9))
	} else {
		applymovement(VAR_LAST_TALKED, moves(walk_left * 8))
	}
	waitmovement(0)
    removeobject(VAR_LAST_TALKED)
    clearflag(FLAG_HIDE_RUSTBORO_CITY_DEVON_CORP_3F_EMPLOYEE)
    setflag(FLAG_RECEIVED_REPEAT_BALL)
    release_end
}

