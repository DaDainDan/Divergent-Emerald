mapscripts LilycoveCity_LilycoveMuseum_2F_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (flag(FLAG_COOL_PAINTING_MADE)) {
			setmetatile(10, 6, METATILE_LilycoveMuseum_Painting2_Left, TRUE)
			setmetatile(11, 6, METATILE_LilycoveMuseum_Painting2_Right, TRUE)
		}
		if (flag(FLAG_BEAUTY_PAINTING_MADE)) {
			setmetatile(18, 6, METATILE_LilycoveMuseum_Painting1_Left, TRUE)
			setmetatile(19, 6, METATILE_LilycoveMuseum_Painting1_Right, TRUE)
		}
		if (flag(FLAG_CUTE_PAINTING_MADE)) {
			setmetatile(14, 10, METATILE_LilycoveMuseum_Painting3_Left, TRUE)
			setmetatile(15, 10, METATILE_LilycoveMuseum_Painting3_Right, TRUE)
		}
		if (flag(FLAG_SMART_PAINTING_MADE)) {
			setmetatile(6, 10, METATILE_LilycoveMuseum_Painting0_Left, TRUE)
			setmetatile(7, 10, METATILE_LilycoveMuseum_Painting0_Right, TRUE)
		}
		if (flag(FLAG_TOUGH_PAINTING_MADE)) {
			setmetatile(2, 6, METATILE_LilycoveMuseum_Painting4_Left, TRUE)
			setmetatile(3, 6, METATILE_LilycoveMuseum_Painting4_Right, TRUE)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LILYCOVE_MUSEUM_2F_STATE, 0: LilycoveCity_LilycoveMuseum_2F_EventScript_ShowExhibitHall
    ]
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_ShowExhibitHall {
    lockall
    applymovement(LOCALID_MUSEUM_2F_CURATOR, Common_Movement_FacePlayer)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ThisIsExhibitHall, MSGBOX_SIGN)
    applymovement(LOCALID_MUSEUM_2F_CURATOR, moves(face_up,  delay_16))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(face_up,  delay_16))
    waitmovement(0)
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ExplainExhibitHall, MSGBOX_SIGN)
    applymovement(LOCALID_MUSEUM_2F_CURATOR, Common_Movement_FacePlayer)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_PleaseObtainPaintingsForExhibit, MSGBOX_SIGN)
    goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowExhibitHallEnd)
	end
}

raw `
LilycoveCity_LilycoveMuseum_2F_EventScript_ShowExhibitHallEnd::
#ifdef UBFIX
	setvar VAR_LILYCOVE_MUSEUM_2F_STATE, 1
#else
	copyvar VAR_LILYCOVE_MUSEUM_2F_STATE, 1, warn=FALSE
#endif
	releaseall
	end
`

script LilycoveCity_LilycoveMuseum_2F_EventScript_Curator {
    lockall
    if (flag(FLAG_RECEIVED_GLASS_ORNAMENT)) {
        msgbox(LilycoveCity_LilycoveMuseum_2F_Text_HonorToHaveYouVisit, MSGBOX_NPC)
    	releaseall
    	end
    }
    specialvar(VAR_0x8004, CountPlayerMuseumPaintings)
    switch (var(VAR_0x8004)) {
		case 0: msgbox(LilycoveCity_LilycoveMuseum_2F_Text_WishToFillExhibit, MSGBOX_NPC)
        case 1:
        case 2:
        case 3:
        case 4: msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ThanksAddedNewPainting, MSGBOX_NPC)
        case 5:
			applymovement(LOCALID_MUSEUM_2F_CURATOR, Common_Movement_FacePlayer)
			waitmovement(0)
			msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsYouPlayer, MSGBOX_DEFAULT)
			applymovement(LOCALID_MUSEUM_2F_CURATOR, moves(face_up,  delay_16))
			msgbox(LilycoveCity_LilycoveMuseum_2F_Text_PaintingsAttractedMoreGuests, MSGBOX_DEFAULT)
			applymovement(LOCALID_MUSEUM_2F_CURATOR, Common_Movement_FacePlayer)
			msgbox(LilycoveCity_LilycoveMuseum_2F_Text_TokenOfGratitude, MSGBOX_DEFAULT)
			if (givedecoration(DECOR_GLASS_ORNAMENT) == FALSE) {
				call(Common_EventScript_NoRoomForDecor)
				msgbox(LilycoveCity_LilycoveMuseum_2F_Text_KeepThisForYou, MSGBOX_DEFAULT)
			} else {
				setflag(FLAG_RECEIVED_GLASS_ORNAMENT)
			}
			closemessage
			releaseall
    }
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_CutePainting {
    lockall
    if (flag(FLAG_CUTE_PAINTING_MADE)) {
        setvar(VAR_0x8007, 2)
    	goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting)
    }
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsPinkPictureFrame, MSGBOX_SIGN)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_ToughPainting {
    lockall
    if (flag(FLAG_TOUGH_PAINTING_MADE)) {
        setvar(VAR_0x8007, 4)
    	goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting)
    }
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsYellowPictureFrame, MSGBOX_SIGN)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_CoolPainting {
    lockall
    if (flag(FLAG_COOL_PAINTING_MADE)) {
        setvar(VAR_0x8007, 0)
    	goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting)
    }
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsRedPictureFrame, MSGBOX_SIGN)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_BeautyPainting {
    lockall
    if (flag(FLAG_BEAUTY_PAINTING_MADE)) {
        setvar(VAR_0x8007, 1)
    	goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting)
    }
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsBluePictureFrame, MSGBOX_SIGN)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_SmartPainting {
    lockall
    if (flag(FLAG_SMART_PAINTING_MADE)) {
        setvar(VAR_0x8007, 3)
    	goto(LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting)
    }
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsGreenPictureFrame, MSGBOX_SIGN)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_ShowPainting {
	msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ItsPaintingOfPokemon, MSGBOX_SIGN)
    fadescreen(FADE_TO_BLACK)
	switch (var(VAR_0x8007)) {
		case 0: showcontestpainting(CONTEST_WINNER_MUSEUM_COOL)
		case 1: showcontestpainting(CONTEST_WINNER_MUSEUM_BEAUTY)
		case 2: showcontestpainting(CONTEST_WINNER_MUSEUM_CUTE)
		case 3: showcontestpainting(CONTEST_WINNER_MUSEUM_SMART)
		case 4: showcontestpainting(CONTEST_WINNER_MUSEUM_TOUGH)
	}
    releaseall
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_Girl {
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_NewPaintingsSurprisedMe, MSGBOX_NPC)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_ExpertM {
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_NewPaintingsRatherAmusing, MSGBOX_NPC)
    end
}

script LilycoveCity_LilycoveMuseum_2F_EventScript_RichBoy {
    msgbox(LilycoveCity_LilycoveMuseum_2F_Text_ThesePaintingsOfYourPokemon, MSGBOX_NPC)
    end
}

text LilycoveCity_LilycoveMuseum_2F_Text_ThisIsExhibitHall {
	"This is our special exhibit hall."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ExplainExhibitHall {
	"As you can plainly see, there is not
	a single painting on exhibit.

	Here, I don't wish to exhibit works of
	so-called classical art.

	Such classical works you can see on
	our ground floor.

	I wish to exhibit work that is far
	different from the classics.

	Art, after all, is not restricted to old,
	famous works!

	This exhibit hall, I wish to fill it with…

	Modern and vibrant artworks of
	POKéMON seemingly ready to spring
	forth into glorious life!"
}

text LilycoveCity_LilycoveMuseum_2F_Text_PleaseObtainPaintingsForExhibit {
	"I beg your pardon. I didn't intend
	to monopolize the conversation.

	Now, as you are young, and yet
	obviously well traveled…

	You must encounter lively POKéMON
	and works of art depicting them.

	If you were to come across such
	a painting, may we ask you to obtain
	the artist's permission to exhibit
	it here?"
}

text LilycoveCity_LilycoveMuseum_2F_Text_WishToFillExhibit {
	"I wish to fill this exhibit hall with
	modern and vibrant paintings of
	POKéMON."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ThanksAddedNewPainting {
	"Thanks to you, we've added a new
	painting to our collection!

	I've heard it depicts your POKéMON.
	Truly magnificent!

	Thank you so very, very much!"
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsYouPlayer {
	"Ah! It's you!
	{PLAYER}!"
}

text LilycoveCity_LilycoveMuseum_2F_Text_PaintingsAttractedMoreGuests {
	"Isn't this marvelous?
	This collection of paintings!

	Each one of them flawless!
	None better than another!

	These paintings have attracted
	more guests to our ART MUSEUM.

	Sincerely, I thank you, {PLAYER}.
	This is my dream come true!"
}

text LilycoveCity_LilycoveMuseum_2F_Text_TokenOfGratitude {
	"This is merely a token of my gratitude."
}

text LilycoveCity_LilycoveMuseum_2F_Text_KeepThisForYou {
	"I will keep this for you until we
	meet again."
}

text LilycoveCity_LilycoveMuseum_2F_Text_HonorToHaveYouVisit {
	"Ah, so good to see you, {PLAYER}!

	It's an honor to have you visit us
	on your busy journeys.

	Please, relax and do enjoy your
	visit with us."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsPinkPictureFrame {
	"It's a picture frame with pink-colored
	adornments."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsYellowPictureFrame {
	"It's a picture frame with
	yellow-colored adornments."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsBluePictureFrame {
	"It's a picture frame with
	blue-colored adornments."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsRedPictureFrame {
	"It's a picture frame with
	red-colored adornments."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsGreenPictureFrame {
	"It's a picture frame with
	green-colored adornments."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ItsPaintingOfPokemon {
	"It's a painting of POKéMON."
}

text LilycoveCity_LilycoveMuseum_2F_Text_NewPaintingsSurprisedMe {
	"I've been away awhile, so the new
	paintings up here surprised me.

	I wish someone would paint my POKéMON
	this pretty."
}

text LilycoveCity_LilycoveMuseum_2F_Text_NewPaintingsRatherAmusing {
	"Well… So this is where they show
	the topical POKéMON paintings.

	I see, these new paintings are indeed
	rather amusing."
}

text LilycoveCity_LilycoveMuseum_2F_Text_ThesePaintingsOfYourPokemon {
	"Wow, is that right?
	These paintings are of your POKéMON.

	Isn't that just the ultimate joy for
	a TRAINER?"
}
