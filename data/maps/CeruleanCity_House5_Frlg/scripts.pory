mapscripts CeruleanCity_House5_Frlg_MapScripts {}

script CeruleanCity_House5_EventScript_BerryPowderMan {
    lock_faceplayer
    if (flag(FLAG_GOT_POWDER_JAR)) {
        special(DisplayBerryPowderVendorMenu)
		msgbox(CeruleanCity_House1_Text_HaveYouBroughtBerryPowder)
		goto(CeruleanCity_House5_EventScript_ChooseExchangeItem)
    }
    msgbox(CeruleanCity_House1_Text_AnyInterestInBerries, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(CeruleanCity_House1_Text_TakeInterestInAllSortsOfThings)
    }
    elif (!flag(FLAG_SYS_GOT_BERRY_POUCH)) {
        msgbox(CeruleanCity_House1_Text_WhyMustYouLieNoBerries)
    }
	else {
		msgbox(CeruleanCity_House1_Text_HaveJustTheThing)
		setflag(FLAG_GOT_POWDER_JAR)
		if (giveitem(ITEM_POWDER_JAR) == FALSE) {
			goto(EventScript_BagIsFull)
		}
		msgbox(CeruleanCity_House1_Text_GoCrushBerriesAtDirectCorner)
	}
    release_end
}

script CeruleanCity_House5_EventScript_ChooseExchangeItem {
    message(CeruleanCity_House5_Text_ExchangeWithWhat)
    waitmessage
    setvar(VAR_0x8004, SCROLL_MULTI_BERRY_POWDER_VENDOR)
    special(ShowScrollableMultichoice)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(ITEM_ENERGY_POWDER, 50)
        case 1: setitemandprice(ITEM_ENERGY_ROOT, 80)
        case 2: setitemandprice(ITEM_HEAL_POWDER, 50)
        case 3: setitemandprice(ITEM_REVIVAL_HERB, 300)
        case 4: setitemandprice(ITEM_PROTEIN, 1000)
        case 5: setitemandprice(ITEM_IRON, 1000)
        case 6: setitemandprice(ITEM_CARBOS, 1000)
        case 7: setitemandprice(ITEM_CALCIUM, 1000)
        case 8: setitemandprice(ITEM_ZINC, 1000)
        case 9: setitemandprice(ITEM_HP_UP, 1000)
        case 10: setitemandprice(ITEM_PP_UP, 3000)
        case 11:
        case MULTI_B_PRESSED:
			msgbox(CeruleanCity_House1_Text_SeeMeIfYoudLikeToTradePowder)
			special(RemoveBerryPowderVendorMenu)
			release_end
    }
	bufferitemname(STR_VAR_1, VAR_GIFT_ITEM)
	goto(CeruleanCity_House5_EventScript_ExchangePowderForItem)
    end
}

script CeruleanCity_House5_EventScript_ExchangePowderForItem {
    msgbox(CeruleanCity_House1_Text_YoullExchangeBerryPowderForItem, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CeruleanCity_House5_EventScript_ChooseExchangeItem)
    }
    copyvar(VAR_0x8004, VAR_EXCHANGE_PRICE)
    if (specialvar(VAR_RESULT, HasEnoughBerryPowder) == FALSE) {
        msgbox(CeruleanCity_House1_Text_DontHaveEnoughBerryPowder)
    	goto(CeruleanCity_House5_EventScript_ChooseExchangeItem)
    }
    elif (giveitem(VAR_GIFT_ITEM) == FALSE) {
        msgbox(gText_TheBagIsFull)
    }
	else {
		copyvar(VAR_0x8004, VAR_EXCHANGE_PRICE)
		special(TakeBerryPowder)
		special(PrintPlayerBerryPowderAmount)
		msgbox(CeruleanCity_House1_Text_TradeMoreBerryPowder, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			goto(CeruleanCity_House5_EventScript_ChooseExchangeItem)
		}
		msgbox(CeruleanCity_House1_Text_HopeToSeeYouAgain)
	}
    special(RemoveBerryPowderVendorMenu)
    release_end
}

script CeruleanCity_House5_EventScript_BerryCrushRankings {
    lockall
    special(ShowBerryCrushRankings)
    releaseall
    end
}

text CeruleanCity_House1_Text_AnyInterestInBerries {
	"I concoct a variety of medicine
	from BERRY POWDER.

	Using good BERRY POWDER, I can
	make any kind of medicine.

	Now tell me, have you any interest
	in BERRIES?"
}

text CeruleanCity_House1_Text_HaveJustTheThing {
	"Ah, good! For you, then, I have
	just the thing."
}

text CeruleanCity_House1_Text_GoCrushBerriesAtDirectCorner {
	"There's something new on the second
	floor of POKéMON CENTERS, at the
	DIRECT CORNER.

	They installed a Wireless Adapter
	machine for crushing BERRIES.

	This is where you come in.

	I have a favor to ask, one that
	I can entrust only to you.

	Could you make BERRY POWDER for
	me using that machine?

	Don't forget, the machine is at the
	DIRECT CORNER of POKéMON CENTERS.

	I'll concoct medicine for you if
	you bring me some BERRY POWDER.

	Don't forget, crush BERRIES into
	BERRY POWDER and bring it to me."
}

text CeruleanCity_House1_Text_WhyMustYouLieNoBerries {
	"Why must you lie to me?

	How many BERRIES do you have?
	Not a one!"
}

text CeruleanCity_House1_Text_TakeInterestInAllSortsOfThings {
	"You have no interest in BERRIES?

	Young one, it's important to take an
	interest in all sorts of things."
}

text CeruleanCity_House1_Text_HaveYouBroughtBerryPowder {
	"Er-hem! Have you brought me some
	BERRY POWDER?"
}

text CeruleanCity_House5_Text_ExchangeWithWhat {
	"With what would you like to 
	exchange it?"
}

text CeruleanCity_House1_Text_YoullExchangeBerryPowderForItem {
	"Fine, you'll exchange your BERRY
	POWDER for one {STR_VAR_1}?"
}

text CeruleanCity_House1_Text_DontHaveEnoughBerryPowder {
	"Hm? You don't have enough
	BERRY POWDER."
}

text CeruleanCity_House1_Text_TradeMoreBerryPowder {
	"This is fine BERRY POWDER indeed.
	It will make excellent medicine.

	Would you like to trade more BERRY
	POWDER for something else?"
}

text CeruleanCity_House1_Text_HopeToSeeYouAgain {
	"That's fine, then.
	I'll hope to see you back again."
}

text CeruleanCity_House1_Text_SeeMeIfYoudLikeToTradePowder {
	"Come see me if you'd like to trade
	your BERRY POWDER."
}
