mapscripts TrainerHill_Entrance_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        trainerhill_resumetimer
		setvar(VAR_TEMP_0, 0)
		trainerhill_getusingereader
		if (var(VAR_RESULT) == FALSE) { // VAR_RESULT always FALSE here
			trainerhill_getwon
			if (var(VAR_RESULT) == FALSE) {
				applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
			}
			end
		}
		setobjectxy(LOCALID_PLAYER, 9, 6)
		applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
		end
    }
    MAP_SCRIPT_ON_RETURN_TO_FIELD {
        addobject(LOCALID_TRAINER_HILL_NURSE)
		addobject(LOCALID_TRAINER_HILL_ATTENDANT)
		addobject(LOCALID_TRAINER_HILL_MAN)
		addobject(LOCALID_TRAINER_HILL_GIRL)
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_LANDMARK_TRAINER_HILL)
		getplayerxy(VAR_TEMP_D, VAR_RESULT)
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_TEMP_D) == 17) {
			setmetatile(17, 10, METATILE_TrainerHill_GreenFloorTile, FALSE)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: TrainerHill_Entrance_EventScript_ExitChallenge
		VAR_TEMP_D, 17: TrainerHill_Entrance_EventScript_ExitElevator
		VAR_TEMP_5, 1: TrainerHill_Entrance_EventScript_EntryTrigger
		VAR_TEMP_1, 1: TrainerHill_EventScript_WarpToEntranceCounter
    ]
}

script TrainerHill_Entrance_EventScript_ExitElevator {
    lockall
    applymovement(LOCALID_PLAYER, moves(walk_down * 2))
    waitmovement(0)
    setmetatile(17, 10, METATILE_TrainerHill_CounterDoor, TRUE)
    special(DrawWholeMapView)
    playse(SE_CLICK)
    waitse
    setvar(VAR_TEMP_D, 0)
    releaseall
    end
}

script TrainerHill_Entrance_EventScript_ExitChallenge {
    setvar(VAR_TEMP_0, 1)
    trainerhill_getstatus
    switch (var(VAR_RESULT)) {
        case TRAINER_HILL_PLAYER_STATUS_LOST:
			lockall
    		applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    		msgbox(TrainerHill_Entrance_Text_TooBadTremendousEffort, MSGBOX_DEFAULT)
        case TRAINER_HILL_PLAYER_STATUS_ECARD_SCANNED:
			lockall
    		applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    		msgbox(TrainerHill_Entrance_Text_MovedReceptionHereForSwitch, MSGBOX_DEFAULT)
		default: end
    }
	closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    setvar(VAR_TRAINER_HILL_IS_ACTIVE, 0)
    special(HealPlayerParty)
    callnative(UpdateFollowingPokemon)
    releaseall
    end
}

script TrainerHill_Entrance_EventScript_Nurse {
    setvar(VAR_0x800B, LOCALID_TRAINER_HILL_NURSE)
    call(Common_EventScript_PkmnCenterNurse)
    waitmessage
    waitbuttonpress
    release_end
}

script TrainerHill_Entrance_EventScript_Attendant {
    lock_faceplayer
    trainerhill_inchallenge
    if (var(VAR_RESULT) == FALSE) {
        msgbox(TrainerHill_Entrance_Text_ThankYouForPlaying, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(TrainerHill_Entrance_Text_HopeYouGiveItYourBest, MSGBOX_DEFAULT)
    release_end
}

script TrainerHill_Entrance_EventScript_EntryTrigger {
    lockall
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    if (!flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(TrainerHill_Entrance_Text_StillGettingReady, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
		waitmovement(0)
		releaseall
		end
    }
    msgbox(TrainerHill_Entrance_Text_WelcomeToTrainerHill, MSGBOX_DEFAULT)
    trainerhill_getsaved
    if (var(VAR_RESULT) == FALSE) {
        msgbox(TrainerHill_Entrance_Text_SaveGameBeforeEnter, MSGBOX_DEFAULT)
		trainerhill_setsaved
		setvar(VAR_TEMP_5, 1)
		call(Common_EventScript_SaveGame)
		if (var(VAR_RESULT) == FALSE) {
			trainerhill_clearsaved
			goto(TrainerHill_Entrance_EventScript_CancelEntry)
		}
		trainerhill_setsaved
    }
    trainerhill_allfloorsused
    if (var(VAR_RESULT) == TRUE) {
        msgbox(TrainerHill_Entrance_Text_TrainersInEveryRoom, MSGBOX_DEFAULT)
    } else {
		msgbox(TrainerHill_Entrance_Text_TrainersUpToFloorX, MSGBOX_DEFAULT)
	}
    goto(TrainerHill_Entrance_EventScript_AskChallengeTrainers)
	end
}

script TrainerHill_Entrance_EventScript_AskChallengeTrainers {
    message(TrainerHill_Entrance_Text_LikeToChallengeTrainers)
    waitmessage
    multichoice(15, 6, MULTI_YESNOINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(TrainerHill_Entrance_EventScript_ChooseChallenge)
        case 2:
			msgbox(TrainerHill_Entrance_Text_ExplainTrainerHill, MSGBOX_DEFAULT)
    		goto(TrainerHill_Entrance_EventScript_AskChallengeTrainers)
		case 1:
        case MULTI_B_PRESSED: goto(TrainerHill_Entrance_EventScript_CancelEntry)
    }
    end
}

script TrainerHill_Entrance_EventScript_ChooseChallenge {
    multichoice(13, 2, MULTI_TAG_MATCH_TYPE, FALSE)
	if (var(VAR_RESULT) == 4 || var(VAR_RESULT) == MULTI_B_PRESSED) {
		goto(TrainerHill_Entrance_EventScript_CancelEntry)
	}
    trainerhill_setmode(VAR_RESULT)
    setvar(VAR_TRAINER_HILL_IS_ACTIVE, 1)
    setvar(VAR_TEMP_5, 0)
    special(HealPlayerParty)
    callnative(UpdateFollowingPokemon)
    msgbox(TrainerHill_Entrance_Text_TimeProgessGetSetGo, MSGBOX_DEFAULT)
    trainerhill_start
    releaseall
    end
}

script TrainerHill_Entrance_EventScript_CancelEntry {
    setvar(VAR_TEMP_5, 0)
    msgbox(TrainerHill_Entrance_Text_PleaseVisitUsAgain, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_WalkDown)
    waitmovement(0)
    releaseall
    end
}

// Unused
movement TrainerHill_Entrance_Movement_FaceUp {
    // moves(face_up)
    face_up
}

script TrainerHill_Entrance_EventScript_Records {
    lockall
    fadescreen(FADE_TO_BLACK)
    setvar(VAR_0x8004, 0)
    special(ShowTrainerHillRecords)
    releaseall
    end
}

script TrainerHill_Entrance_EventScript_Man {
    if (!flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(TrainerHill_Entrance_Text_CantWaitToTestTheWaters, MSGBOX_NPC)
    	end
    }
    msgbox(TrainerHill_Entrance_Text_WhatSortOfTrainersAreAhead, MSGBOX_NPC)
    end
}

script TrainerHill_Entrance_EventScript_Girl {
    if (!flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(TrainerHill_Entrance_Text_DoYouKnowWhenTheyOpen, MSGBOX_NPC)
    	end
    }
    msgbox(TrainerHill_Entrance_Text_FriendsTryingToReachTimeBoardTop, MSGBOX_NPC)
    end
}

script TrainerHill_Entrance_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        goto(TrainerHill_Entrance_EventScript_ExpandedPokemart)
    }
    pokemart(TrainerHill_Entrance_Pokemart_Basic)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart TrainerHill_Entrance_Pokemart_Basic {
    ITEM_SUPER_POTION
    ITEM_ANTIDOTE
    ITEM_PARALYZE_HEAL
    ITEM_AWAKENING
    ITEM_X_SPEED
    ITEM_X_SP_ATK
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
    ITEM_DIRE_HIT
    ITEM_GUARD_SPEC
    ITEM_X_ACCURACY
}

script TrainerHill_Entrance_EventScript_ExpandedPokemart {
    pokemart(TrainerHill_Entrance_Pokemart_Expanded)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart TrainerHill_Entrance_Pokemart_Expanded {
    ITEM_HYPER_POTION
    ITEM_MAX_POTION
    ITEM_FULL_RESTORE
    ITEM_FULL_HEAL
    ITEM_REVIVE
    ITEM_X_SPEED
    ITEM_X_SP_ATK
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
    ITEM_DIRE_HIT
    ITEM_GUARD_SPEC
    ITEM_X_ACCURACY
}

text TrainerHill_Entrance_Text_StillGettingReady {
	"This is the TRAINER HILL where
	you may enjoy tag battles with many
	TRAINERS.

	Unfortunately, we're still getting
	things ready. Please come back later!"
}

text TrainerHill_Entrance_Text_WelcomeToTrainerHill {
	"Welcome!

	This is the TRAINER HILL where
	you may enjoy tag battles with many
	TRAINERS!"
}

text TrainerHill_Entrance_Text_SaveGameBeforeEnter {
	"Is this your first visit here?

	Before you enter, please save
	your game."
}

text TrainerHill_Entrance_Text_TrainersUpToFloorX {
	"Let's see…
	The TRAINERS here now are…

	Up to floor no. {STR_VAR_1}."
}

text TrainerHill_Entrance_Text_TrainersInEveryRoom {
	"Let's see…
	The TRAINERS here now are…

	There appear to be TRAINERS gathered
	in every room."
}

text TrainerHill_Entrance_Text_LikeToChallengeTrainers {
	"Would you like to challenge the
	waiting TRAINERS?"
}

text TrainerHill_Entrance_Text_TimeProgessGetSetGo {
	"I will time your progress.
	Best of luck!

	On your marks…

	Get set…

	Go!"
}

text TrainerHill_Entrance_Text_PleaseVisitUsAgain {
	"Please do visit us again!"
}

text TrainerHill_Entrance_Text_TooBadTremendousEffort {
	"That was too bad.

	I think you put in a tremendous
	effort in your battling.

	Please come back and try again!"
}

text TrainerHill_Entrance_Text_HopeYouGiveItYourBest {
	"I hope you give it your best."
}

text TrainerHill_Entrance_Text_MovedReceptionHereForSwitch {
	"When the TRAINERS switch places,
	the movement can be hectic.

	To avoid the stampede, we moved
	the reception counter here.

	I'm sorry for the inconvenience."
}

text TrainerHill_Entrance_Text_ThankYouForPlaying {
	"Thank you for playing!"
}

text TrainerHill_Entrance_Text_ExplainTrainerHill {
	"Here at the TRAINER HILL, we conduct
	an event called the Time Attack.

	It is a race that measures how long
	you take to reach our owner on
	the rooftop from this counter.

	The fastest times are posted on
	the Time Board--try competing with
	your friends.

	In TRAINER battles along the way,
	neither Exp. Points nor money will
	be awarded."
}

text TrainerHill_Entrance_Text_NeedAtLeastTwoPokemon {
	"Oh, I'm sorry, but you appear to have
	only one POKéMON with you.

	You will need at least two POKéMON
	to enter this event."
}

text TrainerHill_Roof_Text_YouFinallyCameBravo {
	"Hm! Hm!

	You finally came!
	Yes, you have arrived!

	Wait! Don't say it!
	I know why you came all the way
	here by yourself!

	You wanted to see me, the owner
	of the TRAINER HILL, because…

	You want to form a tag team with me!
	Wa-hoo!

	…Uh?
	That's not it?

	Anyway, I watched you on your way up.
	Marvelous battling! Bravo, indeed!"
}

text TrainerHill_Roof_Text_HaveTheMostMarvelousGift {
	"For a marvelous someone like you,
	I have the most marvelous gift!"
}

text TrainerHill_Roof_Text_FullUpBeBackLaterForThis {
	"Oh, no, full up with things!
	You'll be back later for this!"
}

text TrainerHill_Roof_Text_GotHereMarvelouslyQuickly {
	"Oh, hold on here! Did you possibly get
	here marvelously quickly?

	How splendid! You needn't have
	hurried so to see me!

	That is so delightful. I'll have the Time
	Board at the reception updated!"
}

text TrainerHill_Roof_Text_YouWerentVeryQuick {
	"But, oh…
	You weren't very quick getting here."
}

text TrainerHill_Roof_Text_ArriveZippierNextTime {
	"Perhaps it would please me more if you
	arrived zippier next time.

	Then, I should be pleased to form
	a tag team with you!

	Until we meet again, amigo!"
}

text TrainerHill_Roof_Text_BuiltTrainerHillToFindPartner {
	"I had the TRAINER HILL built for but
	one reason and one only!

	To find the most suitable partner
	with whom I may form a tag team!"
}

text TrainerHill_Entrance_Text_ChallengeTime {
	"{STR_VAR_1} min. {STR_VAR_2}.{STR_VAR_3} sec."
}

text TrainerHill_Entrance_Text_WhatSortOfTrainersAreAhead {
	"Who knows what sort of TRAINERS
	and POKéMON combos are ahead?

	All I know is that I'll knock aside
	anyone that stands in my way!"
}

text TrainerHill_Entrance_Text_CantWaitToTestTheWaters {
	"I heard tough TRAINERS come to this
	TRAINER HILL from all over.

	I can't wait to test the waters!

	I'll knock aside anyone that stands
	in my way!"
}

text TrainerHill_Entrance_Text_FriendsTryingToReachTimeBoardTop {
	"Do you see the Time Board over there?

	My friends and I are trying to see who
	can reach the top in the least time."
}

text TrainerHill_Entrance_Text_DoYouKnowWhenTheyOpen {
	"Do you know when they're opening
	this place up?

	I'm waiting here to be the first
	challenger ever!"
}

text TrainerHill_Elevator_Text_ReturnToReception {
	"Would you like to return to
	the reception counter?"
}
