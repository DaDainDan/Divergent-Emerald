// On this map the player will automatically walk into the room, but the camera is supposed to remain still.
// To do this GF sets the player (LOCALID_PLAYER) invisible and creates a fake player object (LOCALID_TOWER_MULTI_BATTLE_PLAYER).
// The graphics of this fake player object are represented with VAR_OBJ_GFX_ID_F.
// The graphics of the partner are represented with VAR_OBJ_GFX_ID_E, which will ultimately be set by tower_setpartnergfx.
// The graphics of the opponents are represented with VAR_OBJ_GFX_ID_0 and OBJ_EVENT_GFX_VAR_1, which will ultimately be set by tower_setopponent.

mapscripts BattleFrontier_BattleTowerMultiBattleRoom_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_MULTIS) {
			tower_setpartnergfx
			if (checkplayergender == FEMALE) {
				setvar(VAR_OBJ_GFX_ID_F, OBJ_EVENT_GFX_MAY_NORMAL)
			} else {
				setvar(VAR_OBJ_GFX_ID_F, OBJ_EVENT_GFX_BRENDAN_NORMAL)
			}
		}
		if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
			special(SetBattleTowerLinkPlayerGfx)
		}
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			hideobjectat(LOCALID_PLAYER, MAP_BATTLE_FRONTIER_BATTLE_TOWER_MULTI_BATTLE_ROOM)
		}
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattleTowerMultiBattleRoom_EventScript_EnterRoom
    ]
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_EnterRoom {
    setvar(VAR_TEMP_0, 1)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PLAYER, moves(walk_up * 4,  face_right))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PARTNER, moves(walk_left,  walk_up * 3,  face_right))
    waitmovement(0)
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    if (var(VAR_RESULT) == 0) {
        goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_OpponentsEnter)
    }
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_1, moves(walk_right * 2))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_2, moves(walk_right * 2))
    waitmovement(0)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PLAYER, Common_Movement_FaceLeft)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PARTNER, Common_Movement_FaceLeft)
    waitmovement(0)
    frontier_set(FRONTIER_DATA_RECORD_DISABLED, TRUE)
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_OpponentsEnter {
    tower_setopponent
    addobject(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_1)
    addobject(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_1, moves(walk_down * 4,  face_left))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2, moves(walk_right,  walk_down * 3,  face_left))
    waitmovement(0)
	tower_getopponentintro(0)
    delay(15)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_1, Common_Movement_StepLeft)
    waitmovement(0)
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        messageautoscroll(gStringVar4)
		waitmessage
		delay(48)
		tower_getopponentintro(1)
		applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2, Common_Movement_StepLeft)
		waitmovement(0)
		messageautoscroll(gStringVar4)
		waitmessage
		delay(48)
    } else {
		msgbox(gStringVar4, MSGBOX_DEFAULT)
		waitmessage
		tower_getopponentintro(1)
		applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2, Common_Movement_StepLeft)
		waitmovement(0)
		msgbox(gStringVar4, MSGBOX_DEFAULT)
		waitmessage
	}
    call(BattleFrontier_BattleTowerBattleRoom_EventScript_DoTowerBattle)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_DefeatedOpponents)
	}
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_WarpToLobbyLost)
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_WarpToLobbyLost {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST)
    tower_set(TOWER_DATA_LVL_MODE)
    setvar(VAR_0x8004, FANCOUNTER_USED_BATTLE_TOWER)
    special(Script_TryGainNewFanFromCounter)
    goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobby)
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_DefeatedOpponents {
    frontier_incrementstreak
    tower_setbattlewon
	if (var(VAR_RESULT) == 7) {
		frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_WON)
		tower_set(TOWER_DATA_LVL_MODE)
		setvar(VAR_0x8004, FANCOUNTER_USED_BATTLE_TOWER)
		special(Script_TryGainNewFanFromCounter)
		goto(BattleFrontier_BattleTowerBattleRoom_EventScript_WarpToLobby)
	}
    applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2, moves(walk_up * 3,  set_invisible))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_1, moves(walk_up * 4))
    waitmovement(0)
    removeobject(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_1)
    removeobject(LOCALID_TOWER_MULTI_BATTLE_OPPONENT_2)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_1, moves(walk_right * 2))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_2, moves(walk_right * 2))
    waitmovement(0)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PLAYER, Common_Movement_FaceLeft)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PARTNER, Common_Movement_FaceLeft)
    waitmovement(0)
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        messageautoscroll(BattleFrontier_BattleTowerBattleRoom_Text_RestoreMonsToFullHealth)
		waitmessage
		delay(48)
    } else {
		msgbox(BattleFrontier_BattleTowerBattleRoom_Text_RestoreMonsToFullHealth, MSGBOX_DEFAULT)
	}
    special(LoadPlayerParty)
    frontier_setpartyorder(FRONTIER_MULTI_PARTY_SIZE)
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        special(BattleTowerReconnectLink)
    }
    playfanfare(MUS_HEAL)
    waitfanfare
    special(HealPlayerParty)
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
	end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
    call(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ReadyForNextOpponentSet)
    if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallenge)
    }
    frontier_get(FRONTIER_DATA_RECORD_DISABLED)
    if (var(VAR_RESULT) == TRUE) {
        multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallenge)
			case 1: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskPauseChallenge)
			case 2: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallenge)
			case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
		}
    } else {
		multichoice(19, 4, MULTI_GO_ON_RECORD_REST_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallenge)
			case 1: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRecordBattle)
			case 2: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskPauseChallenge)
			case 3: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallenge)
			case MULTI_B_PRESSED: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
		}
	}
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRecordBattle {
    message(BattleFrontier_BattleTowerBattleRoom_Text_RecordYourBattle)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		call(BattleFrontier_EventScript_SaveBattle)
	}
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattleTowerBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
	if (var(VAR_RESULT) == YES) {
		message(BattleFrontier_BattleTowerBattleRoom_Text_SavingPleaseWait)
		waitmessage
		tower_save(CHALLENGE_STATUS_PAUSED)
		playse(SE_SAVE)
		waitse
		fadescreen(1)
		frontier_reset
		end
	}
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattleTowerBattleRoom_Text_CancelYourChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    switch (var(VAR_RESULT)) {
		case 0: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_WarpToLobbyLost)
        case 1:
        case MULTI_B_PRESSED: 
            goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
    }
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallenge {
    closemessage
    clearflag(FLAG_TEMP_2)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PLAYER, Common_Movement_StepFasterRight)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_PARTNER, Common_Movement_StepFasterRight)
    waitmovement(0)
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_1, moves(walk_left * 2,  step_faster_right))
    applymovement(LOCALID_TOWER_MULTI_BATTLE_ATTENDANT_2, moves(walk_left * 2,  step_faster_right))
    waitmovement(0)
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_OpponentsEnter)
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ReadyForNextOpponentSet {
    copyvar(VAR_TEMP_F, VAR_RESULT)
    switch (var(VAR_TEMP_F)) {
        case 1: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor2ndOpponentSet)
        case 2: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor3rdOpponentSet)
        case 3: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor4thOpponentSet)
        case 4: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor5thOpponentSet)
        case 5: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor6thOpponentSet)
        case 6: message(BattleFrontier_BattleTowerMultiBattleRoom_Text_ReadyFor7thOpponentSet)
    }
	waitmessage
	if (var(VAR_FRONTIER_BATTLE_MODE) == FRONTIER_MODE_LINK_MULTIS) {
        goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponentsLink)
    }
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponentsLink {
    if (flag(FLAG_TEMP_2)) {
        multichoice(20, 8, MULTI_GO_ON_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallengeLink)
			case 1:
			case MULTI_B_PRESSED: 
                goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallengeLink)
		}
    } else {
		multichoice(19, 6, MULTI_GO_ON_RECORD_RETIRE, TRUE)
		switch (var(VAR_RESULT)) {
			case 0: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallengeLink)
			case 1: goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRecordBattleLink)
			case 2:
			case MULTI_B_PRESSED: 
                goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallengeLink)
		}
	}
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_ContinueChallengeLink {
    setvar(VAR_0x8004, BATTLE_TOWER_LINK_CONTINUE)
    setvar(VAR_0x8005, 0)
    message(gText_LinkStandby3)
    waitmessage
    special(LinkRetireStatusWithBattleTowerPartner)
    if (var(VAR_RESULT) != BATTLE_TOWER_LINKSTAT_CONTINUE) {
        goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_WarpToLobbyLost)
    }
    waitmessage
    delay(48)
    return
	end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRecordBattleLink {
    message(BattleFrontier_BattleTowerBattleRoom_Text_RecordYourBattle)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
	if (var(VAR_RESULT) == 0) {
		call(BattleFrontier_EventScript_SaveBattle)
		setflag(FLAG_TEMP_2)
	}
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
    end
}

script BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskRetireChallengeLink {
    message(BattleFrontier_BattleTowerBattleRoom_Text_CancelYourChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    if (var(VAR_RESULT) == 0) {
        setvar(VAR_0x8004, BATTLE_TOWER_LINK_RETIRE)
		setvar(VAR_0x8005, 0)
		message(gText_LinkStandby3)
		waitmessage
		special(LinkRetireStatusWithBattleTowerPartner)
		goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_WarpToLobbyLost)
    }
    goto(BattleFrontier_BattleTowerMultiBattleRoom_EventScript_AskReadyForOpponents)
    end
}

