mapscripts BattleFrontier_BattlePikeRoomFinal_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0 {
			delay(16)
			applymovement(LOCALID_PIKE_FINAL_ROOM_ATTENDANT, moves(walk_down * 2))
			waitmovement(0)
			frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_WON)
			lockall
			msgbox(BattleFrontier_BattlePikeRoomFinal_Text_CongratsThisWayPlease, MSGBOX_DEFAULT)
			closemessage
			releaseall
			warp(MAP_BATTLE_FRONTIER_BATTLE_PIKE_LOBBY, 5, 6)
			waitstate
			end
		}
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_4, 0 {
			setvar(VAR_TEMP_4, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

text BattleFrontier_BattlePikeRoomFinal_Text_CongratsThisWayPlease {
	"Congratulations…
	Now, this way, please…"
}
