mapscripts Route104_MrBrineysHouse_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_LANDMARK_MR_BRINEY_HOUSE)
		if (var(VAR_BRINEY_HOUSE_STATE) == 1) {
			setobjectxyperm(LOCALID_BRINEYS_HOUSE_BRINEY, 9, 3)
			setobjectmovementtype(LOCALID_BRINEYS_HOUSE_BRINEY, MOVEMENT_TYPE_WALK_SEQUENCE_DOWN_LEFT_UP_RIGHT)
			setobjectxyperm(LOCALID_BRINEYS_HOUSE_PEEKO, 9, 6)
			setobjectmovementtype(LOCALID_BRINEYS_HOUSE_PEEKO, MOVEMENT_TYPE_WALK_SEQUENCE_LEFT_UP_RIGHT_DOWN)
		}
		if (flag(FLAG_RECEIVED_POKENAV)) {
			setflag(FLAG_HIDE_RUSTBORO_CITY_RIVAL)
		}
		end
    }
}

script Route104_MrBrineysHouse_EventScript_Briney {
    lock_faceplayer
    if (!flag(FLAG_MR_BRINEY_SAILING_INTRO)) {
        setflag(FLAG_MR_BRINEY_SAILING_INTRO)
    	msgbox(Route104_MrBrineysHouse_Text_WaitUpPeeko, MSGBOX_DEFAULT)
    	msgbox(Route104_MrBrineysHouse_Text_ItsYouLetsSailToDewford, MSGBOX_YESNO)
    }
    elif (!flag(FLAG_DELIVERED_STEVEN_LETTER)) {
        msgbox(Route104_MrBrineysHouse_Text_NeedToMakeDeliveriesSailToDewford, MSGBOX_YESNO)
    }
    elif (!flag(FLAG_DELIVERED_DEVON_GOODS)) {
        msgbox(Route104_MrBrineysHouse_Text_NeedToDeliverPackageSailToDewford, MSGBOX_YESNO)
    }
	else {
		goto(Route104_MrBrineysHouse_EventScript_WhereAreWeBound)
	}
	goto(Route104_MrBrineysHouse_EventScript_SailingYesNoResult)
    end
}

script Route104_MrBrineysHouse_EventScript_SailingYesNoResult {
	if (var(VAR_RESULT) == NO) {
        msgbox(Route104_MrBrineysHouse_Text_DeclineDeliverySail, MSGBOX_DEFAULT)
    	release_end
    }
    goto(Route104_MrBrineysHouse_EventScript_SailToDewford)
    end
}

script Route104_MrBrineysHouse_EventScript_WhereAreWeBound {
    message(Route104_MrBrineysHouse_Text_WhereAreWeBound)
    waitmessage
    multichoicedefault(20, 8, MULTI_BRINEY_OFF_DEWFORD, 1, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(Route104_MrBrineysHouse_EventScript_SailToDewford)
        case 1:
        case MULTI_B_PRESSED:
			msgbox(Route104_MrBrineysHouse_Text_TellMeWheneverYouWantToSail, MSGBOX_DEFAULT)
    		release_end
    }
    end
}

script Route104_MrBrineysHouse_EventScript_SailToDewford {
    msgbox(Route104_MrBrineysHouse_Text_SetSailForDewford, MSGBOX_DEFAULT)
    call(EventScript_BackupMrBrineyLocation)
    setvar(VAR_BOARD_BRINEY_BOAT_STATE, 1)
    clearflag(FLAG_HIDE_ROUTE_104_MR_BRINEY)
    setflag(FLAG_HIDE_BRINEYS_HOUSE_MR_BRINEY)
    setflag(FLAG_HIDE_BRINEYS_HOUSE_PEEKO)
    setvar(VAR_RUSTBORO_CITY_STATE, 8)
    setvar(VAR_ROUTE104_STATE, 2)
    setflag(FLAG_HIDE_RUSTBORO_CITY_RIVAL)
    setflag(FLAG_HIDE_ROUTE_104_RIVAL)
    warp(MAP_ROUTE104, 13, 51)
    waitstate
    releaseall
    end
}

script Route104_MrBrineysHouse_EventScript_Peeko {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_WINGULL, CRY_MODE_NORMAL)
    msgbox(Route104_MrBrineysHouse_Text_Peeko, MSGBOX_DEFAULT)
    waitmoncry
    release_end
}

text Route104_MrBrineysHouse_Text_WaitUpPeeko {
	"{SPEAKER NAME_BRINEY}Hold on, lass!
	Wait up, PEEKO!"
}

text Route104_MrBrineysHouse_Text_ItsYouLetsSailToDewford {
	"Hm? You're {PLAYER}{KUN}!
	You saved my darling PEEKO!
	We owe so much to you!

	What's that?
	You want to sail with me?

	Hmhm…

	You have a LETTER bound for DEWFORD
	and a package for SLATEPORT, then?

	Quite the busy life you must lead!

	But, certainly, what you're asking is
	no problem at all.

	You've come to the right man!
	We'll set sail for DEWFORD."
}

text Route104_MrBrineysHouse_Text_SetSailForDewford {
	"{SPEAKER NAME_BRINEY}DEWFORD it is, then!

	Anchors aweigh!
	PEEKO, we're setting sail, my darling!"
}

text Route104_MrBrineysHouse_Text_DeclineDeliverySail {
	"{SPEAKER NAME_BRINEY}Is that so?
	Your deliveries can wait?

	You just go on and tell me whenever
	you want to set sail!"
}

text Route104_MrBrineysHouse_Text_NeedToMakeDeliveriesSailToDewford {
	"{SPEAKER NAME_BRINEY}Ahoy!
	I know exactly what you want to say!

	You're to deliver a LETTER to DEWFORD
	and a package to SLATEPORT.

	What you need me to do is no problem
	at all--I'm the man for the job!

	First, we'll set sail for DEWFORD."
}

text Route104_MrBrineysHouse_Text_NeedToDeliverPackageSailToDewford {
	"{SPEAKER NAME_BRINEY}Ahoy!
	I know exactly what you want to say!

	You're to deliver a package to
	CAPT. STERN in SLATEPORT.

	What you need me to do is no problem
	at all--I'm the man for the job!

	First, we'll set sail for DEWFORD."
}

text Route104_MrBrineysHouse_Text_WhereAreWeBound {
	"{SPEAKER NAME_BRINEY}Ahoy!
	For you, I'll go out to sea anytime!

	Now, my friend, where are we bound?"
}

text Route104_MrBrineysHouse_Text_TellMeWheneverYouWantToSail {
	"{SPEAKER NAME_BRINEY}Is that so?
	Well, PEEKO owes her life to you.

	You just go on and tell me whenever
	you want to set sail!"
}

text Route104_MrBrineysHouse_Text_Peeko {
	"{SPEAKER NAME_PEEKO}Pii piihyoro!"
}
