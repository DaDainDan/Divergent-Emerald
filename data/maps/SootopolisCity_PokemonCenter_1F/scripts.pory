mapscripts SootopolisCity_PokemonCenter_1F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_SOOTOPOLIS_CITY)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script SootopolisCity_PokemonCenter_1F_EventScript_Nurse {
    setvar(VAR_0x800B, LOCALID_SOOTOPOLIS_NURSE)
    call(Common_EventScript_PkmnCenterNurse)
    waitmessage
    waitbuttonpress
    release_end
}

script SootopolisCity_PokemonCenter_1F_EventScript_Gentleman {
    lock_faceplayer
    if (var(VAR_SKY_PILLAR_STATE) >= 2 || !flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN)) {
        msgbox(SootopolisCity_PokemonCenter_1F_Text_WallaceToughestInHoenn, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_PokemonCenter_1F_Text_EveryoneTakenRefuge, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_PokemonCenter_1F_EventScript_Woman {
    lock_faceplayer
    if (var(VAR_SKY_PILLAR_STATE) >= 2 || !flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN)) {
        msgbox(SootopolisCity_PokemonCenter_1F_Text_AlwaysBeFriendsWithPokemon, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_PokemonCenter_1F_Text_ArentPokemonOurFriends, MSGBOX_DEFAULT)
    release_end
}

text SootopolisCity_PokemonCenter_1F_Text_WallaceToughestInHoenn {
	"WALLACE is rumored to be the toughest
	TRAINER in the whole HOENN region.

	This town's GYM is led by the TRAINER
	who taught WALLACE.

	But the ELITE FOUR… They're said to be
	even stronger than WALLACE's mentor.

	How strong could they be?"
}

text SootopolisCity_PokemonCenter_1F_Text_EveryoneTakenRefuge {
	"Everyone in town has taken refuge
	and won't come out of their homes.

	Even I would rather not venture
	outside."
}

text SootopolisCity_PokemonCenter_1F_Text_AlwaysBeFriendsWithPokemon {
	"Whenever, wherever, and whatever
	happens, I will always be friends with
	POKéMON.

	Because it's fun to be with POKéMON!"
}

text SootopolisCity_PokemonCenter_1F_Text_ArentPokemonOurFriends {
	"Aren't POKéMON our friends?

	Why are they going wild this way?"
}
