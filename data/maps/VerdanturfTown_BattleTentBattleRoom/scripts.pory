// On this map the player will automatically walk into the room, but the camera is supposed to remain still.
// To do this GF sets the player (LOCALID_PLAYER) invisible and creates a fake player object (LOCALID_VERDANTURF_TENT_BATTLE_PLAYER).
// The graphics of this fake player object are represented with VAR_OBJ_GFX_ID_1.
// The graphics of the opponent are represented with VAR_OBJ_GFX_ID_0, which will ultimately be set by tower_setopponent.
mapscripts VerdanturfTown_BattleTentBattleRoom_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        call(VerdanturfTown_BattleTentBattleRoom_EventScript_SetPlayerGfx)
    	end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0 {
			showobjectat(LOCALID_VERDANTURF_TENT_BATTLE_PLAYER, MAP_VERDANTURF_TOWN_BATTLE_TENT_BATTLE_ROOM)
			applymovement(LOCALID_VERDANTURF_TENT_BATTLE_PLAYER, moves(set_visible,  walk_up * 3,  face_right))
			waitmovement(0)
			frontier_get(FRONTIER_DATA_BATTLE_NUM)
			if (var(VAR_RESULT) != 0) {
				goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskContinueChallenge)
			}
			goto(VerdanturfTown_BattleTentBattleRoom_EventScript_NextOpponentEnter)
		}
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			hideobjectat(LOCALID_VERDANTURF_TENT_BATTLE_PLAYER, MAP_VERDANTURF_TOWN_BATTLE_TENT_BATTLE_ROOM)
			call(VerdanturfTown_BattleTentBattleRoom_EventScript_SetPlayerGfx)
			setvar(VAR_TEMP_1, 1)
			applymovement(LOCALID_PLAYER, Common_Movement_SetInvisible)
			removeobject(LOCALID_VERDANTURF_TENT_BATTLE_OPPONENT)
			end
		}
    ]
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_SetPlayerGfx {
    if (checkplayergender == MALE) {
		setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_RIVAL_BRENDAN_NORMAL)
    	setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_RIVAL_BRENDAN_NORMAL)
	} else {
		setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_RIVAL_MAY_NORMAL)
    	setvar(VAR_OBJ_GFX_ID_0, OBJ_EVENT_GFX_RIVAL_MAY_NORMAL)
	}
    return
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_NextOpponentEnter {
    tower_setopponent
    addobject(LOCALID_VERDANTURF_TENT_BATTLE_OPPONENT)
    applymovement(LOCALID_VERDANTURF_TENT_BATTLE_OPPONENT, moves(walk_down * 4,  face_left))
    waitmovement(0)
    battletent_getopponentintro
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    waitmessage
    call(BattleFrontier_BattlePalaceBattleRoom_EventScript_DoPalaceBattle)
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		frontier_get(FRONTIER_DATA_BATTLE_NUM)
		addvar(VAR_RESULT, 1)
		frontier_set(FRONTIER_DATA_BATTLE_NUM, VAR_RESULT)
		if (var(VAR_RESULT) == 3) {
			frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_WON)
			special(LoadPlayerParty)
			warp(MAP_VERDANTURF_TOWN_BATTLE_TENT_LOBBY, 6, 6)
			waitstate
		}
		applymovement(LOCALID_VERDANTURF_TENT_BATTLE_OPPONENT, moves(walk_up * 4))
		waitmovement(0)
		removeobject(LOCALID_VERDANTURF_TENT_BATTLE_OPPONENT)
		applymovement(LOCALID_VERDANTURF_TENT_BATTLE_ATTENDANT, Common_Movement_StepFasterDown)
		applymovement(LOCALID_VERDANTURF_TENT_BATTLE_PLAYER, Common_Movement_StepFasterUp)
		waitmovement(0)
		msgbox(BattleFrontier_BattlePalaceBattleRoom_Text_LetMeRestoreYourMons, MSGBOX_DEFAULT)
		special(LoadPlayerParty)
		special(SavePlayerParty)
		frontier_setpartyorder(FRONTIER_PARTY_SIZE)
		playfanfare(MUS_HEAL)
		waitfanfare
		special(HealPlayerParty)
		goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskContinueChallenge)
	}
    goto(VerdanturfTown_BattleTentBattleRoom_EventScript_WarpToLobbyLost)
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_WarpToLobbyLost {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST)
    special(LoadPlayerParty)
    warp(MAP_VERDANTURF_TOWN_BATTLE_TENT_LOBBY, 6, 6)
    waitstate
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_AskContinueChallenge {
    frontier_get(FRONTIER_DATA_BATTLE_NUM)
	switch (var(VAR_RESULT)) {
		case 1: message(BattleFrontier_BattlePalaceBattleRoom_Text_PreparedFor2ndOpponent)
		case 2: message(BattleFrontier_BattlePalaceBattleRoom_Text_PreparedFor3rdOpponent)
	}
    waitmessage
    multichoice(20, 6, MULTI_GO_ON_REST_RETIRE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_ContinueChallenge)
        case 1: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskPauseChallenge)
        case 2: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskRetireChallenge)
    }
    end
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_ContinueChallenge {
    applymovement(LOCALID_VERDANTURF_TENT_BATTLE_ATTENDANT, Common_Movement_StepFasterRight)
    applymovement(LOCALID_VERDANTURF_TENT_BATTLE_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    closemessage
    goto(VerdanturfTown_BattleTentBattleRoom_EventScript_NextOpponentEnter)
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_AskPauseChallenge {
    msgbox(BattleFrontier_BattlePalaceBattleRoom_Text_SaveAndQuitGame, MSGBOX_YESNO)
    switch (var(VAR_RESULT)) {
        case YES:
			message(BattleFrontier_BattlePalaceBattleRoom_Text_SavingData)
			waitmessage
			verdanturftent_save(CHALLENGE_STATUS_PAUSED)
			playse(SE_SAVE)
			waitse
			fadescreen(FADE_TO_BLACK)
			frontier_reset
		case NO:
        case MULTI_B_PRESSED: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskContinueChallenge)
    }
    end
}

script VerdanturfTown_BattleTentBattleRoom_EventScript_AskRetireChallenge {
    message(BattleFrontier_BattlePalaceBattleRoom_Text_WishToQuitChallenge)
    waitmessage
    multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_WarpToLobbyLost)
		case 1:
        case MULTI_B_PRESSED: goto(VerdanturfTown_BattleTentBattleRoom_EventScript_AskContinueChallenge)
    }
    end
}
