mapscripts LavenderTown_House1_Frlg_MapScripts {}

script LavenderTown_House1_EventScript_CooltrainerF {
    lock_faceplayer
    if (flag(FLAG_RESCUED_MR_FUJI)) {
        msgbox(LavenderTown_House1_Text_GhostOfPokemonTowerIsGone)
    	release_end
    }
    msgbox(LavenderTown_House1_Text_RocketsKilledCubonesMother)
    release_end
}

script LavenderTown_House1_EventScript_Cubone {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_CUBONE, CRY_MODE_NORMAL)
    msgbox(LavenderTown_House1_Text_Cubone)
    waitmoncry
    release_end
}

text LavenderTown_House1_Text_Cubone {
	"CUBONE: Kyarugoo!"
}

text LavenderTown_House1_Text_RocketsKilledCubonesMother {
	"Those horrible ROCKETS!
	They deserve no mercy!

	That poor CUBONE's mother…

	It was killed trying to escape from
	TEAM ROCKET."
}

text LavenderTown_House1_Text_GhostOfPokemonTowerIsGone {
	"The ghost of POKéMON TOWER is
	gone!

	Someone must have soothed its
	restless spirit!"
}
