mapscripts AbandonedShip_Rooms2_1F_MapScripts {}

script AbandonedShip_Rooms2_1F_EventScript_Dan {
    trainerbattle_double(TRAINER_KIRA_AND_DAN_1, AbandonedShip_Rooms2_1F_Text_DanIntro, AbandonedShip_Rooms2_1F_Text_DanDefeat, AbandonedShip_Rooms2_1F_Text_DanNotEnoughMons, AbandonedShip_Rooms2_1F_EventScript_RegisterKiraDan)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
		trainerbattle_rematch_double(TRAINER_KIRA_AND_DAN_1, AbandonedShip_Rooms2_1F_Text_DanRematchIntro, AbandonedShip_Rooms2_1F_Text_DanRematchDefeat, AbandonedShip_Rooms2_1F_Text_DanRematchNotEnoughMons)
    	msgbox(AbandonedShip_Rooms2_1F_Text_DanPostRematch, MSGBOX_AUTOCLOSE)
    	end
	}
    msgbox(AbandonedShip_Rooms2_1F_Text_DanPostBattle, MSGBOX_DEFAULT)
    release_end
}

script AbandonedShip_Rooms2_1F_EventScript_RegisterKiraDan {
    msgbox(AbandonedShip_Rooms2_1F_Text_KiraRegister, MSGBOX_DEFAULT  @ Kira speaks for both when registering KiraAndDan)
    register_matchcall(TRAINER_KIRA_AND_DAN_1)
    release_end
}

script AbandonedShip_Rooms2_1F_EventScript_Kira {
    trainerbattle_double(TRAINER_KIRA_AND_DAN_1, AbandonedShip_Rooms2_1F_Text_KiraIntro, AbandonedShip_Rooms2_1F_Text_KiraDefeat, AbandonedShip_Rooms2_1F_Text_KiraNotEnoughMons, AbandonedShip_Rooms2_1F_EventScript_RegisterKiraDan)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
		trainerbattle_rematch_double(TRAINER_KIRA_AND_DAN_1, AbandonedShip_Rooms2_1F_Text_KiraRematchIntro, AbandonedShip_Rooms2_1F_Text_KiraRematchDefeat, AbandonedShip_Rooms2_1F_Text_KiraRematchNotEnoughMons)
    	msgbox(AbandonedShip_Rooms2_1F_Text_KiraPostRematch, MSGBOX_AUTOCLOSE)
    	end
	}
    msgbox(AbandonedShip_Rooms2_1F_Text_KiraPostBattle, MSGBOX_DEFAULT)
    release_end
}

script AbandonedShip_Rooms2_1F_EventScript_Jani {
    trainerbattle_single(TRAINER_JANI, AbandonedShip_Rooms2_1F_Text_JaniIntro, AbandonedShip_Rooms2_1F_Text_JaniDefeat)
    msgbox(AbandonedShip_Rooms2_1F_Text_JaniPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script AbandonedShip_Rooms2_1F_EventScript_Garrison {
    trainerbattle_single(TRAINER_GARRISON, AbandonedShip_Rooms2_1F_Text_GarrisonIntro, AbandonedShip_Rooms2_1F_Text_GarrisonDefeat)
    msgbox(AbandonedShip_Rooms2_1F_Text_GarrisonPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text AbandonedShip_Rooms2_1F_Text_DanIntro {
	"{SPEAKER NAME_DAN}While searching for treasures,
	we discovered a TRAINER!"
}

text AbandonedShip_Rooms2_1F_Text_DanDefeat {
	"{SPEAKER NAME_DAN}We couldn't win even though
	we worked together…"
}

text AbandonedShip_Rooms2_1F_Text_DanPostBattle {
	"{SPEAKER NAME_DAN}We can't find any treasures…
	I wonder if someone got them already?"
}

text AbandonedShip_Rooms2_1F_Text_DanNotEnoughMons {
	"{SPEAKER NAME_DAN}You don't even have two POKéMON.
	You can't expect to beat us like that."
}

text AbandonedShip_Rooms2_1F_Text_KiraIntro {
	"{SPEAKER NAME_KIRA}Oh?
	We were searching for treasures.
	But we discovered a TRAINER instead!"
}

text AbandonedShip_Rooms2_1F_Text_KiraDefeat {
	"{SPEAKER NAME_KIRA}Ooh, so strong!"
}

text AbandonedShip_Rooms2_1F_Text_KiraPostBattle {
	"{SPEAKER NAME_KIRA}Where could the treasures be?

	I've already decided what I'm buying
	when we find the treasures!"
}

text AbandonedShip_Rooms2_1F_Text_KiraNotEnoughMons {
	"{SPEAKER NAME_KIRA}Oh, you don't have two POKéMON?
	We'll have to battle some other time!"
}

text AbandonedShip_Rooms2_1F_Text_KiraRegister {
	"{SPEAKER NAME_KIRA}Oh, you make me so angry!
	I'm going to register you for that!"
}

text AbandonedShip_Rooms2_1F_Text_DanRematchIntro {
	"{SPEAKER NAME_DAN}We've been searching for
	treasures all this time.

	Our POKéMON have grown stronger, too.
	Let us show you, okay?"
}

text AbandonedShip_Rooms2_1F_Text_DanRematchDefeat {
	"{SPEAKER NAME_DAN}You're strong, as usual!"
}

text AbandonedShip_Rooms2_1F_Text_DanPostRematch {
	"{SPEAKER NAME_DAN}We can't find any treasures,
	we lose at POKéMON…

	I want to go home… But if I say that,
	she gets all angry with me…"
}

text AbandonedShip_Rooms2_1F_Text_DanRematchNotEnoughMons {
	"{SPEAKER NAME_DAN}You don't even have two POKéMON.
	You can't expect to beat us like that."
}

text AbandonedShip_Rooms2_1F_Text_KiraRematchIntro {
	"{SPEAKER NAME_KIRA}Oh? We meet again!

	Just like us, you still haven't given up
	searching for treasures, have you?

	Want to make it so the loser has
	to give up searching?"
}

text AbandonedShip_Rooms2_1F_Text_KiraRematchDefeat {
	"{SPEAKER NAME_KIRA}Oh, we lost again…"
}

text AbandonedShip_Rooms2_1F_Text_KiraPostRematch {
	"{SPEAKER NAME_KIRA}We're not leaving until we raise
	our POKéMON some more and we find
	the treasures here!"
}

text AbandonedShip_Rooms2_1F_Text_KiraRematchNotEnoughMons {
	"{SPEAKER NAME_KIRA}Oh, you don't have two POKéMON?
	We'll have to battle some other time!"
}

text AbandonedShip_Rooms2_1F_Text_JaniIntro {
	"I'm not good at swimming,
	but I am good at battles!"
}

text AbandonedShip_Rooms2_1F_Text_JaniDefeat {
	"Oops.
	That didn't go very well."
}

text AbandonedShip_Rooms2_1F_Text_JaniPostBattle {
	"Walking around barefoot in this ship
	is kind of gross."
}

text AbandonedShip_Rooms2_1F_Text_GarrisonIntro {
	"Strength and compassion…
	Those are a TRAINER's treasures!"
}

text AbandonedShip_Rooms2_1F_Text_GarrisonDefeat {
	"Ah, there is something about you
	that sparkles."
}

text AbandonedShip_Rooms2_1F_Text_GarrisonPostBattle {
	"In a cabin somewhere on board,
	I saw something sparkle."
}
