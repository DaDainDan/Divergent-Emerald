mapscripts SlateportCity_BattleTentLobby_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_CHALLENGE_STATUS, 0 {
			frontier_getstatus
    		end
		}
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING: SlateportCity_BattleTentLobby_EventScript_QuitWithoutSaving
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_PAUSED: SlateportCity_BattleTentLobby_EventScript_ResumeChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_WON: SlateportCity_BattleTentLobby_EventScript_WonChallenge
		VAR_TEMP_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST: SlateportCity_BattleTentLobby_EventScript_LostChallenge
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			setvar(VAR_TEMP_1, 1)
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
}

script SlateportCity_BattleTentLobby_EventScript_QuitWithoutSaving {
    lockall
    msgbox(SlateportCity_BattleTentLobby_Text_DidntSaveBeforeQuitting, MSGBOX_DEFAULT)
    closemessage
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    releaseall
    end
}

script SlateportCity_BattleTentLobby_EventScript_WonChallenge {
    lockall
    message(SlateportCity_BattleTentLobby_Text_WonThreeMatchesReturnMons)
    waitmessage
    slateporttent_setrandomprize
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    slateporttent_save(0)
    playse(SE_SAVE)
    waitse
    goto(SlateportCity_BattleTentLobby_EventScript_GivePrize)
}

script SlateportCity_BattleTentLobby_EventScript_GivePrize {
    msgbox(SlateportCity_BattleTentLobby_Text_AwardYouThisPrize, MSGBOX_DEFAULT)
    slateporttent_giveprize
	if (var(VAR_RESULT) == FALSE) {
		msgbox(SlateportCity_BattleTentLobby_Text_NoRoomInBagMakeRoom, MSGBOX_DEFAULT)
	}
    else {
		frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
		message(BattleFrontier_BattleTowerLobby_Text_ReceivedPrize) // Odd that it uses Tower's instead of Factory's or its own
		waitmessage
		playfanfare(MUS_OBTAIN_ITEM)
		waitfanfare
	}
    msgbox(SlateportCity_BattleTentLobby_Text_LookForwardToNextVisit, MSGBOX_DEFAULT)
    closemessage
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    releaseall
    end
}

script SlateportCity_BattleTentLobby_EventScript_LostChallenge {
    lockall
    message(SlateportCity_BattleTentLobby_Text_ReturnRentalMonsSaveResults)
    waitmessage
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    slateporttent_save(0)
    playse(SE_SAVE)
    waitse
    end
}

script SlateportCity_BattleTentLobby_EventScript_ResumeChallenge {
    lockall
    message(SlateportCity_BattleTentLobby_Text_BeenWaitingForYou)
    waitmessage
    slateporttent_save(CHALLENGE_STATUS_SAVING)
    playse(SE_SAVE)
    waitse
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    setvar(VAR_0x8006, 2)
    goto(SlateportCity_BattleTentLobby_EventScript_EnterChallenge)
}

script SlateportCity_BattleTentLobby_EventScript_Attendant {
    lock_faceplayer
    slateporttent_getprize
    if (var(VAR_RESULT) != ITEM_NONE) {
        goto(SlateportCity_BattleTentLobby_EventScript_GivePrize)
    }
    special(SavePlayerParty)
    msgbox(SlateportCity_BattleTentLobby_Text_WelcomeToBattleTent, MSGBOX_DEFAULT)
    goto(SlateportCity_BattleTentLobby_EventScript_AskEnterChallenge)
}

script SlateportCity_BattleTentLobby_EventScript_AskEnterChallenge {
    message(SlateportCity_BattleTentLobby_Text_TakeChallenge)
    waitmessage
    multichoice(17, 6, MULTI_CHALLENGEINFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: 
			goto(SlateportCity_BattleTentLobby_EventScript_TryEnterChallenge)
        case 1:
			msgbox(SlateportCity_BattleTentLobby_Text_ExplainSlateportTent, MSGBOX_DEFAULT)
    		goto(SlateportCity_BattleTentLobby_EventScript_AskEnterChallenge)
        case 2:
        case MULTI_B_PRESSED: goto(SlateportCity_BattleTentLobby_EventScript_CancelChallenge)
    }
    end
}

script SlateportCity_BattleTentLobby_EventScript_TryEnterChallenge {
    setvar(VAR_FRONTIER_FACILITY, FRONTIER_FACILITY_FACTORY)
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_SINGLES)
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_TENT)
    msgbox(SlateportCity_BattleTentLobby_Text_SaveBeforeChallenge, MSGBOX_YESNO)
    switch (var(VAR_RESULT)) {
        case YES: goto(SlateportCity_BattleTentLobby_EventScript_SaveBeforeChallenge)
		case NO:
        case MULTI_B_PRESSED: 
			special(LoadPlayerParty)
    		goto(SlateportCity_BattleTentLobby_EventScript_CancelChallenge)
    }
    end
}

script SlateportCity_BattleTentLobby_EventScript_SaveBeforeChallenge {
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    frontier_set(FRONTIER_DATA_SELECTED_MON_ORDER)
    slateporttent_init
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_SAVING)
    frontier_set(FRONTIER_DATA_PAUSED, FALSE)
    closemessage
    delay(2)
    call(Common_EventScript_SaveGame)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 255)
    if (var(VAR_RESULT) == 0) {
        frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, 0)
    	goto(SlateportCity_BattleTentLobby_EventScript_CancelChallenge)
    }
    setvar(VAR_0x8006, 0)
    goto(SlateportCity_BattleTentLobby_EventScript_EnterChallenge)
}

script SlateportCity_BattleTentLobby_EventScript_EnterChallenge {
    msgbox(SlateportCity_BattleTentLobby_Text_StepThisWay, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SLATEPORT_TENT_ATTENDANT, moves(walk_up * 3))
    applymovement(LOCALID_PLAYER, moves(walk_up * 3))
    waitmovement(0)
    opendoor(6, 1)
    waitdooranim
    applymovement(LOCALID_SLATEPORT_TENT_ATTENDANT, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  set_invisible))
    waitmovement(0)
    closedoor(6, 1)
    waitdooranim
    warp(MAP_SLATEPORT_CITY_BATTLE_TENT_CORRIDOR, 2, 7)
    setvar(VAR_TEMP_CHALLENGE_STATUS, 0)
    waitstate
    end
}

script SlateportCity_BattleTentLobby_EventScript_CancelChallenge {
    msgbox(SlateportCity_BattleTentLobby_Text_LookForwardToNextVisit, MSGBOX_DEFAULT)
    release_end
}

// Unused
movement(global) SlateportCity_BattleTentLobby_Movement_UnusedEnterDoor {
    // moves(walk_up * 3,  set_invisible)
    walk_up * 3
    set_invisible
}

script SlateportCity_BattleTentLobby_EventScript_TormentGiver {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_TM_TORMENT)) {
        msgbox(SlateportCity_BattleTentLobby_Text_ExplainTorment, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SlateportCity_BattleTentLobby_Text_CouldntFindMonForMe, MSGBOX_DEFAULT)
    if (giveitem(ITEM_TM_TORMENT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_RECEIVED_TM_TORMENT)
    msgbox(SlateportCity_BattleTentLobby_Text_ExplainTorment, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_BattleTentLobby_EventScript_Man {
    msgbox(SlateportCity_BattleTentLobby_Text_IllTryUsingBugMons, MSGBOX_NPC)
    end
}

script SlateportCity_BattleTentLobby_EventScript_Girl {
    msgbox(SlateportCity_BattleTentLobby_Text_BattleEvenWithoutToughMons, MSGBOX_NPC)
    end
}

script SlateportCity_BattleTentLobby_EventScript_Woman {
    msgbox(SlateportCity_BattleTentLobby_Text_NiceIfMoreSelection, MSGBOX_NPC)
    end
}

script SlateportCity_BattleTentLobby_EventScript_RulesBoard {
    lockall
    msgbox(BattleFrontier_BattleFactoryLobby_Text_RulesAreListed, MSGBOX_DEFAULT)
    goto(SlateportCity_BattleTentLobby_EventScript_ReadRulesBoard)
    end
}

script SlateportCity_BattleTentLobby_EventScript_ReadRulesBoard {
    message(BattleFrontier_BattleFactoryLobby_Text_ReadWhichHeading)
    waitmessage
    multichoice(17, 0, MULTI_SLATEPORT_TENT_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(SlateportCity_BattleTentLobby_Text_ExplainBasicRules, MSGBOX_DEFAULT)
        case 1: msgbox(SlateportCity_BattleTentLobby_Text_ExplainSwapPartnerRules, MSGBOX_DEFAULT)
        case 2: msgbox(SlateportCity_BattleTentLobby_Text_ExplainSwapNumberRules, MSGBOX_DEFAULT)
        case 3: msgbox(SlateportCity_BattleTentLobby_Text_ExplainSwapNotes, MSGBOX_DEFAULT)
        case 4: msgbox(SlateportCity_BattleTentLobby_Text_ExplainMonRules, MSGBOX_DEFAULT)
        case 5:
        case MULTI_B_PRESSED:
			releaseall
    		end
    }
    goto(SlateportCity_BattleTentLobby_EventScript_ReadRulesBoard)
    end
}

text SlateportCity_BattleTentLobby_Text_CouldntFindMonForMe {
	"So, like, I couldn't find myself any
	POKéMON that were, like, for me.

	So, I figured, like, hey, I should file
	a complaint to the guy there?

	And he wouldn't hear me out, like, hey!
	So, like, total bummer, man!

	Hey, like, you! Zip it, you know?
	Just, you know, take this!"
}

text SlateportCity_BattleTentLobby_Text_ExplainTorment {
	"That's, like, TM41, you know?
	Hey, it's TORMENT, you hearing me?

	Like, it won't let the other guy
	use the same move twice in a row, see?

	Hey, now, you listen here, like,
	I'm not laying a torment on you!"
}

text SlateportCity_BattleTentLobby_Text_IllTryUsingBugMons {
	"I don't really like BUG POKéMON,
	but maybe I'll try using some for
	a change of pace.

	Who knows, I might even get to like
	them!"
}

text SlateportCity_BattleTentLobby_Text_BattleEvenWithoutToughMons {
	"You can battle all you want here even
	if you don't have any tough POKéMON."
}

text SlateportCity_BattleTentLobby_Text_NiceIfMoreSelection {
	"Wouldn't it be nice if they had more of
	a selection?"
}
