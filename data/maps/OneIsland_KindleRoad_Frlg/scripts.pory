mapscripts OneIsland_KindleRoad_Frlg_MapScripts {}

script OneIsland_KindleRoad_EventScript_RouteSign {
    msgbox(OneIsland_KindleRoad_Text_RouteSign, MSGBOX_SIGN)
    end
}

script OneIsland_KindleRoad_EventScript_EmberSpaSign {
    msgbox(OneIsland_KindleRoad_Text_EmberSpaSign, MSGBOX_SIGN)
    end
}

text OneIsland_KindleRoad_Text_MariaIntro {
	"The weather's gorgeous!
	Perfect for a battle!"
}

text OneIsland_KindleRoad_Text_MariaDefeat {
	"Aiyeeeeh!"
}

text OneIsland_KindleRoad_Text_MariaPostBattle {
	"Please don't splash my face!
	You'll ruin the makeup."
}

text OneIsland_KindleRoad_Text_AbigailIntro {
	"I'm beginning to get a sunburn…"
}

text OneIsland_KindleRoad_Text_AbigailDefeat {
	"Oh, you're so awful."
}

text OneIsland_KindleRoad_Text_AbigailPostBattle {
	"I like that cap you have.
	Maybe I should wear one, too…"
}

text OneIsland_KindleRoad_Text_FinnIntro {
	"Seen from here, MT. EMBER towers
	into the sky."
}

text OneIsland_KindleRoad_Text_FinnDefeat {
	"Well, aren't you tough?"
}

text OneIsland_KindleRoad_Text_FinnPostBattle {
	"The sky is immense around these
	parts."
}

text OneIsland_KindleRoad_Text_GarrettIntro {
	"I took a break from swimming,
	only to have you challenge me?"
}

text OneIsland_KindleRoad_Text_GarrettDefeat {
	"Hey, what the…
	You're good, you!"
}

text OneIsland_KindleRoad_Text_GarrettPostBattle {
	"Instead of using SURF all the time,
	you should swim some."
}

text OneIsland_KindleRoad_Text_TommyIntro {
	"Wait! Wait a second!
	I think I've hooked a big one!"
}

text OneIsland_KindleRoad_Text_TommyDefeat {
	"I've lost it all again…"
}

text OneIsland_KindleRoad_Text_TommyPostBattle {
	"Not only did I lose, the big one
	got away from me, too!"
}

text OneIsland_KindleRoad_Text_SharonIntro {
	"Could you help me out with my
	training?"
}

text OneIsland_KindleRoad_Text_SharonDefeat {
	"You were a cut above me."
}

text OneIsland_KindleRoad_Text_SharonPostBattle {
	"It's clear that you're skilled.
	I like you!"
}

text OneIsland_KindleRoad_Text_TanyaIntro {
	"There isn't a day in which we don't
	train!"
}

text OneIsland_KindleRoad_Text_TanyaDefeat {
	"I'm such a fool!"
}

text OneIsland_KindleRoad_Text_TanyaPostBattle {
	"I'll train even harder from now on!"
}

text OneIsland_KindleRoad_Text_SheaIntro {
	"Every morning, before breakfast,
	I swim around this island."
}

text OneIsland_KindleRoad_Text_SheaDefeat {
	"Gasp…
	Gasp…"
}

text OneIsland_KindleRoad_Text_SheaPostBattle {
	"I lost because I'm pooped from all
	the running I did…"
}

text OneIsland_KindleRoad_Text_HughIntro {
	"Dress appropriately for battle!
	Lose that frivolous outfit!"
}

text OneIsland_KindleRoad_Text_HughDefeat {
	"Why me?!"
}

text OneIsland_KindleRoad_Text_HughPostBattle {
	"Even martial artists are becoming
	fashion conscious these days…"
}

text OneIsland_KindleRoad_Text_BryceIntro {
	"You know, everything tastes great
	when you're out in the wild."
}

text OneIsland_KindleRoad_Text_BryceDefeat {
	"Awww, blown!"
}

text OneIsland_KindleRoad_Text_BrycePostBattle {
	"The water in volcanic regions is
	delicious."
}

text OneIsland_KindleRoad_Text_ClaireIntro {
	"My lunch filled us up, so will you
	battle us for some exercise?"
}

text OneIsland_KindleRoad_Text_ClaireDefeat {
	"That made me all sweaty."
}

text OneIsland_KindleRoad_Text_ClairePostBattle {
	"What should I do?
	I feel famished again."
}

text OneIsland_KindleRoad_Text_KiaIntro {
	"KIA: My big brother and I make
	an awesome combination!"
}

text OneIsland_KindleRoad_Text_KiaDefeat {
	"KIA: Huh?!
	I can't believe it!"
}

text OneIsland_KindleRoad_Text_KiaPostBattle {
	"KIA: How could there be anyone
	better than my big brother?"
}

text OneIsland_KindleRoad_Text_KiaNotEnoughMons {
	"KIA: If you want to battle with
	us, you have to bring at least two
	POKéMON with you."
}

text OneIsland_KindleRoad_Text_MikIntro {
	"MIK: Together with KIA, I'm afraid
	of nothing!"
}

text OneIsland_KindleRoad_Text_MikDefeat {
	"MIK: Whoa!
	That's too much!"
}

text OneIsland_KindleRoad_Text_MikPostBattle {
	"MIK: How could my combination
	with KIA fail?"
}

text OneIsland_KindleRoad_Text_MikNotEnoughMons {
	"MIK: Hey, do you want to battle
	with us two?

	Bring two or more POKéMON with
	you, then."
}

text OneIsland_KindleRoad_Text_RouteSign {
	"This is KINDLE ROAD.

	Go straight for MT. EMBER."
}

text OneIsland_KindleRoad_Text_EmberSpaSign {
	"Light the Fire in Your Heart!
	EMBER SPA"
}
