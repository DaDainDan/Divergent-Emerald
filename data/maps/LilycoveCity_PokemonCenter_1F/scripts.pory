mapscripts LilycoveCity_PokemonCenter_1F_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_LILYCOVE_CITY)
		special(SetLilycoveLadyGfx)
		// SetLilycoveLadyGfx returns TRUE if its the Contest Lady
		if (var(VAR_RESULT) == FALSE) {
			setflag(FLAG_HIDE_LILYCOVE_POKEMON_CENTER_CONTEST_LADY_MON)
		}
		if (var(VAR_RESULT) == TRUE) {
			clearflag(FLAG_HIDE_LILYCOVE_POKEMON_CENTER_CONTEST_LADY_MON)
		}
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script LilycoveCity_PokemonCenter_1F_EventScript_Nurse {
    setvar(VAR_0x800B, LOCALID_LILYCOVE_NURSE)
    call(Common_EventScript_PkmnCenterNurse)
    waitmessage
    waitbuttonpress
    release_end
}

script LilycoveCity_PokemonCenter_1F_EventScript_Boy {
    msgbox(LilycoveCity_PokemonCenter_1F_Text_HowManyKindsOfPokemon, MSGBOX_NPC)
    end
}

script LilycoveCity_PokemonCenter_1F_EventScript_Maniac {
    lock_faceplayer
    if (flag(FLAG_BADGE07_GET)) {
        msgbox(LilycoveCity_PokemonCenter_1F_Text_HaventSeenRottenScoundrels, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_PokemonCenter_1F_Text_HeardAboutRottenScoundrels, MSGBOX_DEFAULT)
    release_end
}

text LilycoveCity_PokemonCenter_1F_Text_HowManyKindsOfPokemon {
	"I wonder how many kinds of POKéMON
	there are in the world.

	It'd be great to cross seas and
	trade POKéMON with people far away."
}

text LilycoveCity_PokemonCenter_1F_Text_HeardAboutRottenScoundrels {
	"I've been hearing about some rotten
	scoundrels who steal POKéMON and rip
	off METEORITES."
}

text LilycoveCity_PokemonCenter_1F_Text_HaventSeenRottenScoundrels {
	"Those rotten scoundrels who steal
	POKéMON and rip off METEORITES…

	I haven't seen them around recently."
}
