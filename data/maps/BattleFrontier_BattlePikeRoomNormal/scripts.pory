text BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreAllMons {
	"I welcome you…

	Giggle…
	You should thank your lucky stars…

	Since you have chosen this room,
	all your POKéMON will be restored…"
}

text BattleFrontier_BattlePikeRoomNormal_Text_ShallFetchOurMaster {
	"I shall go fetch our master…"
}

text BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreTwoMons {
	"Ah, you're a lucky one!
	I'm in good spirits now.

	I will restore two of your POKéMON
	to full health!"
}
