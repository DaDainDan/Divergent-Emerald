	"I see…
	How unsporting of you…"
}

// Unused
text BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreMonsAsPromised {
	"Magnificent…

	As promised, I shall restore your
	POKéMON to full health."
}

// Unused
text BattleFrontier_BattlePikeRoomNormal_Text_BestOfLuckFarewell2 {
	"The best of luck to you.
	Farewell."
