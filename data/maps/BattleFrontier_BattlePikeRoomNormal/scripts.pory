mapscripts BattleFrontier_BattlePikeRoomNormal_MapScripts {
    MAP_SCRIPT_ON_RESUME: BattleFrontier_BattlePikeRoom_OnResume
    MAP_SCRIPT_ON_TRANSITION: BattleFrontier_BattlePikeRoom_OnTransition
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattlePikeRoomNormal_EventScript_EnterRoom
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE: BattleFrontier_BattlePikeRoom_OnWarp
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterRoom {
    setvar(VAR_TEMP_0, 1)
    pike_getroomtype
    switch (var(VAR_RESULT)) {
        case PIKE_ROOM_SINGLE_BATTLE: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterSingleBattleRoom)
        case PIKE_ROOM_HEAL_FULL: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterFullHealRoom)
        case PIKE_ROOM_STATUS: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterStatusRoom)
        case PIKE_ROOM_HARD_BATTLE: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterHardBattleRoom)
        case PIKE_ROOM_DOUBLE_BATTLE: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterDoubleBattleRoom)
        case PIKE_ROOM_BRAIN: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_EnterBrainRoom)
    }
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterSingleBattleRoom {
    lockall
    delay(16)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_down * 2))
    waitmovement(0)
    pike_gettrainerintro(0)
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    waitmessage
    closemessage
    releaseall
    dofacilitytrainerbattle(FACILITY_BATTLE_PIKE_SINGLE)
    waitstate
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_up * 3,  set_invisible,  walk_up))
		waitmovement(0)
		end
	}
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost {
    frontier_set(FRONTIER_DATA_CHALLENGE_STATUS, CHALLENGE_STATUS_LOST)
    warp(MAP_BATTLE_FRONTIER_BATTLE_PIKE_LOBBY, 5, 6)
    waitstate
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterHardBattleRoom {
    lockall
    delay(16)
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_BattleSomewhatToughTrainer, MSGBOX_DEFAULT)
    waitmessage
    closemessage
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_down * 2))
    waitmovement(0)
    pike_gettrainerintro(0)
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    waitmessage
    closemessage
    releaseall
    dofacilitytrainerbattle(FACILITY_BATTLE_PIKE_SINGLE)
    waitstate
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_up * 3,  set_invisible,  walk_up))
		waitmovement(0)
		applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_down * 2,  walk_right,  face_down))
		waitmovement(0)
		lock_faceplayer
		msgbox(BattleFrontier_BattlePikeRoomNormal_Text_RestoreToFullHealth, MSGBOX_DEFAULT)
		playfanfare(MUS_HEAL)
		waitfanfare
		special(HealPlayerParty)
		msgbox(BattleFrontier_BattlePikeRoomNormal_Text_EnjoyRestOfChallenge2, MSGBOX_DEFAULT)
		closemessage
		release
		applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_up * 3,  set_invisible,  walk_up))
		waitmovement(0)
		end
	}
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost)
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterBrainRoom {
    delay(22)
    lockall
    applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_down * 2))
    waitmovement(0)
    pike_prequeenheal
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ChoseRoomNoHeal, MSGBOX_DEFAULT)
        case 1:
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ChoseRoomHealOne, MSGBOX_DEFAULT)
			playfanfare(MUS_HEAL)
			waitfanfare
        case 2:
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ChoseRoomHealTwo, MSGBOX_DEFAULT)
			playfanfare(MUS_HEAL)
			waitfanfare
    }
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_LucyEnter)
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_LucyEnter {
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ShallFetchOurMaster, MSGBOX_DEFAULT)
    closemessage
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(walk_up * 2))
    applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_up * 3,  set_invisible))
    waitmovement(0)
    playse(SE_PIKE_CURTAIN_CLOSE)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesLittleClosed)
    delay(4)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesMostlyClosed)
    delay(4)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesClosed)
    delay(4)
    waitse
    delay(60)
    playse(SE_PIKE_CURTAIN_OPEN)
    delay(65)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesMostlyClosed)
    showobjectat(LOCALID_PIKE_ROOM_NPC_1, MAP_BATTLE_FRONTIER_BATTLE_PIKE_ROOM_NORMAL)
    delay(4)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesLittleClosed)
    delay(4)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesOpen)
    waitse
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(set_visible,  walk_down))
    waitmovement(0)
    pike_getbrainstatus
    switch (var(VAR_RESULT)) {
        case FRONTIER_BRAIN_STREAK: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucySilver)
        case FRONTIER_BRAIN_STREAK_LONG: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucyGold)
		case FRONTIER_BRAIN_GOLD:
			frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
			if (var(VAR_RESULT) == FALSE) {
				msgbox(BattleFrontier_BattlePikeRoomNormal_Text_LucyYouAgain, MSGBOX_DEFAULT)
				frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
			}
			goto(BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucyGold)
    }
    frontier_get(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    if (var(VAR_RESULT) == FALSE) {
        msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ImThePikeQueen, MSGBOX_DEFAULT)
    	frontier_set(FRONTIER_DATA_HEARD_BRAIN_SPEECH)
    }
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucySilver)
	end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucySilver {
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_HopeYouDidntUseUpLuck, MSGBOX_DEFAULT)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_DoPikeQueenBattle)
    if (var(VAR_RESULT) == 1) {
        frontier_getsymbols
		if (var(VAR_RESULT) == 0) {
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_LucyShowMeFrontierPass, MSGBOX_DEFAULT)
			waitmessage
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattlePikeRoomNormal_Text_ReceivedLuckSymbol)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_AllThereIsDisappear, MSGBOX_DEFAULT)
			closemessage
		}
		goto(BattleFrontier_BattlePikeRoomNormal_EventScript_DefeatedLucy)
    }
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_BattleLucyGold {
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_NowComeOn, MSGBOX_DEFAULT)
    call(BattleFrontier_BattlePikeRoomNormal_EventScript_DoPikeQueenBattle)
    if (var(VAR_RESULT) == 1) {
        frontier_getsymbols
		if (var(VAR_RESULT) != 2) {
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_LucyFrontierPass, MSGBOX_DEFAULT)
			waitmessage
			playfanfare(MUS_OBTAIN_SYMBOL)
			message(BattleFrontier_BattlePikeRoomNormal_Text_LuckSymbolTookGoldenShine)
			waitmessage
			waitfanfare
			frontier_givesymbol
			msgbox(BattleFrontier_BattlePikeRoomNormal_Text_IWontForget, MSGBOX_DEFAULT)
			closemessage
		}
		goto(BattleFrontier_BattlePikeRoomNormal_EventScript_DefeatedLucy)
    }
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost)
	end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_DefeatedLucy {
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_left,  face_right))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, moves(walk_up * 2))
    waitmovement(0)
    pike_get(PIKE_DATA_WIN_STREAK)
    addvar(VAR_RESULT, 1)
    pike_set(PIKE_DATA_WIN_STREAK, VAR_RESULT)
    call(BattleFrontier_BattlePikeRoom_EventScript_WarpToFinalRoom)
    waitstate
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterFullHealRoom {
    lockall
    delay(16)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_down * 2))
    waitmovement(0)
    message(BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreToFullHealth)
    waitmessage
    playfanfare(MUS_HEAL)
    waitfanfare
    special(HealPlayerParty)
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_EnjoyRestOfChallenge, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_up * 3,  set_invisible,  walk_up))
    waitmovement(0)
    releaseall
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterDoubleBattleRoom {
    lockall
    delay(16)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, Common_Movement_WalkRight)
    applymovement(LOCALID_PIKE_ROOM_NPC_2, Common_Movement_WalkLeft)
    waitmovement(0)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_down * 2))
    applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_down * 2))
    waitmovement(0)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, Common_Movement_FaceRight)
    applymovement(LOCALID_PIKE_ROOM_NPC_2, Common_Movement_FaceLeft)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_FaceLeft)
    waitmovement(0)
    pike_gettrainerintro(0)
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    closemessage
    delay(16)
    applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
    waitmovement(0)
    pike_gettrainerintro(1)
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    closemessage
    dofacilitytrainerbattle(FACILITY_BATTLE_PIKE_DOUBLE)
    waitstate
	if (var(VAR_RESULT) == B_OUTCOME_WON) {
		applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
		waitmovement(0)
		applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_up * 3,  walk_right,  walk_up,  set_invisible,  walk_up))
		waitmovement(0)
		applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(walk_up * 3,  walk_left,  walk_up,  set_invisible,  walk_up))
		waitmovement(0)
		applymovement(LOCALID_PLAYER, Common_Movement_FaceUp)
		waitmovement(0)
		end
	}
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_WarpToLobbyLost)
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_EnterStatusRoom {
    lockall
    message(BattleFrontier_BattlePikeRoomNormal_Text_WatchOut)
    applymovement(LOCALID_PIKE_ROOM_NPC_2, moves(run_down,  run_right * 2,  run_down,  run_left,  face_down))
    waitmovement(0)
    pike_getstatusmon
    copyvar(VAR_0x8004, VAR_RESULT)
	switch (var(VAR_0x8004)) {
		case PIKE_STATUSMON_KIRLIA: call(BattleFrontier_BattlePikeRoomNormal_EventScript_KirliaAttack)
		case PIKE_STATUSMON_DUSCLOPS: call(BattleFrontier_BattlePikeRoomNormal_EventScript_DusclopsAttack)
	}
	call(BattleFrontier_BattlePikeRoomNormal_EventScript_StatusMonFinish)
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_AttacksWhenStartled, MSGBOX_DEFAULT)
    closemessage
    releaseall
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_KirliaAttack {
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_KirliaStop, MSGBOX_DEFAULT)
    closemessage
    waitse
    playmoncry(SPECIES_KIRLIA, CRY_MODE_NORMAL)
    waitmoncry
    pike_getstatus
	switch (var(VAR_RESULT)) {
		case PIKE_STATUS_TOXIC: message(BattleFrontier_BattlePikeRoomNormal_Text_KirliaUsedToxic)
		case PIKE_STATUS_BURN: message(BattleFrontier_BattlePikeRoomNormal_Text_KirliaUsedWillOWisp)
		case PIKE_STATUS_PARALYSIS: message(BattleFrontier_BattlePikeRoomNormal_Text_KirliaUsedThunderWave)
		case PIKE_STATUS_SLEEP: message(BattleFrontier_BattlePikeRoomNormal_Text_KirliaUsedHypnosis)
	}
	setvar(VAR_0x8003, SPECIES_KIRLIA)
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_DusclopsAttack {
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_DusclopsStop, MSGBOX_DEFAULT)
    closemessage
    waitse
    playmoncry(SPECIES_DUSCLOPS, CRY_MODE_NORMAL)
    waitmoncry
    pike_getstatus
	switch (var(VAR_RESULT)) {
		case PIKE_STATUS_FREEZE: message(BattleFrontier_BattlePikeRoomNormal_Text_DusclopsUsedIceBeam)
		case PIKE_STATUS_BURN: message(BattleFrontier_BattlePikeRoomNormal_Text_DusclopsUsedWillOWisp)
	}
	setvar(VAR_0x8003, SPECIES_DUSCLOPS)
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_StatusMonFinish {
	waitmessage
    pike_flashscreen
    waitstate
    applymovement(LOCALID_PIKE_ROOM_NPC_1, Common_Movement_WalkDown)
    waitmovement(0)
    applymovement(LOCALID_PIKE_ROOM_NPC_2, Common_Movement_FaceUp)
    waitmovement(0)
    waitse
    playmoncry(VAR_0x8003, CRY_MODE_NORMAL)
    waitmoncry
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ThatsEnough, MSGBOX_DEFAULT)
    waitse
    playmoncry(VAR_0x8003, CRY_MODE_NORMAL)
    waitmoncry
    closemessage
    applymovement(LOCALID_PIKE_ROOM_NPC_2, Common_Movement_WalkLeft)
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_down,  face_left,  delay_16 * 2,  face_down))
    waitmovement(0)
	switch (var(VAR_0x8003)) {
		case SPECIES_KIRLIA: msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ApologizeForKirlia, MSGBOX_DEFAULT)
		case SPECIES_DUSCLOPS: msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ApologizeForDusclops, MSGBOX_DEFAULT)
	}
	return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_DoPikeQueenBattle {
    closemessage
    applymovement(LOCALID_PLAYER, moves(walk_up * 2))
    waitmovement(0)
    dofacilitytrainerbattle(FACILITY_BATTLE_PIKE_SINGLE)
    waitstate
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_NPC {
    pike_getroomtype
    switch (var(VAR_RESULT)) {
        case PIKE_ROOM_NPC: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_NormalNPC)
        case PIKE_ROOM_STATUS: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_StatusNPC)
        case PIKE_ROOM_HEAL_PART: goto(BattleFrontier_BattlePikeRoomNormal_EventScript_HealNPC)
    }
    goto(BattleFrontier_BattlePikeRoomNormal_EventScript_NormalNPC)
	end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_NormalNPC {
    lock_faceplayer
    pike_getnpcmsg
    msgbox(gStringVar4, MSGBOX_DEFAULT)
    waitmessage
    closemessage
    release_end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_StatusNPC {
    lock_faceplayer
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_ApologizeHopeMonsAreFine, MSGBOX_DEFAULT)
    closemessage
    release_end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_HealNPC {
    pike_healonetwomons
	if (var(VAR_RESULT) != 0) {
		lock_faceplayer
		switch (var(VAR_RESULT)) {
			case 2: msgbox(BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreTwoMons, MSGBOX_DEFAULT)
			case 1: msgbox(BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreOneMon, MSGBOX_DEFAULT)
		}
		closemessage
	}
    playfanfare(MUS_HEAL)
    waitfanfare
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_BestOfLuckFarewell, MSGBOX_DEFAULT)
    closemessage
    release
    applymovement(LOCALID_PIKE_ROOM_NPC_1, moves(walk_up,  set_invisible,  walk_up))
    waitmovement(0)
    end
}

// Dusclops or Kirlia
script BattleFrontier_BattlePikeRoomNormal_EventScript_StatusMon {
    lock_faceplayer
    msgbox(BattleFrontier_BattlePikeRoomNormal_Text_Silence, MSGBOX_DEFAULT)
    closemessage
    release
    applymovement(LOCALID_PIKE_ROOM_NPC_2, Common_Movement_FaceRight)
    waitmovement(0)
    end
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesMostlyClosed {
    setmetatile(4, 1, METATILE_BattlePike_Curtain_Stage1_Tile0, TRUE)
    setmetatile(3, 2, METATILE_BattlePike_Curtain_Stage1_Tile1, TRUE)
    setmetatile(4, 2, METATILE_BattlePike_Curtain_Stage1_Tile2, TRUE)
    setmetatile(5, 2, METATILE_BattlePike_Curtain_Stage1_Tile3, TRUE)
    setmetatile(3, 3, METATILE_BattlePike_Curtain_Stage1_Tile4, TRUE)
    setmetatile(4, 3, METATILE_BattlePike_Curtain_Stage1_Tile5, FALSE)
    setmetatile(5, 3, METATILE_BattlePike_Curtain_Stage1_Tile6, TRUE)
    special(DrawWholeMapView)
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesLittleClosed {
    setmetatile(4, 1, METATILE_BattlePike_Curtain_Stage2_Tile0, TRUE)
    setmetatile(3, 2, METATILE_BattlePike_Curtain_Stage2_Tile1, TRUE)
    setmetatile(4, 2, METATILE_BattlePike_Curtain_Stage2_Tile2, TRUE)
    setmetatile(5, 2, METATILE_BattlePike_Curtain_Stage2_Tile3, TRUE)
    setmetatile(3, 3, METATILE_BattlePike_Curtain_Stage2_Tile4, TRUE)
    setmetatile(4, 3, METATILE_BattlePike_Curtain_Stage2_Tile5, FALSE)
    setmetatile(5, 3, METATILE_BattlePike_Curtain_Stage2_Tile6, TRUE)
    special(DrawWholeMapView)
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesOpen {
    setmetatile(4, 1, METATILE_BattlePike_Curtain_Stage3_Tile0, TRUE)
    setmetatile(3, 2, METATILE_BattlePike_Curtain_Stage3_Tile1, TRUE)
    setmetatile(4, 2, METATILE_BattlePike_Curtain_Stage3_Tile2, TRUE)
    setmetatile(5, 2, METATILE_BattlePike_Curtain_Stage3_Tile3, TRUE)
    setmetatile(3, 3, METATILE_BattlePike_Curtain_Stage3_Tile4, TRUE)
    setmetatile(4, 3, METATILE_BattlePike_Curtain_Stage3_Tile5, FALSE)
    setmetatile(5, 3, METATILE_BattlePike_Curtain_Stage3_Tile6, TRUE)
    special(DrawWholeMapView)
    return
}

script BattleFrontier_BattlePikeRoomNormal_EventScript_SetCurtainTilesClosed {
    setmetatile(4, 1, METATILE_BattlePike_Curtain_Stage0_Tile0, TRUE)
    setmetatile(3, 2, METATILE_BattlePike_Curtain_Stage0_Tile1, TRUE)
    setmetatile(4, 2, METATILE_BattlePike_Curtain_Stage0_Tile2, TRUE)
    setmetatile(5, 2, METATILE_BattlePike_Curtain_Stage0_Tile3, TRUE)
    setmetatile(3, 3, METATILE_BattlePike_Curtain_Stage0_Tile4, TRUE)
    setmetatile(4, 3, METATILE_BattlePike_Curtain_Stage0_Tile5, FALSE)
    setmetatile(5, 3, METATILE_BattlePike_Curtain_Stage0_Tile6, TRUE)
    special(DrawWholeMapView)
    return
}

// Unused
movement BattleFrontier_BattlePikeRoomNormal_Movement_CameraPanDown {
    // moves(walk_down * 2)
    walk_down * 2
}

text BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreToFullHealth {
	"Welcome…
	You must be commended for your luck…

	Your POKéMON shall be restored
	to full health…"
}

text BattleFrontier_BattlePikeRoomNormal_Text_EnjoyRestOfChallenge {
	"I urge you to enjoy the rest of your
	Battle Choice challenge…"
}

text BattleFrontier_BattlePikeRoomNormal_Text_WillRestoreOneMon {
	"Ah, you're a lucky one.
	I'm in somewhat-good spirits now.

	I will restore one of your POKéMON
	to full health."
}

text BattleFrontier_BattlePikeRoomNormal_Text_BestOfLuckFarewell {
	"The best of luck to you.
	Farewell."
}

