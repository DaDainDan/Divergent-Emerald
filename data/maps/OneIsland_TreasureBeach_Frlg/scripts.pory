mapscripts OneIsland_TreasureBeach_Frlg_MapScripts {}

script OneIsland_TreasureBeach_EventScript_Boy {
    msgbox(OneIsland_TreasureBeach_Text_GoodThingsWashUpOnBeach, MSGBOX_NPC)
    end
}

text OneIsland_TreasureBeach_Text_AmaraIntro {
	"Lying back, rocked by the waves…
	It's exquisite."
}

text OneIsland_TreasureBeach_Text_AmaraDefeat {
	"I lost…
	It feels awful."
}

text OneIsland_TreasureBeach_Text_AmaraPostBattle {
	"The sea is pleasantly warm in these
	parts."
}

text OneIsland_TreasureBeach_Text_GoodThingsWashUpOnBeach {
	"Good things get washed up by the
	ocean current onto this beach.

	That's why I often come here for
	some beachcombing."
}
