const REQUIRED_OWNED_MONS = 20

mapscripts Route10_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_ROUTE10_POKEMON_CENTER_1F)
		setrespawn(HEAL_LOCATION_ROUTE10)
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script Route10_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script Route10_PokemonCenter_1F_EventScript_FatMan {
    msgbox(Route10_PokemonCenter_1F_Text_NuggetUselessSoldFor5000, MSGBOX_NPC)
    end
}

script Route10_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(Route10_PokemonCenter_1F_Text_EveryTypeStrongerThanOthers, MSGBOX_NPC)
    end
}

script Route10_PokemonCenter_1F_EventScript_Youngster {
    msgbox(Route10_PokemonCenter_1F_Text_HeardGhostsHauntLavender, MSGBOX_NPC)
    end
}

script Route10_PokemonCenter_1F_EventScript_Aide {
    lock_faceplayer
    call(Route10_PokemonCenter_1F_EventScript_GetAideRequestInfo)
    if (!flag(FLAG_GOT_EVERSTONE_FROM_OAKS_AIDE)) {
        msgbox(Route10_PokemonCenter_1F_Text_GiveEverstoneIfCaught20Mons, MSGBOX_YESNO)
		if (var(VAR_RESULT) == NO) {
			goto(Aide_EventScript_DeclineCheckMons)
		}
		setvar(VAR_0x8004, 0)
		specialvar(VAR_RESULT, GetFrlgPokedexCount)
		buffernumberstring(STR_VAR_3, VAR_0x8006)
		call(Route10_PokemonCenter_1F_EventScript_GetAideRequestInfo)
		if (var(VAR_0x8006) < REQUIRED_OWNED_MONS) {
			goto(Aide_EventScript_HaventCaughtEnough)
		}
		msgbox(Route10_PokemonCenter_1F_Text_GreatHereYouGo)
		if (checkitemspace(ITEM_EVERSTONE) == FALSE) {
			goto(Aide_EventScript_NoRoomForItem)
		}
		giveitem_msg(Route10_PokemonCenter_1F_Text_ReceivedEverstoneFromAide, ITEM_EVERSTONE)
		setflag(FLAG_GOT_EVERSTONE_FROM_OAKS_AIDE)
    }
    msgbox(Route10_PokemonCenter_1F_Text_ExplainEverstone)
    release_end
}

script Route10_PokemonCenter_1F_EventScript_GetAideRequestInfo {
    buffernumberstring(STR_VAR_1, REQUIRED_OWNED_MONS)
    bufferitemname(STR_VAR_2, ITEM_EVERSTONE)
    return
}

text Route10_PokemonCenter_1F_Text_EveryTypeStrongerThanOthers {
	"The types of POKéMON match up
	differently with each other.

	Every type is stronger than some
	types and weaker than others."
}

text Route10_PokemonCenter_1F_Text_NuggetUselessSoldFor5000 {
	"A NUGGET is totally useless.
	So I sold it for ¥5000."
}

text Route10_PokemonCenter_1F_Text_HeardGhostsHauntLavender {
	"I heard that ghosts haunt
	LAVENDER TOWN."
}

text Route10_PokemonCenter_1F_Text_GiveEverstoneIfCaught20Mons {
	"Oh… {PLAYER}!
	I've been looking for you!

	It's me, one of the ever-present
	AIDES to PROF. OAK.

	If your POKéDEX has complete data
	on twenty species, I'm supposed to
	give you a reward from PROF. OAK.

	He entrusted me with this
	EVERSTONE.

	So, {PLAYER}, let me ask you.

	Have you gathered data on at least
	twenty kinds of POKéMON?"
}

text Route10_PokemonCenter_1F_Text_GreatHereYouGo {
	"Great! You have caught or owned
	{STR_VAR_3} kinds of POKéMON!

	Congratulations!
	Here you go!"
}

text Route10_PokemonCenter_1F_Text_ReceivedEverstoneFromAide {
	"{PLAYER} received the EVERSTONE
	from the AIDE."
}

text Route10_PokemonCenter_1F_Text_ExplainEverstone {
	"Making POKéMON evolve certainly
	can add to the POKéDEX.

	However, at times, you may not
	want a certain POKéMON to evolve.

	In that case, give the EVERSTONE
	to that POKéMON.

	It will prevent evolution according
	to the PROFESSOR."
}
