mapscripts SevenIsland_SevaultCanyon_Frlg_MapScripts {}

script SevenIsland_SevaultCanyon_EventScript_RouteSign {
    msgbox(SevenIsland_SevaultCanyon_Text_RouteSign, MSGBOX_SIGN)
    end
}

text SevenIsland_SevaultCanyon_Text_CyndyIntro {
	"My conditioning's in top form!"
}

text SevenIsland_SevaultCanyon_Text_CyndyDefeat {
	"Huh?
	Something's not right…"
}

text SevenIsland_SevaultCanyon_Text_CyndyPostBattle {
	"The way I am now, I may have to
	hold off on TRAINER TOWER…"
}

text SevenIsland_SevaultCanyon_Text_EvanIntro {
	"It doesn't matter if you happen to
	have the strongest POKéMON…

	It doesn't mean a thing if you don't
	know how to use them properly!"
}

text SevenIsland_SevaultCanyon_Text_EvanDefeat {
	"You're a master at this."
}

text SevenIsland_SevaultCanyon_Text_EvanPostBattle {
	"You see them every so often,
	TRAINERS with awesome POKéMON
	who have no idea what to do.

	Before training POKéMON, TRAINERS
	themselves need to grow up."
}

text SevenIsland_SevaultCanyon_Text_JacksonIntro {
	"I work to protect the environment.
	In turn, nature protects me!"
}

text SevenIsland_SevaultCanyon_Text_JacksonDefeat {
	"Whoa! You're tough!
	How about protecting me?"
}

text SevenIsland_SevaultCanyon_Text_JacksonPostBattle {
	"From far out among the stars, our
	planet is just a drop of water.

	But we want to protect that drop
	of water for everyone."
}

text SevenIsland_SevaultCanyon_Text_KatelynIntro {
	"Those shoes you have are pretty
	snazzy."
}

text SevenIsland_SevaultCanyon_Text_KatelynDefeat {
	"You're hot stuff in spite of your
	cute looks."
}

text SevenIsland_SevaultCanyon_Text_KatelynPostBattle {
	"Your mom bought those snazzy
	RUNNING SHOES for you?

	She must adore you."
}

text SevenIsland_SevaultCanyon_Text_LeroyIntro {
	"You look strong.
	Let me battle you, please!"
}

text SevenIsland_SevaultCanyon_Text_LeroyDefeat {
	"I knew it!
	You're as tough as I thought!"
}

text SevenIsland_SevaultCanyon_Text_LeroyPostBattle {
	"The way you battle has given me
	a lot of useful data.

	Thanks so much!"
}

text SevenIsland_SevaultCanyon_Text_MichelleIntro {
	"I was given the best possible
	education to become this strong.

	I don't want to lose to anyone!"
}

text SevenIsland_SevaultCanyon_Text_MichelleDefeat {
	"Thank you. I feel like I've been
	set free by losing to you."
}

text SevenIsland_SevaultCanyon_Text_MichellePostBattle {
	"For some reason, I get furious
	over the slightest thing.

	I'll calm myself by breathing
	deeply."
}

text SevenIsland_SevaultCanyon_Text_LexIntro {
	"LEX: My darling NYA, together
	we could win!"
}

text SevenIsland_SevaultCanyon_Text_LexDefeat {
	"LEX: I seem to have been too
	careless…"
}

text SevenIsland_SevaultCanyon_Text_LexPostBattle {
	"LEX: I think it was a good
	experience for NYA.

	You have my gratitude."
}

text SevenIsland_SevaultCanyon_Text_LexNotEnoughMons {
	"LEX: May I ask you to battle the
	both of us at the same time?"
}

text SevenIsland_SevaultCanyon_Text_NyaIntro {
	"NYA: I'll do my best so I won't
	drag down my mentor, LEX!"
}

text SevenIsland_SevaultCanyon_Text_NyaDefeat {
	"NYA: Oh, no…
	I'm so sorry, I…"
}

text SevenIsland_SevaultCanyon_Text_NyaPostBattle {
	"NYA: I think I'm going to need
	much more seasoning and tutoring
	under LEX…

	…So, LEX, please, may I stay with
	you like this?"
}

text SevenIsland_SevaultCanyon_Text_NyaNotEnoughMons {
	"NYA: I'm sorry, but may we battle
	in two-on-two style?"
}

text SevenIsland_SevaultCanyon_Text_RouteSign {
	"SEVAULT CANYON
	TANOBY RUINS AHEAD"
}

text SevenIsland_SevaultCanyon_Text_BrunoTrainedWithBrawly {
	"Training by oneself is certainly
	not a bad thing.

	But it's also not bad to aim for
	the top with a partner.

	Even BRUNO…
	He trained with a fellow by the
	name of BRAWLY before."
}
