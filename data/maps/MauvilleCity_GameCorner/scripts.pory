mapscripts MauvilleCity_GameCorner_MapScripts {}

// Game Corner prices
const TM_DOUBLE_TEAM_COINS = 1500
const TM_PSYCHIC_COINS = 3500
const TM_FLAMETHROWER_COINS = 4000
const TM_THUNDERBOLT_COINS = 4000
const TM_ICE_BEAM_COINS = 4000
const DOLL_COINS = 1000

const COINS_PRICE_50 = 1000
const COINS_PRICE_500 = 10000

script MauvilleCity_GameCorner_EventScript_CoinsClerk {
    lock_faceplayer
    msgbox(MauvilleCity_GameCorner_Text_ThisIsMauvilleGameCorner, MSGBOX_DEFAULT)
    if (checkitem(ITEM_COIN_CASE) == FALSE) {
        msgbox(MauvilleCity_GameCorner_Text_NeedCoinCaseForCoins, MSGBOX_DEFAULT)
        release_end
    }
    message(MauvilleCity_GameCorner_Text_WereYouLookingForCoins)
    waitmessage
    showmoneybox(0, 0)
    showcoinsbox(1, 6)
    goto(MauvilleCity_GameCorner_EventScript_ChooseCoinAmount)
}

script MauvilleCity_GameCorner_EventScript_ChooseCoinAmount {
    multichoicedefault(15, 0, MULTI_GAME_CORNER_COINS, 1, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: setcurrencyexchange(COINS_PRICE_50, 50, COIN_LIMIT_50)
        case 1: setcurrencyexchange(COINS_PRICE_500, 500, COIN_LIMIT_500)
        default: 
            msgbox(MauvilleCity_GameCorner_Text_DontNeedCoinsThen, MSGBOX_DEFAULT)
            goto(MauvilleCity_GameCorner_EventScript_BuyCoinsEnd)
    }
    goto(MauvilleCity_GameCorner_EventScript_BuyCoins)
    end
}

script MauvilleCity_GameCorner_EventScript_BuyCoins {
    if (checkcoins(VAR_TEMP_1) >= VAR_0x8007) {
        msgbox(MauvilleCity_GameCorner_Text_CoinCaseIsFull, MSGBOX_DEFAULT)
    }
    elif (checkmoney(VAR_0x8008) == FALSE) {
        msgbox(MauvilleCity_GameCorner_Text_DontHaveEnoughMoney, MSGBOX_DEFAULT)
    }
    else {
        addcoins(VAR_0x8009)
        removemoney(VAR_0x8008)
        updatemoneybox
        updatecoinsbox(1, 6)
        playse(SE_SHOP)
        msgbox(MauvilleCity_GameCorner_Text_ThankYouHereAreYourCoins, MSGBOX_DEFAULT)
    }
    goto(MauvilleCity_GameCorner_EventScript_BuyCoinsEnd)
    end
}

script MauvilleCity_GameCorner_EventScript_BuyCoinsEnd {
    hidemoneybox
    hidecoinsbox(0, 5)
    release_end
}

script MauvilleCity_GameCorner_EventScript_PrizeCornerDolls {
    lock_faceplayer
    msgbox(MauvilleCity_GameCorner_Text_ExchangeCoinsForPrizes, MSGBOX_DEFAULT)
    if (checkitem(ITEM_COIN_CASE) == TRUE) {
        message(MauvilleCity_GameCorner_Text_WhichPrize)
        waitmessage
        showcoinsbox(1, 1)
        goto(MauvilleCity_GameCorner_EventScript_ChooseDollPrize)
    }
    release_end
}

script MauvilleCity_GameCorner_EventScript_ChooseDollPrize {
    multichoice(12, 0, MULTI_GAME_CORNER_DOLLS, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: setvar(VAR_GIFT_ITEM, DECOR_TREECKO_DOLL)
        case 1: setvar(VAR_GIFT_ITEM, DECOR_TORCHIC_DOLL)
        case 2: setvar(VAR_GIFT_ITEM, DECOR_MUDKIP_DOLL)
        default: 
            goto(MauvilleCity_GameCorner_EventScript_CancelDollSelect)
    }
    bufferdecorationname(STR_VAR_1, VAR_GIFT_ITEM)
    goto(MauvilleCity_GameCorner_EventScript_ConfirmDollPrize)
    end
}

script MauvilleCity_GameCorner_EventScript_CancelDollSelect {
    msgbox(MauvilleCity_GameCorner_Text_OhIsThatSo, MSGBOX_DEFAULT)
    hidecoinsbox(0, 0)
    release_end
}

script MauvilleCity_GameCorner_EventScript_ConfirmDollPrize {
    msgbox(MauvilleCity_GameCorner_Text_SoYourChoiceIsX, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(MauvilleCity_GameCorner_EventScript_CancelDollSelect)
    }
    if (checkcoins(VAR_TEMP_2) < DOLL_COINS) {
        msgbox(MauvilleCity_GameCorner_Text_NotEnoughCoins, MSGBOX_DEFAULT)
        goto(MauvilleCity_GameCorner_EventScript_ReturnToChooseDollPrize)
    }
    bufferdecorationname(STR_VAR_2, VAR_GIFT_ITEM)
    if (checkdecorspace(VAR_GIFT_ITEM) == FALSE) {
        call(Common_EventScript_NoRoomForDecor)
        goto(MauvilleCity_GameCorner_EventScript_ReturnToChooseDollPrize)
    }
    removecoins(DOLL_COINS)
    adddecoration(VAR_GIFT_ITEM)
    updatecoinsbox(1, 1)
    playse(SE_SHOP)
    msgbox(MauvilleCity_GameCorner_Text_SendToYourHomePC, MSGBOX_DEFAULT)
    goto(MauvilleCity_GameCorner_EventScript_ReturnToChooseDollPrize)
    end
}

script MauvilleCity_GameCorner_EventScript_ReturnToChooseDollPrize {
    message(MauvilleCity_GameCorner_Text_WhichPrize)
    waitmessage
    goto(MauvilleCity_GameCorner_EventScript_ChooseDollPrize)
}

script MauvilleCity_GameCorner_EventScript_PrizeCornerTMs {
    lock_faceplayer
    msgbox(MauvilleCity_GameCorner_Text_ExchangeCoinsForPrizes, MSGBOX_DEFAULT)
    if (checkitem(ITEM_COIN_CASE) == TRUE) {
        message(MauvilleCity_GameCorner_Text_WhichPrize)
        waitmessage
        showcoinsbox(1, 1)
        goto(MauvilleCity_GameCorner_EventScript_ChooseTMPrize)
    }
    release_end
}

script MauvilleCity_GameCorner_EventScript_ChooseTMPrize {
    multichoice(12, 0, MULTI_GAME_CORNER_TMS, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(ITEM_TM_DOUBLE_TEAM, TM_DOUBLE_TEAM_COINS)
        case 1: setitemandprice(ITEM_TM_PSYCHIC, TM_PSYCHIC_COINS)
        case 2: setitemandprice(ITEM_TM_FLAMETHROWER, TM_FLAMETHROWER_COINS)
        case 3: setitemandprice(ITEM_TM_THUNDERBOLT, TM_THUNDERBOLT_COINS)
        case 4: setitemandprice(ITEM_TM_ICE_BEAM, TM_ICE_BEAM_COINS)
        case 5: 
        default: goto(MauvilleCity_GameCorner_EventScript_CancelTMSelect)
    }
    copyvar(VAR_0x8004, VAR_GIFT_ITEM)
    bufferitemname(STR_VAR_1, VAR_GIFT_ITEM)
    special(BufferTMHMMoveName)
    msgbox(MauvilleCity_GameCorner_Text_SoYourChoiceIsTheTMX, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(MauvilleCity_GameCorner_EventScript_CancelTMSelect)
    }
    goto(MauvilleCity_GameCorner_EventScript_PurchaseTM)
    end
}

script MauvilleCity_GameCorner_EventScript_PurchaseTM {
    if (checkcoins(VAR_TEMP_2) < VAR_EXCHANGE_PRICE) {
        msgbox(MauvilleCity_GameCorner_Text_NotEnoughCoins, MSGBOX_DEFAULT)
    }
    elif (checkitemspace(VAR_GIFT_ITEM) == FALSE) {
        call(Common_EventScript_BagIsFull)
    }
    else {
        removecoins(VAR_EXCHANGE_PRICE)
        additem(VAR_GIFT_ITEM)
        updatecoinsbox(1, 1)
        playse(SE_SHOP)
        msgbox(MauvilleCity_GameCorner_Text_HereYouGo, MSGBOX_DEFAULT)
    }
    message(MauvilleCity_GameCorner_Text_WhichPrize)
    waitmessage
    goto(MauvilleCity_GameCorner_EventScript_ChooseTMPrize)
    end
}

script MauvilleCity_GameCorner_EventScript_CancelTMSelect {
    msgbox(MauvilleCity_GameCorner_Text_OhIsThatSo, MSGBOX_DEFAULT)
    hidecoinsbox(0, 0)
    release_end
}

script MauvilleCity_GameCorner_EventScript_Woman2 {
    msgbox(MauvilleCity_GameCorner_Text_CoinsAreNeededToPlay, MSGBOX_NPC)
    end
}

script MauvilleCity_GameCorner_EventScript_Gentleman {
    msgbox(MauvilleCity_GameCorner_Text_RouletteOnlyLuck, MSGBOX_NPC)
    end
}

script MauvilleCity_GameCorner_EventScript_Girl {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_STARTER_DOLL)) {
        msgbox(MauvilleCity_GameCorner_Text_CantWinJackpot, MSGBOX_DEFAULT)
        release_end
    }
    msgbox(MauvilleCity_GameCorner_Text_GotTwoOfSameDollWantOne, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(MauvilleCity_GameCorner_Text_DontBeNegative, MSGBOX_DEFAULT)
    	release_end
    }
    switch (var(VAR_STARTER_MON)) {
        case PC_CHOSE_TREECKO: setvar(VAR_GIFT_ITEM, DECOR_TREECKO_DOLL)
        case PC_CHOSE_TORCHIC: setvar(VAR_GIFT_ITEM, DECOR_TORCHIC_DOLL)
        case PC_CHOSE_MUDKIP: setvar(VAR_GIFT_ITEM, DECOR_MUDKIP_DOLL)
    }
    bufferdecorationname(STR_VAR_2, VAR_GIFT_ITEM)
    if (checkdecorspace(VAR_GIFT_ITEM) == FALSE) {
        call(Common_EventScript_NoRoomForDecor)
        msgbox(MauvilleCity_GameCorner_Text_YouWantItButNotNow, MSGBOX_DEFAULT)
        release_end
    }
    msgbox(MauvilleCity_GameCorner_Text_HereYouGo2, MSGBOX_DEFAULT)
    givedecoration(VAR_GIFT_ITEM)
    setflag(FLAG_RECEIVED_STARTER_DOLL)
    msgbox(MauvilleCity_GameCorner_Text_CantWinJackpot, MSGBOX_DEFAULT)
    release_end
}

script MauvilleCity_GameCorner_EventScript_PokefanM {
    lock_faceplayer
    if (checkitem(ITEM_COIN_CASE) == TRUE) {
        if (!flag(FLAG_RECEIVED_20_COINS) && checkcoins(VAR_TEMP_1) == 0) {
			setflag(FLAG_RECEIVED_20_COINS)
			addcoins(20)
			msgbox(MauvilleCity_GameCorner_Text_LuckOnlyLastSoLongTakeCoins, MSGBOX_DEFAULT)
			playse(SE_SHOP)
		} else {
			msgbox(MauvilleCity_GameCorner_Text_MauvilleSomethingForEveryone, MSGBOX_DEFAULT)
		}
    } else {
		msgbox(MauvilleCity_GameCorner_Text_NeedCoinCaseGoNextDoor, MSGBOX_DEFAULT)
	}
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

script MauvilleCity_GameCorner_EventScript_OldMan {
    lock_faceplayer
    msgbox(MauvilleCity_GameCorner_Text_RouletteTablesDifferentRates, MSGBOX_DEFAULT)
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

