script MauvilleCity_GameCorner_EventScript_SlotMachineMain {
    if (checkitem(ITEM_COIN_CASE) == FALSE) {
        msgbox(MauvilleCity_GameCorner_Text_CantPlayWithNoCoinCase, MSGBOX_DEFAULT)
    } else {
		specialvar(VAR_RESULT, GetSlotMachineId)
		playslotmachine(VAR_RESULT)
	}
    releaseall
    end
}

script MauvilleCity_GameCorner_EventScript_PrizeCornerMons {
    lock_faceplayer
    msgbox(MauvilleCity_GameCorner_Text_ExchangeCoinsForPrizes, MSGBOX_DEFAULT)
    if (checkitem(ITEM_COIN_CASE) == TRUE) {
        message(MauvilleCity_GameCorner_Text_WhichPrize)
		waitmessage
		setvar(VAR_TEMP_1, 0)
		showcoinsbox(1, 1)
		goto(MauvilleCity_GameCorner_EventScript_ChoosePrizeMon)
    }
    release_end
}

script MauvilleCity_GameCorner_EventScript_ReturnToChoosePrizeMon {
    message(MauvilleCity_GameCorner_Text_WhichPrize)
    waitmessage
    goto(MauvilleCity_GameCorner_EventScript_ChoosePrizeMon)
}

script MauvilleCity_GameCorner_EventScript_ChoosePrizeMon {
    multichoice(12, 0, MULTI_GAME_CORNER_MONS, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: 
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_VANILLITE)
			setvar(VAR_EXCHANGE_PRICE, 500)
        case 1: 
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_VAROOM)
			setvar(VAR_EXCHANGE_PRICE, 1500)
        case 2: 
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_DITTO)
			setvar(VAR_EXCHANGE_PRICE, 2500)
        case 3: 
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_PORYGON)
			setvar(VAR_EXCHANGE_PRICE, 5000)
        case 4: 
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ROTOM)
			setvar(VAR_EXCHANGE_PRICE, 5000)
        default:
			goto(MauvilleCity_GameCorner_EventScript_CancelMonSelect)
    }
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    showmonpic(VAR_TEMP_TRANSFERRED_SPECIES, 10, 3)
    msgbox(MauvilleCity_GameCorner_Text_SoYourChoiceIsX, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(MauvilleCity_GameCorner_EventScript_CancelMonSelect)
    }
    hidemonpic
    if (checkcoins(VAR_RESULT) < VAR_EXCHANGE_PRICE) {
		msgbox(MauvilleCity_GameCorner_Text_NotEnoughCoins, MSGBOX_DEFAULT)
    	goto(MauvilleCity_GameCorner_EventScript_ReturnToChoosePrizeMon)
	}
    switch (var(VAR_TEMP_TRANSFERRED_SPECIES)) {
        case SPECIES_VANILLITE: givemon(SPECIES_VANILLITE, 8, ITEM_ICE_STONE)
        case SPECIES_VAROOM: givemon(SPECIES_VAROOM, 15)
        case SPECIES_DITTO: givemon(SPECIES_DITTO, 20)
        case SPECIES_PORYGON: givemon(SPECIES_PORYGON, 25)
        case SPECIES_ROTOM: givemon(SPECIES_ROTOM, 25)
    }
	copyvar(VAR_0x8006, VAR_RESULT)
	if (var(VAR_RESULT) == MON_CANT_GIVE) {
		msgbox(gText_NoMoreRoomForPokemon)
		hidecoinsbox(0, 0)
		release_end
	}
	removecoins(VAR_EXCHANGE_PRICE)
    updatecoinsbox(1, 1)
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    playfanfare(MUS_LEVEL_UP)
    message("{PLAYER} received {STR_VAR_1}!")
    waitmessage
    waitfanfare
    msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8006)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_GetGiftMonPartySlot)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
	goto(MauvilleCity_GameCorner_EventScript_ReturnToChoosePrizeMon)
    end
}

script MauvilleCity_GameCorner_EventScript_CancelMonSelect {
    hidemonpic
    msgbox(MauvilleCity_GameCorner_Text_OhIsThatSo, MSGBOX_DEFAULT)
    hidecoinsbox(0, 0)
    release_end
}


text MauvilleCity_GameCorner_Text_ThisIsMauvilleGameCorner {
	"This is MAUVILLE GAME CORNER."
}

text MauvilleCity_GameCorner_Text_NeedCoinCaseForCoins {
	"Okay, you wanted some COINS for
	the games?

	But you don't have a COIN CASE for
	stowing the COINS."
}

text MauvilleCity_GameCorner_Text_WereYouLookingForCoins {
	"Were you looking for COINS?

	It's ¥1000 for 50 COINS.
	Would you like some?"
}

text MauvilleCity_GameCorner_Text_ThankYouHereAreYourCoins {
	"Thank you very much!
	Here are your COINS!"
}

text MauvilleCity_GameCorner_Text_DontHaveEnoughMoney {
	"Um… You don't appear to have
	enough money…"
}

text MauvilleCity_GameCorner_Text_CoinCaseIsFull {
	"Oh?
	Your COIN CASE is full."
}

text MauvilleCity_GameCorner_Text_DontNeedCoinsThen {
	"Oh… You don't need COINS, then?
	Good luck on your adventure!"
}

text MauvilleCity_GameCorner_Text_ExchangeCoinsForPrizes {
	"Welcome.

	You can exchange your COINS for
	prizes here."
}

text MauvilleCity_GameCorner_Text_WhichPrize {
	"Which prize would you like?"
}

text MauvilleCity_GameCorner_Text_SoYourChoiceIsTheTMX {
	"So your choice is
	the {STR_VAR_1} {STR_VAR_2}?"
}

text MauvilleCity_GameCorner_Text_SendToYourHomePC {
	"Thank you!
	We'll send it to your PC at home."
}

text MauvilleCity_GameCorner_Text_NotEnoughCoins {
	"You don't have enough COINS."
}

text MauvilleCity_GameCorner_Text_NoRoomForPlacingDecor {
	"There isn't any room available for
	placing {STR_VAR_1}."
}

text MauvilleCity_GameCorner_Text_OhIsThatSo {
	"Oh, is that so? 
	You need to save some COINS before
	coming back here."
}

text MauvilleCity_GameCorner_Text_SoYourChoiceIsX {
	"So your choice is {STR_VAR_1}?"
}

text MauvilleCity_GameCorner_Text_HereYouGo {
	"Here you go!"
}

text MauvilleCity_GameCorner_Text_CantCarryAnyMore {
	"Oh, you can't carry any more than that."
}

text MauvilleCity_GameCorner_Text_GotTwoOfSameDollWantOne {
	"I made a mistake and got two of
	the same DOLLS.

	Would you like one of them?"
}

text MauvilleCity_GameCorner_Text_HereYouGo2 {
	"Here you go!"
}

text MauvilleCity_GameCorner_Text_YouWantItButNotNow {
	"Huh?
	You want it, but not right now?"
}

text MauvilleCity_GameCorner_Text_DontBeNegative {
	"Oh, don't be so negative!
	You can have this!"
}

text MauvilleCity_GameCorner_Text_CantWinJackpot {
	"There's a prize I want, but I can't win
	the jackpot."
}

text MauvilleCity_GameCorner_Text_NeedCoinCaseGoNextDoor {
	"Hey, kid, if you want to play here,
	you need a COIN CASE.

	I think the young lady next door
	had one. Go see her!"
}

text MauvilleCity_GameCorner_Text_LuckOnlyLastSoLongTakeCoins {
	"My luck can only last so long.
	This is too much for me.
	Here, take some COINS!"
}

text MauvilleCity_GameCorner_Text_MauvilleSomethingForEveryone {
	"MAUVILLE has something for
	everyone.

	For me, it's the GAME CORNER."
}

text MauvilleCity_GameCorner_Text_RouletteTablesDifferentRates {
	"The ROULETTE tables have different
	rates.

	Check your COINS if you're going to
	pick a table."
}

text MauvilleCity_GameCorner_Text_EasyToLoseTrackOfTime {
	"It's easy to lose track of time in here. 
	I should get back to work."
}

text MauvilleCity_GameCorner_Text_CoinsAreNeededToPlay {
	"COINS are needed to play here
	in the GAME CORNER."
}

text MauvilleCity_GameCorner_Text_RouletteOnlyLuck {
	"This ROULETTE thing…
	It's rather demanding.

	Win or lose, it's only by luck."
}

text MauvilleCity_GameCorner_Text_UpTo3CoinsCanBeUsed {
	"Up to three COINS can be used to play
	the SLOTS."
}

text MauvilleCity_GameCorner_Text_DifficultToStopOn7 {
	"It's very difficult to make it stop
	right on “7.”

	If it stops on “7” during the REEL TIME
	bonus game, you'll receive extra COINS."
}

text MauvilleCity_GameCorner_Text_HeresSomeSlotsInfo {
	"Here's some information for you
	about the SLOTS.

	The more lightning bolts you stock,
	the more REEL TIME chances you get.

	In a game with the maximum five
	REEL TIME chances…

	It is possible to receive four regular
	bonuses, then a big bonus.

	That would total 660 COINS, but it's
	very difficult to get."
}

text MauvilleCity_GameCorner_Text_CantPlayWithNoCoinCase {
	"You can't play if you don't have
	a COIN CASE."
}
