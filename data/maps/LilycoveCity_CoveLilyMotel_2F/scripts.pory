mapscripts LilycoveCity_CoveLilyMotel_2F_MapScripts {}

script LilycoveCity_CoveLilyMotel_2F_EventScript_GameDesigner {
    lock_faceplayer
    if (!flag(FLAG_TEMP_2)) {
        msgbox(LilycoveCity_CoveLilyMotel_2F_Text_ShowMeCompletedDex, MSGBOX_DEFAULT)
		if (specialvar(VAR_RESULT, HasAllHoennMons) == TRUE) {
			setflag(FLAG_TEMP_2)
			playfanfare(MUS_OBTAIN_ITEM)
			waitfanfare
		}
    }
	message(LilycoveCity_CoveLilyMotel_2F_Text_FilledPokedexGiveYouThis)
    waitmessage
    call(Common_EventScript_PlayGymBadgeFanfare)
    special(Special_ShowDiploma)
    release_end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_Programmer {
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_ImTheProgrammer, MSGBOX_NPC)
    end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_GraphicArtist {
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_ImTheGraphicArtist, MSGBOX_NPC)
    end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_FatMan {
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_GirlsAreCute, MSGBOX_NPC)
    end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_Woman {
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_SeaBreezeTicklesHeart, MSGBOX_NPC)
    end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_GameBoyKid {
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_NeverLeaveWithoutGameBoy, MSGBOX_NPC)
    end
}

script LilycoveCity_CoveLilyMotel_2F_EventScript_Scott {
    lock_faceplayer
    if (flag(FLAG_MET_SCOTT_IN_LILYCOVE)) {
        msgbox(LilycoveCity_CoveLilyMotel_2F_Text_ContestsDoTakeStrategy, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_CoveLilyMotel_2F_Text_SnoozingPreferBattles, MSGBOX_DEFAULT)
    addvar(VAR_SCOTT_STATE, 1)
    setflag(FLAG_MET_SCOTT_IN_LILYCOVE)
    release_end
}

text LilycoveCity_CoveLilyMotel_2F_Text_ShowMeCompletedDex {
	"I'm the GAME DESIGNER.

	Oh, is that right?
	You're working on a POKéDEX?

	It's tough trying to complete it,
	but don't give up.

	If you do complete it, please come
	show me."
}

text LilycoveCity_CoveLilyMotel_2F_Text_FilledPokedexGiveYouThis {
	"Wow! That's awesome!
	Yep, it's totally awesome!

	This POKéDEX is completely filled!
	You really must love POKéMON!

	I'm so impressed!

	Let me give you something in
	recognition of your feat!"
}

text LilycoveCity_CoveLilyMotel_2F_Text_ImTheProgrammer {
	"Me? You're talking to me?
	I'm the PROGRAMMER.

	I wonder what the SLOTS are
	like here."
}

text LilycoveCity_CoveLilyMotel_2F_Text_ImTheGraphicArtist {
	"I'm the GRAPHIC ARTIST! Aren't the
	POKéMON of HOENN interesting?"
}

text LilycoveCity_CoveLilyMotel_2F_Text_GirlsAreCute {
	"The girl TUBERS, they're cute, hey?
	To battle against a cute TUBER…

	Whoop, it's so awesome!

	And the TWINS! Aren't they cute?
	A 2-on-2 battle with TWINS…

	Whoop, it's unbearably fun!"
}

text LilycoveCity_CoveLilyMotel_2F_Text_SeaBreezeTicklesHeart {
	"The sea breeze tickles my heart.
	It feels wonderful here!"
}

text LilycoveCity_CoveLilyMotel_2F_Text_NeverLeaveWithoutGameBoy {
	"You never know when and where
	people will challenge you.

	That's why I never leave home without
	my GAME BOY ADVANCE."
}

text LilycoveCity_CoveLilyMotel_2F_Text_SnoozingPreferBattles {
	"{SPEAKER NAME_SCOTT}… … … … …
	… … … … … Zzz…

	… … … … … Huh?!
	Oh, sorry, sorry! I was snoozing!

	I came to check out this POKéMON
	CONTEST thing.

	I have to admit, it does look quite
	entertaining, but…

	Consider me a purist--I prefer
	battles and tough TRAINERS.

	But that's just me.

	{PLAYER}{KUN}, I hope you'll enjoy everything
	like the GYMS, CONTESTS, BATTLE TENT,
	the whole works!"
}

text LilycoveCity_CoveLilyMotel_2F_Text_ContestsDoTakeStrategy {
	"{SPEAKER NAME_SCOTT}I think it does take strategy
	to win a CONTEST.

	Devising CONTEST strategies is one way
	of becoming a better TRAINER, I'd say."
}
