mapscripts SlateportCity_PokemonFanClub_MapScripts {}

script SlateportCity_PokemonFanClub_EventScript_Chairman {
    lock_faceplayer
    if (!flag(FLAG_ENTERED_CONTEST)) {
        if (flag(FLAG_MET_SLATEPORT_FANCLUB_CHAIRMAN)) {
			msgbox(SlateportCity_PokemonFanClub_Text_LikeToSeeEnteredContestPokemon, MSGBOX_DEFAULT)
    		release_end
		}
		msgbox(SlateportCity_PokemonFanClub_Text_MeetChairman, MSGBOX_DEFAULT)
		setflag(FLAG_MET_SLATEPORT_FANCLUB_CHAIRMAN)
		release_end
    }
    if (!flag(FLAG_MET_SLATEPORT_FANCLUB_CHAIRMAN)) {
        msgbox(SlateportCity_PokemonFanClub_Text_MeetChairman, MSGBOX_DEFAULT)
    	setflag(FLAG_MET_SLATEPORT_FANCLUB_CHAIRMAN)
    }
    switch (var(VAR_SLATEPORT_FAN_CLUB_STATE)) {
        case 0: goto(SlateportCity_PokemonFanClub_EventScript_ChairmanFirstAssessment)
        case 1: goto(SlateportCity_PokemonFanClub_EventScript_ChairmanTryAssessPokemon)
        case 2: goto(SlateportCity_PokemonFanClub_EventScript_NoMoreScarves)
    }
    release_end
}

script SlateportCity_PokemonFanClub_EventScript_ChairmanFirstAssessment {
    setvar(VAR_SLATEPORT_FAN_CLUB_STATE, 1)
    msgbox(SlateportCity_PokemonFanClub_Text_AllowMeToExamineYourPokemon, MSGBOX_DEFAULT)
    goto(SlateportCity_PokemonFanClub_EventScript_ChairmanAssessLeadMon)
    end
}

script SlateportCity_PokemonFanClub_EventScript_ChairmanTryAssessPokemon {
    setvar(VAR_TEMP_2, 0)
    if (flag(FLAG_RECEIVED_YELLOW_SCARF)) {
        addvar(VAR_TEMP_2, 1)
    }
    if (flag(FLAG_RECEIVED_GREEN_SCARF)) {
        addvar(VAR_TEMP_2, 1)
    }
    if (flag(FLAG_RECEIVED_PINK_SCARF)) {
        addvar(VAR_TEMP_2, 1)
    }
    if (flag(FLAG_RECEIVED_BLUE_SCARF)) {
        addvar(VAR_TEMP_2, 1)
    }
    if (flag(FLAG_RECEIVED_RED_SCARF)) {
        addvar(VAR_TEMP_2, 1)
    }
    if (var(VAR_TEMP_2) == CONTEST_CATEGORIES_COUNT) {
        setvar(VAR_SLATEPORT_FAN_CLUB_STATE, 2)
    }
    if (var(VAR_SLATEPORT_FAN_CLUB_STATE) == 2) {
        goto(SlateportCity_PokemonFanClub_EventScript_NoMoreScarves)
    }
    msgbox(SlateportCity_PokemonFanClub_Text_HowIsYourPokemonGrowing, MSGBOX_DEFAULT)
    goto(SlateportCity_PokemonFanClub_EventScript_ChairmanAssessLeadMon)
    end
}

script SlateportCity_PokemonFanClub_EventScript_NoMoreScarves {
    msgbox(SlateportCity_PokemonFanClub_Text_NothingElseToGiveYou, MSGBOX_DEFAULT)
    release_end
}

script SlateportCity_PokemonFanClub_EventScript_ChairmanAssessLeadMon {
    msgbox(SlateportCity_PokemonFanClub_Text_HmHmISee, MSGBOX_DEFAULT)
    setvar(VAR_TEMP_1, 0)
    if (!flag(FLAG_RECEIVED_YELLOW_SCARF) && specialvar(VAR_RESULT, CheckLeadMonTough) == TRUE) {
		setvar(VAR_TEMP_1, 5)
    }
    if (!flag(FLAG_RECEIVED_GREEN_SCARF) && specialvar(VAR_RESULT, CheckLeadMonSmart) == TRUE) {
		setvar(VAR_TEMP_1, 4)
    }
    if (!flag(FLAG_RECEIVED_PINK_SCARF) && specialvar(VAR_RESULT, CheckLeadMonCute) == TRUE) {
		setvar(VAR_TEMP_1, 3)
    }
    if (!flag(FLAG_RECEIVED_BLUE_SCARF) && specialvar(VAR_RESULT, CheckLeadMonBeauty) == TRUE) {
		setvar(VAR_TEMP_1, 2)
    }
    if (!flag(FLAG_RECEIVED_RED_SCARF) && specialvar(VAR_RESULT, CheckLeadMonCool) == TRUE) {
		setvar(VAR_TEMP_1, 1)
    }
    bufferleadmonspeciesname(STR_VAR_1)
    switch (var(VAR_TEMP_1)) {
        case 0: msgbox(SlateportCity_PokemonFanClub_Text_GiveMonMorePokeblocks, MSGBOX_DEFAULT)
        case 1: call(SlateportCity_PokemonFanClub_EventScript_GiveRedScarf)
        case 2: call(SlateportCity_PokemonFanClub_EventScript_GiveBlueScarf)
        case 3: call(SlateportCity_PokemonFanClub_EventScript_GivePinkScarf)
        case 4: call(SlateportCity_PokemonFanClub_EventScript_GiveGreenScarf)
        case 5: call(SlateportCity_PokemonFanClub_EventScript_GiveYellowScarf)
    }
    release_end
}

script SlateportCity_PokemonFanClub_EventScript_GiveRedScarf {
    if (checkitemspace(ITEM_RED_SCARF) == FALSE) {
        goto(SlateportCity_PokemonFanClub_EventScript_NoRoomForScarf)
    }
    msgbox(SlateportCity_PokemonFanClub_Text_MonMostImpressiveGiveItThis, MSGBOX_DEFAULT)
    setflag(FLAG_RECEIVED_RED_SCARF)
    giveitem(ITEM_RED_SCARF)
    msgbox(SlateportCity_PokemonFanClub_Text_ExplainRedScarf, MSGBOX_DEFAULT)
    return
}

