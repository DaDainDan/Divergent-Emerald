mapscripts MossdeepCity_House2_MapScripts {}

script MossdeepCity_House2_EventScript_Man {
    msgbox(MossdeepCity_House2_Text_SisterMailsBoyfriendInFortree, MSGBOX_NPC)
    end
}

script MossdeepCity_House2_EventScript_Twin {
    msgbox(MossdeepCity_House2_Text_PokemonCarriesMailBackAndForth, MSGBOX_NPC)
    end
}

script MossdeepCity_House2_EventScript_Wingull {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_WINGULL, CRY_MODE_NORMAL)
    msgbox(MossdeepCity_House2_Text_Wingull, MSGBOX_DEFAULT)
    waitmoncry
    closemessage
    setflag(FLAG_WINGULL_DELIVERED_MAIL)
    clearflag(FLAG_HIDE_FORTREE_CITY_HOUSE_4_WINGULL)
	switch (var(VAR_FACING)) {
		case DIR_NORTH: applymovement(LOCALID_MOSSDEEP_HOUSE_WINGULL, moves(run_right,  run_down * 2,  run_left,  run_down,  delay_8))
		case DIR_WEST: applymovement(LOCALID_MOSSDEEP_HOUSE_WINGULL, moves(run_down * 3,  delay_8))
	}
	waitmovement(0)
    removeobject(LOCALID_MOSSDEEP_HOUSE_WINGULL)
    release_end
}

text MossdeepCity_House2_Text_SisterMailsBoyfriendInFortree {
	"My little sister exchanges MAIL with
	her boyfriend in FORTREE.

	I don't envy her one bit at all."
}

text MossdeepCity_House2_Text_PokemonCarriesMailBackAndForth {
	"Even though I can't see my friend in
	FORTREE, my POKéMON carries MAIL
	back and forth for us.

	I'm not lonesome, even though we're
	apart."
}

text MossdeepCity_House2_Text_Wingull {
	"WINGULL: Pihyoh!"
}
