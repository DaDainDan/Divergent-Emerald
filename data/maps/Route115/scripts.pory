mapscripts Route115_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_115_WEST) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute115West)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_115_EAST) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute115East)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_SHOULD_END_ABNORMAL_WEATHER) == 1) {
			call(AbnormalWeather_EventScript_HideMapNamePopup)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_115_WEST || var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_115_EAST) {
			call(AbnormalWeather_StartGroudonWeather)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SHOULD_END_ABNORMAL_WEATHER, 1: AbnormalWeather_EventScript_EndEventAndCleanup_1
    ]
}

script Route115_EventScript_Woman {
    msgbox(Route115_Text_NeverKnowWhenCavePokemonWillAppear, MSGBOX_NPC)
    end
}

script Route115_EventScript_RouteSignRustboro {
    msgbox(Route115_Text_RouteSignRustboro, MSGBOX_SIGN)
    end
}

script Route115_EventScript_MeteorFallsSign {
    msgbox(Route115_Text_MeteorFallsSign, MSGBOX_SIGN)
    end
}

script Route115_EventScript_Timothy {
    trainerbattle_single(TRAINER_TIMOTHY_1, Route115_Text_TimothyIntro, Route115_Text_TimothyDefeat, Route115_EventScript_RegisterTimothy)
    if (specialvar(VAR_RESULT, ShouldTryRematchBattle) == TRUE) {
        trainerbattle_rematch(TRAINER_TIMOTHY_1, Route115_Text_TimothyRematchIntro, Route115_Text_TimothyRematchDefeat)
		msgbox(Route115_Text_TimothyPostRematch, MSGBOX_AUTOCLOSE)
		end
    }
    msgbox(Route115_Text_TimothyPostBattle, MSGBOX_DEFAULT)
    release_end
}

script Route115_EventScript_RegisterTimothy {
    special(PlayerFaceTrainerAfterBattle)
    waitmovement(0)
    msgbox(Route115_Text_TimothyRegister, MSGBOX_DEFAULT)
    register_matchcall(TRAINER_TIMOTHY_1)
    release_end
}

