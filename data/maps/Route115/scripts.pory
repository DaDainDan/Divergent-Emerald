text Route115_Text_NeverKnowWhenCavePokemonWillAppear {
	"Exploring a cave isn't like walking
	on a road.

	You never know when wild POKéMON will
	appear. It's full of suspense."
}

text Route115_Text_RouteSignRustboro {
	"ROUTE 115
	{DOWN_ARROW} RUSTBORO CITY"
}

text Route115_Text_MeteorFallsSign {
	"METEOR FALLS
	FALLARBOR TOWN THROUGH HERE"
}
