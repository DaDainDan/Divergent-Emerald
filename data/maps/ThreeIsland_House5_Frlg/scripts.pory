mapscripts ThreeIsland_House5_Frlg_MapScripts {}

script ThreeIsland_House5_EventScript_LittleGirl {
    lock_faceplayer
    if (flag(FLAG_RESCUED_LOSTELLE)) {
        msgbox(ThreeIsland_House5_Text_IllGoPlayWithLostelle)
    	release_end
    }
    msgbox(ThreeIsland_House5_Text_ImNotLostelle)
    release_end
}

text ThreeIsland_House5_Text_ImNotLostelle {
	"Me?
	I'm not LOSTELLE.

	She's probably gone to the
	BERRY FOREST, I think.

	She picks BERRIES there for making
	lunch."
}

text ThreeIsland_House5_Text_IllGoPlayWithLostelle {
	"I think I'll go play with LOSTELLE
	today."
}
