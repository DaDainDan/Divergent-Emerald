mapscripts BattleFrontier_ScottsHouse_MapScripts {}

script BattleFrontier_ScottsHouse_EventScript_Scott {
    lock_faceplayer
	if (flag(FLAG_TEMP_4)) {
		msgbox(BattleFrontier_ScottsHouse_Text_SoGladIBroughtYouHere, MSGBOX_DEFAULT)
    	release_end
	} elif (flag(FLAG_TEMP_3)) {
		goto(BattleFrontier_ScottsHouse_EventScript_GivenShield)
	} elif (flag(FLAG_TEMP_2)) {
		msgbox(BattleFrontier_ScottsHouse_Text_ExpectingGreatThings, MSGBOX_DEFAULT)
    	release_end
	}
	goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveItems)
	end
}

script BattleFrontier_ScottsHouse_EventScript_CheckGiveItems {
	if (!flag(FLAG_SCOTT_GIVES_BATTLE_POINTS)) {
		goto(BattleFrontier_ScottsHouse_EventScript_WelcomeToFrontier)
	} elif (!flag(FLAG_COLLECTED_ALL_SILVER_SYMBOLS)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckSilverSymbols)
	} elif (!flag(FLAG_COLLECTED_ALL_GOLD_SYMBOLS)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckGoldSymbols)
	}
    goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveShield)
    end
}

script BattleFrontier_ScottsHouse_EventScript_CheckGiveShield {
    if (!flag(FLAG_RECEIVED_SILVER_SHIELD)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveSilverShield)
	} elif (!flag(FLAG_RECEIVED_GOLD_SHIELD)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveGoldShield)
	}
    goto(BattleFrontier_ScottsHouse_EventScript_RandomComment)
    end
}

script BattleFrontier_ScottsHouse_EventScript_CheckSilverSymbols {
	if (!flag(FLAG_SYS_TOWER_SILVER) || !flag(FLAG_SYS_DOME_SILVER) || !flag(FLAG_SYS_PALACE_SILVER) || !flag(FLAG_SYS_ARENA_SILVER)
	 || !flag(FLAG_SYS_FACTORY_SILVER) || !flag(FLAG_SYS_PIKE_SILVER) || !flag(FLAG_SYS_PYRAMID_SILVER)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveShield)
	 }
    msgbox(BattleFrontier_ScottsHouse_Text_YouveCollectedAllSilverSymbols, MSGBOX_DEFAULT)
    if (giveitem(ITEM_LANSAT_BERRY) == FALSE) {
		goto(BattleFrontier_ScottsHouse_EventScript_BerryPocketFull)
	}
    setflag(FLAG_COLLECTED_ALL_SILVER_SYMBOLS)
    setflag(FLAG_TEMP_4)
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_CheckGoldSymbols {
	if (!flag(FLAG_SYS_TOWER_GOLD) || !flag(FLAG_SYS_DOME_GOLD) || !flag(FLAG_SYS_PALACE_GOLD) || !flag(FLAG_SYS_ARENA_GOLD)
	 || !flag(FLAG_SYS_FACTORY_GOLD) || !flag(FLAG_SYS_PIKE_GOLD) || !flag(FLAG_SYS_PYRAMID_GOLD)) {
		goto(BattleFrontier_ScottsHouse_EventScript_CheckGiveShield)
	 }
    msgbox(BattleFrontier_ScottsHouse_Text_YouveCollectedAllGoldSymbols, MSGBOX_DEFAULT)
    if (giveitem(ITEM_STARF_BERRY) == FALSE) {
		goto(BattleFrontier_ScottsHouse_EventScript_BerryPocketFull)
	}
    setflag(FLAG_COLLECTED_ALL_GOLD_SYMBOLS)
    setflag(FLAG_TEMP_4)
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_BerryPocketFull {
    msgbox(BattleFrontier_ScottsHouse_Text_BerryPocketStuffed, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_RandomComment {
    random(3)
	switch (var(VAR_RESULT)) {
		case 0: msgbox(BattleFrontier_ScottsHouse_Text_WhyIGoSeekingTrainers, MSGBOX_DEFAULT)
		case 1: msgbox(BattleFrontier_ScottsHouse_Text_HaveYouMetFrontierBrain, MSGBOX_DEFAULT)
		case 2: msgbox(BattleFrontier_ScottsHouse_Text_MayFindWildMonsInFrontier, MSGBOX_DEFAULT)
	}
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_CheckGiveSilverShield {
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_SINGLES)
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    tower_get(TOWER_DATA_WIN_STREAK)
	if (var(VAR_RESULT) >= 50) {
		goto(BattleFrontier_ScottsHouse_EventScript_GiveSilverShield)
	}
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_OPEN)
    tower_get(TOWER_DATA_WIN_STREAK)
	if (var(VAR_RESULT) >= 50) {
		goto(BattleFrontier_ScottsHouse_EventScript_GiveSilverShield)
	}
    goto(BattleFrontier_ScottsHouse_EventScript_RandomComment)
    end
}

script BattleFrontier_ScottsHouse_EventScript_GiveSilverShield {
    msgbox(BattleFrontier_ScottsHouse_Text_Beat50TrainersInARow, MSGBOX_DEFAULT)
    if (givedecoration(DECOR_SILVER_SHIELD) == FALSE) {
		goto(BattleFrontier_ScottsHouse_EventScript_NoRoomForShield)
	}
    setflag(FLAG_RECEIVED_SILVER_SHIELD)
    setflag(FLAG_TEMP_3)
    goto(BattleFrontier_ScottsHouse_EventScript_GivenShield)
    end
}

script BattleFrontier_ScottsHouse_EventScript_NoRoomForShield {
    msgbox(BattleFrontier_ScottsHouse_Text_ComeBackForThisLater, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_GivenShield {
    msgbox(BattleFrontier_ScottsHouse_Text_ExpectingToHearEvenGreaterThings, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_ScottsHouse_EventScript_CheckGiveGoldShield {
    setvar(VAR_FRONTIER_BATTLE_MODE, FRONTIER_MODE_SINGLES)
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_50)
    tower_get(TOWER_DATA_WIN_STREAK)
	if (var(VAR_RESULT) >= 100) {
		goto(BattleFrontier_ScottsHouse_EventScript_GiveGoldShield)
	}
    frontier_set(FRONTIER_DATA_LVL_MODE, FRONTIER_LVL_OPEN)
    tower_get(TOWER_DATA_WIN_STREAK)
	if (var(VAR_RESULT) >= 100) {
		goto(BattleFrontier_ScottsHouse_EventScript_GiveGoldShield)
	}
    goto(BattleFrontier_ScottsHouse_EventScript_RandomComment)
    end
}

script BattleFrontier_ScottsHouse_EventScript_GiveGoldShield {
    msgbox(BattleFrontier_ScottsHouse_Text_Beat100TrainersInARow, MSGBOX_DEFAULT)
    if (givedecoration(DECOR_GOLD_SHIELD) == FALSE) {
		goto(BattleFrontier_ScottsHouse_EventScript_NoRoomForShield)
	}
    setflag(FLAG_RECEIVED_GOLD_SHIELD)
    setflag(FLAG_TEMP_3)
    goto(BattleFrontier_ScottsHouse_EventScript_GivenShield)
    end
}

script BattleFrontier_ScottsHouse_EventScript_WelcomeToFrontier {
    msgbox(BattleFrontier_ScottsHouse_Text_WelcomeToBattleFrontier, MSGBOX_DEFAULT)
    closemessage
    delay(30)
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement(LOCALID_SCOTTS_HOUSE_SCOTT, Common_Movement_StepFasterUp)
		case DIR_SOUTH:
			applymovement(LOCALID_SCOTTS_HOUSE_SCOTT, Common_Movement_StepFasterDown)
		case DIR_EAST:
			applymovement(LOCALID_SCOTTS_HOUSE_SCOTT, Common_Movement_StepFasterRight)
		case DIR_WEST:
			applymovement(LOCALID_SCOTTS_HOUSE_SCOTT, Common_Movement_StepFasterLeft)
			
	}
	waitmovement(0)
    msgbox(BattleFrontier_ScottsHouse_Text_HowMuchEffortItTookToMakeReal, MSGBOX_DEFAULT)
    applymovement(LOCALID_SCOTTS_HOUSE_SCOTT, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(BattleFrontier_ScottsHouse_Text_HaveThisAsMementoOfOurPathsCrossing, MSGBOX_DEFAULT)
	if (var(VAR_SCOTT_STATE) == 13) {
		buffernumberstring(STR_VAR_1, 4)
    	setvar(VAR_0x8004, 4)
	}
	elif (var(VAR_SCOTT_STATE) >= 9) {
		buffernumberstring(STR_VAR_1, 3)
		setvar(VAR_0x8004, 3)
	}
	elif (var(VAR_SCOTT_STATE) >= 6) {
		buffernumberstring(STR_VAR_1, 2)
		setvar(VAR_0x8004, 2)
	}
	else {
		buffernumberstring(STR_VAR_1, 1)
    	setvar(VAR_0x8004, 1)
	}
    special(GiveFrontierBattlePoints)
    msgbox(BattleFrontier_ScottsHouse_Text_ObtainedXBattlePoints, MSGBOX_GETPOINTS)
    msgbox(BattleFrontier_ScottsHouse_Text_ExplainBattlePoints, MSGBOX_DEFAULT)
    setflag(FLAG_SCOTT_GIVES_BATTLE_POINTS)
    setflag(FLAG_TEMP_2)
    release_end
    end
}

text BattleFrontier_ScottsHouse_Text_WelcomeToBattleFrontier {
	"{SPEAKER NAME_SCOTT}Well, hello and welcome!
	Heheh… Sorry about the cramped space.

	Anyway, {PLAYER}{KUN}, let me formally
	welcome you to the BATTLE FRONTIER.

	This is my dream come true.
	It took me years and years, but I've
	finally given shape to my dream."
}

text BattleFrontier_ScottsHouse_Text_HowMuchEffortItTookToMakeReal {
	"On reflection, it was a terribly long
	journey…

	I left home alone on a quest to find
	strong TRAINERS.

	No one can imagine how much effort
	or time it took to make this real."
}

text BattleFrontier_ScottsHouse_Text_HaveThisAsMementoOfOurPathsCrossing {
	"But that's all in the past.
	No point dwelling on that!

	All I want for you is to enjoy battling
	to your heart's content here.

	{PLAYER}{KUN}, I want you to have this
	as a memento for all the time our
	paths crossed on our journeys."
}

text BattleFrontier_ScottsHouse_Text_ObtainedXBattlePoints {
	"{PLAYER} obtained
	{STR_VAR_1} Battle Point(s)."
}

text BattleFrontier_ScottsHouse_Text_ExplainBattlePoints {
	"{SPEAKER NAME_SCOTT}You can check your Battle
	Points on your FRONTIER PASS.

	The more success you have here at
	the BATTLE FRONTIER, the more Battle
	Points you will collect.

	Use your Battle Points the way you
	see fit, like trading them for items."
}

text BattleFrontier_ScottsHouse_Text_ExpectingGreatThings {
	"I'm expecting great things from you!"
}

text BattleFrontier_ScottsHouse_Text_WhyIGoSeekingTrainers {
	"{SPEAKER NAME_SCOTT}Every TRAINER is an individual.
	They all lead lives of their own.

	But when they're in a battle,
	it doesn't matter who they are.

	They're all the same!

	I love the purity of battle,
	where everyone is equal.

	That's why I go everywhere seeking
	TRAINERS who are serious about
	battling, and invite them here."
}

text BattleFrontier_ScottsHouse_Text_HaveYouMetFrontierBrain {
	"{SPEAKER NAME_SCOTT}Have you met any of
	the FRONTIER BRAINS?

	Better yet, have you obtained any
	symbols from them?

	I handpicked the FRONTIER BRAINS
	as the toughest TRAINERS anywhere.

	But I'm sure that seeing how tough
	you are will startle even them!"
}

text BattleFrontier_ScottsHouse_Text_MayFindWildMonsInFrontier {
	"{SPEAKER NAME_SCOTT}You don't just train for battle,
	right?

	I think I remember you working on
	a POKéDEX as well.

	Well, guess what?

	You may run into wild POKéMON in
	the BATTLE FRONTIER somewhere…
	Fufufu!"
}

text BattleFrontier_ScottsHouse_Text_YouveCollectedAllSilverSymbols {
	"{SPEAKER NAME_SCOTT}Are you enjoying things in
	the BATTLE FRONTIER?

	…Wait a second…
	Oh!

	Your FRONTIER PASS!
	You've collected the full set
	of silver symbols!

	That's more than impressive!
	You are tough, just as I suspected!

	Normally, I wouldn't do something
	like this, but this is a special time!

	I want you to have this.
	I'm sure you can put it to proper use."
}

text BattleFrontier_ScottsHouse_Text_YouveCollectedAllGoldSymbols {
	"{SPEAKER NAME_SCOTT}I hope you're enjoying
	everything in the BATTLE FRONTIER.

	…Wait a second…
	Oh, my disbelieving eyes!

	Your FRONTIER PASS!
	You've gathered up the full set
	of gold symbols!

	That's more than stupendous!
	You're incredible, just as I suspected!

	… … … … … …

	{PLAYER}, you've got to accept this!

	I think you will be able to
	appreciate the value of my gift!"
}

text BattleFrontier_ScottsHouse_Text_SoGladIBroughtYouHere {
	"I must say I have the gift of knowing
	a good TRAINER when I see one.

	I'm so glad I had the foresight to
	bring you here!"
}

text BattleFrontier_ScottsHouse_Text_BerryPocketStuffed {
	"Your BERRY POCKET seems to
	be stuffed."
}

text BattleFrontier_ScottsHouse_Text_Beat50TrainersInARow {
	"{SPEAKER NAME_SCOTT}Oh, I heard about you!
	How you ruled the BATTLE TOWER!
	You beat over 50 TRAINERS in a row?

	That's fantastic!
	I want you to have this!"
}

text BattleFrontier_ScottsHouse_Text_Beat100TrainersInARow {
	"{SPEAKER NAME_SCOTT}Oh, my! I heard about you!
	How you overwhelmed the BATTLE TOWER!
	You beat over 100 TRAINERS in a row?

	That's ridiculously spectacular!
	You've got to have this!"
}

text BattleFrontier_ScottsHouse_Text_ExpectingToHearEvenGreaterThings {
	"I'll be expecting to hear even greater
	things about you now!"
}

text BattleFrontier_ScottsHouse_Text_ComeBackForThisLater {
	"Oops, well, if you have too much
	stuff, come back for this later."
}
