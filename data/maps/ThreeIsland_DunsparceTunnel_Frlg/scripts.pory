mapscripts ThreeIsland_DunsparceTunnel_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_THREE_ISLAND_DUNSPARCE_TUNNEL)
		specialvar(VAR_RESULT, IsNationalPokedexEnabled)
		copyvar(VAR_0x8008, VAR_RESULT)
		if (var(VAR_0x8008) == TRUE) {
			setmaplayoutindex(LAYOUT_THREE_ISLAND_DUNSPARCE_TUNNEL_DUG_OUT)
		} else {
			setobjectxyperm(LOCALID_PROSPECTOR, 6, 3)
			setobjectmovementtype(LOCALID_PROSPECTOR, MOVEMENT_TYPE_FACE_RIGHT)
		}
		end
    }
}

script ThreeIsland_DunsparceTunnel_EventScript_Prospector {
    lock_faceplayer
    if (flag(FLAG_GOT_NUGGET_FROM_DUNSPARCE_TUNNEL)) {
        msgbox(ThreeIsland_DunsparceTunnel_Text_ThatsANugget)
    }
    elif (specialvar(VAR_RESULT, IsNationalPokedexEnabled) == TRUE) {
        msgbox(ThreeIsland_DunsparceTunnel_Text_StruckGoldThisIsForYou)
		if (giveitem(ITEM_NUGGET) == FALSE) {
			msgbox(ThreeIsland_DunsparceTunnel_Text_WhoopsBagCrammedFull)
			release_end
		}
		setflag(FLAG_GOT_NUGGET_FROM_DUNSPARCE_TUNNEL)
		msgbox(ThreeIsland_DunsparceTunnel_Text_ThatsANugget)
    }
	else {
		msgbox(ThreeIsland_DunsparceTunnel_Text_ProspectingForGold)
    	goto(Common_EventScript_FaceOriginalDirection)
	}
    release_end
}

text ThreeIsland_DunsparceTunnel_Text_ProspectingForGold {
	"Hey, there!
	How's it going?

	What am I doing here, you ask?
	Why, I'm prospecting for gold!

	When I strike it rich, I'm buying
	a house in KANTO."
}

text ThreeIsland_DunsparceTunnel_Text_StruckGoldThisIsForYou {
	"Hey, there! How's it going?
	Did you hear? I've struck gold!

	You remembered that I was
	prospecting, didn't you?

	You can't begin to imagine just
	how happy I am.

	So, I'll show you!
	This is for you!"
}

text ThreeIsland_DunsparceTunnel_Text_ThatsANugget {
	"That's a NUGGET!

	I can't give you any nuggets of
	wisdom, so that'll have to do!"
}

text ThreeIsland_DunsparceTunnel_Text_WhoopsBagCrammedFull {
	"Whoops, your BAG is crammed full!
	I'll give this to you later."
}
