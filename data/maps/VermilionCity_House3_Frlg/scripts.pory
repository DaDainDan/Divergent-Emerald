mapscripts VermilionCity_House3_Frlg_MapScripts {}

script VermilionCity_House3_EventScript_Boy {
    msgbox(VermilionCity_House3_Text_PidgeyFlyLetterToSaffron, MSGBOX_NPC)
    end
}

script VermilionCity_House3_EventScript_Lass {
    msgbox(VermilionCity_House3_Text_SendMyPidgeyToUnionRoom, MSGBOX_NPC)
    end
}

script VermilionCity_House3_EventScript_Pidgey {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PIDGEY, CRY_MODE_NORMAL)
    msgbox(VermilionCity_House3_Text_Pidgey)
    waitmoncry
    release_end
}

script VermilionCity_House3_EventScript_Letter {
    msgbox(VermilionCity_House3_Text_DearPippiLetter, MSGBOX_SIGN)
    end
}

text VermilionCity_House3_Text_PidgeyFlyLetterToSaffron {
	"I'm getting my PIDGEY to fly a
	letter to SAFFRON in the north."
}

text VermilionCity_House3_Text_Pidgey {
	"PIDGEY: Kurukkoo!"
}

text VermilionCity_House3_Text_DearPippiLetter {
	"Dear PIPPI,
	I hope to see you soon.

	I heard SAFFRON has problems with
	TEAM ROCKET.

	VERMILION appears to be safe."
}

text VermilionCity_House3_Text_SendMyPidgeyToUnionRoom {
	"I want to exchange MAIL with all
	sorts of people.

	I send my PIDGEY to a UNION ROOM
	to exchange MAIL for me."
}
