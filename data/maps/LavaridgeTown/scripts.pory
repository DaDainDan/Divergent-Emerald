mapscripts LavaridgeTown_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_VISITED_LAVARIDGE_TOWN)
		if (flag(FLAG_WHITEOUT_TO_LAVARIDGE)) {
			clearflag(FLAG_WHITEOUT_TO_LAVARIDGE)
		}
		if (flag(FLAG_DEFEATED_EVIL_TEAM_MT_CHIMNEY)) {
			clearflag(FLAG_HIDE_MT_CHIMNEY_TRAINERS)
		}
		call(Common_EventScript_SetupRivalGfxId)
		call(Common_EventScript_SetupRivalOnBikeGfxId)
		if (var(VAR_LAVARIDGE_TOWN_STATE) == 1) {
			getplayerxy(VAR_0x8004, VAR_0x8005)
			if (var(VAR_0x8004) == 9) {
				setobjectxyperm(LOCALID_LAVARIDGE_RIVAL, 11, 9)
				setobjectxyperm(LOCALID_LAVARIDGE_RIVAL_ON_BIKE, 9, 8)
				setobjectmovementtype(LOCALID_LAVARIDGE_RIVAL_ON_BIKE, MOVEMENT_TYPE_FACE_UP)
				clearflag(FLAG_HIDE_LAVARIDGE_TOWN_RIVAL)
			}
			setflag(FLAG_HIDE_MAP_NAME_POPUP)
		}
		end
    }
	MAP_SCRIPT_ON_RESUME {
		setstepcallback(STEP_CB_ASH)
		end
	}
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LAVARIDGE_TOWN_STATE, 1: LavaridgeTown_EventScript_RivalGiveGoGoggles
    ]
}

script LavaridgeTown_EventScript_RivalGiveGoGoggles {
    lockall
    getplayerxy(VAR_0x8008, VAR_0x8009)
    if (var(VAR_0x8008) == 9) {
        applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_StepFasterUp)
		waitmovement(0)
		playse(SE_PIN)
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_ExclamationMark)
		waitmovement(0)
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_Delay48)
    } else {
        opendoor(12, 15)
		waitdooranim
		addobject(LOCALID_LAVARIDGE_RIVAL)
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_WalkDown)
		waitmovement(0)
		closedoor(12, 15)
		waitdooranim
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_StepFasterLeft)
		waitmovement(0)
		playse(SE_PIN)
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_ExclamationMark)
		waitmovement(0)
		applymovement(LOCALID_LAVARIDGE_RIVAL, Common_Movement_Delay48)
		waitmovement(0)
		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    }
	waitmovement(0)
    delay(20)
    if (checkplayergender == MALE) {
		playbgm(MUS_ENCOUNTER_MAY, TRUE)
	} else {
		playbgm(MUS_ENCOUNTER_BRENDAN, TRUE)
	}
    if (var(VAR_0x8008) == 9) {
        applymovement(LOCALID_LAVARIDGE_RIVAL, moves(walk_left * 2,  walk_up))
    } else {
        applymovement(LOCALID_LAVARIDGE_RIVAL, moves(walk_left * 6))
    }
	waitmovement(0)
    if (checkplayergender == MALE) {
		msgbox(LavaridgeTown_Text_MayNiceBadgesTakeThis, MSGBOX_DEFAULT)
		giveitem(ITEM_GO_GOGGLES)
		msgbox(LavaridgeTown_Text_MayExplainGoGogglesChallengeDad, MSGBOX_DEFAULT)
	} else {
        msgbox(LavaridgeTown_Text_BrendanNiceBadgesTakeThis, MSGBOX_DEFAULT)
		giveitem(ITEM_GO_GOGGLES)
		msgbox(LavaridgeTown_Text_BrendanExplainGoGogglesChallengeDad, MSGBOX_DEFAULT)
    }
    setflag(FLAG_RECEIVED_GO_GOGGLES)
    closemessage
    removeobject(LOCALID_LAVARIDGE_RIVAL)
    addobject(LOCALID_LAVARIDGE_RIVAL_ON_BIKE)
    delay(30)
    if (var(VAR_0x8008) == 9) {
        applymovement(LOCALID_PLAYER, moves(delay_16,  delay_8,  step_faster_right))
    	applymovement(LOCALID_LAVARIDGE_RIVAL_ON_BIKE, moves(run_down,  run_right * 8))
    } else {
		applymovement(LOCALID_LAVARIDGE_RIVAL_ON_BIKE, moves(run_right * 3,  run_up * 7))
	}
	waitmovement(0)
    removeobject(LOCALID_LAVARIDGE_RIVAL_ON_BIKE)
    setvar(VAR_LAVARIDGE_TOWN_STATE, 2)
    clearflag(FLAG_HIDE_MAP_NAME_POPUP)
    savebgm(MUS_DUMMY)
    fadedefaultbgm
    releaseall
    end
}

script LavaridgeTown_EventScript_HotSpringsTrigger {
    if (specialvar(VAR_RESULT, GetPlayerFacingDirection) == DIR_SOUTH) {
		incrementgamestat(GAME_STAT_ENTERED_HOT_SPRINGS)
	}
    end
}

