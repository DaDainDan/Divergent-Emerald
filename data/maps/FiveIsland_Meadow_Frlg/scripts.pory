mapscripts FiveIsland_Meadow_Frlg_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (flag(FLAG_UNLOCKED_ROCKET_WAREHOUSE)) {
			setmetatile(12, 21, METATILE_SeviiIslands45_RocketWarehouseDoor_Unlocked, 1)
		}
		end
    }
}

script FiveIsland_Meadow_EventScript_WarehouseDoor {
    lockall
    if (flag(FLAG_UNLOCKED_ROCKET_WAREHOUSE)) {
        msgbox(FiveIsland_Meadow_Text_WarehouseDoorAlreadyOpen)
    }
    elif (flag(FLAG_LEARNED_YES_NAH_CHANSEY)) {
        setflag(FLAG_UNLOCKED_ROCKET_WAREHOUSE)
		message(FiveIsland_Meadow_Text_EnteredPasswordDoorOpened)
		waitmessage
		delay(60)
		setmetatile(12, 21, METATILE_SeviiIslands45_RocketWarehouseDoor_Unlocked, 1)
		special(DrawWholeMapView)
		playse(SE_PIN)
		waitse
    }
	else {
		msgbox(FiveIsland_Meadow_Text_EnteredPasswordAnotherNeeded)
	}
    releaseall
    end
}

script FiveIsland_Meadow_EventScript_Rocket1 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_49, FiveIsland_Meadow_Text_Rocket1Intro, FiveIsland_Meadow_Text_Rocket1Defeat)
    msgbox(FiveIsland_Meadow_Text_Rocket1PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_Meadow_EventScript_Rocket2 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_50, FiveIsland_Meadow_Text_Rocket2Intro, FiveIsland_Meadow_Text_Rocket2Defeat)
    msgbox(FiveIsland_Meadow_Text_Rocket2PostBattle, MSGBOX_AUTOCLOSE)
    end
}

script FiveIsland_Meadow_EventScript_Rocket3 {
    trainerbattle_single(TRAINER_TEAM_ROCKET_GRUNT_51, FiveIsland_Meadow_Text_Rocket3Intro, FiveIsland_Meadow_Text_Rocket3Defeat)
    msgbox(FiveIsland_Meadow_Text_Rocket3PostBattle, MSGBOX_AUTOCLOSE)
    end
}

// Unused
text FiveIsland_Meadow_Text_DoorNeedsTwoPasswords {
	"とびらを　あけるには
	パスワードが　2つ　いるようだ"
}

text FiveIsland_Meadow_Text_EnteredPasswordAnotherNeeded {
	"{PLAYER} entered a password.

	“GOLDEEN need log.”

	… …  … …  … …

	Another password is needed to
	open the door…"
}

text FiveIsland_Meadow_Text_EnteredPasswordDoorOpened {
	"{PLAYER} entered two passwords.

	“GOLDEEN need log.”
	“Yes, nah, CHANSEY.”

	… …  … …  … …

	The WAREHOUSE's door opened!"
}

text FiveIsland_Meadow_Text_WarehouseDoorAlreadyOpen {
	"The WAREHOUSE's door is already
	open."
}

text FiveIsland_Meadow_Text_Rocket1Intro {
	"This area's strictly off-limits!
	Out, out!"
}

text FiveIsland_Meadow_Text_Rocket1Defeat {
	"Is this for real?"
}

text FiveIsland_Meadow_Text_Rocket1PostBattle {
	"You don't have any business here!
	Go home!"
}

text FiveIsland_Meadow_Text_Rocket2Intro {
	"There's nothing past here except
	our WAREHOUSE.

	So what brings you here?"
}

text FiveIsland_Meadow_Text_Rocket2Defeat {
	"That wasn't supposed to happen…"
}

text FiveIsland_Meadow_Text_Rocket2PostBattle {
	"You're wanting to know what's inside
	this WAREHOUSE?

	It's better you didn't know.
	For your own sake, I mean."
}

text FiveIsland_Meadow_Text_Rocket3Intro {
	"You'd be wasting time even if you
	were to get by me."
}

text FiveIsland_Meadow_Text_Rocket3Defeat {
	"Oh, that makes me furious!"
}

text FiveIsland_Meadow_Text_Rocket3PostBattle {
	"You won't be able to get in without
	the passwords anyway."
}
