script BattleFrontier_BattleDomeLobby_EventScript_RulesBoard {
    lockall
    msgbox(BattleFrontier_BattleDomeLobby_Text_RulesAreListed, MSGBOX_DEFAULT)
    goto(BattleFrontier_BattleDomeLobby_EventScript_ReadRulesBoard)
    end
}

script BattleFrontier_BattleDomeLobby_EventScript_ReadRulesBoard {
    message(BattleFrontier_BattleDomeLobby_Text_ReadWhichHeading)
    waitmessage
    multichoice(17, 4, MULTI_BATTLE_DOME_RULES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: msgbox(BattleFrontier_BattleDomeLobby_Text_ExplainMatchupRules, MSGBOX_DEFAULT)
        case 1: msgbox(BattleFrontier_BattleDomeLobby_Text_ExplainTourneyTree, MSGBOX_DEFAULT)
        case 2: msgbox(BattleFrontier_BattleDomeLobby_Text_ExplainDoubleKORules, MSGBOX_DEFAULT)
        case 3:
        case MULTI_B_PRESSED:
			releaseall
			end
    }
	goto(BattleFrontier_BattleDomeLobby_EventScript_ReadRulesBoard)
    end
}

text BattleFrontier_BattleDomeLobby_Text_WelcomeSingleBattle {
	"Where the strategies of TRAINERS
	are put to the test!

	Welcome to the BATTLE DOME!

	I am your guide to the SINGLE BATTLE
	Tournament."
}

text BattleFrontier_BattleDomeLobby_Text_TakeSinglesChallenge {
	"Would you like to challenge
	the SINGLE BATTLE Tournament?"
}

text BattleFrontier_BattleDomeLobby_Text_HopeToSeeYouAgain {
	"We hope to see you again."
}

text BattleFrontier_BattleDomeLobby_Text_ExplainSinglesChallenge {
	"The SINGLE BATTLE Tournament
	is exactly as the name suggests--
	a tournament of SINGLE BATTLES.

	All participating TRAINERS must
	enter three POKéMON each.

	In each battle, one of the three
	POKéMON must be held in reserve.

	The other two POKéMON can battle
	one at a time.

	Choose the two battling POKéMON after
	examining the opponent's trio.

	You win the tournament by defeating
	four TRAINERS.

	Battle Points are awarded to
	the tournament winner.

	If you want to interrupt your
	tournament, please save the game.

	If you don't save before interrupting,
	you will be disqualified."
}

text BattleFrontier_BattleDomeLobby_Text_OkayToSaveBeforeChallenge {
	"Before I show you to the BATTLE DOME,
	I must save the data. Is that okay?"
}

text BattleFrontier_BattleDomeLobby_Text_WhichLevelMode {
	"The tournament offers two levels
	of challenge, Level 50 and Open Level.
	Which is your choice?"
}

text BattleFrontier_BattleDomeLobby_Text_SelectThreeMons {
	"Now select the three POKéMON that
	you wish to enter, please."
}

text BattleFrontier_BattleDomeLobby_Text_NotEnoughValidMonsLvOpen {
	"Excuse me!

	You don't have three eligible POKéMON.

	Also, the POKéMON must be holding
	different kinds of items.

	EGGS{STR_VAR_1}."
}

text BattleFrontier_BattleDomeLobby_Text_NotEnoughValidMonsEnd {
	"Please come see me when you are ready."
}

text BattleFrontier_BattleDomeLobby_Text_NotEnoughValidMonsLv50 {
	"Excuse me!

	You don't have three eligible POKéMON.

	You must have three different POKéMON
	of Level 50 or less to enter.

	They also must be holding different
	kinds of items.

	EGGS{STR_VAR_1}."
}

text BattleFrontier_BattleDomeLobby_Text_ShowYouToBattleDome {
	"I will now show you to
	the BATTLE DOME."
}

text BattleFrontier_BattleDomeLobby_Text_DidntSaveBeforeQuitting {
	"Excuse me!

	You didn't save before you quit your
	challenge last time.

	Because of that, your challenge so far
	has been disqualified. Sorry!"
}

text BattleFrontier_BattleDomeLobby_Text_CongratsForWinningTourney {
