mapscripts RustboroCity_Mart_MapScripts {}

script RustboroCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    if (!flag(FLAG_MET_DEVON_EMPLOYEE)) {
        pokemart(RustboroCity_Mart_Pokemart_Basic)
    } else {
        pokemart(RustboroCity_Mart_Pokemart_Expanded)
    }
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart RustboroCity_Mart_Pokemart_Basic {
    ITEM_POKE_BALL
    ITEM_POTION
    ITEM_SUPER_POTION
    ITEM_ANTIDOTE
    ITEM_PARALYZE_HEAL
    ITEM_ESCAPE_ROPE
    ITEM_REPEL
    ITEM_X_SPEED
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
}

mart RustboroCity_Mart_Pokemart_Expanded {
    ITEM_POKE_BALL
    ITEM_TIMER_BALL
    ITEM_REPEAT_BALL
    ITEM_POTION
    ITEM_SUPER_POTION
    ITEM_ANTIDOTE
    ITEM_PARALYZE_HEAL
    ITEM_ESCAPE_ROPE
    ITEM_REPEL
    ITEM_X_SPEED
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
}

script RustboroCity_Mart_EventScript_PokefanF {
    msgbox(RustboroCity_Mart_Text_BuyingHealsInCaseOfShroomish, MSGBOX_NPC)
    end
}

script RustboroCity_Mart_EventScript_Boy {
    msgbox(RustboroCity_Mart_Text_ShouldBuySuperPotionsInstead, MSGBOX_NPC)
    end
}

script RustboroCity_Mart_EventScript_BugCatcher {
    msgbox(RustboroCity_Mart_Text_GettingEscapeRopeJustInCase, MSGBOX_NPC)
    end
}

text RustboroCity_Mart_Text_BuyingHealsInCaseOfShroomish {
	"I'm buying some PARLYZ HEALS and
	ANTIDOTES.

	Just in case I run into SHROOMISH
	in PETALBURG WOODS."
}

text RustboroCity_Mart_Text_ShouldBuySuperPotionsInstead {
	"My POKéMON evolved.
	It has a lot of HP now.

	I should buy SUPER POTIONS for it
	instead of ordinary POTIONS."
}

text RustboroCity_Mart_Text_GettingEscapeRopeJustInCase {
	"I'm getting an ESCAPE ROPE just in
	case I get lost in a cave.

	I just need to use it to get back to
	the entrance."
}
