mapscripts LilycoveCity_DepartmentStore_3F_MapScripts {}

script LilycoveCity_DepartmentStore_3F_EventScript_ClerkLeft {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(LilycoveCity_DepartmentStore_3F_Pokemart_Vitamins)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart LilycoveCity_DepartmentStore_3F_Pokemart_Vitamins {
    ITEM_PROTEIN
    ITEM_CALCIUM
    ITEM_IRON
    ITEM_ZINC
    ITEM_CARBOS
    ITEM_HP_UP
}

script LilycoveCity_DepartmentStore_3F_EventScript_ClerkRight {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(LilycoveCity_DepartmentStore_3F_Pokemart_StatBoosters)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart LilycoveCity_DepartmentStore_3F_Pokemart_StatBoosters {
    ITEM_X_SPEED
    ITEM_X_SP_ATK
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
    ITEM_DIRE_HIT
    ITEM_GUARD_SPEC
    ITEM_X_ACCURACY
}

script LilycoveCity_DepartmentStore_3F_EventScript_TriathleteM {
    msgbox(LilycoveCity_DepartmentStore_3F_Text_ItemsBestForTougheningPokemon, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_3F_EventScript_PokefanM {
    msgbox(LilycoveCity_DepartmentStore_3F_Text_WantMoreEndurance, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_3F_EventScript_Woman {
    msgbox(LilycoveCity_DepartmentStore_3F_Text_GaveCarbosToSpeedUpMon, MSGBOX_NPC)
    end
}

text LilycoveCity_DepartmentStore_3F_Text_ItemsBestForTougheningPokemon {
	"For quickly toughening up POKéMON,
	items are the best.

	PROTEIN boosts ATTACK,
	and CALCIUM raises SP. ATK."
}

text LilycoveCity_DepartmentStore_3F_Text_WantMoreEndurance {
	"I want my POKéMON to have more
	endurance.

	I'm trying to decide whether to raise
	DEFENSE with IRON, or SP. DEF with ZINC."
}

text LilycoveCity_DepartmentStore_3F_Text_GaveCarbosToSpeedUpMon {
	"I gave a CARBOS to my POKéMON,
	and its SPEED went up."
}
