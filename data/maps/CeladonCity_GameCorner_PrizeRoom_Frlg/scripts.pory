mapscripts CeladonCity_GameCorner_PrizeRoom_Frlg_MapScripts {}

script CeladonCity_GameCorner_PrizeRoom_EventScript_BaldingMan {
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_FancyThatPorygon, MSGBOX_NPC)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_OldMan {
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_RakedItInToday, MSGBOX_NPC)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_PrizeClerkMons {
    lock_faceplayer
    if (!flag(FLAG_GOT_COIN_CASE)) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_NeedCoinCase)
    }
    showcoinsbox(1, 1)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_WeExchangeCoinsForPrizes)
    message(CeladonCity_GameCorner_PrizeRoom_Text_WhichPrize)
    waitmessage
    multichoice(11, 0, MULTI_GAME_CORNER_POKEMON_PRIZES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_Abra)
        case 1: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_Clefairy)
        case 2: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_DratiniPinsir)
        case 3: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_ScytherDratini)
        case 4: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_Porygon)
        case 5:
        case MULTI_B_PRESSED: 
			goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange {
    hidecoinsbox(0, 0)
    release_end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon {
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_YouWantPrize, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
    if (checkcoins(VAR_RESULT) < VAR_EXCHANGE_PRICE) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_NotEnoughCoins)
    }
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    switch (var(VAR_TEMP_TRANSFERRED_SPECIES)) {
        case SPECIES_ABRA: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_GiveAbra)
        case SPECIES_CLEFAIRY: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_GiveClefairy)
        case SPECIES_DRATINI: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_GiveDratini)
		case SPECIES_PORYGON: goto(CeladonCity_GameCorner_PrizeRoom_EventScript_GivePorygon)
        case SPECIES_SCYTHER: givemon(VAR_TEMP_TRANSFERRED_SPECIES, 25)
        case SPECIES_PINSIR: givemon(VAR_TEMP_TRANSFERRED_SPECIES, 18)
    }
	goto(CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon)
    end
}

raw `
CeladonCity_GameCorner_PrizeRoom_EventScript_Abra::
	#ifdef FIRERED
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ABRA
	setvar VAR_EXCHANGE_PRICE, 180
	#else
	#ifdef LEAFGREEN
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ABRA
	setvar VAR_EXCHANGE_PRICE, 120
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_Clefairy::
	#ifdef FIRERED
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_CLEFAIRY
	setvar VAR_EXCHANGE_PRICE, 500
	#else
	#ifdef LEAFGREEN
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_CLEFAIRY
	setvar VAR_EXCHANGE_PRICE, 750
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_DratiniPinsir::
	#ifdef FIRERED
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_DRATINI
	setvar VAR_EXCHANGE_PRICE, 2800
	#else
	#ifdef LEAFGREEN
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_PINSIR
	setvar VAR_EXCHANGE_PRICE, 2500
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_ScytherDratini::
	#ifdef FIRERED
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_SCYTHER
	setvar VAR_EXCHANGE_PRICE, 5500
	#else
	#ifdef LEAFGREEN
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_DRATINI
	setvar VAR_EXCHANGE_PRICE, 4600
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_Porygon::
	#ifdef FIRERED
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_PORYGON
	setvar VAR_EXCHANGE_PRICE, 9999
	#else
	#ifdef LEAFGREEN
	setvar VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_PORYGON
	setvar VAR_EXCHANGE_PRICE, 6500
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_ConfirmPrizeMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_GiveAbra::
	#ifdef FIRERED
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 9
	#else
	#ifdef LEAFGREEN
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 7
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_GiveClefairy::
	#ifdef FIRERED
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 8
	#else
	#ifdef LEAFGREEN
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 12
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_GiveDratini::
	#ifdef FIRERED
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 18
	#else
	#ifdef LEAFGREEN
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 24
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon
	end

CeladonCity_GameCorner_PrizeRoom_EventScript_GivePorygon::
	#ifdef FIRERED
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 26
	#else
	#ifdef LEAFGREEN
	givemon VAR_TEMP_TRANSFERRED_SPECIES, 18
	#endif
	#endif
	goto CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon
	end
`

script CeladonCity_GameCorner_PrizeRoom_EventScript_CheckReceivedMon {
	if (var(VAR_RESULT) == CANT_GIVE_MON) {
		textcolor(NPC_TEXT_COLOR_NEUTRAL)
		msgbox(gText_NoMoreRoomForPokemon)
		hidecoinsbox(0, 0)
		release_end
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	removecoins(VAR_EXCHANGE_PRICE)
    updatecoinsbox(0, 5)
    bufferspeciesname(STR_VAR_1, VAR_TEMP_TRANSFERRED_SPECIES)
    playfanfare(MUS_LEVEL_UP)
    message(gText_PlayerObtainedTheMon)
    waitmessage
    waitfanfare
    msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == YES) {
				getpartysize
				subvar(VAR_RESULT, 1)
				copyvar(VAR_0x8004, VAR_RESULT)
				call(Common_EventScript_NameReceivedPartyMon)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == YES) {
				call(Common_EventScript_NameReceivedBoxMon)
			}
			call(Common_EventScript_TransferredToPC)
	}
	goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_NeedCoinCase {
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_CoinCaseRequired)
    release_end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_NotEnoughCoins {
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_NeedMoreCoins)
    goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_PrizeClerkTMs {
    lock_faceplayer
    if (!flag(FLAG_GOT_COIN_CASE)) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_NeedCoinCase)
    }
    showcoinsbox(1, 1)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_WeExchangeCoinsForPrizes)
    message(CeladonCity_GameCorner_PrizeRoom_Text_WhichPrize)
    waitmessage
    multichoice(11, 0, MULTI_GAME_CORNER_TMPRIZES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: 
			setitemandprice(ITEM_TM13, 4000)
			buffermovename(STR_VAR_2, MOVE_ICE_BEAM)
        case 1: 
			setitemandprice(ITEM_TM23, 3500)
			buffermovename(STR_VAR_2, MOVE_IRON_TAIL)
        case 2: 
			setitemandprice(ITEM_TM24, 3000)
			buffermovename(STR_VAR_2, MOVE_THUNDERBOLT)
        case 3: 
			setitemandprice(ITEM_TM30, 4500)
			buffermovename(STR_VAR_2, MOVE_SHADOW_BALL)
        case 4: 
			setitemandprice(ITEM_TM35, 4000)
			buffermovename(STR_VAR_2, MOVE_FLAMETHROWER)
        case 5:
        case MULTI_B_PRESSED: 
			goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
	msgbox(CeladonCity_GameCorner_PrizeRoom_Text_YouWantTM, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
    goto(CeladonCity_GameCorner_PrizeRoom_EventScript_TryGivePrize)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_TryGivePrize {
    bufferitemname(STR_VAR_1, VAR_GIFT_ITEM)
    if (checkcoins(VAR_RESULT) < VAR_EXCHANGE_PRICE) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_NotEnoughCoins)
	}
    if (checkitemspace(VAR_GIFT_ITEM) == FALSE) {
        textcolor(NPC_TEXT_COLOR_NEUTRAL)
		msgbox(gText_TooBadBagIsFull)
		hidecoinsbox(0, 0)
		release_end
    }
    removecoins(VAR_EXCHANGE_PRICE)
    updatecoinsbox(0, 5)
    giveitem(VAR_GIFT_ITEM)
    goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    end
}

script CeladonCity_GameCorner_PrizeRoom_EventScript_PrizeClerkItems {
    lock_faceplayer
    if (!flag(FLAG_GOT_COIN_CASE)) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_NeedCoinCase)
    }
    showcoinsbox(1, 1)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_WeExchangeCoinsForPrizes)
    message(CeladonCity_GameCorner_PrizeRoom_Text_WhichPrize)
    waitmessage
    multichoice(10, 0, MULTI_GAME_CORNER_BATTLE_ITEM_PRIZES, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: setitemandprice(ITEM_SMOKE_BALL, 800)
        case 1: setitemandprice(ITEM_MIRACLE_SEED, 1000)
        case 2: setitemandprice(ITEM_CHARCOAL, 1000)
        case 3: setitemandprice(ITEM_MYSTIC_WATER, 1000)
        case 4: setitemandprice(ITEM_YELLOW_FLUTE, 1600)
        case 5:
        case MULTI_B_PRESSED: 
			goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
	bufferitemname(STR_VAR_1, VAR_GIFT_ITEM)
    msgbox(CeladonCity_GameCorner_PrizeRoom_Text_YouWantPrize, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(CeladonCity_GameCorner_PrizeRoom_EventScript_EndPrizeExchange)
    }
    goto(CeladonCity_GameCorner_PrizeRoom_EventScript_TryGivePrize)
    end
}

