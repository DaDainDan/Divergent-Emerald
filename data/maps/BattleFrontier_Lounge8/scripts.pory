mapscripts BattleFrontier_Lounge8_MapScripts {}

script BattleFrontier_Lounge8_EventScript_Man {
    msgbox(BattleFrontier_Lounge8_Text_WhatATrainerNeeds, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge8_EventScript_Woman {
    msgbox(BattleFrontier_Lounge8_Text_KnowAboutFrontierBrains, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge8_EventScript_NinjaBoy {
    msgbox(BattleFrontier_Lounge8_Text_ToldMeIHaveTalentForBattling, MSGBOX_NPC)
    end
}

text BattleFrontier_Lounge8_Text_WhatATrainerNeeds {
	"What a TRAINER needs…

	Knowledge…
	Strategy…
	Luck…
	Guts…
	Spirit…
	Bravery…
	And ability…

	Well, I'm all set in every way!
	I'll be unstoppable at every building!

	Huh? POKéMON?
	What's that?"
}

text BattleFrontier_Lounge8_Text_KnowAboutFrontierBrains {
	"Do you know about the FRONTIER
	BRAINS?

	That's what SCOTT calls the seven
	special TRAINERS that run the seven
	facilities in the BATTLE FRONTIER."
}

text BattleFrontier_Lounge8_Text_ToldMeIHaveTalentForBattling {
	"At the BATTLE TOWER, an older girl
	told me that I have a lot of talent
	for battling!

	I like POKéMON CONTESTS more!

	But I'm no good at CONTESTS!

	I guess having talent and liking
	something aren't the same."
}
