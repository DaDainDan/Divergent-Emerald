const BET_AMOUNT_5 = 5
const BET_AMOUNT_10 = 10
const BET_AMOUNT_15 = 15

mapscripts BattleFrontier_Lounge3_MapScripts {}

script BattleFrontier_Lounge3_EventScript_Gambler {
    lock_faceplayer
    if (flag(FLAG_MET_BATTLE_FRONTIER_GAMBLER)) {
        msgbox(BattleFrontier_Lounge3_Text_Oh, MSGBOX_DEFAULT)
		if (var(VAR_FRONTIER_GAMBLER_STATE) >= FRONTIER_GAMBLER_PLACED_BET) {
			goto(BattleFrontier_Lounge3_EventScript_CheckBetResults)
		}
		goto(BattleFrontier_Lounge3_EventScript_AskToEnterChallenge)
		end
    }
    call(BattleFrontier_Lounge3_EventScript_CountSilverSymbols)
    if (var(VAR_0x8004) <= 2) {
        msgbox(BattleFrontier_Lounge3_Text_CantYouSeeWereBusyHere, MSGBOX_DEFAULT)
    	goto(Common_EventScript_FaceOriginalDirection)
    	end
    }
    setflag(FLAG_MET_BATTLE_FRONTIER_GAMBLER)
    msgbox(BattleFrontier_Lounge3_Text_YouLookToughExplainGambling, MSGBOX_DEFAULT)
    goto(BattleFrontier_Lounge3_EventScript_AskToEnterChallenge)
    end
}

script BattleFrontier_Lounge3_EventScript_AskToEnterChallenge {
    special(ShowFrontierGamblerLookingMessage)
    waitmessage
    waitbuttonpress
    msgbox(BattleFrontier_Lounge3_Text_HowAboutEnteringEventForMe, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(BattleFrontier_Lounge3_EventScript_DeclineChallenge)
    }
    msgbox(BattleFrontier_Lounge3_Text_SpotMeSomeBattlePoints, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(BattleFrontier_Lounge3_EventScript_DeclineChallenge)
    }
    message(BattleFrontier_Lounge3_Text_HowMuchCanYouSpot)
    waitmessage
    special(ShowBattlePointsWindow)
    goto(BattleFrontier_Lounge3_EventScript_ChooseBetAmount)
    end
}

script BattleFrontier_Lounge3_EventScript_ChooseBetAmount {
    multichoice(20, 4, MULTI_FRONTIER_GAMBLER_BET, FALSE)
    copyvar(VAR_FRONTIER_GAMBLER_AMOUNT_BET, VAR_RESULT)
    switch (var(VAR_RESULT)) {
        case FRONTIER_GAMBLER_BET_5: setvar(VAR_0x8008, BET_AMOUNT_5)
        case FRONTIER_GAMBLER_BET_10: setvar(VAR_0x8008, BET_AMOUNT_10)
        case FRONTIER_GAMBLER_BET_15: setvar(VAR_0x8008, BET_AMOUNT_15)
        case FRONTIER_GAMBLER_BET_CANCEL:
        case MULTI_B_PRESSED:
			special(CloseBattlePointsWindow)
			goto(BattleFrontier_Lounge3_EventScript_DeclineChallenge)
			end
    }
	goto(BattleFrontier_Lounge3_EventScript_TryPlaceBet)
    end
}

script BattleFrontier_Lounge3_EventScript_TryPlaceBet {
    if (specialvar(VAR_TEMP_1, GetFrontierBattlePoints) >= VAR_0x8008) {
		goto(BattleFrontier_Lounge3_EventScript_PlaceBet)
	}
    msgbox(BattleFrontier_Lounge3_Text_YouDontHaveEnoughPoints, MSGBOX_DEFAULT)
    message(BattleFrontier_Lounge3_Text_HowMuchCanYouSpot)
    waitmessage
    goto(BattleFrontier_Lounge3_EventScript_ChooseBetAmount)
    end
}

script BattleFrontier_Lounge3_EventScript_PlaceBet {
    copyvar(VAR_0x8004, VAR_0x8008)
    special(TakeFrontierBattlePoints)
    setvar(VAR_FRONTIER_GAMBLER_STATE, FRONTIER_GAMBLER_PLACED_BET)
    special(UpdateBattlePointsWindow)
    playse(SE_SHOP)
    msgbox(BattleFrontier_Lounge3_Text_ThanksOffYouGo, MSGBOX_DEFAULT)
    special(ShowFrontierGamblerGoMessage)
    waitmessage
    waitbuttonpress
    special(CloseBattlePointsWindow)
    release_end
}

script BattleFrontier_Lounge3_EventScript_CountSilverSymbols {
    setvar(VAR_0x8004, 0)
    if (flag(FLAG_SYS_TOWER_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_DOME_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_PALACE_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_ARENA_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_FACTORY_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_PIKE_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    if (flag(FLAG_SYS_PYRAMID_SILVER)) {
        addvar(VAR_0x8004, 1)
    }
    return
}

script BattleFrontier_Lounge3_EventScript_AlreadyMetGambler {
    msgbox(BattleFrontier_Lounge3_Text_Oh, MSGBOX_DEFAULT)
    if (var(VAR_FRONTIER_GAMBLER_STATE) >= FRONTIER_GAMBLER_PLACED_BET) {
        goto(BattleFrontier_Lounge3_EventScript_CheckBetResults)
    }
    goto(BattleFrontier_Lounge3_EventScript_AskToEnterChallenge)
    end
}

script BattleFrontier_Lounge3_EventScript_CheckBetResults {
    if (var(VAR_FRONTIER_GAMBLER_STATE) == FRONTIER_GAMBLER_PLACED_BET) {
        special(ShowFrontierGamblerGoMessage)
    	waitmessage
    	waitbuttonpress
    	release_end
    }
    if (var(VAR_FRONTIER_GAMBLER_STATE) == FRONTIER_GAMBLER_WON) {
        goto(BattleFrontier_Lounge3_EventScript_WonChallenge)
    }
    msgbox(BattleFrontier_Lounge3_Text_NiceTryCantReturnPoints, MSGBOX_DEFAULT)
    setvar(VAR_FRONTIER_GAMBLER_STATE, FRONTIER_GAMBLER_WAITING)
    release_end
}

script BattleFrontier_Lounge3_EventScript_WonChallenge {
    msgbox(BattleFrontier_Lounge3_Text_HelloChampHeresYourPoints, MSGBOX_DEFAULT)
    if (var(VAR_FRONTIER_GAMBLER_AMOUNT_BET) == FRONTIER_GAMBLER_BET_5) {
        buffernumberstring(STR_VAR_1, (BET_AMOUNT_5 * 2))
    	setvar(VAR_0x8004, (BET_AMOUNT_5 * 2))
    }
    if (var(VAR_FRONTIER_GAMBLER_AMOUNT_BET) == FRONTIER_GAMBLER_BET_10) {
        buffernumberstring(STR_VAR_1, (BET_AMOUNT_10 * 2))
    	setvar(VAR_0x8004, (BET_AMOUNT_10 * 2))
    }
    if (var(VAR_FRONTIER_GAMBLER_AMOUNT_BET) == FRONTIER_GAMBLER_BET_15) {
        buffernumberstring(STR_VAR_1, (BET_AMOUNT_15 * 2))
    	setvar(VAR_0x8004, (BET_AMOUNT_15 * 2))
    }
    msgbox(BattleFrontier_Lounge3_Text_ObtainedBattlePoints, MSGBOX_GETPOINTS)
    special(GiveFrontierBattlePoints)
    msgbox(BattleFrontier_Lounge3_Text_ThinkOfMeForAnotherChallenge, MSGBOX_DEFAULT)
    setvar(VAR_FRONTIER_GAMBLER_STATE, FRONTIER_GAMBLER_WAITING)
    release_end
}

script BattleFrontier_Lounge3_EventScript_DeclineChallenge {
    msgbox(BattleFrontier_Lounge3_Text_NotInterested, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge3_EventScript_Man {
    msgbox(BattleFrontier_Lounge3_Text_ShouldBeTakingChallenges, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge3_EventScript_Woman {
    lock_faceplayer
    msgbox(BattleFrontier_Lounge3_Text_BackedWrongTrainer, MSGBOX_DEFAULT)
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

script BattleFrontier_Lounge3_EventScript_PokefanF {
    lock_faceplayer
    msgbox(BattleFrontier_Lounge3_Text_KnowWinnerWhenISeeOne, MSGBOX_DEFAULT)
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

script BattleFrontier_Lounge3_EventScript_FatMan {
    lock_faceplayer
    msgbox(BattleFrontier_Lounge3_Text_TrainerGoodButRattled, MSGBOX_DEFAULT)
    goto(Common_EventScript_FaceOriginalDirection)
    end
}

text BattleFrontier_Lounge3_Text_CantYouSeeWereBusyHere {
	"…What's that you want?

	Can't you see we're kind of busy here?
	Can't your business wait till later?"
}

text BattleFrontier_Lounge3_Text_YouLookToughExplainGambling {
	"…Huh?
	You look to me like a tough TRAINER.

	Heheh…
	Listen, I have this proposition.

	We have a little group going here,
	and we play a little game with what
	goes on in the BATTLE FRONTIER.

	The rules are really simple.

	First, we pick one of the facilities
	in the BATTLE FRONTIER.

	Then, we each pick a different TRAINER
	who's taking that facility's challenge,
	and bet with our Battle Points.

	The guy who bet on the TRAINER with
	the best record takes all the Battle
	Points in the pool.

	Sounds simple, huh?
	So, anyway…"
}

text BattleFrontier_Lounge3_Text_ChallengeBattleTowerSingle {
	"What I'm looking for is a TRAINER who's
	going to be challenging the BATTLE
	TOWER's SINGLE BATTLE ROOMS.

	But so far, I haven't seen a TRAINER
	that has that winning quality."
}

