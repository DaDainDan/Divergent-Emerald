text BattleFrontier_Lounge3_Text_NiceTryCantReturnPoints {
	"Oh, it's you…
	Nice try…

	I hate to break it to you, but I can't
	return your Battle Points…

	I guess we'll have to let it motivate
	us to try harder next time!"
}

text BattleFrontier_Lounge3_Text_HelloChampHeresYourPoints {
	"Oh, yes!
	Hello there, champ!

	I knew you could!
	I knew you would!
	We're both big winners!

	I'll return your Battle Points and,
	of course, a little extra from me!"
}

text BattleFrontier_Lounge3_Text_ObtainedBattlePoints {
	"{PLAYER} obtained
	{STR_VAR_1} Battle Points."
}

text BattleFrontier_Lounge3_Text_ThinkOfMeForAnotherChallenge {
	"If you're up for another challenge,
	please do think of me!"
}

text BattleFrontier_Lounge3_Text_NotInterested {
	"Not interested?! You shouldn't be
	so afraid to take a chance!"
}

text BattleFrontier_Lounge3_Text_Oh {
	"Oh…"
}

text BattleFrontier_Lounge3_Text_BackedWrongTrainer {
	"I backed the wrong TRAINER again!

	Maybe I should be battling normally
	like everyone else…"
}

text BattleFrontier_Lounge3_Text_TrainerGoodButRattled {
	"That TRAINER…

	He's good, but he gets rattled too
	easily to survive the BATTLE DOME…"
}

text BattleFrontier_Lounge3_Text_KnowWinnerWhenISeeOne {
	"Giggle!
	I know a winner when I see one!"
}

text BattleFrontier_Lounge3_Text_ShouldBeTakingChallenges {
	"Those TRAINERS…
	What are they doing?
	They should be taking challenges."
}
