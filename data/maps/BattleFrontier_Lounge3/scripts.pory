text BattleFrontier_Lounge3_Text_HowAboutEnteringEventForMe {
	"I'll see to it that you benefit, too.
	So how about it?
	How about entering that event for me?"
}

text BattleFrontier_Lounge3_Text_SpotMeSomeBattlePoints {
	"All right, that's perfect.
	So, uh… How about spotting me some
	of your Battle Points?

	Trust me, I'll show you my gratitude
	afterward."
}

text BattleFrontier_Lounge3_Text_HowMuchCanYouSpot {
	"Great, great!
	So, how much can you spot me?"
}

text BattleFrontier_Lounge3_Text_YouDontHaveEnoughPoints {
	"Oh, no, no, no!
	You don't have enough Battle Points!

	I wish you wouldn't monkey around and
	waste everyone's time!"
}

text BattleFrontier_Lounge3_Text_ThanksOffYouGo {
	"Heheh! Thanks much!
	So, off you go!"
}

text BattleFrontier_Lounge3_Text_GetToBattleTowerSingle {
	"Get to the BATTLE TOWER's
	SINGLE BATTLE ROOMS pronto!

	It's a must-win situation!
	Don't blow your chance!
	Both of our futures depend on you!"
}

