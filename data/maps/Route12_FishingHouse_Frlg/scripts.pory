mapscripts Route12_FishingHouse_Frlg_MapScripts {}

script Route12_FishingHouse_EventScript_FishingGuruBrother {
    lock_faceplayer
    if (flag(FLAG_GOT_SUPER_ROD)) {
        goto(Route12_FishingHouse_EventScript_CheckMagikarpRecord)
    }
    msgbox(Route12_FishingHouse_Text_DoYouLikeToFish, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
		msgbox(Route12_FishingHouse_Text_OhThatsDisappointing)
    }
	elif (checkitemspace(ITEM_SUPER_ROD) == FALSE) {
        msgbox(Route12_FishingHouse_Text_NoRoomForGift)
    }
	else {
		additem(ITEM_SUPER_ROD)
		msgbox(Route12_FishingHouse_Text_TakeThisAndFish)
		msgreceiveditem(Route12_FishingHouse_Text_ReceivedSuperRod, ITEM_SUPER_ROD)
		setflag(FLAG_GOT_SUPER_ROD)
		msgbox(Route12_FishingHouse_Text_IfYouCatchBigMagikarpShowMe)
	}
    release_end
}

script Route12_FishingHouse_EventScript_CheckMagikarpRecord {
    setvar(VAR_0x8004, SPECIES_MAGIKARP)
    if (specialvar(VAR_RESULT, DoesPlayerPartyContainSpecies) == FALSE) {
        msgbox(Route12_FishingHouse_Text_TryFishingBringMeMagikarp)
    	release_end
    }
    special(GetMagikarpSizeRecordInfo)
    msgbox(Route12_FishingHouse_Text_OhMagikarpAllowMeToSee)
    special(ChoosePartyMon)
    copyvar(VAR_RESULT, VAR_0x8004)
    if (var(VAR_RESULT) < PARTY_SIZE) {
        special(CompareMagikarpSize)
		if (var(VAR_RESULT) == 1) {
			msgbox(Route12_FishingHouse_Text_DoesntLookLikeMagikarp)
		}
		elif ((var(VAR_RESULT) == 2 || var(VAR_RESULT) == 4) && flag(FLAG_GOT_RECORD_SETTING_MAGIKARP)) {
			switch (var(VAR_RESULT)) {
				case 2: msgbox(Route12_FishingHouse_Text_HmmXInchesDoesntMeasureUp)
				case 4: msgbox(Route12_FishingHouse_Text_HuhXInchesSameSizeAsLast)
			}
		}
		else {
			setflag(FLAG_GOT_RECORD_SETTING_MAGIKARP)
			msgbox(Route12_FishingHouse_Text_WhoaXInchesTakeThis)
			if (giveitem(ITEM_NET_BALL) == FALSE) {
				msgbox(Route12_FishingHouse_Text_NoRoomForGift)
    			release_end
			}
			msgbox(Route12_FishingHouse_Text_LookForwardToGreaterRecords)
		}
    }
    release_end
}

script Route12_FishingHouse_EventScript_MagikarpRecordSign {
    lockall
    if (flag(FLAG_GOT_RECORD_SETTING_MAGIKARP)) {
        special(GetMagikarpSizeRecordInfo)
    	msgbox(Route12_FishingHouse_Text_MostGiganticMagikarpXInches)
    } else {
		msgbox(Route12_FishingHouse_Text_BlankChartOfSomeSort)
	}
    releaseall
    end
}

text Route12_FishingHouse_Text_DoYouLikeToFish {
	"I'm the FISHING GURU's younger
	brother.

	I simply looove fishing!
	I can't bear to go without.

	Tell me, do you like to fish?"
}

text Route12_FishingHouse_Text_TakeThisAndFish {
	"Grand! I like your style.
	I think we can be friends.

	Take this and fish, young friend!"
}

text Route12_FishingHouse_Text_ReceivedSuperRod {
	"{PLAYER} received a SUPER ROD from
	the FISHING GURU's brother."
}

text Route12_FishingHouse_Text_IfYouCatchBigMagikarpShowMe {
	"Fishing is a way of life!
	It is like the finest poetry.

	From the seas to rivers, go out
	and land the big one, my friend.

	Now, I have a request.

	If you catch a big MAGIKARP 
	with that ROD, I want to see it.

	As much as I love to fish, I also
	love seeing gigantic MAGIKARP."
}

text Route12_FishingHouse_Text_OhThatsDisappointing {
	"Oh…
	That's so disappointing…"
}

text Route12_FishingHouse_Text_TryFishingBringMeMagikarp {
	"Hello there, {PLAYER}!
	Have you been fishing?

	Try fishing with the SUPER ROD in
	any body of water.

	You'll find different POKéMON in
	different places.

	Oh, and don't forget to bring me
	gigantic MAGIKARP."
}

text Route12_FishingHouse_Text_OhMagikarpAllowMeToSee {
	"Oh? {PLAYER}?
	Why, if it isn't a MAGIKARP!

	Allow me to see it, quick!"
}

text Route12_FishingHouse_Text_WhoaXInchesTakeThis {
	"… … …Whoa!
	{STR_VAR_2} inches!

	You have a rare appreciation for
	the fine, poetic aspects of fishing!

	You must take this.
	I insist!"
}

text Route12_FishingHouse_Text_LookForwardToGreaterRecords {
	"I'll look forward to seeing greater
	records from you!"
}

text Route12_FishingHouse_Text_HuhXInchesSameSizeAsLast {
	"Huh?
	{STR_VAR_2} inches?

	This is the same size as the one
	I saw before."
}

text Route12_FishingHouse_Text_HmmXInchesDoesntMeasureUp {
	"Hmm…
	This one is {STR_VAR_2} inches long.

	It doesn't measure up to the
	{STR_VAR_3}-inch one you brought before."
}

text Route12_FishingHouse_Text_DoesntLookLikeMagikarp {
	"Uh… That doesn't look much like
	a MAGIKARP."
}

text Route12_FishingHouse_Text_NoRoomForGift {
	"Oh, no!

	I had a gift for you, but you have
	no room for it."
}

text Route12_FishingHouse_Text_MostGiganticMagikarpXInches {
	"The most gigantic MAGIKARP
	I have ever witnessed…

	{STR_VAR_3} inches!"
}

text Route12_FishingHouse_Text_BlankChartOfSomeSort {
	"It's a blank chart of some sort.

	It has spaces for writing in
	records of some kind."
}
