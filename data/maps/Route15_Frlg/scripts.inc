	.string "West to FUCHSIA CITY$"

Route15_Text_MyaIntro::
# 165 "data/maps/Route15_Frlg/scripts.pory"
	.string "MYA: You're perfect.\n"
	.string "Help me train my little brother?$"

Route15_Text_MyaDefeat::
