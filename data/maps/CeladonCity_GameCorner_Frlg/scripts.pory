text CeladonCity_GameCorner_Text_CanExchangeCoinsNextDoor {
	"Welcome!

	You can exchange your COINS for
	fabulous prizes next door."
}

text CeladonCity_GameCorner_Text_WelcomeBuySomeCoins {
	"Welcome to ROCKET GAME CORNER!

	Do you need some game COINS?
	Would you like to buy some?"
}

text CeladonCity_GameCorner_Text_ComePlaySometime {
	"No?
	Please come play sometime!"
}

text CeladonCity_GameCorner_Text_SorryDontHaveCoinCase {
	"Oh, I'm sorry.
	You don't have a COIN CASE."
}

text CeladonCity_GameCorner_Text_CoinCaseIsFull {
	"Whoops!
	Your COIN CASE is full."
}

text CeladonCity_GameCorner_Text_CantAffordCoins {
	"You can't afford the COINS."
}

text CeladonCity_GameCorner_Text_HereAreYourCoins {
	"Thank you.
	Here are your COINS!"
}

text CeladonCity_GameCorner_Text_RumoredTeamRocketRunsThisPlace {
	"Keep this quiet.

	It's rumored that this place is run
	by TEAM ROCKET."
}

text CeladonCity_GameCorner_Text_ThinkMachinesHaveDifferentOdds {
	"I think these machines have
	different odds."
}

text CeladonCity_GameCorner_Text_DoYouWantToPlay {
	"Kid, do you want to play?"
}

text CeladonCity_GameCorner_Text_Received10CoinsFromMan {
	"{PLAYER} received 10 COINS
	from the man."
}

text CeladonCity_GameCorner_Text_DontNeedMyCoins {
	"You don't need my COINS!"
}

text CeladonCity_GameCorner_Text_WinsComeAndGo {
	"Wins seem to come and go.
	Nothing's a sure thing."
}

text CeladonCity_GameCorner_Text_WinOrLoseItsOnlyLuck {
	"These slot games…
	Win or lose, it's only by luck."
}

text CeladonCity_GameCorner_Text_GymGuyAdvice {
	"Hey!

	You have better things to do,
	champ in the making!

	CELADON GYM's LEADER is ERIKA.

	She is a user of GRASS-type
	POKéMON, and at one with nature.

	She might appear docile because of
	her flower arranging…

	But she's not one to be taken
	lightly!"
}

text CeladonCity_GameCorner_Text_RareMonsForCoins {
	"They offer rare POKéMON that can
	be exchanged for your COINS.

	But, I just can't seem to win!"
}

text CeladonCity_GameCorner_Text_SoEasyToGetHooked {
	"Games are scary!
	It's so easy to get hooked!"
}

text CeladonCity_GameCorner_Text_WantSomeCoins {
	"What's up?
	Want some COINS?"
}

text CeladonCity_GameCorner_Text_Received20CoinsFromNiceGuy {
	"{PLAYER} received 20 COINS
	from the nice guy."
}

text CeladonCity_GameCorner_Text_YouHaveLotsOfCoins {
	"You have lots of COINS!"
}

text CeladonCity_GameCorner_Text_NeedMoreCoinsForMonIWant {
	"Darn! I need more COINS for the
	POKéMON I want!"
}

text CeladonCity_GameCorner_Text_HereAreSomeCoinsShoo {
	"Hey, what? You're throwing me off!
	Here are some COINS, so shoo!"
}

text CeladonCity_GameCorner_Text_Received20CoinsFromMan {
	"{PLAYER} received 20 COINS
	from the man."
}

text CeladonCity_GameCorner_Text_YouveGotPlentyCoins {
	"You've got plenty of your own
	COINS!"
}

text CeladonCity_GameCorner_Text_WatchReelsClosely {
	"The trick is to watch the reels
	closely."
}

text CeladonCity_GameCorner_Text_GruntIntro {
	"I'm guarding this poster!
	Go away, or else!"
}

text CeladonCity_GameCorner_Text_GruntDefeat {
	"Dang!"
}

text CeladonCity_GameCorner_Text_GruntPostBattle {
	"The TEAM ROCKET HIDEOUT might
	be discovered!

	I better tell BOSS!"
}

text CeladonCity_GameCorner_Text_SwitchBehindPosterPushIt {
	"Hey!

	A switch behind the poster!?
	Let's push it!"
}

text CeladonCity_GameCorner_Text_CoinCaseIsRequired {
	"A COIN CASE is required…"
}

text CeladonCity_GameCorner_Text_DontHaveCoinCase {
	"Oops!
	Don't have the COIN CASE!"
}

text CeladonCity_GameCorner_Text_SlotMachineWantToPlay {
	"A slot machine!
	Want to play?"
}

text CeladonCity_GameCorner_Text_OutOfOrder {
	"OUT OF ORDER
	This is broken."
}

text CeladonCity_GameCorner_Text_OutToLunch {
	"OUT TO LUNCH
	This is reserved."
}

text CeladonCity_GameCorner_Text_SomeonesKeys {
	"Someone's keys!
	They'll be back."
}
