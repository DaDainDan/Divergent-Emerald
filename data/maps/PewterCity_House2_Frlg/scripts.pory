mapscripts PewterCity_House2_Frlg_MapScripts {}

script PewterCity_House2_EventScript_OldMan {
    msgbox(PewterCity_House2_Text_MonsLearnTechniquesAsTheyGrow, MSGBOX_NPC)
    end
}

script PewterCity_House2_EventScript_LittleBoy {
    msgbox(PewterCity_House2_Text_MonsEasierCatchIfStatused, MSGBOX_NPC)
    end
}

text PewterCity_House2_Text_MonsLearnTechniquesAsTheyGrow {
	"POKéMON learn new techniques as
	they grow.

	But some moves must be taught to
	them by people."
}

text PewterCity_House2_Text_MonsEasierCatchIfStatused {
	"A POKéMON becomes easier to 
	catch if it has a status problem.

	Sleep, poison, burn, or paralysis…
	Those are all effective.

	But catching POKéMON is never
	a sure thing!"
}
