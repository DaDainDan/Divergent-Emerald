mapscripts BattleFrontier_BattlePalaceCorridor_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_TEMP_0, 0: BattleFrontier_BattlePalaceCorridor_EventScript_WalkThroughCorridor
    ]
}

script BattleFrontier_BattlePalaceCorridor_EventScript_WalkThroughCorridor {
    delay(16)
    applymovement(LOCALID_PALACE_CORRIDOR_ATTENDANT, moves(walk_up * 4))
    applymovement(LOCALID_PLAYER, moves(walk_up * 4))
    waitmovement(0)
    lockall
    palace_getcomment
	switch (var(VAR_RESULT)) {
		case 0: msgbox(BattleFrontier_BattlePalaceCorridor_Text_PeopleAndMonAreSame, MSGBOX_DEFAULT)
		case 1: msgbox(BattleFrontier_BattlePalaceCorridor_Text_LetMonDoWhatItLikes, MSGBOX_DEFAULT)
		case 2: msgbox(BattleFrontier_BattlePalaceCorridor_Text_MonDifferentWhenCornered, MSGBOX_DEFAULT)
		case 3: msgbox(BattleFrontier_BattlePalaceCorridor_Text_BeginningToUnderstandNature, MSGBOX_DEFAULT)
		case 4: msgbox(BattleFrontier_BattlePalaceCorridor_Text_HeartfeltBondBetweenYouAndMons, MSGBOX_DEFAULT)
	}
    closemessage
    frontier_get(FRONTIER_DATA_LVL_MODE)
	switch (var(VAR_RESULT)) {
		case FRONTIER_LVL_OPEN:
			applymovement(LOCALID_PALACE_CORRIDOR_ATTENDANT, moves(walk_up,  walk_right * 2,  walk_up * 3))
			applymovement(LOCALID_PLAYER, moves(walk_up * 2,  walk_right * 2,  walk_up * 2))
			waitmovement(0)
			opendoor(10, 3)
		default:
			applymovement(LOCALID_PALACE_CORRIDOR_ATTENDANT, moves(walk_up * 2,  walk_left * 2,  walk_up * 2))
			applymovement(LOCALID_PLAYER, moves(walk_up * 3,  walk_left * 2,  walk_up))
			waitmovement(0)
			opendoor(6, 3)
	}
	waitdooranim
	applymovement(LOCALID_PALACE_CORRIDOR_ATTENDANT, moves(walk_up,  set_invisible))
	applymovement(LOCALID_PLAYER, Common_Movement_WalkUp)
	waitmovement(0)
	switch (var(VAR_RESULT)) {
		case FRONTIER_LVL_OPEN: closedoor(10, 3)
		default: closedoor(6, 3)
	}
    waitdooranim
    warp(MAP_BATTLE_FRONTIER_BATTLE_PALACE_BATTLE_ROOM, 7, 4)
    waitstate
    end
}

text BattleFrontier_BattlePalaceCorridor_Text_PeopleAndMonAreSame {
	"People and POKéMON, they are but
	the same…

	Their individual nature makes them
	good at certain things, and not good
	at others."
}

text BattleFrontier_BattlePalaceCorridor_Text_LetMonDoWhatItLikes {
	"Rather than trying to make a POKéMON
	do what it dislikes, try to let it do
	what it likes and is good at doing.

	Put yourself in the POKéMON's position
	and consider what moves it would like."
}

text BattleFrontier_BattlePalaceCorridor_Text_MonDifferentWhenCornered {
	"A POKéMON's nature is a remarkable
	thing…

	Some POKéMON behave in a completely
	different way when they are cornered."
}

text BattleFrontier_BattlePalaceCorridor_Text_BeginningToUnderstandNature {
	"Are you beginning to understand how
	a POKéMON's nature makes it behave?"
}

text BattleFrontier_BattlePalaceCorridor_Text_HeartfeltBondBetweenYouAndMons {
	"Ah… I see a strong, heartfelt bond
	between you and your POKéMON…"
}
