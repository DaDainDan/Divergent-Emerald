mapscripts PetalburgCity_Gym_MapScripts {
	// NOTE: Strength and OHKO rooms are misleading. Both are more accurately Critical-Hit
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_PETALBURG_GYM_STATE) == 6) {
			setvar(VAR_0x8005, 1)
			call(PetalburgCity_Gym_EventScript_OpenGymEntranceDoors)
			if (defeated(TRAINER_RANDALL)) {
				call(PetalburgCity_Gym_EventScript_OpenSpeedRoomDoors)
			}
			if (defeated(TRAINER_MARY)) {
				call(PetalburgCity_Gym_EventScript_OpenAccuracyRoomDoors)
			}
			if (defeated(TRAINER_PARKER)) {
				call(PetalburgCity_Gym_EventScript_OpenConfusionRoomDoors)
			}
			if (defeated(TRAINER_ALEXIA)) {
				call(PetalburgCity_Gym_EventScript_OpenDefenseRoomDoors)
			}
			if (defeated(TRAINER_GEORGE)) {
				call(PetalburgCity_Gym_EventScript_OpenRecoveryRoomDoors)
			}
			if (defeated(TRAINER_JODY)) {
				call(PetalburgCity_Gym_EventScript_OpenStrengthRoomDoors)
			}
			if (defeated(TRAINER_BERKE)) {
				call(PetalburgCity_Gym_EventScript_OpenOHKORoomDoors)
			}
			end
		}
		if (var(VAR_PETALBURG_GYM_STATE) >= 7) {
			call(PetalburgCity_Gym_EventScript_UnlockAllDoors)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_PETALBURG_GYM_STATE) == 1) {
			setobjectxyperm(LOCALID_PETALBURG_GYM_WALLY, 5, 108)
		}
		if (var(VAR_PETALBURG_GYM_STATE) < 6) {
			setobjectxyperm(LOCALID_PETALBURG_GYM_NORMAN, 4, 107)
		}
		if (flag(FLAG_SYS_GAME_CLEAR)) {
			setorcopyvar(VAR_TRAINER_BATTLE_OPPONENT_A, TRAINER_NORMAN_1)
			if (specialvar(VAR_RESULT, IsTrainerReadyForRematch) == TRUE) {
				setvar(VAR_PETALBURG_GYM_STATE, 8)
				end
			}
			if (var(VAR_PETALBURG_GYM_STATE) == 8) {
				setvar(VAR_PETALBURG_GYM_STATE, 8)
				end
			}
			setobjectxyperm(LOCALID_PETALBURG_GYM_NORMAN, 4, 107)
		}
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_PETALBURG_GYM_STATE, 1 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
    		end
		}
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_PETALBURG_GYM_STATE, 1: PetalburgCity_Gym_EventScript_ReturnFromWallyTutorial
    ]
}

script PetalburgCity_Gym_EventScript_UnlockAllDoors {
    setvar(VAR_0x8005, 1)
    call(PetalburgCity_Gym_EventScript_OpenGymEntranceDoors)
    call(PetalburgCity_Gym_EventScript_OpenSpeedRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenAccuracyRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenConfusionRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenDefenseRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenRecoveryRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenStrengthRoomDoors)
    call(PetalburgCity_Gym_EventScript_OpenOHKORoomDoors)
    return
}

script PetalburgCity_Gym_EventScript_ReturnFromWallyTutorial {
    lockall
    msgbox(PetalburgCity_Gym_Text_DadSoDidItWorkOut, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_WallyThankYouBye, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(walk_down * 3,  delay_16))
    waitmovement(0)
    playse(SE_EXIT)
    removeobject(LOCALID_PETALBURG_GYM_WALLY)
    setflag(FLAG_HIDE_PETALBURG_CITY_WALLY)
    delay(30)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_DadGoCollectBadges, MSGBOX_DEFAULT)
    setvar(VAR_PETALBURG_GYM_STATE, 2)
    releaseall
    end
}

script PetalburgCity_Gym_EventScript_Norman {
    vsseeker_rematchid(TRAINER_NORMAN_1)
    lock_faceplayer
    switch (var(VAR_PETALBURG_GYM_STATE)) {
        case 2:
			msgbox(PetalburgCity_Gym_Text_NormanGoToRustboro, MSGBOX_DEFAULT)
			release_end
        case 3: 
			msgbox(PetalburgCity_Gym_Text_NormanGoToDewford, MSGBOX_DEFAULT)
			release_end
        case 4:
        case 5:
			msgbox(PetalburgCity_Gym_Text_YouHaveGottenStronger, MSGBOX_DEFAULT)
			release_end
        case 6: goto(PetalburgCity_Gym_EventScript_NormanBattle)
        case 7: goto(PetalburgCity_Gym_EventScript_NormanPostBattle)
        case 8: goto(PetalburgCity_Gym_EventScript_NormanRematch)
    }
    msgbox(PetalburgCity_Gym_Text_DadYoureHereWithYourPokemon, MSGBOX_DEFAULT)
    closemessage
    switch (var(VAR_FACING)) {
        case DIR_SOUTH: setvar(VAR_0x8008, 0)
        case DIR_NORTH: setvar(VAR_0x8008, 1)
        case DIR_WEST: setvar(VAR_0x8008, 2)
        case DIR_EAST: setvar(VAR_0x8008, 3)
    }
	goto(PetalburgCity_Gym_EventScript_BeginWallyTutorial)
    end
}

script PetalburgCity_Gym_EventScript_BeginWallyTutorial {
    addobject(LOCALID_PETALBURG_GYM_WALLY)
    playse(SE_DOOR)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
    		applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(delay_16,  walk_up,  delay_16,  delay_8,  walk_up * 2))
		case 1:
			applymovement(LOCALID_PETALBURG_GYM_WALLY, PetalburgCity_Gym_Movement_WallyArriveNorth)
			waitmovement(0)
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterRight)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
		case 2:
		case 3:
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
			applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(delay_16,  walk_up,  delay_16,  delay_8,  walk_up * 2))
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_WallyIdLikeAPokemon, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_DadOhYoureWallyRight, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_WallyIveNeverCaughtAPokemon, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_DadHmISee, MSGBOX_DEFAULT)
	switch (var(VAR_0x8008)) {
		case 0: applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterUp)
		case 1:
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
    		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
		case 2:
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterRight)
    		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
		case 3: 
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterLeft)
    		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_DadPlayerGoWithWally, MSGBOX_DEFAULT)
	if (var(VAR_0x8008) == 1) {
		applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterRight)
	} else {
		applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_IllLoanYouMyZigzagoon, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_WallyThankYouAndDadGivesPokeBall, MSGBOX_DEFAULT)
    msgbox(PetalburgCity_Gym_Text_WallyOhWowThankYou, MSGBOX_DEFAULT)
	if (var(VAR_0x8008) == 1) {
		applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
    	waitmovement(0)
		applymovement(LOCALID_PETALBURG_GYM_WALLY, Common_Movement_StepFasterDown)
	} else {
		applymovement(LOCALID_PETALBURG_GYM_WALLY, Common_Movement_FacePlayer)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_WouldYouReallyComeWithMe, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_DONT_TRANSITION_MUSIC)
    playbgm(MUS_FOLLOW_ME, FALSE)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
    		applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(walk_down * 3,  step_faster_up,  delay_16,  step_down))
    		applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  walk_right,  walk_down * 5,  delay_8))
		case 1:
			applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(walk_down * 4,  step_faster_up,  delay_16,  step_down))
    		applymovement(LOCALID_PLAYER, moves(delay_16 * 3,  walk_down * 3,  delay_8))
		case 2:
			applymovement(LOCALID_PETALBURG_GYM_WALLY, moves(walk_down * 3,  step_faster_up,  delay_16,  step_down))
    		applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  walk_down * 4,  delay_8))
		case 3:
			applymovement(LOCALID_PETALBURG_GYM_WALLY, PetalburgCity_Gym_Movement_WallyExitEast)
    		applymovement(LOCALID_PLAYER, PetalburgCity_Gym_Movement_PlayerExitWithWallyEast)
	}
	waitmovement(0)
    removeobject(LOCALID_PETALBURG_GYM_WALLY)
    setflag(FLAG_HIDE_PETALBURG_CITY_WALLYS_MOM)
    setvar(VAR_PETALBURG_GYM_STATE, 1)
    setvar(VAR_PETALBURG_CITY_STATE, 2)
    clearflag(FLAG_HIDE_PETALBURG_CITY_WALLY)
    clearflag(FLAG_HIDE_PETALBURG_GYM_WALLY)
    setflag(FLAG_HIDE_LITTLEROOT_TOWN_BIRCHS_LAB_RIVAL)
    special(InitBirchState)
    warp(MAP_PETALBURG_CITY, 15, 8)
    waitstate
    release_end
}

movement PetalburgCity_Gym_Movement_WallyArriveNorth {
    // moves(delay_16,  walk_up,  delay_16,  delay_8,  walk_up,  walk_right,  walk_up * 2,  step_faster_left)
    delay_16
    walk_up
    delay_16
    delay_8
    walk_up
    walk_right
    walk_up * 2
    step_faster_left
}

movement PetalburgCity_Gym_Movement_WallyExitEast {
    // moves(walk_down * 2,  walk_right,  walk_down,  step_faster_up,  delay_16,  step_down)
    walk_down * 2
    walk_right
    walk_down
    step_faster_up
    delay_16
    step_down
}

movement PetalburgCity_Gym_Movement_PlayerExitWithWallyEast {
    // moves(step_faster_down,  delay_16 * 2,  walk_down * 3,  walk_right,  walk_down,  delay_8)
    step_faster_down
    delay_16 * 2
    walk_down * 3
    walk_right
    walk_down
    delay_8
}

script PetalburgCity_Gym_EventScript_NormanBattle {
    msgbox(PetalburgCity_Gym_Text_NormanIntro, MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_NORMAN_1, PetalburgCity_Gym_Text_NormanDefeat)
    message(PetalburgCity_Gym_Text_ReceivedBalanceBadge)
    waitmessage
    call(Common_EventScript_PlayGymBadgeFanfare)
    msgbox(PetalburgCity_Gym_Text_ExplainBalanceBadgeTakeThis, MSGBOX_DEFAULT)
    setflag(FLAG_DEFEATED_PETALBURG_GYM)
    setvar(VAR_PETALBURG_GYM_STATE, 7)
    setflag(FLAG_BADGE05_GET)
    special(ResetHealLocationFromDewford)
    call(EventScript_HideMrBriney)
    setflag(FLAG_HIDE_MAUVILLE_GYM_WATTSON)
    clearflag(FLAG_HIDE_MAUVILLE_CITY_WATTSON)
    setvar(VAR_0x8008, 5)
    call(Common_EventScript_SetGymTrainers)
    clearflag(FLAG_HIDE_DEWFORD_HALL_SLUDGE_BOMB_MAN)
    call(PetalburgCity_Gym_EventScript_UnlockAllDoors)
    special(DrawWholeMapView)
    call(PetalburgCity_Gym_EventScript_GiveFacade)
    delay(30)
    msgbox(PetalburgCity_Gym_Text_DadHappyAndSad, MSGBOX_DEFAULT)
    closemessage
    delay(40)
    playse(SE_DOOR)
    delay(10)
    addobject(LOCALID_PETALBURG_GYM_WALLYS_DAD)
    switch (var(VAR_FACING)) {
        case DIR_NORTH: setvar(VAR_0x8008, 1)
		case DIR_EAST: setvar(VAR_0x8008, 2)
        case DIR_WEST: setvar(VAR_0x8008, 3)
    }
	goto(PetalburgCity_Gym_EventScript_WallysDadArrives)
    end
}

script PetalburgCity_Gym_EventScript_GiveFacade {
    if (giveitem(ITEM_TM_FACADE) == FALSE) {
		goto(Common_EventScript_BagIsFull)
	}
    setflag(FLAG_RECEIVED_TM_FACADE)
    msgbox(PetalburgCity_Gym_Text_ExplainFacade, MSGBOX_DEFAULT)
    return
}

script PetalburgCity_Gym_EventScript_WallysDadArrives {
    applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, PetalburgCity_Gym_Movement_WallysDadEnterGym)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, Common_Movement_Delay48)
    waitmovement(0)
    delay(10)
	switch (var(VAR_0x8008)) {
		case 1:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, moves(walk_right * 2,  walk_up * 3,  step_faster_right))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterLeft)
		case 2:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, moves(walk_right * 2,  walk_up * 3))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
		case 3:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, moves(walk_right * 2,  walk_up * 2,  walk_right * 2,  walk_up))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_PleaseComeWithMe, MSGBOX_DEFAULT)
    closemessage
    delay(20)
	switch (var(VAR_0x8008)) {
		case 1: applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, Common_Movement_StepFasterUp)
		case 2: applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, Common_Movement_StepFasterRight)
		case 3: applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, Common_Movement_StepFasterLeft)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Gym_Text_LetMeBorrowPlayer, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_DONT_TRANSITION_MUSIC)
    playbgm(MUS_FOLLOW_ME, FALSE)
	switch (var(VAR_0x8008)) {
		case 1:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, PetalburgCity_Gym_Movement_WallysDadExitNorth)
			applymovement(LOCALID_PETALBURG_GYM_NORMAN, Common_Movement_StepFasterDown)
			applymovement(LOCALID_PLAYER, moves(delay_16,  walk_down * 2,  walk_left * 2,  walk_down * 2))
		case 2:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, PetalburgCity_Gym_Movement_WallysDadExitEast)
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_down * 2,  walk_left,  walk_down * 3))
		case 3:
			applymovement(LOCALID_PETALBURG_GYM_WALLYS_DAD, PetalburgCity_Gym_Movement_WallysDadExitWest)
    		applymovement(LOCALID_PLAYER, moves(delay_16,  walk_down * 3,  walk_left * 3,  walk_down * 2))
	}
	waitmovement(0)
    removeobject(LOCALID_PETALBURG_GYM_WALLYS_DAD)
    setvar(VAR_PETALBURG_CITY_STATE, 4)
    clearflag(FLAG_HIDE_PETALBURG_CITY_WALLYS_DAD)
    warp(MAP_PETALBURG_CITY, 15, 8)
    waitstate
    release_end
}

movement PetalburgCity_Gym_Movement_WallysDadExitNorth {
    // moves(walk_down * 2,  walk_left * 2,  walk_down * 2,  step_faster_up,  delay_8,  step_down,  set_invisible)
    walk_down * 2
    walk_left * 2
    walk_down * 2
    step_faster_up
    delay_8
    step_down
    set_invisible
}

movement PetalburgCity_Gym_Movement_WallysDadExitEast {
    // moves(walk_down * 2,  walk_left * 2,  walk_down * 2,  step_faster_up,  delay_8,  step_down,  set_invisible)
    walk_down * 2
    walk_left * 2
    walk_down * 2
    step_faster_up
    delay_8
    step_down
    set_invisible
}

movement PetalburgCity_Gym_Movement_WallysDadExitWest {
    // moves(walk_down * 2,  walk_left * 4,  walk_down * 2,  step_faster_up,  delay_8,  step_down,  set_invisible)
    walk_down * 2
    walk_left * 4
    walk_down * 2
    step_faster_up
    delay_8
    step_down
    set_invisible
}

movement PetalburgCity_Gym_Movement_WallysDadEnterGym {
    // moves(walk_up,  delay_8,  step_faster_right,  delay_8,  step_faster_left,  delay_16,  step_faster_up)
    walk_up
    delay_8
    step_faster_right
    delay_8
    step_faster_left
    delay_16
    step_faster_up
}

movement PetalburgCity_Gym_Movement_Unused {
    // moves(step_faster_up,  delay_16 * 5,  delay_8,  step_faster_down)
    step_faster_up
    delay_16 * 5
    delay_8
    step_faster_down
}

script PetalburgCity_Gym_EventScript_NormanPostBattle {
    call(PetalburgCity_Gym_EventScript_ShouldGiveEnigmaBerry)
    if (var(VAR_RESULT) == TRUE) {
        if (giveitem(ITEM_ENIGMA_BERRY_E_READER) == FALSE) {
			goto(Common_EventScript_ShowBagIsFull)
		}
		setvar(VAR_ENIGMA_BERRY_AVAILABLE, 0)
		release_end
    }
    if (!flag(FLAG_RECEIVED_TM_FACADE)) {
        call(PetalburgCity_Gym_EventScript_GiveFacade)
    }
    elif (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(PetalburgCity_Gym_Text_DadNoAmountOfTrainingIsEnough, MSGBOX_DEFAULT)
    }
	else {
		msgbox(PetalburgCity_Gym_Text_DadGoingToKeepTraining, MSGBOX_DEFAULT)
	}
    release_end
}

script PetalburgCity_Gym_EventScript_ShouldGiveEnigmaBerry {
    if (specialvar(VAR_RESULT, IsEnigmaBerryValid) == FALSE || checkitem(ITEM_ENIGMA_BERRY_E_READER) == TRUE
     || checkpcitem(ITEM_ENIGMA_BERRY_E_READER) == TRUE || var(VAR_ENIGMA_BERRY_AVAILABLE) == 0) {
		setvar(VAR_RESULT, FALSE)
	} else {
        msgbox(PetalburgCity_Gym_Text_GiveEnigmaBerry, MSGBOX_DEFAULT)
        setvar(VAR_RESULT, TRUE)
    }
    return
}

script PetalburgCity_Gym_EventScript_NormanRematch {
    trainerbattle_rematch_double(TRAINER_NORMAN_1, PetalburgCity_Gym_Text_NormanPreRematch, PetalburgCity_Gym_Text_NormanRematchDefeat, PetalburgCity_Gym_Text_NormanRematchNeedTwoMons)
    msgbox(PetalburgCity_Gym_Text_NormanPostRematch, MSGBOX_AUTOCLOSE)
    end
}

script PetalburgCity_Gym_EventScript_SpeedRoomDoor {
    lockall
    if (var(VAR_PETALBURG_GYM_STATE) < 6) {
        goto(PetalburgCity_Gym_EventScript_DoorLocked)
    }
    setvar(VAR_0x8008, 7)
    setvar(VAR_0x8009, 85)
    msgbox(PetalburgCity_Gym_Text_EnterSpeedRoom, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(PetalburgCity_Gym_EventScript_EnterRoom)
    } else {
        goto(PetalburgCity_Gym_EventScript_DontEnterRoom)
    }
    end
}

script PetalburgCity_Gym_EventScript_EnterRoom {
    closemessage
    delay(30)
    warpdoor(MAP_PETALBURG_CITY_GYM, VAR_0x8008, VAR_0x8009)
    waitstate
    releaseall
    end
}

script PetalburgCity_Gym_EventScript_DontEnterRoom {
    releaseall
    end
}

script PetalburgCity_Gym_EventScript_DoorLocked {
    msgbox(PetalburgCity_Gym_Text_DoorAppearsLocked, MSGBOX_DEFAULT)
    releaseall
    end
}

// VAR_0x8008 and VAR_0x8009 below are the x and y coordinates of the warp
script PetalburgCity_Gym_EventScript_AccuracyRoomDoor {
    lockall
    if (var(VAR_PETALBURG_GYM_STATE) < 6) {
        goto(PetalburgCity_Gym_EventScript_DoorLocked)
    }
    setvar(VAR_0x8008, 1)
    setvar(VAR_0x8009, 98)
    msgbox(PetalburgCity_Gym_Text_EnterAccuracyRoom, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(PetalburgCity_Gym_EventScript_EnterRoom)
    } else {
        goto(PetalburgCity_Gym_EventScript_DontEnterRoom)
    }
    end
}

script PetalburgCity_Gym_EventScript_ConfusionRoomDoor {
    lockall
    if (!defeated(TRAINER_RANDALL)) {
        goto(PetalburgCity_Gym_EventScript_DoorLocked)
    }
    setvar(VAR_0x8008, 7)
    setvar(VAR_0x8009, 46)
    msgbox(PetalburgCity_Gym_Text_EnterConfusionRoom, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(PetalburgCity_Gym_EventScript_EnterRoom)
    } else {
        goto(PetalburgCity_Gym_EventScript_DontEnterRoom)
    }
    end
}

script PetalburgCity_Gym_EventScript_LeftDefenseRoomDoor {
    lockall
    if (!defeated(TRAINER_RANDALL)) {
        goto(PetalburgCity_Gym_EventScript_DoorLocked)
    }
    setvar(VAR_0x8008, 1)
    setvar(VAR_0x8009, 59)
    msgbox(PetalburgCity_Gym_Text_EnterDefenseRoom, MSGBOX_YESNO)
