script PetalburgCity_Gym_EventScript_GymStatue {
    lockall
    if (flag(FLAG_BADGE05_GET)) {
        msgbox(PetalburgCity_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(PetalburgCity_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    return
}

text PetalburgCity_Gym_Text_DadYoureHereWithYourPokemon {
	"DAD: Hm?

	Well, if it isn't {PLAYER}!
	So you're all finished moving in?

	I'm surprised that you managed to
	get here by yourself.

	Oh, I see.
	You're with your POKéMON.

	Hm… Then I guess you're going to
	become a TRAINER like me, {PLAYER}.

	That's great news!
	I'll be looking forward to it!"
}

text PetalburgCity_Gym_Text_WallyIdLikeAPokemon {
	"Um… I…
	I'd like to get a POKéMON, please…"
}

text PetalburgCity_Gym_Text_DadOhYoureWallyRight {
	"DAD: Hm? You're… Uh… Oh, right.
	You're WALLY, right?"
}

text PetalburgCity_Gym_Text_WallyIveNeverCaughtAPokemon {
	"WALLY: I'm going to go stay with my
	relatives in VERDANTURF TOWN.

	I thought I would be lonely by myself,
	so I wanted to take a POKéMON along.

	But I've never caught a POKéMON before.
	I don't know how…"
}

text PetalburgCity_Gym_Text_DadHmISee {
	"DAD: Hm. I see."
}

text PetalburgCity_Gym_Text_DadPlayerGoWithWally {
	"DAD: {PLAYER}, you heard that,
	right?

	Go with WALLY and make sure that he
	safely catches a POKéMON."
}

text PetalburgCity_Gym_Text_IllLoanYouMyZigzagoon {
	"WALLY, here, I'll loan you my POKéMON.

	WALLY received a ZIGZAGOON!"
}

text PetalburgCity_Gym_Text_WallyThankYouAndDadGivesPokeBall {
	"WALLY: Oh, wow!
	A POKéMON!

	DAD: Hm. I'll give you a POKé BALL, too.
	Go for it!

	WALLY received a POKé BALL!"
}

text PetalburgCity_Gym_Text_WallyOhWowThankYou {
	"WALLY: Oh, wow!
	Thank you!"
}

text PetalburgCity_Gym_Text_WouldYouReallyComeWithMe {
	"{PLAYER}… Would you really come
	with me?"
}

text PetalburgCity_Gym_Text_DadSoDidItWorkOut {
	"DAD: So, did it work out?"
}

text PetalburgCity_Gym_Text_WallyThankYouBye {
	"WALLY: Thank you, yes, it did.
	Here's your POKéMON back.

	{PLAYER}, thank you for coming along
	with me.

	You two are why I was able to catch
	my POKéMON.

	I promise I'll take really good
	care of it.

	Oh! My mom's waiting for me,
	so I have to go!

	Bye, {PLAYER}!"
}

text PetalburgCity_Gym_Text_DadGoCollectBadges {
	"DAD: Now…

	{PLAYER}, if you want to become a
	strong TRAINER, here's my advice.

	Head for RUSTBORO CITY beyond this
	town.

	There, you should challenge
	the GYM LEADER, ROXANNE.

	After her, go on to other POKéMON
	GYMS and defeat their LEADERS.

	Collect BADGES from them,
	understood?

	Of course, I'm a GYM LEADER, too.
	We'll battle one day, {PLAYER}.

	But that's only after you become
	stronger."
}

text PetalburgCity_Gym_Text_NormanGoToRustboro {
	"DAD: Hm? Aren't you going to the
	POKéMON GYM in RUSTBORO CITY?

	There's no challenge for me to
	battle a greenhorn TRAINER.

	{PLAYER}, I want you to challenge me
	when you become a lot stronger.

	I'll battle you, {PLAYER}, when you
	can show me four GYM BADGES, okay?"
}

text PetalburgCity_Gym_Text_NormanGoToDewford {
	"DAD: I see… So, you've beaten
	the GYM LEADER in RUSTBORO CITY.

	But there are many more TRAINERS
	who are stronger than you, {PLAYER}.

	Across the sea in DEWFORD TOWN is a
	GYM LEADER named BRAWLY.

	You should go challenge him."
}

text PetalburgCity_Gym_Text_YouHaveGottenStronger {
	"DAD: Hm… {PLAYER}, you have gotten
	stronger.

	I can tell by the number of BADGES
	that you've earned."
}

text PetalburgCity_Gym_Text_NormanIntro {
	"DAD: Hm…
	So, you did get four GYM BADGES.

	Fine, as I promised, we will have
	a POKéMON battle.

	{PLAYER}…

	I'm so happy that I can have
	a real battle with my own child.

	But, a battle is a battle!

	I will do everything in my power as
	a GYM LEADER to win.

	{PLAYER}, you'd better give it your
	best shot, too!"
}

text PetalburgCity_Gym_Text_NormanDefeat {
	"…

	I… I can't…

	I can't believe it. {PLAYER}…

	I lost to {PLAYER}?

	But, rules are rules!
	Here, take this."
}

text PetalburgCity_Gym_Text_ReceivedBalanceBadge {
	"{PLAYER} received the BALANCE BADGE
	from DAD!"
}

text PetalburgCity_Gym_Text_ExplainBalanceBadgeTakeThis {
	"DAD: With that BADGE, the DEFENSE
	of all your POKéMON will increase.

	POKéMON that know the HM move SURF
	will be able to travel over water.

	This is my gift to you. {PLAYER}, I'm
	sure you can use it correctly."
}

text PetalburgCity_Gym_Text_ExplainFacade {
	"DAD: TM42 contains FACADE.

	It doubles the power of moves if
	the POKéMON is poisoned, paralyzed,
	or burned.

	It might be able to turn a bad
	situation into an advantage."
}

text PetalburgCity_Gym_Text_DadHappyAndSad {
	"DAD: As the GYM LEADER, I can't
	express how upset I am…

	But as a father, it makes me both
	happy and a little sad. It's odd…"
}

text PetalburgCity_Gym_Text_PleaseComeWithMe {
	"Ah, there you are, {PLAYER}{KUN}!

	Please come with me.
	I have something I want you to have."
}

text PetalburgCity_Gym_Text_LetMeBorrowPlayer {
	"NORMAN, you don't mind, do you?

	Let me borrow your {PLAYER}{KUN} for
	a minute or two."
}

text PetalburgCity_Gym_Text_DadGoingToKeepTraining {
	"DAD: {PLAYER}, you should go visit
	your mother every so often.

	I'm going to stay here and redouble
	my training.

	It would bother me as a TRAINER to
	not avenge my loss to you, {PLAYER}!"
}

text PetalburgCity_Gym_Text_DadNoAmountOfTrainingIsEnough {
	"DAD: {PLAYER}, how are things going?

	The world of POKéMON is deep.

	I honestly think that no amount of
	training would ever be enough."
}

text PetalburgCity_Gym_Text_GymGuideAdvice {
	"Hey, how's it going, CHAMPION-
	bound {PLAYER}?

	The doors in this GYM open when you
	beat the awaiting TRAINERS.

	Whoops! The doors in this room are
	already open, so don't attack me!

	The TRAINERS of PETALBURG GYM
	use all kinds of items.

	The door at the left leads to
	the SPEED ROOM.

	The door at the right leads to
	the ACCURACY ROOM.

	The room's name will be on
	the door, so choose carefully.

	Once you've chosen the door…
	Well, hey, go for it!"
}

text PetalburgCity_Gym_Text_GymGuidePostVictory {
	"{PLAYER}! Whoa! You've overcome even
	your own father!

	Like, whoa!
	What a stunning turn of events!"
}

text PetalburgCity_Gym_Text_RandallIntro {
	"The ability to attack before the
	opponent…

	Just that alone puts me at a great
	advantage, don't you agree?"
}

text PetalburgCity_Gym_Text_RandallDefeat {
	"That was a magnificent battle!"
}

text PetalburgCity_Gym_Text_RandallPostBattle {
	"Go on to the next room where a new
	challenge awaits you.

	At the left is the CONFUSION ROOM.

	The right door leads to the DEFENSE
	ROOM."
}

text PetalburgCity_Gym_Text_RandallPostBadge {
	"Whomever you beat, and whomever you
	may lose to, you never shirk from
	training yourself and your POKéMON.

	That's what I think being a
	GYM LEADER is all about."
}

text PetalburgCity_Gym_Text_ParkerIntro {
	"This is the CONFUSION ROOM.

	Let me see how well bonded you are
	with your POKéMON!"
}

text PetalburgCity_Gym_Text_ParkerDefeat {
	"I couldn't confuse your team enough…
	You share a strong bond together."
}

text PetalburgCity_Gym_Text_ParkerPostBattle {
	"The next room is the STRENGTH ROOM.
	Can you withstand brute force?"
}

text PetalburgCity_Gym_Text_ParkerPostBadge {
	"After you beat our LEADER, the
	training has become a lot tougher."
}

text PetalburgCity_Gym_Text_GeorgeIntro {
	"Just when you think you're going to
	win, your opponent restores HP…

	Can you just imagine how awful that
	must feel?

	I'll show you exactly how awful it
	feels!"
}

text PetalburgCity_Gym_Text_GeorgeDefeat {
	"I couldn't restore HP enough…
	What ATTACK power…"
}

text PetalburgCity_Gym_Text_GeorgePostBattle {
	"I should have expected no less from
	our LEADER's kid.

	No, wait! A TRAINER's abilities are
	earned only through effort.

	I lost because my own efforts
	weren't enough.

	Go on! The ONE-HIT KO ROOM is next."
}

text PetalburgCity_Gym_Text_GeorgePostBadge {
	"I'm going to keep training at GYMS.
	One day, I'll become a LEADER."
}

text PetalburgCity_Gym_Text_BerkeIntro {
	"I'm not going to take it easy just
	because you're our LEADER's kid.

	I'll show you how horrid it is for
	a POKéMON to take a critical hit!"
}

text PetalburgCity_Gym_Text_BerkeDefeat {
	"Your power…
	You're the real deal."
}

text PetalburgCity_Gym_Text_BerkePostBattle {
	"Your father really is strong.
	He's a TRAINER worth my respect.

	And, I sense the same glow coming
	from you as your father.

	I hope that you'll stage a terrific
	battle with your father!"
}

text PetalburgCity_Gym_Text_BerkePostBadge {
	"Since your dad became the LEADER,
	the TRAINERS of PETALBURG CITY have
	become a lot tougher."
}

text PetalburgCity_Gym_Text_MaryIntro {
	"Giggle…
	This is the ACCURACY ROOM.

	It's pretty nasty when every attack
	lands without fail."
}

text PetalburgCity_Gym_Text_MaryDefeat {
	"You were a cut above me…"
}

text PetalburgCity_Gym_Text_MaryPostBattle {
	"There are some even stronger
	TRAINERS waiting for you.

	The left is the DEFENSE ROOM, and
	the right is the RECOVERY ROOM.

	Your POKéMON's ATTACK power will be
	on trial either way."
}

text PetalburgCity_Gym_Text_MaryPostBadge {
	"Do you know what we're trying to
	achieve as TRAINERS?

	We're striving to become soul mates
	with our POKéMON."
}

text PetalburgCity_Gym_Text_AlexiaIntro {
	"The higher the DEFENSE, the more
	reckless I can be in attack."
}

text PetalburgCity_Gym_Text_AlexiaDefeat {
	"Our defenses weren't enough…"
}

text PetalburgCity_Gym_Text_AlexiaPostBattle {
	"I think you've taught me a valuable
	lesson here.

	Now, go on! The left door goes to
	the STRENGTH ROOM.

	The right door opens to
	the ONE-HIT KO ROOM.

	Both of them have TRAINERS who are
	skilled at offense."
}

text PetalburgCity_Gym_Text_AlexiaPostBadge {
	"Hi! Have you tried using SURF?"
}

text PetalburgCity_Gym_Text_JodyIntro {
	"Our GYM LEADER told us to go all out
	and beat you.

	Even if you happen to be the
	LEADER's kid!"
}

text PetalburgCity_Gym_Text_JodyDefeat {
	"But… I went all out!"
}

text PetalburgCity_Gym_Text_JodyPostBattle {
	"The way you use your POKéMON…
	It's like your father's style.

	Go on through! The GYM LEADER, your
	father, is waiting!"
}

text PetalburgCity_Gym_Text_JodyPostBadge {
	"Sure, it's fine to make your POKéMON
	stronger.

	But what decides the winner?

	Why, it's the feelings TRAINERS have
	for their POKéMON."
}

text PetalburgCity_Gym_Text_DoorAppearsLocked {
	"This door appears to be locked
	right now…"
}

text PetalburgCity_Gym_Text_EnterSpeedRoom {
	"“SPEED ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_DoorAppearsLocked2 {
	"This door appears to be locked
	right now…"
}

text PetalburgCity_Gym_Text_EnterAccuracyRoom {
	"“ACCURACY ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterConfusionRoom {
	"“CONFUSION ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterDefenseRoom {
	"“DEFENSE ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterRecoveryRoom {
	"“RECOVERY ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterStrengthRoom {
	"“STRENGTH ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterOHKORoom {
	"“ONE-HIT KO ROOM,” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_EnterGymLeadersRoom {
	"“GYM LEADER'S ROOM

	“See for yourself what POKéMON await
	you!” the sign says.

	Do you want to go through?"
}

text PetalburgCity_Gym_Text_GymStatue {
	"PETALBURG CITY POKéMON GYM"
}

text PetalburgCity_Gym_Text_GymStatueCertified {
	"PETALBURG CITY POKéMON GYM

	NORMAN'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text PetalburgCity_Gym_Text_NormanPreRematch {
	"DAD: {PLAYER}…
	I had a feeling that you would come.

	I would never refuse to accept
	a challenge from you.

	You do understand, don't you?

	Inside a GYM, it doesn't matter that
	we are a parent and child.

	…No, because we are parent and child,
	we owe it to each other to do the best
	we can. Isn't that right, {PLAYER}?"
}

text PetalburgCity_Gym_Text_NormanRematchDefeat {
	"Uh… Haha…
	Maybe that was going too hard…"
}

text PetalburgCity_Gym_Text_NormanPostRematch {
	"DAD: {PLAYER}…
	What is your dream?

	My dream…
	Hahaha…
	It has already come true, actually."
}

text PetalburgCity_Gym_Text_NormanRematchNeedTwoMons {
	"DAD: {PLAYER}…
	I had a feeling that you would come.

	I would never refuse to accept
	a challenge from you.

	You do understand, don't you?

	Inside a GYM, it doesn't matter that
	we are a parent and child.

	Hm? Wait a second, {PLAYER}.

	Do you only have one POKéMON that is
	capable of battle?

	Sorry, but you'll have to come back
	with at least two POKéMON."
}
