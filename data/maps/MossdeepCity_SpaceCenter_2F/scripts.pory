    msgbox(MossdeepCity_SpaceCenter_2F_Text_Grunt6PostBattle, MSGBOX_NPC)
    end
}

script MossdeepCity_SpaceCenter_2F_EventScript_Grunt7 {
    msgbox(MossdeepCity_SpaceCenter_2F_Text_Grunt7PostBattle, MSGBOX_NPC)
    end
}

script MossdeepCity_SpaceCenter_2F_EventScript_Grunt5 {
    msgbox(MossdeepCity_SpaceCenter_2F_Text_Grunt5PostBattle, MSGBOX_NPC)
    end
}

script MossdeepCity_SpaceCenter_2F_EventScript_Tabitha {
    lock_faceplayer
    msgbox(MossdeepCity_SpaceCenter_2F_Text_WellTakeCareOfYou, MSGBOX_DEFAULT)
    applymovement(VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release_end
}

script MossdeepCity_SpaceCenter_2F_EventScript_Maxie {
    lockall
    msgbox(MossdeepCity_SpaceCenter_2F_Text_MaxieDontInterfere, MSGBOX_DEFAULT)
    releaseall
    end
}

script MossdeepCity_SpaceCenter_2F_EventScript_Steven {
    lockall
    if (flag(FLAG_INTERACTED_WITH_STEVEN_SPACE_CENTER)) {
        goto(MossdeepCity_SpaceCenter_2F_EventScript_ReadyForBattlePrompt)
    }
    setflag(FLAG_INTERACTED_WITH_STEVEN_SPACE_CENTER)
    msgbox(MossdeepCity_SpaceCenter_2F_Text_StevenWhyStealRocketFuel, MSGBOX_DEFAULT)
    msgbox(MossdeepCity_SpaceCenter_2F_Text_MaxieUseFuelToEruptVolcano, MSGBOX_DEFAULT)
    closemessage
    delay(30)
    playse(SE_NOT_EFFECTIVE)
	if (var(VAR_FACING) == DIR_SOUTH) {
		applymovement(LOCALID_SPACE_CENTER_2F_STEVEN, MossdeepCity_SpaceCenter_2F_Movement_StevenFightSouth)
	} else {
		applymovement(LOCALID_SPACE_CENTER_2F_STEVEN, moves(lock_look,  run_up * 2,  unlock_look,  delay_16 * 2,  creep_down * 2))
	}
    waitmovement(0)
    releaseall
    end
}

movement MossdeepCity_SpaceCenter_2F_Movement_StevenFightSouth {
    // moves(face_left,  lock_look,  run_right * 2,  unlock_look,  delay_16 * 2,  creep_left * 2,  face_down)
    face_left
    lock_look
    run_right * 2
    unlock_look
    delay_16 * 2
    creep_left * 2
    face_down
}

script MossdeepCity_SpaceCenter_2F_EventScript_ReadyForBattlePrompt {
    applymovement(VAR_LAST_TALKED, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(MossdeepCity_SpaceCenter_2F_Text_StevenAreYouReadyToBattle, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        goto(MossdeepCity_SpaceCenter_2F_EventScript_ChoosePartyForMultiBattle)
    }
    msgbox(MossdeepCity_SpaceCenter_2F_Text_StevenHurryGetReadyQuickly, MSGBOX_DEFAULT)
    closemessage
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterDown)
    waitmovement(0)
    releaseall
    end
}

script MossdeepCity_SpaceCenter_2F_EventScript_ChoosePartyForMultiBattle {
    applymovement(VAR_LAST_TALKED, Common_Movement_StepFasterDown)
    waitmovement(0)
    special(SavePlayerParty)
    fadescreen(FADE_TO_BLACK)
    special(ChooseHalfPartyForBattle)
    if (var(VAR_RESULT) != 0) {
        multi_2_vs_2(TRAINER_MAXIE_MOSSDEEP, MossdeepCity_SpaceCenter_2F_Text_JustWantToExpandLand, TRAINER_TABITHA_MOSSDEEP, MossdeepCity_SpaceCenter_Text_TabithaDefeat, PARTNER_STEVEN)
		if (var(VAR_RESULT) == B_OUTCOME_WON) {
			goto(MossdeepCity_SpaceCenter_2F_EventScript_DefeatedMaxieTabitha)
		}
		fadescreen(FADE_TO_BLACK)
		special(SetCB2WhiteOut)
		end
    }
    special(LoadPlayerParty)
    goto(MossdeepCity_SpaceCenter_2F_EventScript_ReadyForBattlePrompt)
	end
}

script MossdeepCity_SpaceCenter_2F_EventScript_DefeatedMaxieTabitha {
    msgbox(MossdeepCity_SpaceCenter_2F_Text_MaxieWeFailedIsAquaAlsoMisguided, MSGBOX_DEFAULT)
    closemessage
    delay(20)
    applymovement(LOCALID_SPACE_CENTER_MAXIE, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_SPACE_CENTER_TABITHA, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(60)
    applymovement(LOCALID_SPACE_CENTER_MAXIE, Common_Movement_StepFasterUp)
    applymovement(LOCALID_SPACE_CENTER_TABITHA, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(20)
    msgbox(MossdeepCity_SpaceCenter_2F_Text_MaxieWeWillGiveUp, MSGBOX_DEFAULT)
    closemessage
    setvar(VAR_MOSSDEEP_CITY_STATE, 3)
    fadedefaultbgm
    fadescreen(FADE_TO_BLACK)
    setvar(VAR_MOSSDEEP_SPACE_CENTER_STATE, 3)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_SPACE_CENTER_1F_TEAM_MAGMA)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_SPACE_CENTER_2F_TEAM_MAGMA)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_TEAM_MAGMA)
    removeobject(LOCALID_SPACE_CENTER_GRUNT_6)
    removeobject(LOCALID_SPACE_CENTER_GRUNT_7)
    removeobject(LOCALID_SPACE_CENTER_GRUNT_5)
    removeobject(LOCALID_SPACE_CENTER_TABITHA)
    removeobject(LOCALID_SPACE_CENTER_MAXIE)
    setobjectxy(LOCALID_SPACE_CENTER_2F_SCIENTIST, 5, 6)
    turnobject(LOCALID_SPACE_CENTER_2F_SCIENTIST, DIR_SOUTH)
    setobjectxy(LOCALID_SPACE_CENTER_2F_GENTLEMAN, 11, 8)
    turnobject(LOCALID_SPACE_CENTER_2F_GENTLEMAN, DIR_NORTH)
    setobjectxy(LOCALID_SPACE_CENTER_2F_RICH_BOY, 6, 2)
    turnobject(LOCALID_SPACE_CENTER_2F_RICH_BOY, DIR_NORTH)
    switch (var(VAR_FACING)) {
        case DIR_SOUTH: turnobject(LOCALID_SPACE_CENTER_2F_STEVEN, DIR_NORTH)
        case DIR_WEST: turnobject(LOCALID_SPACE_CENTER_2F_STEVEN, DIR_EAST)
    }
    fadescreen(FADE_FROM_BLACK)
    msgbox(MossdeepCity_SpaceCenter_2F_Text_StevenThankYouComeSeeMeAtHome, MSGBOX_DEFAULT)
    closemessage
    fadescreen(FADE_TO_BLACK)
    setflag(FLAG_DEFEATED_MAGMA_SPACE_CENTER)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_STEVENS_HOUSE_STEVEN)
    removeobject(LOCALID_SPACE_CENTER_2F_STEVEN)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_SPACE_CENTER_MAGMA_NOTE)
    clearflag(FLAG_HIDE_MOSSDEEP_CITY_STEVENS_HOUSE_STEVEN)
    setvar(VAR_STEVENS_HOUSE_STATE, 1)
    setflag(FLAG_HIDE_MOSSDEEP_CITY_SCOTT)
    removeobject(LOCALID_SPACE_CENTER_2F_SCIENTIST)
    setobjectxyperm(LOCALID_SPACE_CENTER_2F_SCIENTIST, 5, 6)
    setobjectmovementtype(LOCALID_SPACE_CENTER_2F_SCIENTIST, MOVEMENT_TYPE_WANDER_AROUND)
    addobject(LOCALID_SPACE_CENTER_2F_SCIENTIST)
    goto(MossdeepCity_SpaceCenter_2F_EventScript_DefeatedMaxieTabithaEnd)
	end
}

raw `
MossdeepCity_SpaceCenter_2F_EventScript_DefeatedMaxieTabithaEnd::
	fadescreen FADE_FROM_BLACK
#ifdef BUGFIX
	releaseall
#endif
	end
`

script MossdeepCity_SpaceCenter_2F_EventScript_RivalRayquazaCall {
    lockall
    if (checkplayergender == MALE) {
		pokenavcall(MatchCall_Text_MayRayquazaCall)
	} else{
        pokenavcall(MatchCall_Text_BrendanRayquazaCall)
    }
	waitmessage
    closemessage
    clearflag(FLAG_DEFEATED_MAGMA_SPACE_CENTER)
    releaseall
    end
}

text MossdeepCity_SpaceCenter_2F_Text_MossdeepIdealForRockets {
	"MOSSDEEP has mainly sunny weather,
	and its winds are stable.

	It's an ideal location for launching
	rockets."
}

text MossdeepCity_SpaceCenter_2F_Text_WhyWouldMagmaStealRocketFuel {
	"Why would TEAM MAGMA want to steal
	our rocket fuel in the first place?"
}

text MossdeepCity_SpaceCenter_2F_Text_WouldveLikedToBeAstronaut {
	"If only I was a little younger, I would
	have liked being an astronaut…

	No… It's not too late!
	I can and will try!"
}

text MossdeepCity_SpaceCenter_2F_Text_MagmaCantGetAwayWithThis {
	"If TEAM MAGMA takes the rocket fuel,
	I won't be able to go to space!

	They can't be allowed to get away
	with such an outrage!"
}

text MossdeepCity_SpaceCenter_2F_Text_WishOrdinaryPeopleCouldGoIntoSpace {
	"I wish ordinary people could go into
	space one day…"
}

text MossdeepCity_SpaceCenter_2F_Text_DoesMagmaWantToGoToSpace {
	"TEAM MAGMA…
	Do they want to go to space, too?"
}

text MossdeepCity_SpaceCenter_2F_Text_YoureOutnumberedTakeUsOn {
	"What's wrong with you?

	You're outnumbered three to one,
	but you still want to take us on?"
}

text MossdeepCity_SpaceCenter_2F_Text_GoodAnswer {
	"Good answer!
	That's what a smart person'll do!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt5Intro {
	"A reckless go-getter, are you?
	Okay, I'll go first!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt5Defeat {
	"I lost!
	But!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt6Intro {
	"It's too soon to be relieved!
	I'm up next!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt6Defeat {
	"I lost, too!
	But!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt7Intro {
	"I bet you want to take a break.
	But I'm not about to let you do that!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt7Defeat {
	"We should've taken a break…
	That's what we should've done…"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt6PostBattle {
	"Three of us here, and look at the sorry
	mess we got ourselves into."
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt7PostBattle {
	"We three losing like this…
	We look worse than usual by triple!"
}

text MossdeepCity_SpaceCenter_2F_Text_Grunt5PostBattle {
	"Are we being useful to our leader
	at all?"
}

text MossdeepCity_SpaceCenter_2F_Text_WellTakeCareOfYou {
	"Hehehe!

	We come all the way here to get some
	fuel, and we're interfered with again!

	If you're going to mess with us too,
	we'll take care of you at the same time!"
}

text MossdeepCity_SpaceCenter_2F_Text_MaxieDontInterfere {
	"{SPEAKER NAME_MAXIE}Clear out of the way!
	Don't you dare interfere!"
}

text MossdeepCity_SpaceCenter_2F_Text_StevenWhyStealRocketFuel {
	"{SPEAKER NAME_STEVEN}TEAM MAGMA…

	What's the point of stealing rocket
	fuel?"
}

text MossdeepCity_SpaceCenter_2F_Text_MaxieUseFuelToEruptVolcano {
	"{SPEAKER NAME_MAXIE}Fufufu… Since you're so
	curious, you deserve an explanation.

	We're going to jettison the entire
	load into MT. CHIMNEY!

	With GROUDON gone, we have no need
	for that slag heap of a mountain!

	So we'll use the fuel's power to make
	the volcano erupt!

	It will be savage!"
}

text MossdeepCity_SpaceCenter_2F_Text_StevenAreYouReadyToBattle {
	"{SPEAKER NAME_STEVEN}{PLAYER}{KUN}!
	You're going to help me?

	Let's go into battle together!
	Are you ready?"
}

text MossdeepCity_SpaceCenter_2F_Text_StevenHurryGetReadyQuickly {
	"{SPEAKER NAME_STEVEN}Then, hurry!
	Get ready quickly!"
}

text MossdeepCity_SpaceCenter_2F_Text_JustWantToExpandLand {
	"All I want…
	I just want to expand the land mass…"
}

text MossdeepCity_SpaceCenter_Text_TabithaDefeat {
	"I'm with our leader…"
}

text MossdeepCity_SpaceCenter_2F_Text_MaxieWeFailedIsAquaAlsoMisguided {
	"{SPEAKER NAME_MAXIE}We failed to make the volcano
	erupt…

	We failed to control GROUDON after
	we had awoken it…

	Is our goal to expand the land
	misguided?

	… … … … … …
	… … … … … …

	If…
	If we, TEAM MAGMA, are wrong…
	… … … … … …

	Then might TEAM AQUA's goal to expand
	the sea also be equally misguided?"
}

text MossdeepCity_SpaceCenter_2F_Text_MaxieWeWillGiveUp {
	"{SPEAKER NAME_MAXIE}All right…
	We will give up on the fuel…

	There appear to be more important
	matters that I must examine…"
}

text MossdeepCity_SpaceCenter_2F_Text_StevenThankYouComeSeeMeAtHome {
	"{SPEAKER NAME_STEVEN}Whew, that was too tense.
	{PLAYER}{KUN}, thank you.

	I have something to give you as
	thanks for your support.

	Please come see me at home
	after this.

	Oh, yes, I don't live in RUSTBORO CITY.
	I live right here on this island."
}
