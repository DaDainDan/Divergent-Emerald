mapscripts SixIsland_House_Frlg_MapScripts {}

script SixIsland_House_EventScript_OldMan {
    msgbox(SixIsland_House_Text_GoodPlaceForNatureAndHistory, MSGBOX_NPC)
    end
}

text SixIsland_House_Text_GoodPlaceForNatureAndHistory {
	"There's nothing that young people'd
	find exciting here on this island.

	But, this is a good place in terms
	of nature and history.

	Relax and enjoy your stay."
}
