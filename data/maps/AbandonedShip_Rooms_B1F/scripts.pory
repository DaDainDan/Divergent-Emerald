mapscripts AbandonedShip_Rooms_B1F_MapScripts {
    MAP_SCRIPT_ON_RESUME {
		setdivewarp(MAP_ABANDONED_SHIP_UNDERWATER2, 17, 4)
		end
	}
}

script AbandonedShip_Rooms_B1F_EventScript_FatMan {
    msgbox(AbandonedShip_Rooms_B1F_Text_GettingQueasy, MSGBOX_NPC)
    end
}

text AbandonedShip_Rooms_B1F_Text_GettingQueasy {
	"Urrrrppp…

	I'm getting queasy just being aboard
	this ship…

	It's not even moving, but…"
}
