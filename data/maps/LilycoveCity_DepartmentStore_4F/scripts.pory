mapscripts LilycoveCity_DepartmentStore_4F_MapScripts {}

script LilycoveCity_DepartmentStore_4F_EventScript_Gentleman {
    msgbox(LilycoveCity_DepartmentStore_4F_Text_AttackOrDefenseTM, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_4F_EventScript_Woman {
    msgbox(LilycoveCity_DepartmentStore_4F_Text_FiftyDifferentTMs, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_4F_EventScript_Youngster {
    msgbox(LilycoveCity_DepartmentStore_4F_Text_PokemonOnlyHaveFourMoves, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_4F_EventScript_ClerkLeft {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(LilycoveCity_DepartmentStore_4F_Pokemart_AttackTMs)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart LilycoveCity_DepartmentStore_4F_Pokemart_AttackTMs {
    ITEM_TM_FIRE_BLAST
    ITEM_TM_THUNDER
    ITEM_TM_BLIZZARD
    ITEM_TM_HYPER_BEAM
}

script LilycoveCity_DepartmentStore_4F_EventScript_ClerkRight {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(LilycoveCity_DepartmentStore_4F_Pokemart_DefenseTMs)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart LilycoveCity_DepartmentStore_4F_Pokemart_DefenseTMs {
    ITEM_TM_PROTECT
    ITEM_TM_SAFEGUARD
    ITEM_TM_REFLECT
    ITEM_TM_LIGHT_SCREEN
}

text LilycoveCity_DepartmentStore_4F_Text_AttackOrDefenseTM {
	"Hmm…

	An attacking move…
	Or a defensive move…

	It's no easy matter to decide which TM
	moves should be taught to POKéMON…"
}

text LilycoveCity_DepartmentStore_4F_Text_FiftyDifferentTMs {
	"There are so many different kinds of
	TM moves.

	A catalog I read said there are fifty
	different kinds."
}

text LilycoveCity_DepartmentStore_4F_Text_PokemonOnlyHaveFourMoves {
	"I'd like to get all the different TMs,
	but a POKéMON learns only four moves."
}
