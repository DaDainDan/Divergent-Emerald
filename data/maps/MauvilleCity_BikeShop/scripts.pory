mapscripts MauvilleCity_BikeShop_MapScripts {}

script MauvilleCity_BikeShop_EventScript_Rydel {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_BIKE)) {
        msgbox(MauvilleCity_BikeShop_Text_WantToSwitchBikes, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			goto(MauvilleCity_BikeShop_EventScript_SwitchBikes)
		}
		if (var(VAR_RESULT) == NO) {
			msgbox(MauvilleCity_BikeShop_Text_HappyYouLikeIt, MSGBOX_DEFAULT)
    		release_end
		}
		end
    }
    if (!flag(FLAG_DECLINED_BIKE)) {
        msgbox(MauvilleCity_BikeShop_Text_RydelGreeting, MSGBOX_DEFAULT)
    }
    msgbox(MauvilleCity_BikeShop_Text_DidYouComeFromFarAway, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        setflag(FLAG_RECEIVED_BIKE)
		goto(MauvilleCity_BikeShop_EventScript_ChooseBike)
    } else {
        setflag(FLAG_DECLINED_BIKE)
		msgbox(MauvilleCity_BikeShop_Text_GuessYouDontNeedBike, MSGBOX_DEFAULT)
    }
    release_end
}

script MauvilleCity_BikeShop_EventScript_ChooseBike {
    message(MauvilleCity_BikeShop_Text_ExplainBikesChooseWhichOne)
    waitmessage
    multichoice(21, 8, MULTI_BIKE, TRUE)
    switch (var(VAR_RESULT)) {
        case 0:
			msgbox(MauvilleCity_BikeShop_Text_ChoseMachBike, MSGBOX_DEFAULT)
    		giveitem(ITEM_MACH_BIKE)
        case 1:
			msgbox(MauvilleCity_BikeShop_Text_ChoseAcroBike, MSGBOX_DEFAULT)
    		giveitem(ITEM_ACRO_BIKE)
    }
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    goto(MauvilleCity_BikeShop_EventScript_ComeBackToSwitchBikes)
    end
}

script MauvilleCity_BikeShop_EventScript_ComeBackToSwitchBikes {
    msgbox(MauvilleCity_BikeShop_Text_ComeBackToSwitchBikes, MSGBOX_DEFAULT)
    special(SwapRegisteredBike)
    release_end
}

// If the player does not have a bike on them Rydel assumes its stored in the PC
script MauvilleCity_BikeShop_EventScript_SwitchBikes {
    msgbox(MauvilleCity_BikeShop_Text_IllSwitchBikes, MSGBOX_DEFAULT)
    if (checkitem(ITEM_ACRO_BIKE) == TRUE) {
		msgbox(MauvilleCity_BikeShop_Text_ExchangedAcroForMach, MSGBOX_DEFAULT)
		removeitem(ITEM_ACRO_BIKE)
		giveitem(ITEM_MACH_BIKE)
		
    }
    elif (checkitem(ITEM_MACH_BIKE) == TRUE) {
		msgbox(MauvilleCity_BikeShop_Text_ExchangedMachForAcro, MSGBOX_DEFAULT)
		removeitem(ITEM_MACH_BIKE)
		giveitem(ITEM_ACRO_BIKE)
    }
	else {
		msgbox(MauvilleCity_BikeShop_Text_OhYourBikeIsInPC, MSGBOX_DEFAULT)
    	release_end
	}
	incrementgamestat(GAME_STAT_TRADED_BIKES)
	goto(MauvilleCity_BikeShop_EventScript_ComeBackToSwitchBikes)
	end
}

script MauvilleCity_BikeShop_EventScript_Assistant {
    msgbox(MauvilleCity_BikeShop_Text_HandbooksAreInBack, MSGBOX_NPC)
    end
}

script MauvilleCity_BikeShop_EventScript_MachBikeHandbook {
    message(MauvilleCity_BikeShop_Text_MachHandbookWhichPage)
    waitmessage
    goto(MauvilleCity_BikeShop_EventScript_ChooseMachHandbookPage)
    end
}

script MauvilleCity_BikeShop_EventScript_ChooseMachHandbookPage {
    multichoice(0, 0, MULTI_MACH_BIKE_INFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: message(MauvilleCity_BikeShop_Text_HowToRideMachBike)
        case 1: message(MauvilleCity_BikeShop_Text_HowToTurnMachBike)
        case 2: message(MauvilleCity_BikeShop_Text_SandySlopes)
        case 3:
        case MULTI_B_PRESSED: release_end
    }
    waitmessage
    goto(MauvilleCity_BikeShop_EventScript_ChooseMachHandbookPage)
    end
}

script MauvilleCity_BikeShop_EventScript_AcroBikeHandbook {
    message(MauvilleCity_BikeShop_Text_AcroHandbookWhichPage)
    waitmessage
    goto(MauvilleCity_BikeShop_EventScript_ChooseAcroHandbookPage)
    end
}

script MauvilleCity_BikeShop_EventScript_ChooseAcroHandbookPage {
    multichoice(0, 0, MULTI_ACRO_BIKE_INFO, FALSE)
    switch (var(VAR_RESULT)) {
        case 0: message(MauvilleCity_BikeShop_Text_Wheelies)
        case 1: message(MauvilleCity_BikeShop_Text_BunnyHops)
        case 2: message(MauvilleCity_BikeShop_Text_Jumps)
        case 3:
        case MULTI_B_PRESSED: release_end
    }
    waitmessage
    goto(MauvilleCity_BikeShop_EventScript_ChooseAcroHandbookPage)
    end
}

text MauvilleCity_BikeShop_Text_RydelGreeting {
	"Well, well, what have we here?
	A most energetic customer!

	Me? You may call me RYDEL.
	I'm the owner of this cycle shop."
}

text MauvilleCity_BikeShop_Text_DidYouComeFromFarAway {
	"RYDEL: Your RUNNING SHOES…
	They're awfully filthy.

	Did you come from far away?"
}

text MauvilleCity_BikeShop_Text_GuessYouDontNeedBike {
	"RYDEL: Is that right?

	Then, I guess you have no need for
	any of my BIKES."
}

text MauvilleCity_BikeShop_Text_ExplainBikesChooseWhichOne {
	"RYDEL: Hm, hm… … … … …

	You're saying that you came all this
	way from LITTLEROOT?

	My goodness!
	That's ridiculously far!

	If you had one of my BIKES, you could
	go anywhere easily while feeling the
	gentle caress of the wind!

	I'll tell you what!
	I'll give you a BIKE!

	Oh, wait a second!

	I forgot to tell you that there are
	two kinds of BIKES!

	They are the MACH BIKE and
	the ACRO BIKE!

	The MACH BIKE is for cyclists who want
	to feel the wind with their bodies!

	And an ACRO BIKE is for those who
	prefer technical rides!

	I'm a real sweetheart, so you can
	have whichever one you like!

	Which one will you choose?"
}

text MauvilleCity_BikeShop_Text_ChoseMachBike {
	"{PLAYER} chose the MACH BIKE."
}

text MauvilleCity_BikeShop_Text_ChoseAcroBike {
	"{PLAYER} chose the ACRO BIKE."
}

text MauvilleCity_BikeShop_Text_ComeBackToSwitchBikes {
	"RYDEL: If you get the urge to switch
	BIKES, just come see me!"
}

text MauvilleCity_BikeShop_Text_WantToSwitchBikes {
	"RYDEL: Oh? Were you thinking about
	switching BIKES?"
}

text MauvilleCity_BikeShop_Text_IllSwitchBikes {
	"RYDEL: Okay, no problem!
	I'll switch BIKES for you!"
}

text MauvilleCity_BikeShop_Text_ExchangedMachForAcro {
	"{PLAYER} got the MACH BIKE exchanged
	for an ACRO BIKE."
}

text MauvilleCity_BikeShop_Text_ExchangedAcroForMach {
	"{PLAYER} got the ACRO BIKE exchanged
	for a MACH BIKE."
}

text MauvilleCity_BikeShop_Text_HappyYouLikeIt {
	"RYDEL: Good, good!
	I'm happy that you like it!"
}

text MauvilleCity_BikeShop_Text_OhYourBikeIsInPC {
	"Oh? What happened to that BIKE
	I gave you?

	Oh, I get it, you stored it using your PC.

	Well, take it out of PC storage,
	and I'll be happy to exchange it!

	May the wind always be at your back
	on your adventure!"
}

text MauvilleCity_BikeShop_Text_HandbooksAreInBack {
	"I'm learning about BIKES while
	I work here.

	If you need advice on how to ride your
	BIKE, there're a couple handbooks in
	the back."
}

text MauvilleCity_BikeShop_Text_MachHandbookWhichPage {
	"It's a handbook on the MACH BIKE.

	Which page do you want to read?"
}

text MauvilleCity_BikeShop_Text_HowToRideMachBike {
	"A BIKE moves in the direction that
	the + Control Pad is pressed.

	It will speed up once it gets rolling.

	To stop, release the + Control Pad.
	The BIKE will slow to a stop.

	Want to read a different page?"
}

text MauvilleCity_BikeShop_Text_HowToTurnMachBike {
	"A MACH BIKE is speedy, but it can't
	stop very quickly.

	It gets a little tricky to get around
	a corner.

	Release the + Control Pad a little
	before the corner and slow down.

	Want to read a different page?"
}

text MauvilleCity_BikeShop_Text_SandySlopes {
	"There are small sandy slopes
	throughout the HOENN region.

	The loose, crumbly sand makes it
	impossible to climb normally.

	But if you have a MACH BIKE, you can
	zip up a sandy slope.

	Want to read a different page?"
}

text MauvilleCity_BikeShop_Text_AcroHandbookWhichPage {
	"It's a handbook on the ACRO BIKE.

	Which page do you want to read?"
}

text MauvilleCity_BikeShop_Text_Wheelies {
	"Press the B Button while riding,
	and the front wheel lifts up.

	You can zip around with the front
	wheel up using the + Control Pad.

	This technique is called a wheelie.

	Want to read a different page?"
}

text MauvilleCity_BikeShop_Text_BunnyHops {
	"Keeping the B Button pressed,
	your BIKE can hop on the spot.

	This technique is called a bunny hop.

	You can ride while hopping, too.

	Want to read a different page?"
}

text MauvilleCity_BikeShop_Text_Jumps {
	"Press the B Button and the + Control
	Pad at the same time to jump.

	Press the + Control Pad to the side
	to jump sideways.

	Press it backwards to make the BIKE
	change directions while jumping.

	Want to read a different page?"
}
