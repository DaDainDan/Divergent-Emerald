mapscripts OneIsland_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_ONE_ISLAND)
		switch (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F)) {
			case 6: setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 7)
			case 0:
				setobjectxyperm(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, 9, 8)
				setobjectmovementtype(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, MOVEMENT_TYPE_FACE_UP)
				setobjectxyperm(LOCALID_CELIO, 15, 6)
				setobjectmovementtype(LOCALID_CELIO, MOVEMENT_TYPE_FACE_UP)
			case 2:
				setobjectxyperm(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, 14, 7)
				setobjectmovementtype(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, MOVEMENT_TYPE_FACE_LEFT)
				setobjectxyperm(LOCALID_CELIO, 14, 8)
				setobjectmovementtype(LOCALID_CELIO, MOVEMENT_TYPE_FACE_LEFT)
		}
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) >= 5) {
			setmetatile(13, 4, METATILE_PokemonCenterFrlg_NetworkMachine_Ruby, 1)
		}
		if (flag(FLAG_IS_CHAMPION)) {
			call(OneIsland_PokemonCenter_1F_EventScript_SetNetworkMachineOn)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 0: OneIsland_PokemonCenter_1F_EventScript_MeetCelioScene
    ]
}

script OneIsland_PokemonCenter_1F_EventScript_SetNetworkMachineOn {
    setmetatile(16, 4, METATILE_PokemonCenterFrlg_NetworkMachine_Sapphire, 1)
    setmetatile(14, 4, METATILE_PokemonCenterFrlg_NetworkMachine_ScreenLeft_On, 1)
    setmetatile(15, 4, METATILE_PokemonCenterFrlg_NetworkMachine_ScreenRight_On, 1)
    return
}

script OneIsland_PokemonCenter_1F_EventScript_MeetCelioScene {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    applymovement(LOCALID_PLAYER, moves(walk_up * 2,  walk_right * 5,  step_faster_up))
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, moves(walk_up,  walk_right * 5,  walk_up,  step_faster_right))
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillHeyThereCelio)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_CELIO, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterLeft)
    waitmovement(0)
    applymovement(LOCALID_CELIO, Common_Movement_Delay48)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioCantBelieveYouCameOut)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillHowsYourResearchComing)
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterDown)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_ThisIsMyBuddyCelio)
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterRight)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(OneIsland_PokemonCenter_1F_Text_PlayerIsReigningPokemonChamp)
    } else {
		msgbox(OneIsland_PokemonCenter_1F_Text_PlayerIsRisingPokemonChamp)
	}
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioThatsReallyImpressive)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillBringMeUpToSpeed)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioPCsCantLinkWithYours)
    closemessage
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillLetMeHelpYou)
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterDown)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CanYouDeliverThisMeteoritePlayer)
    msgreceiveditem(OneIsland_PokemonCenter_1F_Text_AcceptedMeteoriteFromBill, ITEM_METEORITE, 1, MUS_RG_OBTAIN_KEY_ITEM)
    additem(ITEM_METEORITE)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioPleaseTakeThis)
    giveitem_msg(OneIsland_PokemonCenter_1F_Text_ObtainedTriPass, ITEM_TRI_PASS, 1, MUS_RG_OBTAIN_KEY_ITEM)
    msgbox(OneIsland_PokemonCenter_1F_Text_PassLetsYouTravelBetweenIslands)
    if (var(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE) >= 2) {
        textcolor(NPC_TEXT_COLOR_NEUTRAL)
		playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
		message(OneIsland_PokemonCenter_1F_Text_ReceivedExtraPageForTownMap)
		waitmessage
		waitfanfare
		call(EventScript_RestorePrevTextColor)
    } else {
        setflag(FLAG_HIDE_TOWN_MAP)
		setvar(VAR_MAP_SCENE_PALLET_TOWN_RIVALS_HOUSE, 2)
		giveitem_msg(OneIsland_PokemonCenter_1F_Text_ReceivedTownMap, ITEM_TOWN_MAP, 1, MUS_RG_OBTAIN_KEY_ITEM)
    }
    setflag(FLAG_SYS_SEVII_MAP_123)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillCatchYouLater)
    closemessage
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterUp)
    waitmovement(0)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterUp)
    waitmovement(0)
    setflag(FLAG_SYS_PC_STORAGE_DISABLED)
    setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 1)
    releaseall
    end
}

// Unused
movement OneIsland_PokemonCenter_1F_Movement_WalkUp {
    // moves(walk_up)
    walk_up
}

// Unused
movement OneIsland_PokemonCenter_1F_Movement_StepAsideLeft {
    // moves(walk_left,  step_faster_right)
    walk_left
    step_faster_right
}

script OneIsland_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_Bill {
    lock
    if (flag(FLAG_SEVII_DETOUR_FINISHED)) {
        applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(OneIsland_PokemonCenter_1F_Text_GotPCWorkingStrollAWhileMore)
		release_end
    }
    msgbox(OneIsland_PokemonCenter_1F_Text_HmmHowAboutLikeThis)
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_Celio {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 7) {
        goto(OneIsland_PokemonCenter_1F_EventScript_CelioGiveBillFact)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 6) {
        msgbox(OneIsland_PokemonCenter_1F_Text_WishYouBestOfLuck)
    }
    elif (flag(FLAG_RECOVERED_SAPPHIRE)) {
        goto(OneIsland_PokemonCenter_1F_EventScript_GiveCelioSapphire)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 5) {
        msgbox(OneIsland_PokemonCenter_1F_Text_PassLetYouGetToAllIslands)
    }
    elif (flag(FLAG_GOT_RUBY)) {
        goto(OneIsland_PokemonCenter_1F_EventScript_GiveCelioRuby)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 4) {
        msgbox(OneIsland_PokemonCenter_1F_Text_TryingToFindGem)
    }
    elif (specialvar(VAR_RESULT, IsNationalPokedexEnabled) == TRUE) {
        msgbox(OneIsland_PokemonCenter_1F_Text_CelioCaughtMoreMonMaybeICanBeUseful)
		applymovement(LOCALID_CELIO, Common_Movement_StepFasterUp)
		waitmovement(0)
		msgbox(OneIsland_PokemonCenter_1F_Text_YoullBeTradingFromTrainersFarAway)
		applymovement(LOCALID_CELIO, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(OneIsland_PokemonCenter_1F_Text_NeedsSpecialGemstone)
		setvar(VAR_MAP_SCENE_MT_EMBER_EXTERIOR, 1)
		setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 4)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 3) {
        msgbox(OneIsland_PokemonCenter_1F_Text_CelioImModifyingMyNetworkMachine)
    }
	else {
		msgbox(OneIsland_PokemonCenter_1F_Text_SorryForBeingPoorHost)
    	goto(Common_EventScript_FaceOriginalDirection)
	}
	release_end
}

script OneIsland_PokemonCenter_1F_EventScript_CelioGiveBillFact {
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioHearingRumorsAboutYou)
    random(3)
	switch (var(VAR_RESULT)) {
		case 0:
			famechecker(FAMECHECKER_BILL, 3)
    		msgbox(OneIsland_PokemonCenter_1F_Text_BillsFirstMonWasAbra)
		case 1:
			famechecker(FAMECHECKER_BILL, 4)
    		msgbox(OneIsland_PokemonCenter_1F_Text_BillsHometownInGoldenrod)
		default:
			famechecker(FAMECHECKER_BILL, 5)
    		msgbox(OneIsland_PokemonCenter_1F_Text_BillCantStomachMilk)
	}
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_GiveCelioSapphire {
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_OBTAIN_TMHM)
    message(OneIsland_PokemonCenter_1F_Text_HandedSapphireToCelio)
    waitmessage
    waitfanfare
    call(EventScript_RestorePrevTextColor)
    removeitem(ITEM_SAPPHIRE)
    msgbox(OneIsland_PokemonCenter_1F_Text_ThankYouGiveMeTime)
    closemessage
    applymovement(LOCALID_CELIO, moves(step_faster_up,  step_up,  delay_16,  step_up * 2))
    waitmovement(0)
    playse(SE_CLICK)
    setmetatile(16, 4, METATILE_PokemonCenterFrlg_NetworkMachine_Sapphire, 1)
    special(DrawWholeMapView)
    msgbox(OneIsland_PokemonCenter_1F_Text_OkayThisIsGood)
    closemessage
    delay(60)
    applymovement(LOCALID_CELIO, moves(step_up,  delay_8,  step_up))
    waitmovement(0)
    delay(30)
    applymovement(LOCALID_CELIO, moves(step_up,  delay_8,  step_up))
    waitmovement(0)
    delay(40)
    playse(SE_PC_ON)
    call(OneIsland_PokemonCenter_1F_EventScript_SetNetworkMachineOn)
    special(DrawWholeMapView)
    msgbox(OneIsland_PokemonCenter_1F_Text_LinkedUpWithLanette)
    applymovement(LOCALID_CELIO, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_ManagedToLinkWithHoennThankYou)
    special(SetPostgameFlags)
    setflag(FLAG_IS_CHAMPION)
    setflag(FLAG_HIDE_CERULEAN_CAVE_GUARD)
    setflag(FLAG_HIDE_LORELEI_IN_HER_HOUSE)
    setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 6)
    special(InitRoamer)
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_GiveCelioRuby {
    msgbox(OneIsland_PokemonCenter_1F_Text_OhThats)
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_OBTAIN_TMHM)
    message(OneIsland_PokemonCenter_1F_Text_HandedRubyToCelio)
    waitmessage
    waitfanfare
    call(EventScript_RestorePrevTextColor)
    closemessage
    applymovement(LOCALID_CELIO, moves(step_faster_up,  step_up,  delay_16,  step_up * 2))
    waitmovement(0)
    playse(SE_CLICK)
    setmetatile(13, 4, METATILE_PokemonCenterFrlg_NetworkMachine_Ruby, 1)
    special(DrawWholeMapView)
    delay(30)
    applymovement(LOCALID_CELIO, Common_Movement_FacePlayer)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_MayIAskOneMoreFavor, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        do {
			msgbox(OneIsland_PokemonCenter_1F_Text_PleaseINeedYourHelp, MSGBOX_YESNO)
		} while (var(VAR_RESULT) == NO)
    }
    msgbox(OneIsland_PokemonCenter_1F_Text_AnotherGemstoneInSeviiIslands)
    removeitem(ITEM_RUBY)
    removeitem(ITEM_TRI_PASS)
    setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 5)
    additem(ITEM_RAINBOW_PASS)
    setflag(FLAG_SYS_SEVII_MAP_4567)
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
    message(OneIsland_PokemonCenter_1F_Text_ReturnedTriPassForRainbowPass)
    waitmessage
    waitfanfare
    playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
    message(OneIsland_PokemonCenter_1F_Text_ObtainedExtraMapPage)
    waitmessage
    waitfanfare
    call(EventScript_RestorePrevTextColor)
    msgbox(OneIsland_PokemonCenter_1F_Text_PassLetYouGetToAllIslands)
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_LittleBoy {
    msgbox(OneIsland_PokemonCenter_1F_Text_CameFromPalletDontKnowIt, MSGBOX_NPC)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_Hiker {
    msgbox(OneIsland_PokemonCenter_1F_Text_EnormousVolcanoOnIsland, MSGBOX_NPC)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_BattleGirl {
    lock_faceplayer
    if (flag(FLAG_IS_CHAMPION)) {
        msgbox(OneIsland_PokemonCenter_1F_Text_TradedWithFarAwayBoyfriend)
    	release_end
    }
    msgbox(OneIsland_PokemonCenter_1F_Text_WishICouldTradeWithBoyfriend)
    release_end
}

script OneIsland_PokemonCenter_1F_EventScript_NetworkMachine {
    lockall
    if (flag(FLAG_IS_CHAMPION)) {
        msgbox(OneIsland_PokemonCenter_1F_Text_MachineLinkedWithKantoAndHoenn)
    }
    elif (flag(FLAG_SEVII_DETOUR_FINISHED)) {
        msgbox(OneIsland_PokemonCenter_1F_Text_MachineLinkedWithKanto)
    }
	else {
		msgbox(OneIsland_PokemonCenter_1F_Text_MachineUnderAdjustment)
	}
    releaseall
    end
}

script OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandTriggerTop {
    lockall
    setvar(VAR_TEMP_1, 1)
    goto(OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandScene)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandTriggerMidTop {
    lockall
    setvar(VAR_TEMP_1, 2)
    goto(OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandScene)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandTriggerMidBottom {
    lockall
    setvar(VAR_TEMP_1, 3)
    goto(OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandScene)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandTriggerBottom {
    lockall
    setvar(VAR_TEMP_1, 4)
    goto(OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandScene)
    end
}

script OneIsland_PokemonCenter_1F_EventScript_LeaveOneIslandScene {
    textcolor(NPC_TEXT_COLOR_MALE)
    playse(SE_PIN)
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_ExclamationMark)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillOhHeyPlayer)
    closemessage
	switch (var(VAR_TEMP_1)) {
		case 1: applymovement(LOCALID_PLAYER, moves(walk_right,  walk_down,  step_faster_right))
		case 2: applymovement(LOCALID_PLAYER, Common_Movement_WalkRight)
		case 3: applymovement(LOCALID_PLAYER, moves(walk_right,  walk_up,  step_faster_right))
		case 4: applymovement(LOCALID_PLAYER, moves(walk_right,  walk_up * 2,  step_faster_right))
	}
	waitmovement(0)
    delay(10)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillWeGotItDone)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioJobWentQuick)
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterDown)
    waitmovement(0)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterUp)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillYouveLearnedALot)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioOhReallyEhehe)
    closemessage
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterLeft)
    waitmovement(0)
    delay(10)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(15)
    msgbox(OneIsland_PokemonCenter_1F_Text_BillWeShouldHeadBackToKanto)
    closemessage
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, Common_Movement_StepFasterDown)
    waitmovement(0)
    delay(15)
    applymovement(LOCALID_CELIO, Common_Movement_StepFasterLeft)
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
    waitmovement(0)
    msgbox(OneIsland_PokemonCenter_1F_Text_CelioPromiseIllShowYouAroundSometime)
    closemessage
    delay(25)
    applymovement(LOCALID_PLAYER, moves(walk_left * 4,  walk_down * 2))
    applymovement(LOCALID_ONE_ISLAND_POKEMON_CENTER_BILL, moves(walk_left * 5,  walk_down))
    waitmovement(0)
    playse(SE_EXIT)
    setflag(FLAG_HIDE_ONE_ISLAND_POKECENTER_BILL)
    setvar(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F, 3)
    clearflag(FLAG_HIDE_CINNABAR_BILL)
    setvar(VAR_MAP_SCENE_CINNABAR_ISLAND, 3)
    setvar(VAR_0x8004, SEAGALLOP_ONE_ISLAND)
    setvar(VAR_0x8006, SEAGALLOP_CINNABAR_ISLAND)
    goto(EventScript_SetSail)
    end
}

// Unused
movement OneIsland_PokemonCenter_1F_Movement_DelayStepLeft {
    // moves(delay_16 * 2,  delay_4,  step_faster_left)
    delay_16 * 2
    delay_4
    step_faster_left
}

// Unused
movement OneIsland_PokemonCenter_1F_Movement_StepDown {
    // moves(step_fast_down)
    step_fast_down
}

text OneIsland_PokemonCenter_1F_Text_BillHeyThereCelio {
	"BILL: Hey, there!
	CELIO!"
}

text OneIsland_PokemonCenter_1F_Text_CelioCantBelieveYouCameOut {
	"CELIO: BILL!
	I can't believe you came out here."
}

text OneIsland_PokemonCenter_1F_Text_BillHowsYourResearchComing {
	"BILL: Well, absolutely!
	How's your research coming along?

	…Oh, wait a sec."
}

text OneIsland_PokemonCenter_1F_Text_ThisIsMyBuddyCelio {
	"{PLAYER}, this is my buddy CELIO.
	He's one dedicated PC MANIAC!"
}

text OneIsland_PokemonCenter_1F_Text_PlayerIsRisingPokemonChamp {
	"CELIO, this is {PLAYER}, a rising
	contender as the POKéMON CHAMP!"
}

text OneIsland_PokemonCenter_1F_Text_PlayerIsReigningPokemonChamp {
	"CELIO, this is {PLAYER}, the
	reigning POKéMON CHAMP!"
}

text OneIsland_PokemonCenter_1F_Text_CelioThatsReallyImpressive {
	"CELIO: That's really impressive.

	I hate to say it, but I have zero
	aptitude for battling.

	Anyways, I'm glad to meet you."
}

text OneIsland_PokemonCenter_1F_Text_BillBringMeUpToSpeed {
	"BILL: So, bring me up to speed.
	How's your machine running?"
}

text OneIsland_PokemonCenter_1F_Text_CelioPCsCantLinkWithYours {
	"CELIO: It's running fine, but we're
	too remote out here.

	The PCs on this island just can't
	link with your PC, BILL."
}

text OneIsland_PokemonCenter_1F_Text_BillLetMeHelpYou {
	"BILL: Oh, yeah?
	Okay, let me take a look-see.

	…Hang on here…
	I think we can make it work.
	Let me help you, okay?"
}

text OneIsland_PokemonCenter_1F_Text_CanYouDeliverThisMeteoritePlayer {
	"{PLAYER}, can I get you to wait for
	me just a bit?

	…Actually, can I get you to do
	me a favor?

	The island next to this one's
	called TWO ISLAND.

	There's a guy there that runs
	a GAME CORNER.

	He has this thing for rare rocks
	and gems.

	We keep in touch, being fellow
	maniacs.

	So, can I get you to deliver this
	METEORITE to him?"
}

text OneIsland_PokemonCenter_1F_Text_AcceptedMeteoriteFromBill {
	"{PLAYER} accepted the METEORITE
	from BILL."
}

text OneIsland_PokemonCenter_1F_Text_CelioPleaseTakeThis {
	"CELIO: {PLAYER}, if you are going
	to TWO ISLAND, please take this."
}

text OneIsland_PokemonCenter_1F_Text_PassLetsYouTravelBetweenIslands {
	"It's a PASS for the ferry service
	serving the local islands.

	It will let you travel between the
	ISLANDS ONE, TWO, and THREE.

	Oh, you should have this, too."
}

text OneIsland_PokemonCenter_1F_Text_ReceivedExtraPageForTownMap {
	"{PLAYER} received an extra page
	for the TOWN MAP!"
}

text OneIsland_PokemonCenter_1F_Text_ReceivedTownMap {
	"{PLAYER} received
	a TOWN MAP!"
}

text OneIsland_PokemonCenter_1F_Text_BillCatchYouLater {
	"BILL: I'll catch you later!
	Say hi to the guy for me!"
}

text OneIsland_PokemonCenter_1F_Text_HmmHowAboutLikeThis {
	"Hmm…

	How about we try this like this…"
}

text OneIsland_PokemonCenter_1F_Text_GotPCWorkingStrollAWhileMore {
	"Oh, hey, {PLAYER}!

	Did you see?
	We got the PC working!

	I've got a few things to show
	CELIO here.

	Can you go out on a stroll or
	something for a while more?"
}

text OneIsland_PokemonCenter_1F_Text_SorryForBeingPoorHost {
	"I'm sorry for taking up so much of
	BILL's time.

	I'm also sorry for being such a 
	poor host on your visit here."
}

text OneIsland_PokemonCenter_1F_Text_UsualPCServicesUnavailable {
	"The usual PC services aren't
	available…"
}

text OneIsland_PokemonCenter_1F_Text_BillOhHeyPlayer {
	"BILL: Oh, hey!
	{PLAYER}!"
}

text OneIsland_PokemonCenter_1F_Text_BillWeGotItDone {
	"BILL: What kept you so long?
	Been out having a good time?

	We got it done.
	The PCs are up and running!"
}

text OneIsland_PokemonCenter_1F_Text_CelioJobWentQuick {
	"CELIO: The job went incredibly
	quick.

	BILL is one amazing guy…"
}

text OneIsland_PokemonCenter_1F_Text_BillYouveLearnedALot {
	"BILL: No, no! There was almost
	nothing left for me to do.

	CELIO, I have to hand it to you.
	You've learned a lot."
}

text OneIsland_PokemonCenter_1F_Text_CelioOhReallyEhehe {
	"CELIO: Oh, really?
	Ehehe…"
}

text OneIsland_PokemonCenter_1F_Text_BillWeShouldHeadBackToKanto {
	"BILL: Well, there you have it.
	I'm finished with the job.
	We should head back to KANTO.

	CELIO, I'll be seeing you again."
}

text OneIsland_PokemonCenter_1F_Text_CelioPromiseIllShowYouAroundSometime {
	"CELIO: {PLAYER}, I'm really sorry
	that we sent you off alone today.

	I promise, I will show you around
	these islands sometime."
}

text OneIsland_PokemonCenter_1F_Text_CelioImModifyingMyNetworkMachine {
	"CELIO: Hello!
	You look awfully busy as always.

	How am I doing?

	Well, I'm modifying my Network
	Machine.

	When I get done with the machine,
	I hope you'll be first to use it,
	{PLAYER}."
}

text OneIsland_PokemonCenter_1F_Text_CelioCaughtMoreMonMaybeICanBeUseful {
	"CELIO: {PLAYER}, how have things
	been for you?

	Oh, is that right?
	You've caught more POKéMON.

	Do you know what?
	Maybe I can be useful to you."
}

text OneIsland_PokemonCenter_1F_Text_YoullBeTradingFromTrainersFarAway {
	"I'm modifying the Network Machine
	right now.

	I'm changing it so it can handle
	trades over long distances.

	When I get finished, you'll be
	trading for exotic POKéMON from
	TRAINERS far away."
}

text OneIsland_PokemonCenter_1F_Text_NeedsSpecialGemstone {
	"But, there is a slight catch.

	For the link to work, the Machine
	needs a special gemstone.

	It's supposed to be on ONE ISLAND,
	but I haven't found one yet.

	Who knows where it could be."
}

text OneIsland_PokemonCenter_1F_Text_TryingToFindGem {
	"I was trying to find the gem
	even while I was studying.

	As a result, I've made no headway
	in both my search and studies…

	If I relied on BILL, I'm sure my
	research would progress.

	But this time, I want to try to do
	things by myself."
}

text OneIsland_PokemonCenter_1F_Text_OhThats {
	"Oh!
	Th-that's…"
}

text OneIsland_PokemonCenter_1F_Text_HandedRubyToCelio {
	"{PLAYER} handed the RUBY
	to CELIO."
}

text OneIsland_PokemonCenter_1F_Text_MayIAskOneMoreFavor {
	"Thank you!
	{PLAYER}, you're simply amazing.

	… … …  … … …

	Um… May I ask one more giant favor
	of you?"
}

text OneIsland_PokemonCenter_1F_Text_PleaseINeedYourHelp {
	"It… It's not anything weird.
	Please, I need your help."
}

text OneIsland_PokemonCenter_1F_Text_AnotherGemstoneInSeviiIslands {
	"While I was studying gemstones,
	I discovered something important.

	There is another gem that forms
	a pair with this RUBY.

	That other gemstone is supposed to
	be in the SEVII ISLANDS.

	{PLAYER}, please, I need you to go
	find the other gem.

	{PLAYER}, may I have your ferry
	PASS and the TOWN MAP?"
}

text OneIsland_PokemonCenter_1F_Text_ReturnedTriPassForRainbowPass {
	"{PLAYER} returned the TRI-PASS and
	received the RAINBOW PASS."
}

text OneIsland_PokemonCenter_1F_Text_ObtainedExtraMapPage {
	"Obtained an extra page for the
	TOWN MAP!"
}

text OneIsland_PokemonCenter_1F_Text_PassLetYouGetToAllIslands {
	"This is my own ferry PASS.

	It will let you get to all the
	SEVII ISLANDS.

	{PLAYER}, please, I can't do
	it without your help."
}

text OneIsland_PokemonCenter_1F_Text_HandedSapphireToCelio {
	"{PLAYER} handed the SAPPHIRE
	to CELIO."
}

text OneIsland_PokemonCenter_1F_Text_ThankYouGiveMeTime {
	"CELIO: So this is the gem that
	forms a pair with the RUBY…

	{PLAYER}, you've gone through a lot
	to get this, didn't you?

	You don't have to tell me. I know
	it wasn't easy.

	Thank you so much!

	Now it's my turn to work for you!
	Please give me a little time."
}

text OneIsland_PokemonCenter_1F_Text_OkayThisIsGood {
	"Okay, this is good…"
}

text OneIsland_PokemonCenter_1F_Text_LinkedUpWithLanette {
	"I did it!
	I linked up with LANETTE!"
}

text OneIsland_PokemonCenter_1F_Text_ManagedToLinkWithHoennThankYou {
	"{PLAYER}…
	{PLAYER}, I did it!

	I've managed to link up with
	TRAINERS in the HOENN region!

	Finally, the Network Machine is
	fully operational!

	{PLAYER}, I owe it all to you!

	Thanks to you, my dream came
	true…"
}

text OneIsland_PokemonCenter_1F_Text_WishYouBestOfLuck {
	"I…
	I'm not crying.

	That's enough about me!

	{PLAYER}, you're going to keep
	looking for exotic POKéMON, right?

	I wish you the best of luck!"
}

text OneIsland_PokemonCenter_1F_Text_CelioHearingRumorsAboutYou {
	"CELIO: Hello!

	{PLAYER}, I've been hearing rumors
	about you."
}

text OneIsland_PokemonCenter_1F_Text_BillsFirstMonWasAbra {
	"{PLAYER}, what's your favorite kind
	of POKéMON?

	BILL is a POKéMANIAC, so he loves
	every kind.

	Apparently, the first one he caught
	was an ABRA."
}

text OneIsland_PokemonCenter_1F_Text_BillsHometownInGoldenrod {
	"By the way, {PLAYER}, you're from
	PALLET TOWN, aren't you?

	I've heard that it's a quiet and
	pleasant place.

	BILL's hometown is GOLDENROD CITY,
	where his folks still live.

	I've heard that it's quite the
	festive, bustling city.

	I'd like to go there one day."
}

text OneIsland_PokemonCenter_1F_Text_BillCantStomachMilk {
	"{PLAYER}, is there anything that
	you can't stand?

	Apparently, BILL simply can't
	stomach milk at all."
}

text OneIsland_PokemonCenter_1F_Text_CameFromPalletDontKnowIt {
	"Oh, you're a stranger here!
	Hi! Where did you come from?

	…PALLET TOWN?
	I don't know it!"
}

text OneIsland_PokemonCenter_1F_Text_EnormousVolcanoOnIsland {
	"On this island, there's an enormous
	volcano.

	It hasn't erupted lately, so why
	not enjoy a hike?"
}

text OneIsland_PokemonCenter_1F_Text_WishICouldTradeWithBoyfriend {
	"I wish I could trade POKéMON with
	my boyfriend who lives far away…"
}

text OneIsland_PokemonCenter_1F_Text_TradedWithFarAwayBoyfriend {
	"I traded POKéMON with my boyfriend
	far away!

	Everyone's saying that we can
	thank you and CELIO.

	So, thank you!"
}

text OneIsland_PokemonCenter_1F_Text_MachineUnderAdjustment {
	"Network Machine
	Link Level 0

	…POKéMON Storage System under
	adjustment…"
}

text OneIsland_PokemonCenter_1F_Text_MachineLinkedWithKanto {
	"Network Machine
	Link Level 1

	Link established with the KANTO
	region."
}

text OneIsland_PokemonCenter_1F_Text_MachineLinkedWithKantoAndHoenn {
	"Network Machine
	Link Level 2

	Link established with the KANTO
	and HOENN regions."
}

text OneIsland_PokemonCenter_1F_Text_ObtainedTriPass {
	"Obtained the TRI-PASS!"
}
