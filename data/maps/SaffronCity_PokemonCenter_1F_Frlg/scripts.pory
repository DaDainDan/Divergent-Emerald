mapscripts SaffronCity_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_SAFFRON_CITY)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script SaffronCity_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script SaffronCity_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(SaffronCity_PokemonCenter_1F_Text_SilphCoVictimOfFame, MSGBOX_NPC)
    end
}

script SaffronCity_PokemonCenter_1F_EventScript_Woman {
    msgbox(SaffronCity_PokemonCenter_1F_Text_GrowthRatesDifferBySpecies, MSGBOX_NPC)
    end
}

script SaffronCity_PokemonCenter_1F_EventScript_Youngster {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_SILPH_CO_11F) == 1) {
        msgbox(SaffronCity_PokemonCenter_1F_Text_TeamRocketTookOff)
    	release_end
    }
    msgbox(SaffronCity_PokemonCenter_1F_Text_GreatIfEliteFourCameBeatRockets)
    release_end
}

text SaffronCity_PokemonCenter_1F_Text_GrowthRatesDifferBySpecies {
	"POKéMON growth rates differ from
	species to species."
}

text SaffronCity_PokemonCenter_1F_Text_SilphCoVictimOfFame {
	"SILPH CO. is widely known to all.

	It's a victim of its own fame - it
	attracted TEAM ROCKET."
}

text SaffronCity_PokemonCenter_1F_Text_GreatIfEliteFourCameBeatRockets {
	"Sigh…
	Wouldn't this be great?

	If the ELITE FOUR came and
	stomped TEAM ROCKET?"
}

text SaffronCity_PokemonCenter_1F_Text_TeamRocketTookOff {
	"TEAM ROCKET took off!
	We can go out safely again!
	That's great!"
}
