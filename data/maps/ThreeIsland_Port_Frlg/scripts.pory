mapscripts ThreeIsland_Port_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        clearflag(FLAG_SYS_PC_STORAGE_DISABLED)
		setflag(FLAG_SEVII_DETOUR_FINISHED)
		end
    }
}

script ThreeIsland_Port_EventScript_Woman {
    lock_faceplayer
    if (var(VAR_MAP_SCENE_TWO_ISLAND_JOYFUL_GAME_CORNER) >= 2) {
        msgbox(ThreeIsland_Port_Text_EverythingTurnedOutForBest)
    }
    elif (var(VAR_MAP_SCENE_THREE_ISLAND) >= 4) {
        msgbox(ThreeIsland_Port_Text_ThankGoodnessBikersGone)
    }
	else {
		msgbox(ThreeIsland_Port_Text_IllCallThePolice)
	}
    release_end
}

script ThreeIsland_Port_EventScript_Biker1 {
    msgbox(ThreeIsland_Port_Text_WereKantoRiderFederation, MSGBOX_NPC)
    end
}

script ThreeIsland_Port_EventScript_Biker2 {
    lock
    msgbox(ThreeIsland_Port_Text_ForkOverMoney)
    release_end
}

text ThreeIsland_Port_Text_WereKantoRiderFederation {
	"We're the KANTO RIDER FEDERATION!
	Vroom! Vavavavooom! Vroom!

	My bike's wimpy, so I have to
	make exhaust noises myself!"
}

text ThreeIsland_Port_Text_ForkOverMoney {
	"Hey, hey, lady!
	Fork over some spending money!"
}

text ThreeIsland_Port_Text_IllCallThePolice {
	"Aiyeeh!

	Wh-who are you?!
	I… I'll call the police!"
}

text ThreeIsland_Port_Text_ThankGoodnessBikersGone {
	"Those BIKERS…
	Are they gone?

	Oh, thank goodness!
	They certainly had me terrified!"
}

text ThreeIsland_Port_Text_EverythingTurnedOutForBest {
	"Those BIKERS ran off, and
	LOSTELLE was found safe.

	Everything turned out for the best!"
}
