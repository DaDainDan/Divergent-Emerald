mapscripts FuchsiaCity_Mart_Frlg_MapScripts {}

script FuchsiaCity_Mart_EventScript_CooltrainerF {
    msgbox(FuchsiaCity_Mart_Text_DidYouTryXSpeed, MSGBOX_NPC)
    end
}

script FuchsiaCity_Mart_EventScript_Gentleman {
    msgbox(FuchsiaCity_Mart_Text_DontTheyHaveSafariZonePennants, MSGBOX_NPC)
    end
}

script FuchsiaCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(FuchsiaCity_Mart_Items)
    msgbox(gText_PleaseComeAgain)
    release_end
}

mart FuchsiaCity_Mart_Items {
    ITEM_ULTRA_BALL
    ITEM_GREAT_BALL
    ITEM_SUPER_POTION
    ITEM_REVIVE
    ITEM_FULL_HEAL
    ITEM_MAX_REPEL
}

text FuchsiaCity_Mart_Text_DontTheyHaveSafariZonePennants {
	"Don't they have any pennants
	promoting the SAFARI ZONE?

	How about some paper lanterns?
	Aren't there even any calendars?"
}

text FuchsiaCity_Mart_Text_DidYouTryXSpeed {
	"Did you try X SPEED?
	It speeds up a POKéMON in battle."
}
