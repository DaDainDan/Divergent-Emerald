mapscripts SSAnne_2F_Room4_Frlg_MapScripts {}

script SSAnne_2F_Room4_EventScript_Lamar {
    trainerbattle_single(TRAINER_GENTLEMAN_LAMAR, SSAnne_2F_Room4_Text_LamarIntro, SSAnne_2F_Room4_Text_LamarDefeat)
    msgbox(SSAnne_2F_Room4_Text_LamarPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script SSAnne_2F_Room4_EventScript_Dawn {
    trainerbattle_single(TRAINER_LASS_DAWN, SSAnne_2F_Room4_Text_DawnIntro, SSAnne_2F_Room4_Text_DawnDefeat)
    msgbox(SSAnne_2F_Room4_Text_DawnPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text SSAnne_2F_Room4_Text_LamarIntro {
	"Which do you find more worthy,
	a strong or a rare POKéMON?"
}

text SSAnne_2F_Room4_Text_LamarDefeat {
	"I must salute you!"
}

text SSAnne_2F_Room4_Text_LamarPostBattle {
	"Personally, I prefer strong and
	rare POKéMON."
}

text SSAnne_2F_Room4_Text_DawnIntro {
	"I don't believe I saw you at the
	party?"
}

text SSAnne_2F_Room4_Text_DawnDefeat {
	"Take it easy!"
}

text SSAnne_2F_Room4_Text_DawnPostBattle {
	"Oh, I adore your strong POKéMON!
	Oh, how I envy you for them!"
}
