mapscripts PokemonLeague_LancesRoom_Frlg_MapScripts {
    MAP_SCRIPT_ON_RESUME {
        setvar(VAR_0x8004, 3)
		call(PokemonLeague_EventScript_DoLightingEffect)
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_MAP_SCENE_POKEMON_LEAGUE) == 4) {
			call(PokemonLeague_LancesRoom_EventScript_SetEntryClosed)
		}
		if (flag(FLAG_DEFEATED_LANCE)) {
			call(PokemonLeague_EventScript_SetDoorOpenLance)
		}
		end
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_TEMP_1, 0 {
			turnobject(LOCALID_PLAYER, DIR_NORTH)
			end
		}
    ]
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_MAP_SCENE_POKEMON_LEAGUE, 3 {
			lockall
			applymovement(LOCALID_PLAYER, PokemonLeague_LancesRoom_Movement_WalkThroughCorridor)
			waitmovement(0)
			setflag(FLAG_TEMP_2)
			call(PokemonLeague_LancesRoom_EventScript_SetEntryClosed)
			playse(SE_UNLOCK)
			special(DrawWholeMapView)
			waitse
			setvar(VAR_MAP_SCENE_POKEMON_LEAGUE, 4)
			releaseall
			end
		}
    ]
}

script PokemonLeague_LancesRoom_EventScript_SetEntryClosed {
    setmetatile(5, 14, METATILE_PokemonLeague_Entry_TopLeft_Closed, 1)
    setmetatile(6, 14, METATILE_PokemonLeague_Entry_TopMid_Closed, 1)
    setmetatile(7, 14, METATILE_PokemonLeague_Entry_TopRight_Closed, 1)
    setmetatile(5, 15, METATILE_PokemonLeague_Entry_BottomLeft_Closed, 1)
    setmetatile(6, 15, METATILE_PokemonLeague_Entry_BottomMid_Closed, 1)
    setmetatile(7, 15, METATILE_PokemonLeague_Entry_BottomRight_Closed, 1)
    setmetatile(6, 16, METATILE_PokemonLeague_Floor_ShadeFull_Lance, 0)
    setmetatile(7, 16, METATILE_PokemonLeague_Floor_ShadeFull_Lance, 0)
    return
}

movement PokemonLeague_LancesRoom_Movement_WalkThroughCorridor {
    // moves(walk_up * 2,  walk_left * 6,  walk_down * 7,  walk_left * 11,  walk_up * 8)
    walk_up * 2
    walk_left * 6
    walk_down * 7
    walk_left * 11
    walk_up * 8
}

script PokemonLeague_LancesRoom_EventScript_Lance {
    lock_faceplayer
    famechecker(FAMECHECKER_LANCE, FCPICKSTATE_COLORED, UpdatePickStateFromSpecialVar8005)
    if (flag(FLAG_DEFEATED_LANCE)) {
        msgbox(PokemonLeague_LancesRoom_Text_PostBattle)
    	release_end
    }
    famechecker(FAMECHECKER_LANCE, 0)
    famechecker(FAMECHECKER_LANCE, 1)
	if (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(PokemonLeague_LancesRoom_Text_RematchIntro)
    } else {
        msgbox(PokemonLeague_LancesRoom_Text_Intro)
    }
    setflag(FLAG_TEMP_3)
    setflag(FLAG_TEMP_5)
	if (flag(FLAG_IS_CHAMPION)) {
        trainerbattle_no_intro(TRAINER_ELITE_FOUR_LANCE_2, PokemonLeague_LancesRoom_Text_Defeat)
    } else {
        trainerbattle_no_intro(TRAINER_ELITE_FOUR_LANCE, PokemonLeague_LancesRoom_Text_Defeat)
    }
    clearflag(FLAG_TEMP_5)
    setvar(VAR_0x8004, 0)
    special(Script_TryGainNewFanFromCounterFrlg)
    setflag(FLAG_DEFEATED_LANCE)
    call(PokemonLeague_EventScript_OpenDoorLance)
    msgbox(PokemonLeague_LancesRoom_Text_PostBattle)
    closemessage
    release_end
}

script PokemonLeague_LancesRoom_EventScript_LanceMoveOutOfWayLeft {
    applymovement(LOCALID_LANCE, moves(walk_left,  step_faster_right))
    waitmovement(0)
    return
}

script PokemonLeague_LancesRoom_EventScript_LanceMoveOutOfWayRight {
    applymovement(LOCALID_LANCE, moves(walk_right,  step_faster_left))
    waitmovement(0)
    return
}

text PokemonLeague_LancesRoom_Text_Intro {
	"Ah! I've heard about you,
	{PLAYER}!

	I lead the ELITE FOUR.

	You can call me LANCE the dragon
	TRAINER.

	You know that dragons are
	mythical POKéMON.

	They're hard to catch and raise,
	but their powers are superior.

	They're virtually indestructible.
	There's no being clever with them.

	Well, are you ready to lose?

	Your LEAGUE challenge ends with
	me, {PLAYER}!{PLAY_BGM}{MUS_RG_ENCOUNTER_GYM_LEADER}"
}

text PokemonLeague_LancesRoom_Text_RematchIntro {
	"Ah!
	So, you've returned, {PLAYER}!

	I lead the ELITE FOUR.

	You can call me LANCE the dragon
	TRAINER.

	You know that dragons are
	mythical POKéMON.

	They're hard to catch and raise,
	but their powers are superior.

	They're virtually indestructible.
	There's no being clever with them.

	Well, are you ready to lose?

	Your LEAGUE challenge ends with
	me, {PLAYER}!{PLAY_BGM}{MUS_RG_ENCOUNTER_GYM_LEADER}"
}

text PokemonLeague_LancesRoom_Text_Defeat {
	"That's it!

	I hate to admit it, but you are a
	POKéMON master!"
}

text PokemonLeague_LancesRoom_Text_PostBattle {
	"I still can't believe my dragons
	lost to you, {PLAYER}.

	You are now the POKéMON LEAGUE
	CHAMPION!

	…Or, you would have been, but
	you have one more challenge left.

	There is one more TRAINER to face!
	His name is…

	{RIVAL}!

	He beat the ELITE FOUR before
	you.

	He is the real POKéMON LEAGUE
	CHAMPION."
}
