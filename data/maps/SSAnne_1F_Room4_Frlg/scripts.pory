mapscripts SSAnne_1F_Room4_Frlg_MapScripts {}

script SSAnne_1F_Room4_EventScript_Woman {
    lock_faceplayer
    if (checkplayergender == MALE) {
        msgbox(SSAnne_1F_Room4_Text_WaiterCherryPiePlease)
    	release_end
    }
    msgbox(SSAnne_1F_Room4_Text_WaitressCherryPiePlease)
    release_end
}

text SSAnne_1F_Room4_Text_WaiterCherryPiePlease {
	"Waiter, I would like a cherry pie,
	please!"
}

text SSAnne_1F_Room4_Text_WaitressCherryPiePlease {
	"Waitress, I would like a cherry
	pie, please!"
}
