mapscripts SootopolisCity_Mart_MapScripts {}

script SootopolisCity_Mart_EventScript_Clerk {
    lock_faceplayer
    message(gText_HowMayIServeYou)
    waitmessage
    pokemart(SootopolisCity_Mart_Pokemart)
    msgbox(gText_PleaseComeAgain, MSGBOX_DEFAULT)
    release_end
}

mart SootopolisCity_Mart_Pokemart {
    ITEM_ULTRA_BALL
    ITEM_HYPER_POTION
    ITEM_MAX_POTION
    ITEM_FULL_HEAL
    ITEM_REVIVE
    ITEM_MAX_REPEL
    ITEM_X_ATTACK
    ITEM_X_DEFENSE
    ITEM_SHADOW_MAIL
}

script SootopolisCity_Mart_EventScript_FatMan {
    lock_faceplayer
    if (var(VAR_SKY_PILLAR_STATE) >= 2 || !flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN)) {
        msgbox(SootopolisCity_Mart_Text_PPUpIsGreat, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Mart_Text_TooScaryOutside, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_Mart_EventScript_Gentleman {
    lock_faceplayer
    if (var(VAR_SKY_PILLAR_STATE) >= 2 || !flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN)) {
        msgbox(SootopolisCity_Mart_Text_FullRestoreItemOfDreams, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Mart_Text_DidSomethingAwaken, MSGBOX_DEFAULT)
    release_end
}

text SootopolisCity_Mart_Text_PPUpIsGreat {
	"PP UP is great!

	It raises the POWER POINTS, the PP,
	of a POKéMON move."
}

text SootopolisCity_Mart_Text_TooScaryOutside {
	"What…
	What is happening?

	I really want to know, but it's too
	scary to go outside."
}

text SootopolisCity_Mart_Text_FullRestoreItemOfDreams {
	"Do you know FULL RESTORE?

	Full restoration of HP!
	Eradication of all status problems!

	It's truly an item of your dreams!"
}

text SootopolisCity_Mart_Text_DidSomethingAwaken {
	"This weather…
	Did something awaken?"
}
