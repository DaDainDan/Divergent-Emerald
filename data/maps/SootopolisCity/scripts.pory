movement SootopolisCity_Movement_UnusedPanBack {
    // moves(walk_down * 11,  creep_diag_southwest * 2)
    walk_down * 11
    creep_diag_southwest * 2
}

script SootopolisCity_EventScript_CaveOfOriginExpert {
    lock_faceplayer
    if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 6) {
        msgbox(SootopolisCity_Text_CaveOfOriginSleepsToo, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_AwakenedPokemonClash, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) >= 2) {
        msgbox(SootopolisCity_Text_LeadSuperiorTrainerToCave, MSGBOX_DEFAULT)
    }
	else {
		msgbox(SootopolisCity_Text_CaveOfOriginPleaseLeave, MSGBOX_DEFAULT)
	}
    release_end
}

script SootopolisCity_EventScript_Kiri {
    lock_faceplayer
    if (var(VAR_SOOTOPOLIS_CITY_STATE) <= 1 || var(VAR_SOOTOPOLIS_CITY_STATE) >= 6) {
        goto(SootopolisCity_EventScript_KiriGiveBerry)
    }
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_PrettyMonCameFromSky, MSGBOX_DEFAULT)
		closemessage
		release_end
    }
    msgbox(SootopolisCity_Text_BigPokemonFighting, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_KIRI, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    release_end
}

// Gives 2 berries daily. First ranges from BERRY_ID_POMEG to BERRY_ID_NOMEL, second is always Figy or Iapapa
script SootopolisCity_EventScript_KiriGiveBerry {
    dotimebasedevents
    special(GetPlayerBigGuyGirlString)
    if (flag(FLAG_DAILY_SOOTOPOLIS_RECEIVED_BERRY)) {
        msgbox(SootopolisCity_Text_LikeSeasonBornIn, MSGBOX_YESNO)
		if (var(VAR_RESULT) == YES) {
			msgbox(SootopolisCity_Text_ThenILoveAutumn, MSGBOX_DEFAULT)
			release_end
		}
		msgbox(SootopolisCity_Text_OhDoesntMatter, MSGBOX_DEFAULT)
		release_end
    }
    msgbox(SootopolisCity_Text_NameIsKiriHaveOneOfThese, MSGBOX_DEFAULT)
    giverandomberry(BERRY_ID_POMEG, BERRY_ID_NOMEL)
    if (var(VAR_RESULT) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    setflag(FLAG_DAILY_SOOTOPOLIS_RECEIVED_BERRY)
    msgbox(SootopolisCity_Text_GiveYouThisBerryToo, MSGBOX_DEFAULT)
    random(2)
	switch (var(VAR_RESULT)) {
		case 0: setvar(VAR_GIFT_ITEM, ITEM_FIGY_BERRY)
		case 1: setvar(VAR_GIFT_ITEM, ITEM_IAPAPA_BERRY)
	}
    if (giveitem(VAR_GIFT_ITEM) == FALSE) {
        goto(Common_EventScript_ShowBagIsFull)
    }
    msgbox(SootopolisCity_Text_WhatKindOfWishInYourName, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_EventScript_Woman2 {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_WOMAN_2, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_YouBroughtFlyingMon, MSGBOX_DEFAULT)
    } else {
		msgbox(SootopolisCity_Text_WeatherWentWild, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_WOMAN_2, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_Man {
    lock_faceplayer
    if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 6) {
        msgbox(SootopolisCity_Text_CityRegainedCalm, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Text_NoOrdinaryTourist, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_EventScript_Woman1 {
    lock_faceplayer
    if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 6) {
        msgbox(SootopolisCity_Text_NightSkyFavoriteScenery, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_FearedWorstWhenPokemonFlewDown, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) >= 2) {
        msgbox(SootopolisCity_Text_GiganticPokemonFight, MSGBOX_DEFAULT)
    	goto(Common_EventScript_FaceOriginalDirection)
    }
	else {
		msgbox(SootopolisCity_Text_SootopolisSkyBeautiful, MSGBOX_DEFAULT)
	}
    release_end
}

script SootopolisCity_EventScript_NinjaBoy {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_NINJA_BOY, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_ThatWasWicked, MSGBOX_DEFAULT)
    	release_end
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) >= 6 || var(VAR_SOOTOPOLIS_CITY_STATE) <= 1) {
        msgbox(SootopolisCity_Text_WonderWhatWorldIsLike, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(SootopolisCity_Text_ThisIsWicked, MSGBOX_DEFAULT)
    goto(Common_EventScript_FaceOriginalDirection)
	end
}

script SootopolisCity_EventScript_Boy1 {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_BOY_1, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_WhatIsThatGreenPokemon, MSGBOX_DEFAULT)
    }
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        msgbox(SootopolisCity_Text_WhereDidLegendariesGo, MSGBOX_DEFAULT)
    }
    if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 6 || var(VAR_SOOTOPOLIS_CITY_STATE) <= 1) {
        msgbox(SootopolisCity_Text_PhysicallyFitLivingHere, MSGBOX_DEFAULT)
    }
	else {
		msgbox(SootopolisCity_Text_GiantPokemonSuddenlyAppeared, MSGBOX_DEFAULT)
    	goto(Common_EventScript_FaceOriginalDirection)
	}
    release_end
}

script SootopolisCity_EventScript_GymSign {
    msgbox(SootopolisCity_Text_GymSign, MSGBOX_SIGN)
    end
}

script SootopolisCity_EventScript_CitySign {
    msgbox(SootopolisCity_Text_CitySign, MSGBOX_SIGN)
    end
}

script EventScript_ClosedSootopolisDoor {
    msgbox(SootopolisCity_Text_DoorIsClosed, MSGBOX_SIGN)
    end
}

script SootopolisCity_EventScript_Steven {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_STEVEN, Common_Movement_FacePlayer)
    waitmovement(0)
    if (!flag(FLAG_STEVEN_GUIDES_TO_CAVE_OF_ORIGIN)) {
        goto(SootopolisCity_EventScript_StevenLeadPlayerCaveOfOrigin)
    }
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 2) {
        msgbox(SootopolisCity_Text_KnowWhatsNeededToHelpHim, MSGBOX_DEFAULT)
    }
    elif (var(VAR_SOOTOPOLIS_CITY_STATE) == 3 || var(VAR_SOOTOPOLIS_CITY_STATE) == 4) {
        msgbox(SootopolisCity_Text_NeverBeenToSkyPillar, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)) {
        msgbox(SootopolisCity_Text_MaxieArchieLeft, MSGBOX_DEFAULT)
    }
	else {
		msgbox(SootopolisCity_Text_SoThatsRayquaza, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_StevenLeadPlayerCaveOfOrigin {
    msgbox(SootopolisCity_Text_InvolvedWithCrisisComeWithMe, MSGBOX_DEFAULT)
    closemessage
	applymovement(LOCALID_SOOTOPOLIS_STEVEN, SootopolisCity_Movement_StevenStartWalkToCaveOfOrigin)
	switch (var(VAR_FACING)) {
		case DIR_WEST: applymovement(LOCALID_PLAYER, SootopolisCity_Movement_PlayerStartWalkToCaveOfOriginWest)
		case DIR_NORTH: applymovement(LOCALID_PLAYER, SootopolisCity_Movement_PlayerStartWalkToCaveOfOriginNorth)
	}
	waitmovement(0)
    msgbox(SootopolisCity_Text_DoesThisMakeYourFearPokemon, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_SOOTOPOLIS_STEVEN, SootopolisCity_Movement_StevenWalkToCaveOfOrigin)
    applymovement(LOCALID_PLAYER, SootopolisCity_Movement_PlayerWalkToCaveOfOrigin)
    waitmovement(0)
    delay(120)
    applymovement(LOCALID_SOOTOPOLIS_EXPERT, moves(creep_left,  step_faster_right))
    waitmovement(0)
    applymovement(LOCALID_SOOTOPOLIS_STEVEN, SootopolisCity_Movement_StevenArriveCaveEntrance)
    applymovement(LOCALID_PLAYER, moves(delay_16 * 3,  delay_8,  walk_right * 2,  walk_up * 3,  step_faster_right))
    waitmovement(0)
    msgbox(SootopolisCity_Text_HereWereAreHelpWallace, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_STEVEN_GUIDES_TO_CAVE_OF_ORIGIN)
    applymovement(LOCALID_PLAYER, moves(walk_up * 2))
    waitmovement(0)
    warp(MAP_CAVE_OF_ORIGIN_ENTRANCE, 9, 20)
    waitstate
    end
}

movement SootopolisCity_Movement_StevenStartWalkToCaveOfOrigin {
    // moves(walk_up * 3,  walk_right,  walk_up * 11,  walk_left,  walk_up * 4,  walk_left * 4,  walk_up * 11,  step_faster_down)
    walk_up * 3
    walk_right
    walk_up * 11
    walk_left
    walk_up * 4
    walk_left * 4
    walk_up * 11
    step_faster_down
}

movement SootopolisCity_Movement_PlayerStartWalkToCaveOfOriginWest {
    // moves(walk_left,  walk_up * 3,  walk_right,  walk_up * 11,  walk_left,  walk_up * 4,  walk_left * 4,  walk_up * 10)
    walk_left
    walk_up * 3
    walk_right
    walk_up * 11
    walk_left
    walk_up * 4
    walk_left * 4
    walk_up * 10
}

movement SootopolisCity_Movement_PlayerStartWalkToCaveOfOriginNorth {
    // moves(walk_up * 4,  walk_right,  walk_up * 11,  walk_left,  walk_up * 4,  walk_left * 4,  walk_up * 10)
    walk_up * 4
    walk_right
    walk_up * 11
    walk_left
    walk_up * 4
    walk_left * 4
    walk_up * 10
}

movement SootopolisCity_Movement_StevenWalkToCaveOfOrigin {
    // moves(walk_up * 2,  walk_right * 4,  walk_down * 2,  walk_right * 5,  walk_up,  walk_right * 4,  walk_down * 3,  walk_right * 5,  walk_down * 4,  walk_left * 8,  walk_down * 8,  walk_right * 4,  delay_4,  step_faster_left,  delay_16 * 2,  walk_right,  walk_up * 2)
    walk_up * 2
    walk_right * 4
    walk_down * 2
    walk_right * 5
    walk_up
    walk_right * 4
    walk_down * 3
    walk_right * 5
    walk_down * 4
    walk_left * 8
    walk_down * 8
    walk_right * 4
    delay_4
    step_faster_left
    delay_16 * 2
    walk_right
    walk_up * 2
}

movement SootopolisCity_Movement_PlayerWalkToCaveOfOrigin {
    // moves(walk_up * 3,  walk_right * 4,  walk_down * 2,  walk_right * 5,  walk_up,  walk_right * 4,  walk_down * 3,  walk_right * 5,  walk_down * 4,  walk_left * 8,  walk_down * 8,  walk_right * 3)
    walk_up * 3
    walk_right * 4
    walk_down * 2
    walk_right * 5
    walk_up
    walk_right * 4
    walk_down * 3
    walk_right * 5
    walk_down * 4
    walk_left * 8
    walk_down * 8
    walk_right * 3
}

movement SootopolisCity_Movement_StevenArriveCaveEntrance {
    // moves(walk_down * 2,  walk_left,  delay_8,  walk_right,  walk_up * 3,  walk_right,  step_faster_left)
    walk_down * 2
    walk_left
    delay_8
    walk_right
    walk_up * 3
    walk_right
    step_faster_left
}

script SootopolisCity_EventScript_Boy2 {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_BOY_2, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_FlyingMonStoppedRampage, MSGBOX_DEFAULT)
		closemessage
    } else {
		msgbox(SootopolisCity_Text_TwoPokemonArentAngry, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_BOY_2, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_BlackBelt {
    lockall
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        applymovement(LOCALID_SOOTOPOLIS_BLACK_BELT, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(SootopolisCity_Text_GreenOneSettlesThings, MSGBOX_DEFAULT)
    } else {
		msgbox(SootopolisCity_Text_GoRedAndBlueMon, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_BLACK_BELT, Common_Movement_FacePlayer)
		waitmovement(0)
		msgbox(SootopolisCity_Text_DoYouKnowMonNames, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_BLACK_BELT, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_Girl {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_GIRL, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_SootopolisDidntGetWrecked, MSGBOX_DEFAULT)
		closemessage
    } else {
		msgbox(SootopolisCity_Text_SootopolisWillBeWrecked, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_GIRL, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_Maniac {
    lockall
    applymovement(LOCALID_SOOTOPOLIS_MANIAC, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_SawLegendWithOwnEyes, MSGBOX_DEFAULT)
    } else {
		msgbox(SootopolisCity_Text_SeeingLegendWithOwnEyes, MSGBOX_DEFAULT)
		closemessage
		applymovement(LOCALID_SOOTOPOLIS_MANIAC, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
	}
    releaseall
    end
}

script SootopolisCity_EventScript_Wallace {
    lock_faceplayer
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 4) {
        msgbox(SootopolisCity_Text_HaventYouScaledSkyPillar, MSGBOX_DEFAULT)
    	release_end
    }
    if (flag(FLAG_RECEIVED_HM_WATERFALL)) {
        msgbox(SootopolisCity_Text_DazzledByMentor, MSGBOX_DEFAULT)
    	release_end
    }
    if (flag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)) {
        goto(SootopolisCity_EventScript_GiveWaterfall)
    }
    msgbox(SootopolisCity_Text_AquaMagmaDidntMeanHarm, MSGBOX_DEFAULT)
    release_end
}

script SootopolisCity_EventScript_GiveWaterfall {
    msgbox(SootopolisCity_Text_ThankYouForHelpAcceptThis, MSGBOX_DEFAULT)
    giveitem(ITEM_HM_WATERFALL)
    setflag(FLAG_RECEIVED_HM_WATERFALL)
    msgbox(SootopolisCity_Text_ExplainWaterfallGoToGym, MSGBOX_DEFAULT)
    closemessage
    if (var(VAR_FACING) == DIR_WEST) {
        applymovement(LOCALID_SOOTOPOLIS_WALLACE, moves(walk_left,  step_faster_down))
		waitmovement(0)
		copyobjectxytoperm(LOCALID_SOOTOPOLIS_WALLACE)
		setvar(VAR_SOOTOPOLIS_WALLACE_STATE, 2)
    } else {
        applymovement(LOCALID_SOOTOPOLIS_WALLACE, moves(walk_right,  step_faster_down))
		waitmovement(0)
		copyobjectxytoperm(LOCALID_SOOTOPOLIS_WALLACE)
		setvar(VAR_SOOTOPOLIS_WALLACE_STATE, 1)
	}
    release_end
}

script SootopolisCity_EventScript_Maxie {
    lockall
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_AfterAllOurScheming, MSGBOX_DEFAULT)
		setflag(FLAG_MET_MAXIE_SOOTOPOLIS)
		if (flag(FLAG_MET_ARCHIE_SOOTOPOLIS)) {
			goto(SootopolisCity_EventScript_MaxieArchieLeave)
		}
    } else {
		msgbox(SootopolisCity_Text_GroudonPleaseStop, MSGBOX_DEFAULT)
    	closemessage
	}
    releaseall
    end
}

script SootopolisCity_EventScript_Archie {
    lockall
    if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
        msgbox(SootopolisCity_Text_TryingMeaninglessToPokemon, MSGBOX_DEFAULT)
		setflag(FLAG_MET_ARCHIE_SOOTOPOLIS)
		if (flag(FLAG_MET_MAXIE_SOOTOPOLIS)) {
			goto(SootopolisCity_EventScript_MaxieArchieLeave)
		}
    } else {
		msgbox(SootopolisCity_Text_KyogreCalmDown, MSGBOX_DEFAULT)
    	closemessage
	}
    releaseall
    end
}

script SootopolisCity_EventScript_MaxieArchieLeave {
    setflag(FLAG_HIDE_SOOTOPOLIS_CITY_MAXIE)
    setflag(FLAG_HIDE_SOOTOPOLIS_CITY_ARCHIE)
    setflag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)
    clearflag(FLAG_HIDE_MT_PYRE_SUMMIT_MAXIE)
    clearflag(FLAG_HIDE_MT_PYRE_SUMMIT_ARCHIE)
    setvar(VAR_MT_PYRE_STATE, 2)
    warpsilent(MAP_SOOTOPOLIS_CITY, 31, 34)
    waitstate
    releaseall
    end
}

// Unused
movement SootopolisCity_Movement_Levitate {
    // moves(levitate)
    levitate
}

// Unused
movement SootopolisCity_Movement_DestroyTask {
    // moves(destroy_extra_task)
    destroy_extra_task
}

text SootopolisCity_Text_GymSign {
	"SOOTOPOLIS CITY POKéMON GYM
	LEADER: JUAN

	“The GYM LEADER with the beauty
	of pure water!”"
}

text SootopolisCity_Text_CitySign {
	"SOOTOPOLIS CITY

	“The mystical city where history
	slumbers.”"
}

text SootopolisCity_Text_DoorIsClosed {
	"The door is closed."
}

text SootopolisCity_Text_PhysicallyFitLivingHere {
	"Diving in the sea. Climbing up and
	down stairs all the time…

	If you live in this town, you end up
	getting physically fit."
}

text SootopolisCity_Text_GiantPokemonSuddenlyAppeared {
	"These giant POKéMON suddenly appeared
	in the middle of the city!

	And, I've never seen them before!

	Why are they smashing into each
	other like that?

	Why can't they be friends, those
	POKéMON?"
}

text SootopolisCity_Text_WhatIsThatGreenPokemon {
	"What? What? What?
	What is that green POKéMON?!"
}

text SootopolisCity_Text_WhereDidLegendariesGo {
	"GROUDON and KYOGRE…
	Where did they go?

	Will they cause droughts or downpours
	somewhere else?"
}

text SootopolisCity_Text_TwoPokemonArentAngry {
	"I just get this sense somehow that
	the two POKéMON aren't angry.

	I think… They probably can't control
	their own power…"
}

text SootopolisCity_Text_FlyingMonStoppedRampage {
	"That flying POKéMON came down from
	the sky and stopped the rampaging
	POKéMON…"
}

text SootopolisCity_Text_WonderWhatWorldIsLike {
	"I… I've never been out of this city.

	I wonder what the world is like on
	the other side of this round sky?"
}

text SootopolisCity_Text_ThisIsWicked {
	"Wow!
	This is wicked!"
}

text SootopolisCity_Text_ThatWasWicked {
	"Wow!
	That was wicked!"
}

text SootopolisCity_Text_GoRedAndBlueMon {
	"Go for it, red POKéMON!
	Don't back off, blue POKéMON!"
}

text SootopolisCity_Text_DoYouKnowMonNames {
	"… … … … … …

	Hi, do you know the names of those
	POKéMON fighting over there?"
}

text SootopolisCity_Text_GreenOneSettlesThings {
	"I was wondering which one would win,
	the red one or the blue one, but, oh no,
	it's the green one that settles things!

	Talk about a huge turn of events!"
}

text SootopolisCity_Text_SeeingLegendWithOwnEyes {
	"There's an ancient legend that claims
	the land and sea were shaped by
	a colossal battle between POKéMON.

	Well, I'm seeing that happen with
	my very own eyes!

	Whoa! I never expected to be
	witness to something this huge!"
}

text SootopolisCity_Text_SawLegendWithOwnEyes {
	"There's an ancient legend that claims
	the land and sea were shaped by
	a colossal battle between POKéMON.

	Well, I saw that happen with
	my very own eyes!

	Whoa! I never expected to be
	witness to something this huge!"
}

text SootopolisCity_Text_BigPokemonFighting {
	"A big POKéMON is fighting with
	another big POKéMON!

	Please, someone make them stop!"
}

text SootopolisCity_Text_PrettyMonCameFromSky {
	"A pretty POKéMON came down from
	the sky…"
}

text SootopolisCity_Text_SootopolisWillBeWrecked {
	"Oh, no!
	SOOTOPOLIS CITY will get wrecked!"
}

text SootopolisCity_Text_SootopolisDidntGetWrecked {
	"SOOTOPOLIS CITY didn't get wrecked!"
}

text SootopolisCity_Text_NoOrdinaryTourist {
	"Hm!
	You've come all the way to SOOTOPOLIS?
	You're no ordinary tourist.

	But I suppose that doesn't make you
	an extraordinary tourist, either."
}

text SootopolisCity_Text_CityRegainedCalm {
	"The city has regained its calm…"
}

text SootopolisCity_Text_CaveOfOriginPleaseLeave {
	"Who might you be?

	This is the CAVE OF ORIGIN.

	The spirits of POKéMON, becalmed at
	MT. PYRE, are said to be revived here.

	Please leave."
}

text SootopolisCity_Text_LeadSuperiorTrainerToCave {
	"A person with a strong will and
	superior talent…

	A TRAINER who has knowledge and
	experience of many kinds of POKéMON…

	If such a person were to appear, I was
	instructed by WALLACE to lead that
	TRAINER to this CAVE."
}

text SootopolisCity_Text_AwakenedPokemonClash {
	"Oh, my…

	The clash between the two awakened
	POKéMON was quelled by the awakening
	of a third POKéMON…"
}

text SootopolisCity_Text_CaveOfOriginSleepsToo {
	"This is the CAVE OF ORIGIN…

	With the passing of the crisis,
	the cave, too, shall sleep…"
}

text SootopolisCity_Text_SootopolisSkyBeautiful {
	"SOOTOPOLIS sprang up as a town in
	the crater of a volcano.

	If you look up at the sky, the lip of
	the crater is also visible.
	So, all you see is the sky in a circle.

	But that's what makes the sky above
	SOOTOPOLIS the most beautiful."
}

text SootopolisCity_Text_GiganticPokemonFight {
	"When two POKéMON that gigantic
	are fighting that savagely, there's
	not much that we can do."
}

text SootopolisCity_Text_FearedWorstWhenPokemonFlewDown {
	"When that third POKéMON flew down,
	I feared the worst."
}

text SootopolisCity_Text_NightSkyFavoriteScenery {
	"A circle of a night sky framed by
	the crater of a volcano…

	And in that ring, stars flicker and
	blink as if they were alive…
	It's my favorite scenery."
}

text SootopolisCity_Text_WeatherWentWild {
	"The weather was clear this morning,
	but…

	All of a sudden, dark clouds brewed up,
	rain started falling in sheets, and
	there was thunder and lightning, too.

	The weather just went completely
	wild!

	Is all of this because of those
	POKéMON?"
}

text SootopolisCity_Text_YouBroughtFlyingMon {
	"Oh?

	It was you who brought that flying
	POKéMON here?

	Well, aren't you amazing!"
}

text SootopolisCity_Text_GroudonPleaseStop {
	"MAXIE: G… GROUDON…
	Please! Stop what you're doing!

	I know the extent of your power now!

	If you keep going, all HOENN, not just
	SOOTOPOLIS, will be utterly ruined!"
}

text SootopolisCity_Text_AfterAllOurScheming {
	"MAXIE: So the super-ancient POKéMON
	weren't only GROUDON and KYOGRE…

	After all our fruitless scheming and
	frantic efforts, that one POKéMON's
	simple action puts everything right
	again as if nothing had happened…

	Fu…
	Fuhahaha…"
}

text SootopolisCity_Text_KyogreCalmDown {
	"ARCHIE: KYOGRE! What's wrong?!
	Look over here! It's the RED ORB!
	Calm down! KYOGRE!

	… … … … … …
	… … … … … …

	It's no good!
	It's not responding at all!"
}

text SootopolisCity_Text_TryingMeaninglessToPokemon {
	"ARCHIE: KYOGRE and GROUDON both
	flew off to who knows where.

	The weather in HOENN has returned
	to its normal state…

	Haha…
	Hahaha…

	Maybe what we were trying to do was
	something small, even meaningless,
	to POKéMON…"
}

text SootopolisCity_Text_InvolvedWithCrisisComeWithMe {
	"STEVEN: Those POKéMON fighting…
	GROUDON… And KYOGRE…

	The two super-ancient POKéMON
	were awakened from a long sleep…

	And now they are smashing each other
	with their uncontrollable energy…

	…{PLAYER}{KUN}.

	You being here now I'll take to mean
	that you're prepared to become
	involved in this crisis.

	Well, then, there's someone that
	I'd like you to meet.

	Come with me, please."
}

text SootopolisCity_Text_DoesThisMakeYourFearPokemon {
	"STEVEN: Listen, {PLAYER}{KUN}.

	Does seeing GROUDON and KYOGRE make
	you think POKéMON are to be feared?

	But that's not true.
	POKéMON are really more…

	…Why am I asking you this?
	You already know."
}

text SootopolisCity_Text_HereWereAreHelpWallace {
	"STEVEN: Okay, here we are!

	Inside here you'll find someone named
	WALLACE.

	I think you have what's needed to
	help him…"
}

text SootopolisCity_Text_KnowWhatsNeededToHelpHim {
	"STEVEN: I think you have what's
	needed to help him…"
}

text SootopolisCity_Text_NeverBeenToSkyPillar {
	"STEVEN: The SKY PILLAR…

	I've never been there.
	I wonder where it could be?"
}

text SootopolisCity_Text_SoThatsRayquaza {
	"STEVEN: So that's RAYQUAZA…

	It's incredible how the two rampaging
	POKéMON would flee from it in fear…"
}

text SootopolisCity_Text_MaxieArchieLeft {
	"STEVEN: It looks like both MAXIE and
	ARCHIE have gone away somewhere.

	Perhaps they've gone to MT. PYRE to
	return those ORBS…"
}

text SootopolisCity_Text_HaventYouScaledSkyPillar {
	"WALLACE: Oh?
	{PLAYER}{KUN}?

	Haven't you scaled the SKY PILLAR
	yet?

	I'm sure that you can make it to
	the top of the SKY PILLAR…"
}

text SootopolisCity_Text_AquaMagmaDidntMeanHarm {
	"WALLACE: {PLAYER}{KUN}…

	The leaders of TEAM MAGMA and AQUA,
	I don't think they meant harm.

	It wouldn't hurt to hear what they
	have to say for themselves."
}

text SootopolisCity_Text_ThankYouForHelpAcceptThis {
	"WALLACE: {PLAYER}{KUN}…
	My eyes didn't deceive me.

	Thanks to your help, SOOTOPOLIS…
	No, all of HOENN was saved.

	On behalf of the people, I thank you.

	This is a gift from me.
	Please accept it."
}

text SootopolisCity_Text_ExplainWaterfallGoToGym {
	"That HIDDEN MACHINE contains
	WATERFALL.

	If you have the RAIN BADGE, a POKéMON
	that has learned that HM move can
	force its way up waterfalls.

	And where does one get the RAIN BADGE?
	You know, don't you?

	That's right! You have to beat
	the SOOTOPOLIS GYM LEADER.

	When you're all set to go, step through
	that door."
}

text SootopolisCity_Text_DazzledByMentor {
	"WALLACE: I'm sure that you will be
	dazzled by my mentor's breathtakingly
	elegant battle style."
}
