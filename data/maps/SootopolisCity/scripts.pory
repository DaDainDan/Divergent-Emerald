mapscripts SootopolisCity_MapScripts {
    MAP_SCRIPT_ON_LOAD {
        if (!flag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)) {
			setmetatile(31, 32, METATILE_Sootopolis_GymDoor_Closed, TRUE)
		}
		if (flag(FLAG_KYOGRE_ESCAPED_SEAFLOOR_CAVERN) && !flag(FLAG_SOOTOPOLIS_ARCHIE_MAXIE_LEAVE)) {
			setmetatile(9, 6, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(9, 17, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(9, 26, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(44, 17, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(8, 35, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(53, 28, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(45, 6, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(48, 25, METATILE_Sootopolis_Door_Closed, TRUE)
			setmetatile(51, 36, METATILE_Sootopolis_Door_Closed, TRUE)
		}
		end
    }
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_VISITED_SOOTOPOLIS_CITY)
		if (var(VAR_SOOTOPOLIS_CITY_STATE) == 1 || var(VAR_SKY_PILLAR_STATE) == 1) {
			setflag(FLAG_HIDE_MAP_NAME_POPUP)
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 1 && var(VAR_SOOTOPOLIS_CITY_STATE) < 6) {
			if (var(VAR_SOOTOPOLIS_CITY_STATE) == 1 || var(VAR_SKY_PILLAR_STATE) == 1) {
				setweather(WEATHER_DOWNPOUR)
			}
			elif (var(VAR_SKY_PILLAR_STATE) == 0) {
				call(Common_EventScript_SetAbnormalWeather)
			}
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 1 && var(VAR_SOOTOPOLIS_CITY_STATE) < 6) {
			if (var(VAR_SOOTOPOLIS_CITY_STATE) <= 4 || var(VAR_SKY_PILLAR_STATE) <= 1) {
				setmaplayoutindex(LAYOUT_SOOTOPOLIS_CITY_LEGENDS_BATTLE)
			}
			setobjectxyperm(LOCALID_KIRI, 13, 48)
			setobjectxyperm(LOCALID_SOOTOPOLIS_BOY_1, 46, 32)
			setobjectxyperm(LOCALID_SOOTOPOLIS_NINJA_BOY, 48, 41)
			setobjectxyperm(LOCALID_SOOTOPOLIS_WOMAN_1, 45, 43)
			setobjectmovementtype(LOCALID_KIRI, MOVEMENT_TYPE_FACE_UP)
			setobjectmovementtype(LOCALID_SOOTOPOLIS_BOY_1, MOVEMENT_TYPE_FACE_LEFT)
			setobjectmovementtype(LOCALID_SOOTOPOLIS_NINJA_BOY, MOVEMENT_TYPE_FACE_LEFT)
			setobjectmovementtype(LOCALID_SOOTOPOLIS_WOMAN_1, MOVEMENT_TYPE_FACE_LEFT)
		}
		if ((var(VAR_SOOTOPOLIS_CITY_STATE) == 2 || var(VAR_SOOTOPOLIS_CITY_STATE) == 3) && flag(FLAG_STEVEN_GUIDES_TO_CAVE_OF_ORIGIN)) {
			setobjectxyperm(LOCALID_SOOTOPOLIS_EXPERT, 30, 18)
			setobjectxyperm(LOCALID_SOOTOPOLIS_STEVEN, 32, 18)
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) == 4) {
			setobjectxyperm(LOCALID_SOOTOPOLIS_EXPERT, 30, 18)
			setobjectxyperm(LOCALID_SOOTOPOLIS_WALLACE, 31, 18)
			setobjectxyperm(LOCALID_SOOTOPOLIS_STEVEN, 32, 18)
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) == 5) {
			setobjectxyperm(LOCALID_SOOTOPOLIS_EXPERT, 31, 18)
			setobjectxyperm(LOCALID_SOOTOPOLIS_STEVEN, 29, 33)
			setobjectxyperm(LOCALID_SOOTOPOLIS_MAXIE, 33, 35)
			setobjectxyperm(LOCALID_SOOTOPOLIS_ARCHIE, 34, 35)
			switch (var(VAR_SOOTOPOLIS_WALLACE_STATE)) {
				case 0: setobjectxyperm(LOCALID_SOOTOPOLIS_WALLACE, 31, 33)
				case 1: setobjectxyperm(LOCALID_SOOTOPOLIS_WALLACE, 32, 33)
				case 2: setobjectxyperm(LOCALID_SOOTOPOLIS_WALLACE, 30, 33)
			}
			setobjectmovementtype(LOCALID_SOOTOPOLIS_WALLACE, MOVEMENT_TYPE_FACE_DOWN)
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) == 6) {
			setobjectxyperm(LOCALID_SOOTOPOLIS_EXPERT, 31, 18)
		}
		end
    }
    MAP_SCRIPT_ON_RESUME {
        setdivewarp(MAP_UNDERWATER_SOOTOPOLIS_CITY, 9, 6)
    	end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SOOTOPOLIS_CITY_STATE, 1: SootopolisCity_EventScript_StartKyogreGroudonScene
    	VAR_SKY_PILLAR_STATE, 1: SootopolisCity_EventScript_StartRayquazaScene
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_SOOTOPOLIS_CITY_STATE, 5 {
			switch (var(VAR_SKY_PILLAR_STATE)) {
				case 1: turnobject(LOCALID_PLAYER, DIR_NORTH)
				case 2: 
					turnobject(LOCALID_PLAYER, DIR_NORTH)
					setvar(VAR_SKY_PILLAR_STATE, 3)
			}
			end
		}
    ]
}

script SootopolisCity_EventScript_StartKyogreGroudonScene {
    lockall
	call(SootopolisCity_EventScript_LegendSceneIntro)
    goto(SootopolisCity_EventScript_KyogreGroudonScene)
    end
}

// If not at PokeCenter, assumed to have arrived via Dive
script SootopolisCity_EventScript_LegendSceneIntro {
	setvar(VAR_0x8002, 0)
    special(StorePlayerCoordsInVars)
    if (var(VAR_0x8004) != 43 || var(VAR_0x8005) != 32) {
        setvar(VAR_0x8002, 1)
    }
	delay(60)
    special(SpawnCameraObject)
	switch (var(VAR_0x8002)) {
		case 0: applymovement(LOCALID_CAMERA, moves(creep_diag_southwest * 12))
		case 1: applymovement(LOCALID_CAMERA, moves(creep_diag_northeast * 2,  walk_up * 7))
	}
    waitmovement(0)
    special(RemoveCameraObject)
    delay(60)
    fadescreenspeed(FADE_TO_BLACK, 8)
	return
}

script SootopolisCity_EventScript_KyogreGroudonScene {
    setweather(WEATHER_ABNORMAL)
    doweather
    setvar(VAR_0x8004, FALSE) // Just do Groudon/Kyogre fight scene
    special(Script_DoRayquazaScene)
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(60)
    waitse
    playmoncry(SPECIES_KYOGRE, CRY_MODE_ENCOUNTER)
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, SootopolisCity_Movement_KyogreAttack)
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(delay_16 * 9,  run_right))
    waitmovement(0)
    setvar(VAR_0x8004, 1) // vertical pan
    setvar(VAR_0x8005, 1) // horizontal pan
    setvar(VAR_0x8006, 8) // num shakes
    setvar(VAR_0x8007, 5) // shake delay
    special(ShakeCamera)
    waitstate
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, moves(lock_look,  walk_right,  delay_16 * 3,  unlock_look))
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(lock_look,  walk_left,  delay_16 * 3,  unlock_look))
    waitmovement(0)
    waitse
    playmoncry(SPECIES_GROUDON, CRY_MODE_ENCOUNTER)
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, moves(delay_16 * 9,  init_affine_anim,  walk_left_affine,  clear_affine_anim))
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(step_slow_right * 3,  delay_16 * 3,  run_right))
    waitmovement(0)
    setvar(VAR_0x8004, 1) // vertical pan
    setvar(VAR_0x8005, 1) // horizontal pan
    setvar(VAR_0x8006, 8) // num shakes
    setvar(VAR_0x8007, 5) // shake delay
    special(ShakeCamera)
    waitstate
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, moves(lock_look,  walk_right,  delay_16 * 3,  unlock_look))
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(lock_look,  walk_left,  delay_16 * 3,  unlock_look))
    waitmovement(0)
    waitse
    playmoncry(SPECIES_KYOGRE, CRY_MODE_ENCOUNTER)
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, SootopolisCity_Movement_KyogreAttack)
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(delay_16 * 9,  run_right))
    waitmovement(0)
    setvar(VAR_0x8004, 1) // vertical pan
    setvar(VAR_0x8005, 1) // horizontal pan
    setvar(VAR_0x8006, 8) // num shakes
    setvar(VAR_0x8007, 5) // shake delay
    special(ShakeCamera)
    waitstate
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, moves(lock_look,  walk_right,  delay_16 * 3,  unlock_look))
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(lock_look,  walk_left,  delay_16 * 3,  unlock_look))
    waitmovement(0)
    special(SpawnCameraObject)
    applymovement(LOCALID_SOOTOPOLIS_KYOGRE, moves(step_slow_left * 6))
    applymovement(LOCALID_SOOTOPOLIS_GROUDON, moves(step_slow_right * 6))
	switch (var(VAR_0x8002)) {
		case 0: applymovement(LOCALID_CAMERA, moves(creep_diag_northeast * 12))
		case 1: applymovement(LOCALID_CAMERA, moves(walk_down * 7,  creep_diag_southwest * 2))
	}
    waitmovement(0)
    special(RemoveCameraObject)
    setvar(VAR_SOOTOPOLIS_CITY_STATE, 2)
    clearflag(FLAG_HIDE_MAP_NAME_POPUP)
    releaseall
    end
}

movement SootopolisCity_Movement_KyogreAttack {
    // moves(step_slow_left * 3,  delay_16 * 3,  init_affine_anim,  walk_left_affine,  clear_affine_anim)
    step_slow_left * 3
    delay_16 * 3
    init_affine_anim
    walk_left_affine
    clear_affine_anim
}

script SootopolisCity_EventScript_StartRayquazaScene {
    lockall
	call(SootopolisCity_EventScript_LegendSceneIntro)
    goto(SootopolisCity_EventScript_RayquazaScene)
    end
}

script SootopolisCity_EventScript_RayquazaScene {
    call(SootopolisCity_EventScript_SetRoughWater)
    removeobject(LOCALID_SOOTOPOLIS_GROUDON)
    removeobject(LOCALID_SOOTOPOLIS_KYOGRE)
    addobject(LOCALID_SOOTOPOLIS_RAYQUAZA)
	if (var(VAR_0x8002) == 0) {
		hideobjectat(LOCALID_SOOTOPOLIS_RAYQUAZA, MAP_SOOTOPOLIS_CITY)
	}
    setvar(VAR_0x8004, TRUE)
    special(Script_DoRayquazaScene)
	if (var(VAR_0x8002) == 0) {
		playse(SE_THUNDER)
	}
    special(SpawnCameraObject)
    applymovement(LOCALID_CAMERA, moves(walk_up * 4))
	if (var(VAR_0x8002) == 1) {
		applymovement(LOCALID_PLAYER, moves(walk_up * 4))
	}
    waitmovement(0)
    waitse
    playmoncry(SPECIES_RAYQUAZA, CRY_MODE_ENCOUNTER)
    setvar(VAR_0x8004, 1) // vertical pan
    setvar(VAR_0x8005, 1) // horizontal pan
    setvar(VAR_0x8006, 8) // num shakes
    setvar(VAR_0x8007, 3) // shake delay
    special(ShakeCamera)
    waitstate
    waitse
    playmoncry(SPECIES_RAYQUAZA, CRY_MODE_ENCOUNTER)
    setvar(VAR_0x8004, 1) // vertical pan
    setvar(VAR_0x8005, 2) // horizontal pan
    setvar(VAR_0x8006, 8) // num shakes
    setvar(VAR_0x8007, 5) // shake delay
    special(ShakeCamera)
    waitstate
    waitmoncry
    setweather(WEATHER_NONE)
    doweather
    applymovement(LOCALID_SOOTOPOLIS_RAYQUAZA, moves(run_up,  sprint_up * 6))
    waitmovement(0)
    removeobject(LOCALID_SOOTOPOLIS_RAYQUAZA)
    special(WaitWeather)
    clearflag(FLAG_SYS_WEATHER_CTRL)
	switch (var(VAR_0x8002)) {
		case 0: setvar(VAR_SKY_PILLAR_STATE, 3)
		case 1: setvar(VAR_SKY_PILLAR_STATE, 2)
	}
    clearflag(FLAG_LEGENDARIES_IN_SOOTOPOLIS)
	fadenewbgm(MUS_CAVE_OF_ORIGIN)
    delay(120)
    clearflag(FLAG_HIDE_MAP_NAME_POPUP)
	switch (var(VAR_0x8002)) {
		case 0: warpwhitefade(MAP_SOOTOPOLIS_CITY, 43, 32)
		case 1: warpwhitefade(MAP_SOOTOPOLIS_CITY, 29, 53)
	}
    waitstate
    end
}

