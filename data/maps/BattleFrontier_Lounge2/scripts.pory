mapscripts BattleFrontier_Lounge2_MapScripts {}

script BattleFrontier_Lounge2_EventScript_FrontierManiac {
    lock_faceplayer
    if (flag(FLAG_MET_BATTLE_FRONTIER_MANIAC)) {
        msgbox(BattleFrontier_Lounge2_Text_SwingByForTheLatestWord, MSGBOX_DEFAULT)
    } else {
		setflag(FLAG_MET_BATTLE_FRONTIER_MANIAC)
    	msgbox(BattleFrontier_Lounge2_Text_FrontierManiacIntro, MSGBOX_DEFAULT)
	}
    goto(BattleFrontier_Lounge2_EventScript_GiveAdvice)
    end
}

script BattleFrontier_Lounge2_EventScript_GiveAdvice {
	switch (var(VAR_FRONTIER_MANIAC_FACILITY)) {
		case FRONTIER_MANIAC_TOWER_SINGLES: bufferstdstring(STR_VAR_1, STDSTRING_SINGLE)
		case FRONTIER_MANIAC_TOWER_DOUBLES: bufferstdstring(STR_VAR_1, STDSTRING_DOUBLE)
		case FRONTIER_MANIAC_TOWER_MULTIS: bufferstdstring(STR_VAR_1, STDSTRING_MULTI)
		case FRONTIER_MANIAC_TOWER_LINK: bufferstdstring(STR_VAR_1, STDSTRING_MULTI_LINK)
		case FRONTIER_MANIAC_DOME: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_DOME)
		case FRONTIER_MANIAC_FACTORY: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_FACTORY)
		case FRONTIER_MANIAC_PALACE: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_PALACE)
		case FRONTIER_MANIAC_ARENA: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_ARENA)
		case FRONTIER_MANIAC_PIKE: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_PIKE)
		case FRONTIER_MANIAC_PYRAMID: bufferstdstring(STR_VAR_1, STDSTRING_BATTLE_PYRAMID)
	}
    // <= FRONTIER_MANIAC_TOWER_LINK is any Battle Tower mode
    if (var(VAR_FRONTIER_MANIAC_FACILITY) <= FRONTIER_MANIAC_TOWER_LINK) {
        msgbox(BattleFrontier_Lounge2_Text_BattleTowerIsHottest, MSGBOX_DEFAULT)
    }
    // >= FRONTIER_MANIAC_DOME is any facility other than Battle Tower
    if (var(VAR_FRONTIER_MANIAC_FACILITY) >= FRONTIER_MANIAC_DOME) {
        msgbox(BattleFrontier_Lounge2_Text_FacilityIsHottest, MSGBOX_DEFAULT)
    }
    special(ShowFrontierManiacMessage)
    waitmessage
    waitbuttonpress
    release_end
}

script BattleFrontier_Lounge2_EventScript_Maniac1 {
    lock
    msgbox(BattleFrontier_Lounge2_Text_NewsGatheringPower, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge2_EventScript_Maniac2 {
    lock
    msgbox(BattleFrontier_Lounge2_Text_AmazingPowersOfObservation, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge2_EventScript_Maniac3 {
    lock
    msgbox(BattleFrontier_Lounge2_Text_AmazingPowerOfPersuasion, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge2_EventScript_TriathleteF {
    msgbox(BattleFrontier_Lounge2_Text_ThisPlaceIsScaringMe, MSGBOX_NPC)
    end
}

text BattleFrontier_Lounge2_Text_FrontierManiacIntro {
	"Howdy! When it comes to news about
	the BATTLE FRONTIER, I'm no. 1.

	You can think of me as
	the FRONTIER MANIAC.

	Just checking, but you are a TRAINER,
	isn't that right?

	I'll happily share the hottest news
	I gathered about the BATTLE FRONTIER."
}

text BattleFrontier_Lounge2_Text_SwingByForTheLatestWord {
	"Howdy! Did you swing by to grill me
	about the latest word? Oh, all right!"
}

text BattleFrontier_Lounge2_Text_MyInformationsBeenUsefulRight {
	"Well? Well? Well?

	I'm sure my information's been
	seriously useful to you, right?"
}

text BattleFrontier_Lounge2_Text_FacilityIsHottest {
	"Let's see now…

	It sounds like the {STR_VAR_1}
	is the hottest place going."
}

text BattleFrontier_Lounge2_Text_BattleTowerIsHottest {
	"Let's see now…

	It sounds like BATTLE TOWER
	{STR_VAR_1} is the hottest."
}

text BattleFrontier_Lounge2_Text_SalonMaidenIsThere {
	"Bet you didn't know this!

	One of those top TRAINERS that SCOTT
	calls the FRONTIER BRAINS is there.

	It's this mysterious TRAINER called
	the SALON MAIDEN that runs the place."
}

text BattleFrontier_Lounge2_Text_SalonMaidenSilverMons {
	"Have you battled the SALON MAIDEN?

	When she's measuring up her opponent,
	she apparently uses these POKéMON:

	A PSYCHIC-type PSI POKéMON,
	a FIRE-type VOLCANO POKéMON,
	and a NORMAL-type SLEEPING POKéMON."
}

text BattleFrontier_Lounge2_Text_SalonMaidenGoldMons {
	"Have you battled the SALON MAIDEN
	when she's serious?

	When she's battling flat out,
	she apparently uses these POKéMON:

	A DRAGON & PSYCHIC EON POKéMON,
	an ELECTRIC-type THUNDER POKéMON,
	and a NORMAL-type SLEEPING POKéMON."
}

text BattleFrontier_Lounge2_Text_DomeAceIsThere {
	"Bet you didn't know this!

	One of those top TRAINERS that SCOTT
	calls the FRONTIER BRAINS is there.

	It's this flamboyant TRAINER called
	the DOME ACE that runs the place."
}

text BattleFrontier_Lounge2_Text_DomeAceSilverMons {
	"Have you battled the DOME ACE?

	When he's treating the opponent
	lightly, he uses these three POKéMON:

	A DRAGON & FLYING DRAGON POKéMON,
	a WATER & GROUND MUD FISH POKéMON,
	and a FIRE & FLYING FLAME POKéMON."
}

text BattleFrontier_Lounge2_Text_DomeAceGoldMons {
	"Have you battled the DOME ACE
	when he's serious?

	When he's demonstrating his strategy,
	he uses these three POKéMON:

	A DRAGON & FLYING EON POKéMON,
	a WATER & GROUND MUD FISH POKéMON,
	and a STEEL- & PSYCHIC-type IRON LEG
	POKéMON."
}

text BattleFrontier_Lounge2_Text_FactoryHeadIsThere {
	"Bet you didn't know this!

	One of those top TRAINERS that SCOTT
	calls the FRONTIER BRAINS is there.

	It's this freaky TRAINER called
