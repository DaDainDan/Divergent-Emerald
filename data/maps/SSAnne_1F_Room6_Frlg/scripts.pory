mapscripts SSAnne_1F_Room6_Frlg_MapScripts {}

script SSAnne_1F_Room6_EventScript_Woman {
    lock_faceplayer
    msgbox(SSAnne_1F_Room6_Text_TakeAShortRest, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        closemessage
		call(Common_EventScript_OutOfCenterPartyHeal)
		msgbox(SSAnne_1F_Room6_Text_GladEveryoneIsRefreshed)
    }
	elif (checkplayergender == MALE) {
		msgbox(SSAnne_1F_Room6_Text_SorryYouLookLikeMyBrother)
	}
	else {
		msgbox(SSAnne_1F_Room6_Text_SorryYouLookLikeMySister)
	}
	release_end
}

text SSAnne_1F_Room6_Text_TakeAShortRest {
	"You look tired. Would you like to
	take a short rest?"
}

text SSAnne_1F_Room6_Text_GladEveryoneIsRefreshed {
	"I'm glad to see that everyone is
	looking refreshed and chipper."
}

text SSAnne_1F_Room6_Text_SorryYouLookLikeMyBrother {
	"Oh, I'm sorry for fussing over you.
	You look like my little brother…"
}

text SSAnne_1F_Room6_Text_SorryYouLookLikeMySister {
	"Oh, I'm sorry for fussing over you.
	You look like my little sister…"
}
