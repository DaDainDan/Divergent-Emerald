mapscripts PetalburgCity_WallysHouse_MapScripts {
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_PETALBURG_CITY_STATE, 4: PetalburgCity_WallysHouse_EventScript_GiveHMSurf
    ]
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_PETALBURG_CITY_STATE, 4 {
			turnobject(LOCALID_PLAYER, DIR_EAST)
			turnobject(LOCALID_WALLYS_HOUSE_WALLYS_DAD, DIR_WEST)
			end
		}
    ]
}

script PetalburgCity_WallysHouse_EventScript_GiveHMSurf {
    lockall
    msgbox(PetalburgCity_WallysHouse_Text_PleaseExcuseUs, MSGBOX_DEFAULT)
    giveitem(ITEM_HM_SURF)
    setflag(FLAG_RECEIVED_HM_SURF)
    msgbox(PetalburgCity_WallysHouse_Text_SurfGoAllSortsOfPlaces, MSGBOX_DEFAULT)
    setvar(VAR_PETALBURG_CITY_STATE, 5)
    releaseall
    end
}

script PetalburgCity_WallysHouse_EventScript_WallysDad {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_WALLY_VICTORY_ROAD)) {
        msgbox(PetalburgCity_WallysHouse_Text_YouMetWallyInEverGrandeCity, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_RECEIVED_HM_SURF)) {
        msgbox(PetalburgCity_WallysHouse_Text_WallyIsComingHomeSoon, MSGBOX_DEFAULT)
    }
    elif (flag(FLAG_THANKED_FOR_PLAYING_WITH_WALLY)) {
        msgbox(PetalburgCity_WallysHouse_Text_WonderHowWallyIsDoing, MSGBOX_DEFAULT)
    }
	else {
		msgbox(PetalburgCity_WallysHouse_Text_ThanksForPlayingWithWally, MSGBOX_DEFAULT)
    	setflag(FLAG_THANKED_FOR_PLAYING_WITH_WALLY)
	}
    release_end
}

script PetalburgCity_WallysHouse_EventScript_WallysMom {
    lock_faceplayer
    if (flag(FLAG_RECEIVED_HM_SURF)) {
        msgbox(PetalburgCity_WallysHouse_Text_WallyLeftWithoutTelling, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(PetalburgCity_WallysHouse_Text_WallyWasReallyHappy, MSGBOX_DEFAULT)
    release_end
}

text PetalburgCity_WallysHouse_Text_ThanksForPlayingWithWally {
	"You're…
	Ah, you must be {PLAYER}{KUN}, right?

	Thank you for playing with WALLY a
	little while ago.

	He's been frail and sickly ever
	since he was a baby.

	We've sent him to stay with my relatives
	in VERDANTURF TOWN for a while.

	The air is a lot cleaner there
	than it is here.

	What's that? Where's WALLY?
	He's already left, our WALLY.

	I wonder where he could have
	gotten by now?"
}

text PetalburgCity_WallysHouse_Text_WonderHowWallyIsDoing {
	"I wonder how our WALLY is doing?"
}

text PetalburgCity_WallysHouse_Text_PleaseExcuseUs {
	"{PLAYER}{KUN}! Please excuse us for
	dragging you here this way.

	But our WALLY's become very healthy
	since he went to VERDANTURF TOWN.

	We owe it all to you!

	When WALLY left town, you helped
	him catch a POKéMON, right?

	I think that made WALLY really
	happy.

	Actually, not just WALLY.
	It made me, his father, happy too.

	Happy that he's gained such a great
	friend as you.

	This isn't a bribe or anything, but
	I'd really like you to have this."
}

text PetalburgCity_WallysHouse_Text_SurfGoAllSortsOfPlaces {
	"If your POKéMON can SURF, you'll be
	able to go to all sorts of places."
}

text PetalburgCity_WallysHouse_Text_WallyIsComingHomeSoon {
	"WALLY's coming home soon.
	I'm looking forward to that."
}

text PetalburgCity_WallysHouse_Text_YouMetWallyInEverGrandeCity {
	"Oh? You met WALLY in
	EVER GRANDE CITY?

	Oh, {PLAYER}{KUN}, don't be silly.

	He may have gotten healthy, but he
	can't go somewhere far away like
	that all by himself."
}

text PetalburgCity_WallysHouse_Text_WallyWasReallyHappy {
	"WALLY was really happy when he told
	us that he caught a POKéMON.

	It's been ages since I've seen him
	smile like that."
}

text PetalburgCity_WallysHouse_Text_WallyLeftWithoutTelling {
	"I want you to keep this a secret
	from my husband…

	But our WALLY left VERDANTURF TOWN
	without telling anyone.

	You know, WALLY is frail, but
	he's surprisingly strong-willed.

	I'm sure that he'll come back safe
	and sound one day!"
}
