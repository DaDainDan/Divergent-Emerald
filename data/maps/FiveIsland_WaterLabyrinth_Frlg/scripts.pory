mapscripts FiveIsland_WaterLabyrinth_Frlg_MapScripts {}

script FiveIsland_WaterLabyrinth_EventScript_EggGentleman {
    lock_faceplayer
    if (flag(FLAG_GOT_TOGEPI_EGG)) {
        goto(FiveIsland_WaterLabyrinth_EventScript_PostEggComment)
    }
    if (flag(FLAG_NO_ROOM_FOR_TOGEPI_EGG)) {
        goto(FiveIsland_WaterLabyrinth_EventScript_TryGiveEgg)
    }
    msgbox(FiveIsland_WaterLabyrinth_Text_LetMeTakeLookAtMons)
    if (specialvar(VAR_RESULT, GetLeadMonFriendship) == 6) {
        msgbox(FiveIsland_WaterLabyrinth_Text_TreatMonRightHaveThis)
    	goto(FiveIsland_WaterLabyrinth_EventScript_TryGiveEgg)
    }
    msgbox(FiveIsland_WaterLabyrinth_Text_HmmISeeIsee)
    release_end
}

script FiveIsland_WaterLabyrinth_EventScript_TryGiveEgg {
    if (getpartysize == PARTY_SIZE) {
        setflag(FLAG_NO_ROOM_FOR_TOGEPI_EGG)
		msgbox(FiveIsland_WaterLabyrinth_Text_DontHaveSpaceInYourParty)
		release_end
    }
    setflag(FLAG_GOT_TOGEPI_EGG)
    giveegg(SPECIES_TOGEPI)
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    playfanfare(MUS_LEVEL_UP)
    message(FiveIsland_WaterLabyrinth_Text_ReceivedEggFromMan)
    waitfanfare
    waitmessage
    call(EventScript_RestorePrevTextColor)
    goto(FiveIsland_WaterLabyrinth_EventScript_PostEggComment)
    end
}

// If the player has a Togepi/Togetic from this game (assumed to be the one the man gave you) then comment on it
// Otherwise make normal comment
script FiveIsland_WaterLabyrinth_EventScript_PostEggComment {
    bufferspeciesname(STR_VAR_2, SPECIES_TOGEPI)
    setvar(VAR_0x8004, SPECIES_TOGEPI)
    if (specialvar(VAR_RESULT, PlayerPartyContainsSpeciesWithPlayerID) == TRUE) {
        goto(FiveIsland_WaterLabyrinth_EventScript_MonDaisyComment)
    }
    bufferspeciesname(STR_VAR_2, SPECIES_TOGETIC)
    setvar(VAR_0x8004, SPECIES_TOGETIC)
    if (specialvar(VAR_RESULT, PlayerPartyContainsSpeciesWithPlayerID) == TRUE) {
        goto(FiveIsland_WaterLabyrinth_EventScript_MonDaisyComment)
    }
    msgbox(FiveIsland_WaterLabyrinth_Text_GladIMetSomeoneLikeYou)
    release_end
}

script FiveIsland_WaterLabyrinth_EventScript_MonDaisyComment {
    famechecker(FAMECHECKER_DAISY, 2)
    msgbox(FiveIsland_WaterLabyrinth_Text_CuteMonRemindsMeOfDaisy)
    release_end
}

text FiveIsland_WaterLabyrinth_Text_LetMeTakeLookAtMons {
	"You travel all over the place,
	don't you?

	You're not driving your POKéMON
	too harshly, are you?

	Let me take a look.
	… … …   … … …"
}

text FiveIsland_WaterLabyrinth_Text_HmmISeeIsee {
	"Ah, hmm…
	I see, I see…"
}

text FiveIsland_WaterLabyrinth_Text_TreatMonRightHaveThis {
	"Oh, impressive.
	You treat your POKéMON right.

	I think you can be entrusted with
	this.

	Please, I'd like you to have this."
}

text FiveIsland_WaterLabyrinth_Text_ReceivedEggFromMan {
	"{PLAYER} received an EGG
	from the man!"
}

text FiveIsland_WaterLabyrinth_Text_DontHaveSpaceInYourParty {
	"…Unfortunately, you don't have
	space for this in your party.

	You'd better come back for it
	another time."
}

// Unused
text FiveIsland_WaterLabyrinth_Text_YouveComeBackForTheEgg {
	"やあ
	タマゴを　もらいに
	きて　くれたんだね"
}

text FiveIsland_WaterLabyrinth_Text_GladIMetSomeoneLikeYou {
	"I received that EGG while I was
	traveling.

	I'm glad I met someone like you."
}

text FiveIsland_WaterLabyrinth_Text_CuteMonRemindsMeOfDaisy {
	"Oh, hello.
	That's a cute {STR_VAR_2}.

	Seeing it reminds me of a sweet 
	little girl I met while traveling.

	She was gently grooming POKéMON…
	She was a little angel.

	That little girl's name…
	I think it was DAISY."
}

text FiveIsland_WaterLabyrinth_Text_AlizeIntro {
	"This is an excellent environment
	for raising POKéMON."
}

text FiveIsland_WaterLabyrinth_Text_AlizeDefeat {
	"Your POKéMON are growing up
	admirably well!"
}

text FiveIsland_WaterLabyrinth_Text_AlizePostBattle {
	"You know, I think you have the
	talent to be a good BREEDER."
}
