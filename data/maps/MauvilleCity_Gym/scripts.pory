script MauvilleCity_Gym_EventScript_GymGuide {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_MAUVILLE_GYM)) {
        msgbox(MauvilleCity_Gym_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(MauvilleCity_Gym_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

script MauvilleCity_Gym_EventScript_LeftGymStatue {
    lockall
    goto(MauvilleCity_Gym_EventScript_GymStatue)
	end
}

script MauvilleCity_Gym_EventScript_RightGymStatue {
    lockall
    goto(MauvilleCity_Gym_EventScript_GymStatue)
	end
}

script MauvilleCity_Gym_EventScript_GymStatue {
    if (flag(FLAG_BADGE03_GET)) {
        msgbox(MauvilleCity_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(MauvilleCity_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

text MauvilleCity_Gym_Text_GymGuideAdvice {
	"Hey, how's it going, CHAMPION-
	bound {PLAYER}?

	WATTSON, the LEADER of MAUVILLE
	GYM, uses ELECTRIC-type POKéMON.

	If you challenge him with WATER-type
	POKéMON, he'll zap them! Bzzt!

	And, he's put in switch-controlled
	doors all over his GYM! Eccentric!

	Hey, go for it!"
}

text MauvilleCity_Gym_Text_GymGuidePostVictory {
	"Whoa, you're electrifying!
	You've powered the door open!"
}

text MauvilleCity_Gym_Text_KirkIntro {
	"My electric soul, it'll shatter your
	dreams whole, whoa-yeahah!"
}

text MauvilleCity_Gym_Text_KirkDefeat {
	"That was plugged in, amped up,
	over-driven electric, man!"
}

text MauvilleCity_Gym_Text_KirkPostBattle {
	"POKéMON and rock, it's all about heart,
	whoa-yeah!"
}

text MauvilleCity_Gym_Text_ShawnIntro {
	"I trained under WATTSON!
	There ain't no way I'll lose easily!"
}

text MauvilleCity_Gym_Text_ShawnDefeat {
	"Unplugged and turned off…"
}

text MauvilleCity_Gym_Text_ShawnPostBattle {
	"WATTSON, our GYM LEADER, has been
	around for a long, long time.

	He was battling even before your
	daddy was born, that tough coot."
}

text MauvilleCity_Gym_Text_BenIntro {
	"This GYM's got puzzles!
	Isn't it fun?"
}

text MauvilleCity_Gym_Text_BenDefeat {
	"It's no fun to lose…"
}

text MauvilleCity_Gym_Text_BenPostBattle {
	"WATTSON says he likes setting up
	little traps with switches."
}

text MauvilleCity_Gym_Text_VivianIntro {
	"With my charm and my POKéMON's moves,
	you'll be shocked!"
}

text MauvilleCity_Gym_Text_VivianDefeat {
	"I'm shocked by your power!"
}

text MauvilleCity_Gym_Text_VivianPostBattle {
	"I've heard that MAUVILLE was founded
	by WATTSON.

	He was a TRAINER long before we
	became TRAINERS.
	He must know all sorts of things!"
}

text MauvilleCity_Gym_Text_AngeloIntro {
	"I love shiny things!"
}

text MauvilleCity_Gym_Text_AngeloDefeat {
	"Oh…
	My eyes are frazzled…"
}

text MauvilleCity_Gym_Text_AngeloPostBattle {
	"MAUVILLE GYM's WATTSON has a shiny
	forehead. It makes me happy!"
}

text MauvilleCity_Gym_Text_WattsonIntro {
	"I've given up on my plans to convert
	the city, I have.

	And so, I put my time into making
	door traps in my GYM.

	Oh? Now, what are you doing here?

	What's that? You say you've gotten
	past all my rigged doors?

	Wahahahah!
	Now, that is amusing!

	Then, I, WATTSON, the LEADER of
	MAUVILLE GYM, shall electrify you!"
}

text MauvilleCity_Gym_Text_WattsonDefeat {
	"Wahahahah!
	Fine, I lost!

	You ended up giving me a thrill!
	Take this BADGE!"
}

text MauvilleCity_Gym_Text_ReceivedDynamoBadge {
	"{PLAYER} received the DYNAMO BADGE
	from WATTSON."
}

text MauvilleCity_Gym_Text_ExplainDynamoBadgeTakeThis {
	"With the DYNAMO BADGE, POKéMON can
	use ROCK SMASH out of battle.

	And, it will make your POKéMON a little
	bit faster, too.

	Hmm…
	You should take this, too!"
}

text MauvilleCity_Gym_Text_ExplainShockWave {
	"That TM34 there contains SHOCK WAVE.

	It's a trustworthy move that never
	misses! You can count on it!

	… … … … … …"
}

text MauvilleCity_Gym_Text_RegisteredWattson {
	"Registered GYM LEADER WATTSON
	in the POKéNAV."
}

text MauvilleCity_Gym_Text_WattsonPostBattle {
	"I swell with optimism, seeing a promising
	young TRAINER like you!"
}

text MauvilleCity_Gym_Text_WattsonGoForthAndEndeavor {
	"Wahahahah!
	Go forth and endeavor, youngster!"
}

text MauvilleCity_Gym_Text_GymStatue {
	"MAUVILLE CITY POKéMON GYM"
}

text MauvilleCity_Gym_Text_GymStatueCertified {
	"MAUVILLE CITY POKéMON GYM

	WATTSON'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text MauvilleCity_Gym_Text_WattsonPreRematch {
	"WATTSON: Ah-ha! Here at last!
	I know what you want.
	You want to battle my POKéMON!

	Wahahahaha!

	I'll make sparks fly from you!
	Don't say I didn't warn you!"
}

text MauvilleCity_Gym_Text_WattsonRematchDefeat {
	"Oof…
	Our batteries ran dry…"
}

text MauvilleCity_Gym_Text_WattsonPostRematch {
	"WATTSON: We'll have to recharge our
	batteries again.

	When we're fully charged up, we'll
	gladly accept your challenge.

	So, come back again sometime,
	won't you?"
}

text MauvilleCity_Gym_Text_WattsonRematchNeedTwoMons {
	"WATTSON: Ah-ha! Here at last!
	I know what you want.
	You want to battle my POKéMON!

	Wahahahaha!

	Oops! Wait!
	You've only one POKéMON with you!

	Come see me with two or more
	POKéMON, all right?"
}
