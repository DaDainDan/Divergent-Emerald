mapscripts PetalburgCity_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setflag(FLAG_VISITED_PETALBURG_CITY)
		switch(var(VAR_PETALBURG_CITY_STATE)) {
			case 0: setobjectxyperm(LOCALID_GYM_BOY, 5, 15)
			case 2:
			case 4:
				setflag(FLAG_HIDE_MAP_NAME_POPUP)
				savebgm(MUS_FOLLOW_ME)
		}
		if (var(VAR_PETALBURG_GYM_STATE) == 8) {
			setvar(VAR_PETALBURG_GYM_STATE, 7)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_PETALBURG_CITY_STATE, 2: PetalburgCity_EventScript_WallyTutorial
    	VAR_PETALBURG_CITY_STATE, 4: PetalburgCity_EventScript_WalkToWallyHouse
    ]
}

script PetalburgCity_EventScript_WallyTutorial {
    lockall
    special(SavePlayerParty)
    special(LoadWallyZigzagoon)
    applymovement(LOCALID_PETALBURG_WALLY, PetalburgCity_Movement_WallyTutorialWally)
    applymovement(LOCALID_PLAYER, moves(delay_8,  walk_down * 3,  walk_left * 2,  walk_down * 11,  walk_right * 20,  walk_up * 2,  step_faster_right))
    waitmovement(0)
    msgbox(Route102_Text_WatchMeCatchPokemon, MSGBOX_DEFAULT)
    special(StartWallyTutorialBattle)
    msgbox(Route102_Text_WallyIDidIt, MSGBOX_DEFAULT)
    applymovement(LOCALID_PETALBURG_WALLY, Common_Movement_StepFasterLeft, MAP_PETALBURG_CITY)
    waitmovement(LOCALID_PETALBURG_WALLY, MAP_PETALBURG_CITY)
    msgbox(Route102_Text_LetsGoBack, MSGBOX_DEFAULT)
    closemessage
    clearflag(FLAG_HIDE_MAP_NAME_POPUP)
    setvar(VAR_PETALBURG_CITY_STATE, 3) 
    fadedefaultbgm
    clearflag(FLAG_DONT_TRANSITION_MUSIC)
    special(LoadPlayerParty)
    setvar(VAR_PETALBURG_GYM_STATE, 1)
    warp(MAP_PETALBURG_CITY_GYM, 4, 108)
    waitstate
    releaseall
    end
}

movement PetalburgCity_Movement_WallyTutorialWally {
    delay_8
	walk_down * 2
	walk_left * 2
    walk_down * 11
    walk_right * 20
    walk_up * 2
    walk_right
    delay_16
    step_faster_up
    delay_16 * 2
    step_faster_right
}

script PetalburgCity_EventScript_WalkToWallyHouse {
    lockall
    setflag(FLAG_HIDE_MAP_NAME_POPUP)
    applymovement(LOCALID_PETALBURG_WALLYS_DAD, moves(delay_8,  walk_down * 2,  walk_left * 2,  walk_down * 6,  walk_left * 8,  walk_up * 6))
    applymovement(LOCALID_PLAYER, moves(delay_8,  walk_down * 3,  walk_left * 2,  walk_down * 6,  walk_left * 8,  walk_up * 5))
    waitmovement(0)
    setvar(VAR_0x8004, 7)
    setvar(VAR_0x8005, 5)
    opendoor(VAR_0x8004, VAR_0x8005)
    waitdooranim
    applymovement(LOCALID_PETALBURG_WALLYS_DAD, moves(walk_up,  set_invisible))
    applymovement(LOCALID_PLAYER, moves(walk_up * 2))
    waitmovement(0)
    setflag(FLAG_HIDE_PETALBURG_CITY_WALLYS_DAD)
    hideobjectat(LOCALID_PLAYER, MAP_PETALBURG_CITY)
    closedoor(VAR_0x8004, VAR_0x8005)
    waitdooranim
    clearflag(FLAG_HIDE_MAP_NAME_POPUP)
    fadedefaultbgm
    clearflag(FLAG_DONT_TRANSITION_MUSIC)
    warp(MAP_PETALBURG_CITY_WALLYS_HOUSE, 2, 4)
    waitstate
    releaseall
    end
}

