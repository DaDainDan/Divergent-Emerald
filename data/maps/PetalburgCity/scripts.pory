    setobjectxy(LOCALID_PETALBURG_SCOTT, 13, 17)
    goto(PetalburgCity_EventScript_Scott)
    end
}

script PetalburgCity_EventScript_Scott {
    applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_left * 4))
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_PETALBURG_SCOTT, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_PETALBURG_SCOTT, Common_Movement_Delay48)
    waitmovement(0)
    applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_left * 4))
    waitmovement(0)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterRight)
    waitmovement(0)
    setvar(VAR_SCOTT_STATE, 1)
    msgbox(PetalburgCity_Text_AreYouATrainer, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PETALBURG_SCOTT, Common_Movement_StepFasterRight)
    waitmovement(0)
    delay(30)
    msgbox(PetalburgCity_Text_WellMaybeNot, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_PETALBURG_SCOTT, Common_Movement_StepFasterLeft)
    waitmovement(0)
    delay(30)
    msgbox(PetalburgCity_Text_ImLookingForTalentedTrainers, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down,  delay_16 * 2,  delay_8,  step_faster_left))
    		applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_down * 2,  walk_left * 11))
		case 1:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down,  delay_16,  delay_8,  step_faster_left))
    		applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_down,  walk_left * 11))
		case 2:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_down,  delay_16,  delay_8,  step_faster_left))
    		applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_down,  walk_left * 11))
		case 3:
			applymovement(LOCALID_PLAYER, moves(delay_16,  step_faster_up,  delay_16,  delay_8,  step_faster_left))
    		applymovement(LOCALID_PETALBURG_SCOTT, moves(walk_up,  walk_left * 11))
	}
	waitmovement(0)
    setvar(VAR_SCOTT_PETALBURG_ENCOUNTER, 1)
    removeobject(LOCALID_PETALBURG_SCOTT)
    releaseall
    end
}

script PetalburgCity_EventScript_GymBoy {
    msgbox(PetalburgCity_Text_AreYouRookieTrainer, MSGBOX_NPC)
    end
}

text PetalburgCity_Text_WhereIsWally {
	"Where has our WALLY gone?

	We have to leave for VERDANTURF TOWN
	very soon…"
}

text PetalburgCity_Text_AreYouRookieTrainer {
	"Hiya! Are you maybe…
	A rookie TRAINER?

	Do you know what POKéMON TRAINERS
	do when they reach a new town?

	They first check what kind of GYM
	is in the town."
}

text PetalburgCity_Text_ThisIsPetalburgGym {
	"See? This is PETALBURG CITY's GYM."
}

text PetalburgCity_Text_ThisIsGymSign {
	"This is the GYM's sign. Look for it
	whenever you're looking for a GYM."
}

text PetalburgCity_Text_WaterReflection {
	"My face is reflected in the water.

	It's a shining grin full of hope…

	Or it could be a look of somber silence
	struggling with fear…

	What do you see reflected in your face?"
}

text PetalburgCity_Text_FullPartyExplanation {
	"Let's say you have six POKéMON.
	If you catch another one…

	It is automatically sent to a STORAGE
	BOX over a PC connection."
}

text PetalburgCity_Text_GymSign {
	"PETALBURG CITY POKéMON GYM
	LEADER: NORMAN
	“A man in pursuit of power!”"
}

text PetalburgCity_Text_CitySign {
	"PETALBURG CITY
	“Where people mingle with nature.”"
}

text PetalburgCity_Text_WallyHouseSign {
	"WALLY'S HOUSE"
}

text PetalburgCity_Text_AreYouATrainer {
	"Excuse me!

	Let me guess, from the way you're
	dressed, are you a POKéMON TRAINER?"
}

text PetalburgCity_Text_WellMaybeNot {
	"… … … … … …

	Well, maybe not.
	Your clothes aren't all that dirty.

	You're either a rookie TRAINER,
	or maybe you're just an ordinary kid."
}

text PetalburgCity_Text_ImLookingForTalentedTrainers {
	"I'm roaming the land in search of
	talented TRAINERS.

	I'm sorry to have taken your time."
}
