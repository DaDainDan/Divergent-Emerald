script PetalburgCity_EventScript_ShowGymToPlayer0 {
    lockall
    setvar(VAR_0x8008, 0)
    goto(PetalburgCity_EventScript_ShowGymToPlayer)
    end
}

script PetalburgCity_EventScript_ShowGymToPlayer1 {
    lockall
    setvar(VAR_0x8008, 1)
    goto(PetalburgCity_EventScript_ShowGymToPlayer)
    end
}

script PetalburgCity_EventScript_ShowGymToPlayer2 {
    lockall
    setvar(VAR_0x8008, 2)
    goto(PetalburgCity_EventScript_ShowGymToPlayer)
    end
}

script PetalburgCity_EventScript_ShowGymToPlayer3 {
    lockall
    setvar(VAR_0x8008, 3)
    goto(PetalburgCity_EventScript_ShowGymToPlayer)
    end
}

script PetalburgCity_EventScript_ShowGymToPlayer {
    applymovement(LOCALID_GYM_BOY, Common_Movement_FacePlayer)
    waitmovement(0)
    playbgm(MUS_FOLLOW_ME, FALSE)
    playse(SE_PIN)
    applymovement(LOCALID_GYM_BOY, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_GYM_BOY, Common_Movement_Delay48)
    waitmovement(0)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 3,  step_faster_up))
    		waitmovement(0)
    		applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
		case 1: 
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 2))
		case 2:
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 3,  step_faster_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
		case 3:
			applymovement(LOCALID_GYM_BOY, moves(walk_down,  walk_right * 3,  step_faster_down))
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
	}
	waitmovement(0)
    msgbox(PetalburgCity_Text_AreYouRookieTrainer, MSGBOX_DEFAULT)
    closemessage
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 7,  walk_up,  walk_up * 6))
    		applymovement(LOCALID_PLAYER, moves(walk_down,  walk_right * 7,  walk_up * 6,  walk_right,  walk_up))
		case 1:
			applymovement(LOCALID_GYM_BOY, moves(walk_down,  walk_right * 7,  walk_up * 6,  walk_right,  walk_up * 2))
			applymovement(LOCALID_PLAYER, moves(delay_16 * 2,  walk_down,  walk_right * 6,  walk_up * 6,  walk_right,  walk_up,  walk_right,  walk_up))
		case 2:
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 7,  walk_up,  walk_up * 6))
			applymovement(LOCALID_PLAYER, moves(walk_up,  walk_right * 7,  walk_up * 6,  walk_right,  walk_up))
		case 3:
			applymovement(LOCALID_GYM_BOY, moves(walk_right * 7,  walk_up * 2,  walk_up * 6))
			applymovement(LOCALID_PLAYER, moves(walk_up,  walk_right * 7,  walk_up * 7,  walk_right,  walk_up))
	}
	waitmovement(0)
    msgbox(PetalburgCity_Text_ThisIsPetalburgGym, MSGBOX_DEFAULT)
    applymovement(LOCALID_GYM_BOY, Common_Movement_StepFasterLeft)
    applymovement(LOCALID_PLAYER, Common_Movement_StepFasterLeft)
    waitmovement(0)
    msgbox(PetalburgCity_Text_ThisIsGymSign, MSGBOX_DEFAULT)
    closemessage
    applymovement(LOCALID_GYM_BOY, moves(walk_down * 7,  sprint_left * 10,  step_faster_down))
    waitmovement(0)
    fadedefaultbgm
    releaseall
    end
}

// Unused
movement PetalburgCity_Movement_Delay48 {
    delay_16 * 3
}

script PetalburgCity_EventScript_Scott0 {
    lockall
    addobject(LOCALID_PETALBURG_SCOTT)
    setvar(VAR_0x8008, 0)
    setobjectxy(LOCALID_PETALBURG_SCOTT, 13, 14)
    goto(PetalburgCity_EventScript_Scott)
    end
}

