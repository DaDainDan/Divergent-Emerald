mapscripts LilycoveCity_DepartmentStore_1F_MapScripts {}

script LilycoveCity_DepartmentStore_1F_EventScript_Greeter {
    msgbox(LilycoveCity_DepartmentStore_1F_Text_WelcomeToDeptStore, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_1F_EventScript_LotteryClerk {
    lock_faceplayer
    dotimebasedevents
    if (var(VAR_POKELOT_PRIZE_ITEM) != ITEM_NONE) {
        msgbox(LilycoveCity_DepartmentStore_1F_Text_PrizeWeveBeenHolding, MSGBOX_DEFAULT)
		if (giveitem(VAR_POKELOT_PRIZE_ITEM) == FALSE) {
			msgbox(LilycoveCity_DepartmentStore_1F_Text_NoRoomForThis, MSGBOX_DEFAULT)
    		release_end
		}
		copyvar(VAR_0x8004, VAR_POKELOT_PRIZE_PLACE)
		copyvar(VAR_0x8005, VAR_POKELOT_PRIZE_ITEM)
		special(TryPutLotteryWinnerReportOnAir)
		setvar(VAR_POKELOT_PRIZE_ITEM, ITEM_NONE)
		setvar(VAR_POKELOT_PRIZE_PLACE, 0)
		release_end
    }
    if (flag(FLAG_DAILY_PICKED_LOTO_TICKET)) {
        msgbox(LilycoveCity_DepartmentStore_1F_Text_ComeBackTomorrow, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(LilycoveCity_DepartmentStore_1F_Text_LotteryCornerDrawTicket, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(LilycoveCity_DepartmentStore_1F_Text_PleaseVisitAgain, MSGBOX_DEFAULT)
    	release_end
    }
    setflag(FLAG_DAILY_PICKED_LOTO_TICKET)
    message(LilycoveCity_DepartmentStore_1F_Text_PleasePickTicket)
    waitmessage
    special(RetrieveLotteryNumber)
    copyvar(VAR_0x8008, VAR_RESULT)
    special(BufferLottoTicketNumber)
    msgbox(LilycoveCity_DepartmentStore_1F_Text_TicketNumberIsXPleaseWait, MSGBOX_DEFAULT)
    applymovement(LOCALID_LOTTERY_CLERK, Common_Movement_StepFasterRight)
    waitmovement(0)
    playse(SE_PC_ON)
    special(DoLotteryCornerComputerEffect)
    special(PickLotteryCornerTicket)
    delay(220)
    special(EndLotteryCornerComputerEffect)
    delay(10)
    applymovement(LOCALID_LOTTERY_CLERK, Common_Movement_FacePlayer)
    waitmovement(0)
    if (var(VAR_0x8004) == 0) {
        msgbox(LilycoveCity_DepartmentStore_1F_Text_NoNumbersMatched, MSGBOX_DEFAULT)
    } else {
		incrementgamestat(GAME_STAT_WON_POKEMON_LOTTERY)
		switch (var(VAR_0x8006)) {
			case 0: msgbox(LilycoveCity_DepartmentStore_1F_Text_TicketMatchesPartyMon, MSGBOX_DEFAULT)
			case 1: msgbox(LilycoveCity_DepartmentStore_1F_Text_TicketMatchesPCMon, MSGBOX_DEFAULT)
		}
		bufferitemname(STR_VAR_1, VAR_0x8005)
		switch (var(VAR_0x8004)) {
			case 1: msgbox(LilycoveCity_DepartmentStore_1F_Text_TwoDigitsMatched, MSGBOX_DEFAULT)
			case 2: msgbox(LilycoveCity_DepartmentStore_1F_Text_ThreeDigitsMatched, MSGBOX_DEFAULT)
			case 3: msgbox(LilycoveCity_DepartmentStore_1F_Text_FourDigitsMatched, MSGBOX_DEFAULT)
			case 4: msgbox(LilycoveCity_DepartmentStore_1F_Text_AllFiveDigitsMatched, MSGBOX_DEFAULT)
		}
		if (giveitem(VAR_0x8005) == FALSE) {
			copyvar(VAR_POKELOT_PRIZE_PLACE, VAR_0x8004)
			copyvar(VAR_POKELOT_PRIZE_ITEM, VAR_0x8005)
			msgbox(LilycoveCity_DepartmentStore_1F_Text_NoRoomForThis, MSGBOX_DEFAULT)
    		release_end
		}
		special(TryPutLotteryWinnerReportOnAir)
	}
    msgbox(LilycoveCity_DepartmentStore_1F_Text_PleaseVisitAgain2, MSGBOX_DEFAULT)
    release_end
}

script LilycoveCity_DepartmentStore_1F_EventScript_PokefanF {
    msgbox(LilycoveCity_DepartmentStore_1F_Text_IBuyAllSortsOfThings, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_1F_EventScript_LittleGirl {
    msgbox(LilycoveCity_DepartmentStore_1F_Text_MomBuyingMeFurniture, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_1F_EventScript_PokefanM {
    msgbox(LilycoveCity_DepartmentStore_1F_Text_BuyingSomethingForAzumarill, MSGBOX_NPC)
    end
}

script LilycoveCity_DepartmentStore_1F_EventScript_Azumarill {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_AZUMARILL, CRY_MODE_NORMAL)
    msgbox(LilycoveCity_DepartmentStore_1F_Text_Azumarill, MSGBOX_DEFAULT)
    waitmoncry
    release_end
}

script LilycoveCity_DepartmentStore_1F_EventScript_FloorNamesSign {
    msgbox(LilycoveCity_DepartmentStore_1F_Text_FloorNamesSign, MSGBOX_SIGN)
    end
}

text LilycoveCity_DepartmentStore_1F_Text_WelcomeToDeptStore {
	"Welcome to LILYCOVE DEPARTMENT STORE."
}

text LilycoveCity_DepartmentStore_1F_Text_IBuyAllSortsOfThings {
	"Whenever I come to the DEPARTMENT
	STORE, I always end up buying all sorts
	of things because it's so fun."
}

text LilycoveCity_DepartmentStore_1F_Text_MomBuyingMeFurniture {
	"Today, my mom is going to buy me some
	nice furniture."
}

text LilycoveCity_DepartmentStore_1F_Text_BuyingSomethingForAzumarill {
	"I'm buying something for my AZUMARILL
	as a reward for winning a CONTEST."
}

text LilycoveCity_DepartmentStore_1F_Text_Azumarill {
	"Maririroo!"
}

text LilycoveCity_DepartmentStore_1F_Text_FloorNamesSign {
	"1F: SERVICE COUNTER
	    LOTTERY CORNER

	2F: TRAINER'S ZONE

	3F: BATTLE COLLECTION

	4F: TM CORNER

	5F: POKé DOLL FLOOR

	ROOFTOP: ROOFTOP PLAZA"
}

text LilycoveCity_DepartmentStore_1F_Text_WirelessCommIsFun {
	"Wireless Communication is a
	lot of fun, isn't it?

	I think it lets you do things that
	weren't possible before.

	For instance, you can now trade
	with people you couldn't before.

	I think it's going to be exciting!"
}

text LilycoveCity_DepartmentStore_1F_Text_SpreadWordAboutWirelessComm {
	"I want to spread the word about how
	fun Wireless Communication can be."
}
