mapscripts MtEmber_Exterior_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_MT_EMBER_EXTERIOR)
		if (var(VAR_MAP_SCENE_MT_EMBER_EXTERIOR) == 2) {
			call(MtEmber_Exterior_EventScript_RocketsFaceDown)
		}
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) >= 4) {
			setmetatile(42, 39, METATILE_MtEmber_CaveEntrance, 0)
		}
		end
    }
}

script MtEmber_Exterior_EventScript_RocketsFaceDown {
    setobjectmovementtype(LOCALID_MT_EMBER_GRUNT1, MOVEMENT_TYPE_FACE_DOWN)
    setobjectmovementtype(LOCALID_MT_EMBER_GRUNT2, MOVEMENT_TYPE_FACE_DOWN)
    return
}

script MtEmber_Exterior_EventScript_Grunt1 {
    lock
    if (defeated(TRAINER_TEAM_ROCKET_GRUNT_43)) {
        msgbox(MtEmber_Exterior_Text_Grunt1PostBattle)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 4) {
        applymovement(LOCALID_MT_EMBER_GRUNT1, Common_Movement_FacePlayer)
		waitmovement(0)
		playbgm(MUS_RG_ENCOUNTER_ROCKET, 0)
		msgbox(MtEmber_Exterior_Text_Grunt1Intro)
		trainerbattle_no_intro(TRAINER_TEAM_ROCKET_GRUNT_43, MtEmber_Exterior_Text_Grunt1Defeat)
		msgbox(MtEmber_Exterior_Text_Grunt1PostBattle)
		if (defeated(TRAINER_TEAM_ROCKET_GRUNT_44)) {
			goto(MtEmber_Exterior_EventScript_DefeatedBothGrunts)
		}
    }
	else {
		msgbox(MtEmber_Exterior_Text_WellTryDiggingHere)
	}
    release_end
}

script MtEmber_Exterior_EventScript_DefeatedBothGrunts {
    msgbox(MtEmber_Exterior_Text_WellRegroupDontStepInsideThere)
    closemessage
    fadescreenswapbuffers(FADE_TO_BLACK)
    removeobject(LOCALID_MT_EMBER_GRUNT1)
    removeobject(LOCALID_MT_EMBER_GRUNT2)
    fadescreenswapbuffers(FADE_FROM_BLACK)
    release_end
}

script MtEmber_Exterior_EventScript_Grunt2 {
    lock_faceplayer
    if (defeated(TRAINER_TEAM_ROCKET_GRUNT_44)) {
        msgbox(MtEmber_Exterior_Text_Grunt2PostBattle)
    }
    elif (var(VAR_MAP_SCENE_ONE_ISLAND_POKEMON_CENTER_1F) == 4) {
        playbgm(MUS_RG_ENCOUNTER_ROCKET, 0)
		msgbox(MtEmber_Exterior_Text_Grunt2Intro)
		trainerbattle_no_intro(TRAINER_TEAM_ROCKET_GRUNT_44, MtEmber_Exterior_Text_Grunt2Defeat)
		msgbox(MtEmber_Exterior_Text_Grunt2PostBattle)
		if (defeated(TRAINER_TEAM_ROCKET_GRUNT_43)) {
			goto(MtEmber_Exterior_EventScript_DefeatedBothGrunts)
		}
    }
	else {
		msgbox(MtEmber_Exterior_Text_YoureInTheWayGetLost)
		goto(Common_EventScript_FaceOriginalDirection)
	}
    release_end
}

script MtEmber_Exterior_EventScript_RocketPasswordScene {
    lockall
    textcolor(NPC_TEXT_COLOR_MALE)
    msgbox(MtEmber_Exterior_Text_PunchedThroughAtLast)
    message(MtEmber_Exterior_Text_WhatsPasswordAgain)
    waitmessage
    playse(SE_PIN)
    applymovement(LOCALID_MT_EMBER_GRUNT2, Common_Movement_QuestionMark)
    waitmovement(0)
    waitbuttonpress
    msgbox(MtEmber_Exterior_Text_FirstPasswordGoldeen)
    applymovement(LOCALID_MT_EMBER_GRUNT1, Common_Movement_StepFasterDown)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_MT_EMBER_GRUNT1, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_MT_EMBER_GRUNT1, Common_Movement_Delay48)
    waitmovement(0)
    applymovement(LOCALID_MT_EMBER_GRUNT2, Common_Movement_StepFasterDown)
    waitmovement(0)
    call(MtEmber_Exterior_EventScript_RocketsFaceDown)
    msgbox(MtEmber_Exterior_Text_SnoopsBeenListeningIn)
    setvar(VAR_MAP_SCENE_MT_EMBER_EXTERIOR, 2)
    releaseall
    end
}

script MtEmber_Exterior_EventScript_Logan {
    trainerbattle_single(TRAINER_PKMN_RANGER_LOGAN, MtEmber_Exterior_Text_LoganIntro, MtEmber_Exterior_Text_LoganDefeat)
    msgbox(MtEmber_Exterior_Text_LoganPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script MtEmber_Exterior_EventScript_Beth {
    trainerbattle_single(TRAINER_PKMN_RANGER_BETH, MtEmber_Exterior_Text_BethIntro, MtEmber_Exterior_Text_BethDefeat)
    msgbox(MtEmber_Exterior_Text_BethPostBattle, MSGBOX_AUTOCLOSE)
    end
}

script MtEmber_Exterior_EventScript_Jocelyn {
    trainerbattle_single(TRAINER_CRUSH_GIRL_JOCELYN, MtEmber_Exterior_Text_JocelynIntro, MtEmber_Exterior_Text_JocelynDefeat)
    msgbox(MtEmber_Exterior_Text_JocelynPostBattle, MSGBOX_AUTOCLOSE)
    end
}

text Text_ExplosionTeach {
	"Can you imagine?
	If this volcano were to erupt?

	The explosion would be the end of
	us. How terrifying is that?

	While we're terrified, would you
	like me to teach EXPLOSION?"
}

text Text_ExplosionDeclined {
	"Yeah, you're right.
	It is too terrifying."
}

text Text_ExplosionWhichMon {
	"You're terribly brave!

	Which POKéMON should I teach
	EXPLOSION?"
}

text Text_ExplosionTaught {
	"Using EXPLOSION while on this
	volcano…

	What a terrifying thrill!"
}

text MtEmber_Exterior_Text_WellTryDiggingHere {
	"Over here.
	We'll try digging here.

	That treasure the ADMINS've been
	talking about should be here."
}

text MtEmber_Exterior_Text_YoureInTheWayGetLost {
	"What the…?
	You're in the way. Get lost."
}

text MtEmber_Exterior_Text_PunchedThroughAtLast {
	"Whew, punched through at last.
	Let's go treasure hunting!"
}

text MtEmber_Exterior_Text_WhatsPasswordAgain {
	"Any treasure we find, we haul back
	to the WAREHOUSE, understood?

	…Oh, and what're the passwords?
	At the ROCKET WAREHOUSE, I mean."
}

text MtEmber_Exterior_Text_FirstPasswordGoldeen {
	"What, you forgot the password?
	There're actually two.

	The first one's “GOLDEEN need
	log.”

	And the second one is…"
}

text MtEmber_Exterior_Text_SnoopsBeenListeningIn {
	"Hey!
	This snoop's been listening in!"
}

text MtEmber_Exterior_Text_Grunt1Intro {
	"You've been eavesdropping on us,
	haven't you?"
}

text MtEmber_Exterior_Text_Grunt1Defeat {
	"Huh, what?"
}

text MtEmber_Exterior_Text_Grunt1PostBattle {
	"Why'd you have to win?"
}

text MtEmber_Exterior_Text_Grunt2Intro {
	"Trying to horn in on our treasure?
	Don't bet on it!"
}

text MtEmber_Exterior_Text_Grunt2Defeat {
	"Wait!
	But how?"
}

text MtEmber_Exterior_Text_Grunt2PostBattle {
	"Develop amnesia conveniently and
	forget everything you heard!"
}

text MtEmber_Exterior_Text_WellRegroupDontStepInsideThere {
	"What a setback…
	We'll have to regroup.

	You! Don't even think about taking
	a step inside here!

	If you know what's good for you,
	don't even think about this!"
}

text MtEmber_Exterior_Text_LoganIntro {
	"An active volcano is one that's
	erupting, or about to."
}

text MtEmber_Exterior_Text_LoganDefeat {
	"Whew… That was hot!
	Sweat's erupting from me!"
}

text MtEmber_Exterior_Text_LoganPostBattle {
	"They say there're over 1,500
	active volcanoes in the world.

	Just thinking about them makes me
	feel all hot and gooey inside!"
}

text MtEmber_Exterior_Text_BethIntro {
	"Do you know how caves form inside
	volcanoes?"
}

text MtEmber_Exterior_Text_BethDefeat {
	"Atchah!
	You're shockingly good!"
}

text MtEmber_Exterior_Text_BethPostBattle {
	"When lava at the surface of magma
	hardens, and the magma inside flows
	out, caverns are left behind."
}

text MtEmber_Exterior_Text_JocelynIntro {
	"I've been in training so I can mend
	my broken heart…

	It toughened me up physically at
	least! Hi-yah!"
}

text MtEmber_Exterior_Text_JocelynDefeat {
	"I think I tried to overdo it…"
}

text MtEmber_Exterior_Text_JocelynPostBattle {
	"The way you battle, it reminds me
	of the guy who dumped me…"
}
