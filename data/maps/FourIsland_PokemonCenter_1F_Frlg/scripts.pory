mapscripts FourIsland_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setrespawn(HEAL_LOCATION_FOUR_ISLAND)
    	end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script FourIsland_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script FourIsland_PokemonCenter_1F_EventScript_Man {
    msgbox(FourIsland_PokemonCenter_1F_Text_RareIceMonsInCave, MSGBOX_NPC)
    end
}

script FourIsland_PokemonCenter_1F_EventScript_Woman {
    msgbox(FourIsland_PokemonCenter_1F_Text_DayCarePeopleFoundEggBefore, MSGBOX_NPC)
    end
}

script FourIsland_PokemonCenter_1F_EventScript_Gentleman {
    msgbox(FourIsland_PokemonCenter_1F_Text_NewPokemonJournalHasntArrived, MSGBOX_NPC)
    end
}

// The 5 texts below are supposed to be in FourIsland_House1
text Text_BodySlamTeach {
	"Ready?
	Boing!

	We're having a BODY SLAM match
	to see who wimps out first.

	If you were to join us, you'd be
	squashed like a bug, though…

	How about I teach BODY SLAM to
	a POKéMON of yours instead?"
}

text Text_BodySlamDeclined {
	"Come again!
	Boing!"
}

text Text_BodySlamWhichMon {
	"Which POKéMON wants to learn how
	to BODY SLAM?"
}

text Text_BodySlamTaught {
	"Boioing!"
}

text FourIsland_House1_Text_FatMan {
	"それ　ぼよーん！
	おまえ　おもいなあー！"
}

text FourIsland_PokemonCenter_1F_Text_RareIceMonsInCave {
	"There's a rare kind of ICE POKéMON
	that lives in the cave.

	We get a lot of visitors hoping to
	see that POKéMON."
}

text FourIsland_PokemonCenter_1F_Text_DayCarePeopleFoundEggBefore {
	"Oh? A POKéMON EGG?
	…I have no idea.

	…Oh, wait. The DAY-CARE people
	in town were saying something.

	They said that they'd found EGGS
	before on their property."
}

text FourIsland_PokemonCenter_1F_Text_NewPokemonJournalHasntArrived {
	"What's this?

	The new POKéMON JOURNAL hasn't
	arrived on this island?"
}
