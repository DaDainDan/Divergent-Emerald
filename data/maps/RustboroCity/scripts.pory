script RustboroCity_EventScript_ReturnGoods {
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterUp)
		case 1: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterRight)
		case 2:
		case 3: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterDown)
		case 4: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterLeft)
	}
	call(RustboroCity_EventScript_EmployeeAlert)
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
		case 1: applymovement(LOCALID_PLAYER, Common_Movement_FaceLeft)
		case 2: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
		case 3:
			applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_WalkDown)
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
	}
	waitmovement(0)
    msgbox(RustboroCity_Text_YouGotItThankYou, MSGBOX_DEFAULT)
    if (giveitem(ITEM_GREAT_BALL) == FALSE) {
        msgbox(RustboroCity_Text_YoureLoadedWithItems, MSGBOX_DEFAULT)
    }
    msgbox(RustboroCity_Text_PleaseComeWithMe, MSGBOX_DEFAULT)
    closemessage
    setflag(FLAG_RETURNED_DEVON_GOODS)
    setflag(FLAG_HIDE_RUSTBORO_CITY_DEVON_EMPLOYEE_1)
    setvar(VAR_RUSTBORO_CITY_STATE, 5)
    delay(30)
    warp(MAP_RUSTBORO_CITY_DEVON_CORP_3F, 2, 2)
    waitstate
    releaseall
    end
}

script RustboroCity_EventScript_Rival {
    lockall
    if (!flag(FLAG_MET_RIVAL_RUSTBORO)) {
        call(RustboroCity_EventScript_PlayRivalMusic)
    }
    applymovement(LOCALID_RUSTBORO_RIVAL, Common_Movement_FacePlayer)
    waitmovement(0)
    goto(RustboroCity_EventScript_RivalEncounter)
}

script RustboroCity_EventScript_PlayRivalMusic {
    if (checkplayergender == MALE) {
        playbgm(MUS_ENCOUNTER_MAY, TRUE)
    } else {
		playbgm(MUS_ENCOUNTER_BRENDAN, TRUE)
	}
    return
}

script RustboroCity_EventScript_RivalIntro {
	lockall
    call(RustboroCity_EventScript_PlayRivalMusic)
    applymovement(LOCALID_RUSTBORO_RIVAL, Common_Movement_StepFasterDown)
    waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_RUSTBORO_RIVAL, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_RUSTBORO_RIVAL, Common_Movement_Delay48)
    waitmovement(0)
	return
}

