movement RustboroCity_Movement_ScientistWalkAroundPlayer {
    // moves(delay_16,  walk_left,  walk_down * 2,  walk_right,  step_faster_up,  delay_16)
    delay_16
    walk_left
    walk_down * 2
    walk_right
    step_faster_up
    delay_16
}

