script RustboroCity_EventScript_EmployeeAskToGetGoods {
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterUp)
		case 1: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterLeft)
		case 2:
		case 3: applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_StepFasterDown)
	}
	call(RustboroCity_EventScript_EmployeeAlert)
	switch (var(VAR_TEMP_1)) {
		case 0: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterDown)
		case 1: applymovement(LOCALID_PLAYER, Common_Movement_FaceRight)
		case 2: applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
		case 3:
			applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_WalkDown)
			waitmovement(0)
			applymovement(LOCALID_PLAYER, Common_Movement_StepFasterUp)
	}
	waitmovement(0)
    setflag(FLAG_INTERACTED_WITH_DEVON_EMPLOYEE_GOODS_STOLEN)
    setvar(VAR_RUSTBORO_CITY_STATE, 3)
    copyobjectxytoperm(LOCALID_RUSTBORO_DEVON_EMPLOYEE)
    msgbox(RustboroCity_Text_HelpMeIWasRobbed, MSGBOX_DEFAULT)
    releaseall
    end
}

script RustboroCity_EventScript_EmployeeAlert {
	waitmovement(0)
    playse(SE_PIN)
    applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_ExclamationMark)
    waitmovement(0)
    applymovement(LOCALID_RUSTBORO_DEVON_EMPLOYEE, Common_Movement_Delay48)
    waitmovement(0)
	return
}

