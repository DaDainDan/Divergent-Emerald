Route129_MapScripts::
# 2 "data/maps/Route129/scripts.pory"
	map_script MAP_SCRIPT_ON_TRANSITION, Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION
# 14 "data/maps/Route129/scripts.pory"
	map_script MAP_SCRIPT_ON_LOAD, Route129_MapScripts_MAP_SCRIPT_ON_LOAD
# 23 "data/maps/Route129/scripts.pory"
	map_script MAP_SCRIPT_ON_FRAME_TABLE, Route129_MapScripts_MAP_SCRIPT_ON_FRAME_TABLE
	.byte 0

Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION:
# 3 "data/maps/Route129/scripts.pory"
	compare VAR_SHOULD_END_ABNORMAL_WEATHER, 1
	goto_if_eq Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_2
Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_1:
# 6 "data/maps/Route129/scripts.pory"
	compare VAR_SOOTOPOLIS_CITY_STATE, 4
	goto_if_ge Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_6
Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_4:
# 9 "data/maps/Route129/scripts.pory"
	compare VAR_ABNORMAL_WEATHER_LOCATION, ABNORMAL_WEATHER_ROUTE_129_WEST
	goto_if_eq Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_10
# 9 "data/maps/Route129/scripts.pory"
	compare VAR_ABNORMAL_WEATHER_LOCATION, ABNORMAL_WEATHER_ROUTE_129_EAST
	goto_if_eq Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_10
Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_9:
	end

Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_2:
# 4 "data/maps/Route129/scripts.pory"
	call AbnormalWeather_EventScript_HideMapNamePopup
	goto Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_1

Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_5:
# 7 "data/maps/Route129/scripts.pory"
	call Common_EventScript_SetAbnormalWeather
	goto Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_4

Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_6:
# 6 "data/maps/Route129/scripts.pory"
	goto_if_set FLAG_SYS_WEATHER_CTRL, Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_5
	goto Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_4

Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_10:
# 10 "data/maps/Route129/scripts.pory"
	call AbnormalWeather_StartKyogreWeather
	goto Route129_MapScripts_MAP_SCRIPT_ON_TRANSITION_9

Route129_MapScripts_MAP_SCRIPT_ON_LOAD:
# 15 "data/maps/Route129/scripts.pory"
	compare VAR_ABNORMAL_WEATHER_LOCATION, ABNORMAL_WEATHER_ROUTE_129_WEST
	goto_if_eq Route129_MapScripts_MAP_SCRIPT_ON_LOAD_2
Route129_MapScripts_MAP_SCRIPT_ON_LOAD_1:
# 18 "data/maps/Route129/scripts.pory"
	compare VAR_ABNORMAL_WEATHER_LOCATION, ABNORMAL_WEATHER_ROUTE_129_EAST
	goto_if_eq Route129_MapScripts_MAP_SCRIPT_ON_LOAD_5
Route129_MapScripts_MAP_SCRIPT_ON_LOAD_4:
	end

Route129_MapScripts_MAP_SCRIPT_ON_LOAD_2:
# 16 "data/maps/Route129/scripts.pory"
	call AbnormalWeather_EventScript_PlaceTilesRoute129West
	goto Route129_MapScripts_MAP_SCRIPT_ON_LOAD_1

Route129_MapScripts_MAP_SCRIPT_ON_LOAD_5:
# 19 "data/maps/Route129/scripts.pory"
	call AbnormalWeather_EventScript_PlaceTilesRoute129East
	goto Route129_MapScripts_MAP_SCRIPT_ON_LOAD_4

Route129_MapScripts_MAP_SCRIPT_ON_FRAME_TABLE:
# 24 "data/maps/Route129/scripts.pory"
	map_script_2 VAR_SHOULD_END_ABNORMAL_WEATHER, 1, AbnormalWeather_EventScript_EndEventAndCleanup_1
	.2byte 0


