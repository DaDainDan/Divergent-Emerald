mapscripts Route129_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        if (var(VAR_SHOULD_END_ABNORMAL_WEATHER) == 1) {
			call(AbnormalWeather_EventScript_HideMapNamePopup)
		}
		if (var(VAR_SOOTOPOLIS_CITY_STATE) >= 4 && flag(FLAG_SYS_WEATHER_CTRL)) {
			call(Common_EventScript_SetAbnormalWeather)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_129_WEST || var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_129_EAST) {
			call(AbnormalWeather_StartKyogreWeather)
		}
		end
    }
    MAP_SCRIPT_ON_LOAD {
        if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_129_WEST) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute129West)
		}
		if (var(VAR_ABNORMAL_WEATHER_LOCATION) == ABNORMAL_WEATHER_ROUTE_129_EAST) {
			call(AbnormalWeather_EventScript_PlaceTilesRoute129East)
		}
		end
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_SHOULD_END_ABNORMAL_WEATHER, 1: AbnormalWeather_EventScript_EndEventAndCleanup_1
    ]
}

script Route129_EventScript_Chase {
    trainerbattle_single(TRAINER_CHASE, Route129_Text_ChaseIntro, Route129_Text_ChaseDefeat)
    msgbox(Route129_Text_ChasePostBattle, MSGBOX_AUTOCLOSE)
    end
}

