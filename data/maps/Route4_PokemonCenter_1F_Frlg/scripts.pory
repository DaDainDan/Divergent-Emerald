const MAGIKARP_PRICE = 500

mapscripts Route4_PokemonCenter_1F_Frlg_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        setworldmapflag(FLAG_WORLD_MAP_ROUTE4_POKEMON_CENTER_1F)
		setrespawn(HEAL_LOCATION_ROUTE4)
		end
    }
    MAP_SCRIPT_ON_RESUME: CableClub_OnResume
}

script Route4_PokemonCenter_1F_EventScript_Boy {
    msgbox(Route4_PokemonCenter_1F_Text_CanHaveSixMonsWithYou, MSGBOX_NPC)
    end
}

script Route4_PokemonCenter_1F_EventScript_Gentleman {
    lock
    msgbox(Route4_PokemonCenter_1F_Text_TeamRocketAttacksCerulean)
    release_end
}

script Route4_PokemonCenter_1F_EventScript_MagikarpSalesman {
    lock_faceplayer
    if (flag(FLAG_BOUGHT_MAGIKARP)) {
        msgbox(Route4_PokemonCenter_1F_Text_IDontGiveRefunds)
    	release_end
    }
    showmoneybox(0, 0)
    if (checkplayergender == MALE) {
        msgbox(Route4_PokemonCenter_1F_Text_LaddieBuyMagikarpForJust500, MSGBOX_YESNO)
    } else {
        msgbox(Route4_PokemonCenter_1F_Text_SweetieBuyMagikarpForJust500, MSGBOX_YESNO)
    }
	goto(Route4_PokemonCenter_1F_EventScript_TryBuyMagikarp)
    end
}

script Route4_PokemonCenter_1F_EventScript_TryBuyMagikarp {
    if (var(VAR_RESULT) == NO) {
        msgbox(Route4_PokemonCenter_1F_Text_OnlyDoingThisAsFavorToYou)
		hidemoneybox
		release_end
    }
    elif (checkmoney(MAGIKARP_PRICE) == FALSE) {
        msgbox(Route4_PokemonCenter_1F_Text_YoullNeedMoreMoney)
		hidemoneybox
		release_end
    }
    textcolor(NPC_TEXT_COLOR_NEUTRAL)
    setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_MAGIKARP)
    if (givemon(SPECIES_MAGIKARP, 5) == MON_CANT_GIVE) {
		textcolor(NPC_TEXT_COLOR_MALE)
		msgbox(Route4_PokemonCenter_1F_Text_NoRoomForMorePokemon)
		hidemoneybox
		release_end
	}
	copyvar(VAR_0x8007, VAR_RESULT)
	removemoney(MAGIKARP_PRICE)
    updatemoneybox
    playfanfare(MUS_LEVEL_UP)
    message(Route4_PokemonCenter_1F_Text_PaidOutrageouslyForMagikarp)
    waitmessage
    waitfanfare
    bufferspeciesname(STR_VAR_1, SPECIES_MAGIKARP)
	msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
	switch (var(VAR_0x8007)) {
		case MON_GIVEN_TO_PARTY:
			if (var(VAR_RESULT) == NO) {
				hidemoneybox
			} else {
				call(Common_EventScript_GetGiftMonPartySlot)
				fadescreen(FADE_TO_BLACK)
				hidemoneybox
				special(ChangePokemonNickname)
			}
		case MON_GIVEN_TO_PC:
			if (var(VAR_RESULT) == NO) {
				call(Common_EventScript_TransferredToPC)
    			hidemoneybox
			} else {
				fadescreen(FADE_TO_BLACK)
				hidemoneybox
				special(ChangePokemonNickname)
				lock_faceplayer
				call(Common_EventScript_TransferredToPC)
			}
	}
	setflag(FLAG_BOUGHT_MAGIKARP)
    release_end
}

script Route4_PokemonCenter_1F_EventScript_Nurse {
    lock_faceplayer
    call(EventScript_PkmnCenterNurse_Frlg)
    release_end
}

script Route4_PokemonCenter_1F_EventScript_Youngster {
    msgbox(Route4_PokemonCenter_1F_Text_ShouldStoreMonsUsingPC, MSGBOX_NPC)
    end
}

script Route4_PokemonCenter_1F_EventScript_Newspaper {
    lock
    msgbox(Route4_PokemonCenter_1F_Text_ItsANewspaper)
    release_end
}

text Route4_PokemonCenter_1F_Text_CanHaveSixMonsWithYou {
	"Okay, set six POKé BALLS in my
	belt…

	Yeah, that'll do it. At most, you
	can have six POKéMON with you."
}

text Route4_PokemonCenter_1F_Text_TeamRocketAttacksCerulean {
	"TEAM ROCKET attacks CERULEAN
	citizens…

	Not a day goes by without TEAM
	ROCKET being in the news."
}

text Route4_PokemonCenter_1F_Text_LaddieBuyMagikarpForJust500 {
	"MAN: Hello there, laddie!
	Have I got a deal just for you!

	I'll let you have a secret POKéMON
	- a MAGIKARP - for just ¥500!

	So, you'll buy it, am I right?"
}

text Route4_PokemonCenter_1F_Text_SweetieBuyMagikarpForJust500 {
	"MAN: Hello there, sweetie pie!
	Have I got a deal just for you!

	I'll let you have a secret POKéMON
	- a MAGIKARP - for just ¥500!

	So, you'll buy it, am I right?"
}

text Route4_PokemonCenter_1F_Text_PaidOutrageouslyForMagikarp {
	"{PLAYER} paid an outrageous ¥500
	and bought the MAGIKARP…"
}

text Route4_PokemonCenter_1F_Text_OnlyDoingThisAsFavorToYou {
	"No? You say no? I'm only doing this
	as a favor to you!"
}

text Route4_PokemonCenter_1F_Text_NoRoomForMorePokemon {
	"There's no more room for any more
	POKéMON, it looks like."
}

text Route4_PokemonCenter_1F_Text_YoullNeedMoreMoney {
	"You'll need more money than that!"
}

text Route4_PokemonCenter_1F_Text_IDontGiveRefunds {
	"MAN: Well, I don't give refunds.
	You knew what you were getting!"
}

text Route4_PokemonCenter_1F_Text_ShouldStoreMonsUsingPC {
	"Sometimes, you'll have too many
	POKéMON with you to add any more.

	In that case, you should just
	store some using any PC."
}

text Route4_PokemonCenter_1F_Text_ItsANewspaper {
	"It's a newspaper."
}
