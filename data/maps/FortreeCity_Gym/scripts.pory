script FortreeCity_Gym_EventScript_GymGuide {
    lock_faceplayer
    if (flag(FLAG_DEFEATED_FORTREE_GYM)) {
        msgbox(FortreeCity_Gym_Text_GymGuidePostVictory, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(FortreeCity_Gym_Text_GymGuideAdvice, MSGBOX_DEFAULT)
    release_end
}

script FortreeCity_Gym_EventScript_LeftGymStatue {
    lockall
	goto(FortreeCity_Gym_EventScript_GymStatue)
    end
}

script FortreeCity_Gym_EventScript_RightGymStatue {
    lockall
    goto(FortreeCity_Gym_EventScript_GymStatue)
}

script FortreeCity_Gym_EventScript_GymStatue {
    if (flag(FLAG_BADGE06_GET)) {
        msgbox(FortreeCity_Gym_Text_GymStatueCertified, MSGBOX_DEFAULT)
    } else {
		msgbox(FortreeCity_Gym_Text_GymStatue, MSGBOX_DEFAULT)
	}
    releaseall
    end
}

text FortreeCity_Gym_Text_GymGuideAdvice {
	"Yo, how's it going, CHAMPION-
	bound {PLAYER}?

	FORTREE GYM LEADER WINONA is
	a master of FLYING-type POKéMON.

	She's waiting at the back of this GYM,
	behind the rotating doors.

	She's waiting for new challengers
	who are trying to take wing!

	Okay, go for it!"
}

text FortreeCity_Gym_Text_GymGuidePostVictory {
	"You did it!
	You've achieved liftoff!"
}

text FortreeCity_Gym_Text_JaredIntro {
	"Behold the elegant battle style of
	BIRD POKéMON!"
}

text FortreeCity_Gym_Text_JaredDefeat {
	"You…
	You're strong…"
}

text FortreeCity_Gym_Text_JaredPostBattle {
	"A TRAINER has to be smart to keep
	up with unexpected turns of events.

	Do you have the smarts to get to
	our LEADER?"
}

text FortreeCity_Gym_Text_EdwardoIntro {
	"The lovers of BIRD POKéMON aspire
	to join this GYM.

	As a member of the FORTREE GYM,
	I'm not allowed to lose!"
}

text FortreeCity_Gym_Text_EdwardoDefeat {
	"It was too much of a load for me
	to bear…"
}

text FortreeCity_Gym_Text_EdwardoPostBattle {
	"The world is huge, and there are
	countless tough TRAINERS.

	I'm going to keep training and make
	myself even stronger."
}

text FortreeCity_Gym_Text_FlintIntro {
	"There's no need for WINONA, our GYM
	LEADER, to deal with you!

	I'm plenty good enough for you!"
}

text FortreeCity_Gym_Text_FlintDefeat {
	"WINONA, I…
	I lost!"
}

text FortreeCity_Gym_Text_FlintPostBattle {
	"WINONA is cute and she's strong.
	She's the ultimate LEADER!

	Blush…"
}

text FortreeCity_Gym_Text_AshleyIntro {
	"WINONA taught me personally!
	You can't beat me easily!"
}

text FortreeCity_Gym_Text_AshleyDefeat {
	"I was beaten…"
}

text FortreeCity_Gym_Text_AshleyPostBattle {
	"Thanks to WINONA, the people of
	FORTREE can live without fear."
}

text FortreeCity_Gym_Text_HumbertoIntro {
	"When WINONA takes to battle, her face
	shines with beautiful determination…

	I'm not letting you witness that
	lovely sight!"
}

text FortreeCity_Gym_Text_HumbertoDefeat {
	"Urk!
	I couldn't stop you."
}

text FortreeCity_Gym_Text_HumbertoPostBattle {
	"You'd better watch it!
	Don't get distracted staring at WINONA
	or you'll go crashing down in a heap!"
}

text FortreeCity_Gym_Text_DariusIntro {
	"You'd better know that there are all
	sorts of FLYING-type POKéMON.

	You do know that, right?"
}

text FortreeCity_Gym_Text_DariusDefeat {
	"You seem to know your stuff!"
}

text FortreeCity_Gym_Text_DariusPostBattle {
	"Sure, you beat me all right.
	But you'd better watch it! Our LEADER
	WINONA's POKéMON are all business."
}

text FortreeCity_Gym_Text_WinonaIntro {
	"I am WINONA. I am the LEADER of
	the FORTREE POKéMON GYM.

	I have become one with BIRD POKéMON
	and have soared the skies…

	However grueling the battle, we have
	triumphed with grace…

	Witness the elegant choreography
	of BIRD POKéMON and I!"
}

text FortreeCity_Gym_Text_WinonaDefeat {
	"Never before have I seen a TRAINER
	command POKéMON with more grace
	than I…

	In recognition of your prowess,
	I present to you this GYM BADGE."
}

text FortreeCity_Gym_Text_ReceivedFeatherBadge {
	"{PLAYER} received the FEATHER BADGE
	from WINONA."
}

text FortreeCity_Gym_Text_ExplainFeatherBadgeTakeThis {
	"With the FEATHER BADGE, all POKéMON up
	to LV 70, even those received through
	trades, will obey your every command.

	You will also be able to use
	the HM move FLY outside of battle.

	And this…
	This is a gift from me."
}

text FortreeCity_Gym_Text_ExplainAerialAce {
	"TM40 contains AERIAL ACE.

	Its speed…
	No POKéMON should be able to avoid it.

	… … … … … …"
}

text FortreeCity_Gym_Text_RegisteredWinona {
	"Registered GYM LEADER WINONA
	in the POKéNAV."
}

text FortreeCity_Gym_Text_WinonaPostBattle {
	"Though I fell to you, I will remain
	devoted to BIRD POKéMON."
}

text FortreeCity_Gym_Text_GymStatue {
	"FORTREE CITY POKéMON GYM"
}

text FortreeCity_Gym_Text_GymStatueCertified {
	"FORTREE CITY POKéMON GYM

	WINONA'S CERTIFIED TRAINERS:
	{PLAYER}"
}

text FortreeCity_Gym_Text_WinonaPreRematch {
	"WINONA: We humans can never escape
	gravity's pull on the ground.

	But by striving for excellence,
	we have the power to soar!

	You have scaled the pinnacle as
	the reigning CHAMPION.

	Please, allow me to see your power
	at full flight!"
}

text FortreeCity_Gym_Text_WinonaRematchDefeat {
	"I failed to reach your height again…"
}

text FortreeCity_Gym_Text_WinonaPostRematch {
	"WINONA: Even though I have lost,
	the wings of my heart remain unbroken.

	I can rise and soar again and
	yet again.

	I am convinced of it!"
}

text FortreeCity_Gym_Text_WinonaRematchNeedTwoMons {
	"WINONA: We humans can never escape
	gravity's pull on the ground.

	But by striving for excellence,
	we have the power to soar!

	You have scaled the pinnacle as
	the reigning CHAMPION.

	Please, allow me to see your power
	at full flight!

	Oh, no… Do you have but one
	POKéMON with you?

	Please return with two POKéMON
	at the very least."
}
