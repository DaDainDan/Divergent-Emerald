mapscripts BattleFrontier_Lounge7_MapScripts {}

//special ChooseMonForMoveTutor
// VAR_0x8008 is the price
// VAR_TEMP_C is the scroll multichoice ID
// VAR_TEMP_FRONTIER_TUTOR_SELECTION is the move selection
// VAR_TEMP_FRONTIER_TUTOR_ID is which move tutor was spoken to
script BattleFrontier_Lounge7_EventScript_LeftMoveTutor {
    lock_faceplayer
    setvar(VAR_TEMP_C, SCROLL_MULTI_BF_MOVE_TUTOR_1)
    if (flag(FLAG_MET_FRONTIER_BEAUTY_MOVE_TUTOR)) {
        msgbox(BattleFrontier_Lounge7_Text_LeftTutorWelcomeBack, MSGBOX_DEFAULT)
    } else {
		msgbox(BattleFrontier_Lounge7_Text_LeftTutorIntro, MSGBOX_DEFAULT)
		setflag(FLAG_MET_FRONTIER_BEAUTY_MOVE_TUTOR)
	}
    call(BattleFrontier_Lounge7_EventScript_TutorFirstMoveSetup)
    goto(BattleFrontier_Lounge7_EventScript_LeftTutorMoveSelection)
    end
}

script BattleFrontier_Lounge7_EventScript_LeftTutorMoveSelection {
	setvar(VAR_TEMP_FRONTIER_TUTOR_ID, 0)
    setvar(VAR_0x8004, SCROLL_MULTI_BF_MOVE_TUTOR_1)
	special(ShowScrollableMultichoice)
    copyvar(VAR_TEMP_FRONTIER_TUTOR_SELECTION, VAR_RESULT)
    switch (var(VAR_RESULT)) {
        case 0: setmoveandprice(MOVE_SOFT_BOILED, 16)
        case 1: setmoveandprice(MOVE_SEISMIC_TOSS, 24)
        case 2: setmoveandprice(MOVE_DREAM_EATER, 24)
        case 3: setmoveandprice(MOVE_MEGA_PUNCH, 24)
		case 4: setmoveandprice(MOVE_MEGA_KICK, 48)
		case 5: setmoveandprice(MOVE_BODY_SLAM, 48)
		case 6: setmoveandprice(MOVE_ROCK_SLIDE, 48)
		case 7: setmoveandprice(MOVE_COUNTER, 48)
		case 8: setmoveandprice(MOVE_THUNDER_WAVE, 48)
		case 9: setmoveandprice(MOVE_SWORDS_DANCE, 48)
        case 10:
        case MULTI_B_PRESSED:
			goto(BattleFrontier_Lounge7_EventScript_ExitTutorMoveSelect)
			end
    }
	goto(BattleFrontier_Lounge7_EventScript_ConfirmMoveSelection)
    end
}

script BattleFrontier_Lounge7_EventScript_RightMoveTutor {
    lock_faceplayer
    setvar(VAR_TEMP_C, SCROLL_MULTI_BF_MOVE_TUTOR_2)
    if (flag(FLAG_MET_FRONTIER_SWIMMER_MOVE_TUTOR)) {
        msgbox(BattleFrontier_Lounge7_Text_RightTutorWelcomeBack, MSGBOX_DEFAULT)
    } else {
		msgbox(BattleFrontier_Lounge7_Text_RightTutorIntro, MSGBOX_DEFAULT)
		setflag(FLAG_MET_FRONTIER_SWIMMER_MOVE_TUTOR)
	}
	call(BattleFrontier_Lounge7_EventScript_TutorFirstMoveSetup)
    goto(BattleFrontier_Lounge7_EventScript_RightTutorMoveSelection)
    end
}

script BattleFrontier_Lounge7_EventScript_RightTutorMoveSelection {
	setvar(VAR_TEMP_FRONTIER_TUTOR_ID, 1)
    setvar(VAR_0x8004, SCROLL_MULTI_BF_MOVE_TUTOR_2)
	special(ShowScrollableMultichoice)
    copyvar(VAR_TEMP_FRONTIER_TUTOR_SELECTION, VAR_RESULT)
    switch (var(VAR_RESULT)) {
        case 0: setmoveandprice(MOVE_DEFENSE_CURL, 16)
        case 1: setmoveandprice(MOVE_SNORE, 24)
        case 2: setmoveandprice(MOVE_MUD_SLAP, 24)
        case 3: setmoveandprice(MOVE_SWIFT, 24)
        case 4: setmoveandprice(MOVE_ICY_WIND, 24)
        case 5: setmoveandprice(MOVE_ENDURE, 48)
        case 6: setmoveandprice(MOVE_PSYCH_UP, 48)
        case 7: setmoveandprice(MOVE_ICE_PUNCH, 48)
        case 8: setmoveandprice(MOVE_THUNDER_PUNCH, 48)
        case 9: setmoveandprice(MOVE_FIRE_PUNCH, 48)
        case 10:
        case MULTI_B_PRESSED: 
			goto(BattleFrontier_Lounge7_EventScript_ExitTutorMoveSelect)
			end
    }
	goto(BattleFrontier_Lounge7_EventScript_ConfirmMoveSelection)
    end
}

script BattleFrontier_Lounge7_EventScript_TutorFirstMoveSetup {
	message(BattleFrontier_Lounge7_Text_TeachWhichMove)
    waitmessage
    special(ShowBattlePointsWindow)
	setvar(VAR_0x8006, 0)
	return
}

script BattleFrontier_Lounge7_EventScript_ExitTutorMoveSelect {
    special(CloseBattleFrontierTutorWindow)
    special(CloseBattlePointsWindow)
    msgbox(BattleFrontier_Lounge7_Text_YouDontWantTo, MSGBOX_DEFAULT)
    release_end
}

script BattleFrontier_Lounge7_EventScript_ConfirmMoveSelection {
    special(BufferBattleFrontierTutorMoveName)
    buffernumberstring(STR_VAR_2, VAR_EXCHANGE_PRICE)
    msgbox(BattleFrontier_Lounge7_Text_MoveWillBeXBattlePoints, MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        goto(BattleFrontier_Lounge7_EventScript_ChooseNewMove)
    }
    if (specialvar(VAR_TEMP_1, GetFrontierBattlePoints) >= VAR_EXCHANGE_PRICE) {
		goto(BattleFrontier_Lounge7_EventScript_TeachTutorMove)
	}
    msgbox(BattleFrontier_Lounge7_Text_HaventGotEnoughPoints, MSGBOX_DEFAULT)
    goto(BattleFrontier_Lounge7_EventScript_ChooseNewMove)
    end
}

script BattleFrontier_Lounge7_EventScript_TeachTutorMove {
    msgbox(BattleFrontier_Lounge7_Text_TeachMoveToWhichMon, MSGBOX_DEFAULT)
    fadescreen(FADE_TO_BLACK)
    special(CloseBattlePointsWindow)
    special(CloseBattleFrontierTutorWindow)
    chooseboxmon(SELECT_PC_MON_MOVE_TUTOR)
    waitstate
    if (var(VAR_RESULT) == FALSE) {
        msgbox(BattleFrontier_Lounge7_Text_YouDontWantTo, MSGBOX_DEFAULT)
    	release_end
    }
    msgbox(BattleFrontier_Lounge7_Text_IllTakeBattlePoints, MSGBOX_DEFAULT)
    copyvar(VAR_0x8004, VAR_EXCHANGE_PRICE)
    special(TakeFrontierBattlePoints)
    release_end
}

script BattleFrontier_Lounge7_EventScript_ChooseNewMove {
    message(BattleFrontier_Lounge7_Text_TeachWhichMove)
	waitmessage
	setvar(VAR_0x8006, 1)
	if (var(VAR_TEMP_FRONTIER_TUTOR_ID) == 0) {
		goto(BattleFrontier_Lounge7_EventScript_LeftTutorMoveSelection)
    }
    goto(BattleFrontier_Lounge7_EventScript_RightTutorMoveSelection)
    end
}

script BattleFrontier_Lounge7_EventScript_Sailor {
    msgbox(BattleFrontier_Lounge7_Text_ThinkLadiesDontGetAlong, MSGBOX_NPC)
    end
}

script BattleFrontier_Lounge7_EventScript_Gentleman {
    msgbox(BattleFrontier_Lounge7_Text_LadiesWereStrongAndBeautiful, MSGBOX_NPC)
    end
}

text BattleFrontier_Lounge7_Text_LeftTutorIntro {
	"Buhahaha!

	You couldn't tell it from looking now,
	but I used to be one tough TRAINER.

	I had a reputation as the toughest
	BEAUTY around, I tell you!

	… … … … … …

	What is it now?
	You don't believe me.

	I'm not like that blowhard woman over
	there. I'm actually talented!

	Let me prove it to you.
	I can teach your POKéMON special and
	yet cute moves.

	But my lessons don't come free.
	How about paying for the moves I teach
	with a wee bit of Battle Points?"
}

text BattleFrontier_Lounge7_Text_LeftTutorWelcomeBack {
	"Buhahaha!

	Are you back to learn special and
	yet cute POKéMON moves?"
}

text BattleFrontier_Lounge7_Text_TeachWhichMove {
	"Fine, fine, look here!
	Which move should I teach?"
}

text BattleFrontier_Lounge7_Text_MoveWillBeXBattlePoints {
	"The move {STR_VAR_1}, is it?
	That will be {STR_VAR_2} Battle Points, okay?"
}

text BattleFrontier_Lounge7_Text_TeachMoveToWhichMon {
	"Fine, fine, now pick the POKéMON
	I should teach the move to."
}

text BattleFrontier_Lounge7_Text_HaventGotEnoughPoints {
	"What the…
	You haven't got enough Battle Points!"
}

text BattleFrontier_Lounge7_Text_IllTakeBattlePoints {
	"Do you see how skilled I am now?
	I'll take your Battle Points, thanks!"
}

text BattleFrontier_Lounge7_Text_YouDontWantTo {
	"What's that?
	You don't want to…

	If you want to see how skilled I am,
	you come see me anytime!"
}

text BattleFrontier_Lounge7_Text_RightTutorIntro {
	"Ihihihi!

	I know it's hard to see now, but I used
	to be one fantastic TRAINER.

	I had a reputation as the most
	invincible SWIMMER around, I tell you!

	… … … … … …

	What's wrong?
	You don't believe me.

	I'm not like that buffoonish woman over
	there. I'm actually experienced!

	I can prove it to you.
	I can teach your POKéMON hard and
	yet pretty moves.

	But my lessons don't come free.
	How about paying for the moves I teach
	with a wee bit of Battle Points?"
}

text BattleFrontier_Lounge7_Text_RightTutorWelcomeBack {
	"Ihihihi!

	Have you come to learn hard and
	yet pretty POKéMON moves?"
}

text BattleFrontier_Lounge7_Text_ThinkLadiesDontGetAlong {
	"Those ladies, the way they bad-mouth
	each other, you probably think that
	they don't get along.

	But if that were true, they wouldn't
	stay out here together, would they?"
}

text BattleFrontier_Lounge7_Text_LadiesWereStrongAndBeautiful {
	"When I was just a wee YOUNGSTER,
	those ladies were strong and beautiful.

	They were idols among us TRAINERS.

	Even now, age hasn't dulled their
	abilities.

	In fact, their POKéMON moves have
	grown even more polished.

	But… For some reason, I can't help
	but feel this…

	Time is so cruel…"
}

text BattleFrontier_Lounge7_Text_SoftboiledDesc {
	"Recovers up to
	half the user's
	maximum HP."
}

text BattleFrontier_Lounge7_Text_SeismicTossDesc {
	"Inflicts damage
	identical to the
	user's level."
}

text BattleFrontier_Lounge7_Text_DreamEaterDesc {
	"Recovers half the
	damage inflicted
	on a sleeping foe."
}

text BattleFrontier_Lounge7_Text_MegaPunchDesc {
	"A strong punch
	thrown with
	incredible power."
}

text BattleFrontier_Lounge7_Text_MegaKickDesc {
	"An extremely
	powerful kick with
	intense force."
}

text BattleFrontier_Lounge7_Text_BodySlamDesc {
	"A full-body slam
	that may cause
	paralysis."
