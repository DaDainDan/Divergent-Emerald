mapscripts ThreeIsland_BondBridge_Frlg_MapScripts {}

script ThreeIsland_BondBridge_EventScript_BerryForestSign {
    msgbox(ThreeIsland_BondBridge_Text_BerryForestAhead, MSGBOX_SIGN)
    end
}

script ThreeIsland_BondBridge_EventScript_BondBridgeSign {
    msgbox(ThreeIsland_BondBridge_Text_BondBridgeSign, MSGBOX_SIGN)
    end
}

text ThreeIsland_BondBridge_Text_NikkiIntro {
	"The salty tang of the sea…
	It tickles my heart."
}

text ThreeIsland_BondBridge_Text_NikkiDefeat {
	"…Sniff, sniff…
	Something smells unpleasant…"
}

text ThreeIsland_BondBridge_Text_NikkiPostBattle {
	"Perhaps that reek is your sweaty
	POKéMON's body odor…"
}

text ThreeIsland_BondBridge_Text_VioletIntro {
	"Where are you off to in such
	a hurry?"
}

text ThreeIsland_BondBridge_Text_VioletDefeat {
	"You're raising some wonderful
	POKéMON."
}

text ThreeIsland_BondBridge_Text_VioletPostBattle {
	"If you keep going this way, you'll
	eventually reach BERRY FOREST."
}

text ThreeIsland_BondBridge_Text_AmiraIntro {
	"My mommy said that I can't swim
	without my float ring."
}

text ThreeIsland_BondBridge_Text_AmiraDefeat {
	"Waaah!
	Waaah!"
}

text ThreeIsland_BondBridge_Text_AmiraPostBattle {
	"This year, I'm going to finally
	learn how to swim!"
}

text ThreeIsland_BondBridge_Text_AlexisIntro {
	"Yay, yay!
	POKéMON!"
}

text ThreeIsland_BondBridge_Text_AlexisDefeat {
	"What happens now?"
}

text ThreeIsland_BondBridge_Text_AlexisPostBattle {
	"Did I just win?
	Or did I lose?"
}

text ThreeIsland_BondBridge_Text_TishaIntro {
	"Oh, no, don't come here!
	Please, stay away from me!"
}

text ThreeIsland_BondBridge_Text_TishaDefeat {
	"Okay, you've won!
	Now will you please go away?"
}

text ThreeIsland_BondBridge_Text_TishaPostBattle {
	"A POKéMON bit through my 
	swimsuit.

	I can't get out of the water!"
}

text ThreeIsland_BondBridge_Text_JoyIntro {
	"{SPEAKER NAME_UNKNOWN}We'll teach you what our
	favorite POKéMON is!"
}

text ThreeIsland_BondBridge_Text_JoyDefeat {
	"JOY: Ohh…
	MEG!"
}

text ThreeIsland_BondBridge_Text_JoyPostBattle {
	"{SPEAKER NAME_JOY}Wasn't that fun?
	I hope we can battle again!"
}

text ThreeIsland_BondBridge_Text_JoyNotEnoughMons {
	"{SPEAKER NAME_JOY}I really want to battle with
	MEG.

	One POKéMON isn't enough."
}

text ThreeIsland_BondBridge_Text_MegIntro {
	"{SPEAKER NAME_UNKNOWN}We'll show you our favorite
	POKéMON."
}

text ThreeIsland_BondBridge_Text_MegDefeat {
	"MEG: Ohh…
	JOY!"
}

text ThreeIsland_BondBridge_Text_MegPostBattle {
	"{SPEAKER NAME_MEG}JOY, wasn't that fun?"
}

text ThreeIsland_BondBridge_Text_MegNotEnoughMons {
	"{SPEAKER NAME_MEG}I want to battle together
	with JOY.

	One POKéMON isn't enough."
}

text ThreeIsland_BondBridge_Text_BerryForestAhead {
	"BERRY FOREST AHEAD"
}

text ThreeIsland_BondBridge_Text_BondBridgeSign {
	"BOND BRIDGE
	Please be quiet when crossing.

	BERRY FOREST AHEAD"
}
