const SPOKE_TO_WOMAN_LAST = FLAG_TEMP_2
const SPOKE_TO_FAT_MAN_LAST = FLAG_TEMP_3

mapscripts VermilionCity_PokemonFanClub_Frlg_MapScripts {}

script VermilionCity_PokemonFanClub_EventScript_Chairman {
    lock_faceplayer
    if (flag(FLAG_GOT_BIKE_VOUCHER)) {
        msgbox(VermilionCity_PokemonFanClub_Text_DidntComeToSeeAboutMonsAgain)
    	release_end
    }
    msgbox(VermilionCity_PokemonFanClub_Text_DidYouComeToHearAboutMyMons, MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(VermilionCity_PokemonFanClub_Text_ChairmansStory)
		if (checkitemspace(ITEM_BIKE_VOUCHER) == FALSE) {
			msgbox(VermilionCity_PokemonFanClub_Text_MakeRoomForThis)
			release_end
		}
		setflag(FLAG_GOT_BIKE_VOUCHER)
		giveitem_msg(VermilionCity_PokemonFanClub_Text_ReceivedBikeVoucherFromChairman, ITEM_BIKE_VOUCHER, 1, MUS_RG_OBTAIN_KEY_ITEM)
		msgbox(VermilionCity_PokemonFanClub_Text_ExplainBikeVoucher)
		release_end
    }
    msgbox(VermilionCity_PokemonFanClub_Text_ComeBackToHearStory)
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_WorkerF {
    lock_faceplayer
    if (flag(FLAG_SYS_GAME_CLEAR)) {
        famechecker(FAMECHECKER_DAISY, 1)
		msgbox(VermilionCity_PokemonFanClub_Text_ChairmanReallyAdoresHisMons)
		release_end
    }
    msgbox(VermilionCity_PokemonFanClub_Text_ChairmanVeryVocalAboutPokemon)
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_Woman {
    lock_faceplayer
    if (flag(SPOKE_TO_FAT_MAN_LAST)) {
        msgbox(VermilionCity_PokemonFanClub_Text_SeelFarMoreAttractive)
		closemessage
		applymovement(LOCALID_POKEMON_FAN_CLUB_WOMAN, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
		clearflag(SPOKE_TO_FAT_MAN_LAST)
		release_end
    }
    msgbox(VermilionCity_PokemonFanClub_Text_AdoreMySeel)
    closemessage
    applymovement(LOCALID_POKEMON_FAN_CLUB_WOMAN, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    setflag(SPOKE_TO_WOMAN_LAST)
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_FatMan {
    lock_faceplayer
    if (flag(SPOKE_TO_WOMAN_LAST)) {
        msgbox(VermilionCity_PokemonFanClub_Text_PikachuTwiceAsCute)
		closemessage
		applymovement(LOCALID_POKEMON_FAN_CLUB_FAT_MAN, Common_Movement_FaceOriginalDirection)
		waitmovement(0)
		clearflag(SPOKE_TO_WOMAN_LAST)
		release_end
    }
    msgbox(VermilionCity_PokemonFanClub_Text_AdmirePikachusTail)
    closemessage
    applymovement(LOCALID_POKEMON_FAN_CLUB_FAT_MAN, Common_Movement_FaceOriginalDirection)
    waitmovement(0)
    setflag(SPOKE_TO_FAT_MAN_LAST)
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_Pikachu {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_PIKACHU, CRY_MODE_NORMAL)
    msgbox(VermilionCity_PokemonFanClub_Text_Pikachu)
    waitmoncry
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_Seel {
    lock_faceplayer
    waitse
    playmoncry(SPECIES_SEEL, CRY_MODE_NORMAL)
    msgbox(VermilionCity_PokemonFanClub_Text_Seel)
    waitmoncry
    release_end
}

script VermilionCity_PokemonFanClub_EventScript_RulesSign1 {
    msgbox(VermilionCity_PokemonFanClub_Text_ListenPolitelyToOtherTrainers, MSGBOX_SIGN)
    end
}

script VermilionCity_PokemonFanClub_EventScript_RulesSign2 {
    msgbox(VermilionCity_PokemonFanClub_Text_SomeoneBragsBragBack, MSGBOX_SIGN)
    end
}

text VermilionCity_PokemonFanClub_Text_AdmirePikachusTail {
	"Won't you admire my PIKACHU's
	adorable tail?"
}

text VermilionCity_PokemonFanClub_Text_PikachuTwiceAsCute {
	"Humph!

	My PIKACHU is twice as cute as
	that one!"
}

text VermilionCity_PokemonFanClub_Text_AdoreMySeel {
	"I just adore my SEEL!
	It's so lovable!

	It squeals, “Kyuuuh,” when I
	hug it!"
}

text VermilionCity_PokemonFanClub_Text_SeelFarMoreAttractive {
	"Oh, dear!

	My SEEL is far more attractive.
	By double, I would say."
}

text VermilionCity_PokemonFanClub_Text_Pikachu {
	"PIKACHU: Chu! Pikachu!"
}

text VermilionCity_PokemonFanClub_Text_Seel {
	"SEEL: Kyuoo!"
}

text VermilionCity_PokemonFanClub_Text_DidYouComeToHearAboutMyMons {
	"I chair the POKéMON Fan Club!

	I raise more than a hundred
	POKéMON!

	I'm very fussy when it comes to
	POKéMON! I surely am!

	So…

	Did you come visit to hear about
	my POKéMON?"
}

text VermilionCity_PokemonFanClub_Text_ChairmansStory {
	"Good!
	Then listen up!

	My favorite RAPIDASH…

	It's…cute…lovely…smart… 
	plus…amazing…you think so?…
	oh yes…it's…stunning…
	kindly…love it!

	Hug it…when…sleeping…warm
	and cuddly…spectacular…
	ravishing…
	…Oops! Look at the time!
	I kept you too long!

	Thanks for hearing me out!
	I want you to have this!"
}

text VermilionCity_PokemonFanClub_Text_ReceivedBikeVoucherFromChairman {
	"{PLAYER} received a BIKE VOUCHER
	from the CHAIRMAN."
}

text VermilionCity_PokemonFanClub_Text_ExplainBikeVoucher {
	"Take that BIKE VOUCHER to the
	BIKE SHOP in CERULEAN CITY.

	Exchange that for a BICYCLE
	free of charge!

	Don't worry, my favorite FEAROW
	will FLY me anywhere I need to go.

	So, I have no need for a BICYCLE.

	I hope you like cycling!"
}

text VermilionCity_PokemonFanClub_Text_ComeBackToHearStory {
	"Oh. Come back when you want to
	hear my story!"
}

text VermilionCity_PokemonFanClub_Text_DidntComeToSeeAboutMonsAgain {
	"Hello, {PLAYER}!

	Did you come see me about my
	POKéMON again?

	No?
	Too bad!"
}

text VermilionCity_PokemonFanClub_Text_MakeRoomForThis {
	"Make room for this!"
}

text VermilionCity_PokemonFanClub_Text_ChairmanVeryVocalAboutPokemon {
	"Our CHAIRMAN is very vocal about
	POKéMON."
}

text VermilionCity_PokemonFanClub_Text_ListenPolitelyToOtherTrainers {
	"Let's all listen politely to other
	TRAINERS!"
}

text VermilionCity_PokemonFanClub_Text_SomeoneBragsBragBack {
	"If someone brags, brag right back!"
}

text VermilionCity_PokemonFanClub_Text_ChairmanReallyAdoresHisMons {
	"Our CHAIRMAN really does adore his
	POKéMON.

	But the person who is most liked by
	POKéMON is DAISY, I think."
}
